{
    "$schema": "https://smapi.io/schemas/content-patcher.json",
    "Changes": [
        //////////////////////////////////////
		// RINGS
		//////////////////////////////////////

        // ADD VARIANTS TO RING DATA
		//////////////////////////////////////

        // Individual charm ring
        {
            "LogName": "LT_Individual charm ring data - same monster",
            "Action": "EditData",
            "Target": "juminos.MonsterHutchFramework/CharmerRingData",
            "TargetField": [ "{{ModId}}_{{LT_MonsterId}}Ring", "CharmedMonsters" ],
            "Entries": {
                // Monster Sanctuary variant
                "{{ModId}}_{{LT_MS_VariantId}}": {
                    "Id": "{{ModId}}_{{LT_MS_VariantId}}",
                    "MonsterName": "{{ModId}}_{{LT_MS_VariantId}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
            },
        },

        // Master charm ring
        {
            "LogName": "LT_Master charm ring data - same monster",
            "Action": "EditData",
            "Target": "juminos.MonsterHutchFramework/CharmerRingData",
            "TargetField": [ "{{ModId}}_MasterCharmerRing", "CharmedMonsters" ],
            "Entries": {
                // Monster Sanctuary variant
                "{{ModId}}_{{LT_MS_VariantId}}": {
                    "Id": "{{ModId}}_{{LT_MS_VariantId}}",
                    "MonsterName": "{{ModId}}_{{LT_MS_VariantId}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
            },
        },

        //////////////////////////////////////
		// SOULS
		//////////////////////////////////////

        // CREATE SOUL OBJECT
		//////////////////////////////////////

        {
            "LogName": "LT_Create soul",
            "Action": "EditData",
            "Target": "Data/Objects",
            "Entries": {
                "{{ModId}}_{{LT_MS_VariantId}}Soul": {
                    "Name": "{{ModId}}_{{LT_MS_VariantId}}Soul",
                    "DisplayName": "{{i18n: object.display-name.monster-soul |name.variant= {{i18n: name.variant.{{LT_MS_VariantId}} }} }}",
                    "Description": "{{i18n: object.description.monster-soul}}",
                    "Type": "Basic",
                    "Category": -28,
                    "Price": 150,
                    "Texture": "{{ModId}}/Souls",
                    "SpriteIndex": "{{LT_SoulSpriteIndex}}",
                    "ExcludeFromShippingCollection": "{{CT_Perfection}}",
                    "ExcludeFromRandomSale": true,
                    "ContextTags": [
                        "soul_item",
                        "not_giftable"
                    ]
                },
            },
            "When": {
                "LT_MS_VariantId |contains=DustSpriteMagmaCap, MetalHeadGold, ShadowBruteMushroom, ShadowShamanMusk, SkeletonGoldPumpkin, SquidKidPink, StoneGolemPrismatic": false,
                "HasValue:{{LT_SoulSpriteIndex}}": true
            }
        },
        {
            "LogName": "LT_Create super rare soul",
            "Action": "EditData",
            "Target": "Data/Objects",
            "Entries": {
                "{{ModId}}_{{LT_MS_VariantId}}Soul": {
                    "Name": "{{ModId}}_{{LT_MS_VariantId}}Soul",
                    "DisplayName": "{{i18n: object.display-name.monster-soul |name.variant= {{i18n: name.variant.{{LT_MS_VariantId}} }} }}",
                    "Description": "{{i18n: object.description.monster-soul}}",
                    "Type": "Basic",
                    "Category": -28,
                    "Price": 150,
                    "Texture": "{{ModId}}/SuperRareSouls",
                    "SpriteIndex": "{{LT_SoulSpriteIndex}}",
                    "ExcludeFromShippingCollection": "{{CT_Perfection}}",
                    "ExcludeFromRandomSale": true,
                    "ContextTags": [
                        "soul_item",
                        "not_giftable"
                    ]
                },
            },
            "When": {
                "LT_MS_VariantId |contains=DustSpriteMagmaCap, MetalHeadGold, ShadowBruteMushroom, ShadowShamanMusk, SkeletonGoldPumpkin, SquidKidPink, StoneGolemPrismatic": true,
                "HasValue:{{LT_SoulSpriteIndex}}": true
            }
        },

        // ADD SOULS TO MONSTER MASH DROPS
		//////////////////////////////////////
        {
            "LogName": "LT_Add monster souls to MM drops",
            "Action": "EditData",
            "Target": "mushymato.MonsterVariety/Data",
            "TargetField": [ "Bogs.Monsters_{{LT_MonsterId}}", "Varieties", "Bogs.Monsters_{{LT_MS_VariantId}}", "ExtraDrops" ],
            "Entries": {
                "{{ModId}}_{{LT_MS_VariantId}}Soul": {
                    "Id":"{{ModId}}_{{LT_MS_VariantId}}Soul",
                    "ItemId": "(O){{ModId}}_{{LT_MS_VariantId}}Soul",
                    "Condition": "RANDOM .01"
                }
            },
            "When": {
                "HasValue:{{LT_SoulSpriteIndex}}": true,
                "LT_MS_VariantId |contains=DustSpriteMagmaCap, MetalHeadGold, ShadowBruteMushroom, ShadowShamanMusk, SkeletonGoldPumpkin, SquidKidPink, StoneGolemPrismatic, SkeletonPumpkin": false,
                "Spiderbuttons.CMCT/Config: Bogs.Monsters, CT_Enable{{LT_MonsterId}}": true
            }
        },
        {
            "LogName": "LT_Add pumpkin skeleton monster soul to MM drops",
            "Action": "EditData",
            "Target": "mushymato.MonsterVariety/Data",
            "TargetField": [ "Bogs.Monsters_{{LT_MonsterId}}", "Varieties", "Bogs.Monsters_{{LT_MS_VariantId}}", "ExtraDrops" ],
            "Entries": {
                "{{ModId}}_{{LT_MS_VariantId}}Soul": {
                    "Id":"{{ModId}}_{{LT_MS_VariantId}}Soul",
                    "ItemId": "(O){{ModId}}_{{LT_MS_VariantId}}Soul",
                    "Condition": "RANDOM .1"
                }
            },
            "When": {
                "HasValue:{{LT_SoulSpriteIndex}}": true,
                "LT_MS_VariantId |contains=SkeletonPumpkin": true,
                "Spiderbuttons.CMCT/Config: Bogs.Monsters, CT_EnableSkeleton": true
            }
        },
        {
            "LogName": "LT_Add super rare monster soul to MM drops",
            "Action": "EditData",
            "Target": "mushymato.MonsterVariety/Data",
            "TargetField": [ "Bogs.Monsters_{{LT_MonsterId}}", "Varieties", "Bogs.Monsters_{{LT_MS_VariantId}}", "ExtraDrops" ],
            "Entries": {
                "{{ModId}}_{{LT_MS_VariantId}}Soul": {
                    "Id":"{{ModId}}_{{LT_MS_VariantId}}Soul",
                    "ItemId": "(O){{ModId}}_{{LT_MS_VariantId}}Soul",
                }
            },
            "When": {
                "LT_MS_VariantId |contains=DustSpriteMagmaCap, MetalHeadGold, ShadowBruteMushroom, ShadowShamanMusk, SkeletonGoldPumpkin, SquidKidPink, StoneGolemPrismatic": true,
                "Spiderbuttons.CMCT/Config: Bogs.Monsters, CT_Enable{{LT_MonsterId}}": true
            }
        },
    ]
}