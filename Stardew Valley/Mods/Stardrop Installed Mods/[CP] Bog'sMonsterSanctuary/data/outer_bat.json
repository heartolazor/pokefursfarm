{
    "$schema": "https://smapi.io/schemas/content-patcher.json",
    "Changes": [
        //////////////////////////////////////
		// RINGS
		//////////////////////////////////////

        // CREATE RING OBJECT
		//////////////////////////////////////

        {
            "LogName": "LT_Add ring",
            "Action": "EditData",
            "Target": "Data/Objects",
            "Entries": {
                "{{ModId}}_{{LT_MainMonsterId}}Ring": {
                    "Name": "{{ModId}}_{{LT_MainMonsterId}}Ring",
                    "DisplayName": "{{i18n: object.display-name.charm-ring |name.monster= {{i18n: name.monster.{{LT_MainMonsterId}} }} }}",
                    "Description": "{{i18n: object.description.{{LT_MainMonsterId}}-charm-ring }}",
                    "Type": "Ring",
                    "Category": 0,
                    "Price": 150,
                    "Texture": "{{ModId}}/Rings",
                    "SpriteIndex": "{{LT_RingSpriteIndex}}",
                    "ExcludeFromShippingCollection": true,
                    "ExcludeFromRandomSale": true,
                    "ContextTags": [
                        "ring_item",
                        "{{LT_RingColour}}",
                        "not_giftable"
                    ]
                },
            }
        },

        // ADD VANILLA MONSTERS TO RING DATA
		//////////////////////////////////////

        // Individual charm ring
        {
            "LogName": "LT_Individual charm ring data - same monster",
            "Action": "EditData",
            "Target": "juminos.MonsterHutchFramework/CharmerRingData",
            "TargetField": [ "{{ModId}}_{{LT_MainMonsterId}}Ring", "CharmedMonsters" ],
            "Entries": {
                // Vanilla Bat
                "{{ModId}}_Vanilla{{LT_MainMonsterId}}": {
                    "Id": "{{ModId}}_Vanilla{{LT_MainMonsterId}}",
                    "MonsterName": "{{LT_MainMonsterVanilla}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
                // Vanilla Frost Bat
                "{{ModId}}_Vanilla{{LT_SecondMonsterId}}": {
                    "Id": "{{ModId}}_Vanilla{{LT_SecondMonsterId}}",
                    "MonsterName": "{{LT_SecondMonsterVanilla}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
                // Vanilla Lava Bat
                "{{ModId}}_Vanilla{{LT_ThirdMonsterId}}": {
                    "Id": "{{ModId}}_Vanilla{{LT_ThirdMonsterId}}",
                    "MonsterName": "{{LT_ThirdMonsterVanilla}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
            },
        },

        // Master charm ring
        {
            "LogName": "LT_Master charm ring data - same monster",
            "Action": "EditData",
            "Target": "juminos.MonsterHutchFramework/CharmerRingData",
            "TargetField": [ "{{ModId}}_MasterCharmerRing", "CharmedMonsters" ],
            "Entries": {
                // Vanilla Bat
                "{{ModId}}_Vanilla{{LT_MainMonsterId}}": {
                    "Id": "{{ModId}}_Vanilla{{LT_MainMonsterId}}",
                    "MonsterName": "{{LT_MainMonsterVanilla}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
                // Vanilla Frost Bat
                "{{ModId}}_Vanilla{{LT_SecondMonsterId}}": {
                    "Id": "{{ModId}}_Vanilla{{LT_SecondMonsterId}}",
                    "MonsterName": "{{LT_SecondMonsterVanilla}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
                // Vanilla Lava Bat
                "{{ModId}}_Vanilla{{LT_ThirdMonsterId}}": {
                    "Id": "{{ModId}}_Vanilla{{LT_ThirdMonsterId}}",
                    "MonsterName": "{{LT_ThirdMonsterVanilla}}",
                    "Sound": "magma_sprite_spot",
                    "SpeechBubbles": [
                        {
                            "Id": "heart",
                            "Text": "<", // this character is displayed as a heart
                            "Weight": 1,
                            "Pretimer": -1,
                            "Duration": 1500,
                            "Style": 2,
                        }
                    ]
                },
            },
        },

        //////////////////////////////////////
		// INNER INCLUDE
		//////////////////////////////////////

        {
            "Action": "Include",
            "FromFile": "data/inner_bat.json",
            "LocalTokens": {
                "LT_RingId": "{{LT_MainMonsterId}}",
                "LT_MonsterId": "{{LT_MainMonsterId}}",
                "LT_MS_VariantId": "{{LT_MainMonsterId}}",
                "LT_SoulSpriteIndex": "{{LT_MainMonsterSoulSpriteIndex}}",
            },
            "When": {
                "HasValue:{{LT_MainMonsterSoulSpriteIndex}}": true
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/inner_bat.json",
            "LocalTokens": {
                "LT_RingId": "{{LT_MainMonsterId}}",
                "LT_MonsterId": "{{LT_SecondMonsterId}}",
                "LT_MS_VariantId": "{{LT_SecondMonsterId}}",
                "LT_SoulSpriteIndex": "{{LT_SecondMonsterSoulSpriteIndex}}",
            },
            "When": {
                "HasValue:{{LT_SecondMonsterSoulSpriteIndex}}": true
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/inner_bat.json",
            "LocalTokens": {
                "LT_RingId": "{{LT_MainMonsterId}}",
                "LT_MonsterId": "{{LT_ThirdMonsterId}}",
                "LT_MS_VariantId": "{{LT_ThirdMonsterId}}",
                "LT_SoulSpriteIndex": "{{LT_ThirdMonsterSoulSpriteIndex}}",
            },
            "When": {
                "HasValue:{{LT_ThirdMonsterSoulSpriteIndex}}": true
            }
        },
    ]
}