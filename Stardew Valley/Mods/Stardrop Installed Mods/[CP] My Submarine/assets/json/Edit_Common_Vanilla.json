  //★★★潜水艦内部の明るさの変更★★★

    //●悪天候の明るさ変更
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_MySubmarine_GoIsland",
        "MapProperties": { "AmbientLight": "120 120 120" },
        "When": {
          "SubmarineAction": "WarpInsideSubmarine",
          "HasReadLetter": "MySubmarine.AvailableMailId",
          "Weather": "Rain, Storm"
        }
      }, 
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_MySubmarine_GoBeach",
        "MapProperties": { "AmbientLight": "120 120 120" },
        "When": {
          "SubmarineAction": "WarpInsideSubmarine",
          "HasReadLetter": "MySubmarine.AvailableMailId",
          "Weather": "Rain, Storm"
        }
      }, 

    //●夜の明るさ変更 1900-2150
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_MySubmarine_GoIsland",
        "MapProperties": { "AmbientLight": "140 140 140" },
        "When": {
          "SubmarineAction": "WarpInsideSubmarine",
          "HasReadLetter": "MySubmarine.AvailableMailId",
          "Time": "{{range:1900,2600}}"
        },
        "Update": "OnTimeChange"
      }, 
      {
        "Action": "EditMap",
        "Target": "Maps/Custom_MySubmarine_GoBeach",
        "MapProperties": { "AmbientLight": "140 140 140" },
        "When": {
          "SubmarineAction": "WarpInsideSubmarine",
          "HasReadLetter": "MySubmarine.AvailableMailId",
          "Time": "{{range:1900,2600}}"
        },
        "Update": "OnTimeChange"
      }, 


  //★★★メール と トリガーアクション 関係★★★

     //●メールデータ
      {
        "Action": "EditData",
        "Target": "Data/Mail",
        "Entries": {
          "MySubmarine.AvailableMailId": "{{i18n:MySubmarine.Mail_Text}}[#]{{i18n:MySubmarine.Mail_Title}}",
        }
      },
 
     //●トリガーアクション(メール送信)
      {
        "Action": "EditData",
        "Target": "Data/TriggerActions",
        "Entries": {
          "MySubmarine.AvailableMailId_SendMail": {
            "Id": "MySubmarine.AvailableMailId_SendMail",
            "Trigger": "DayStarted",
            "Actions": [
              "AddMail Current MySubmarine.AvailableMailId now"
            ],
            "Condition": "PLAYER_FRIENDSHIP_POINTS Current Maru 2000,PLAYER_HAS_MAIL Current Island_Turtle Received",
          }
        }
      }


    ]//▼▼"Changes"の終了▼▼
