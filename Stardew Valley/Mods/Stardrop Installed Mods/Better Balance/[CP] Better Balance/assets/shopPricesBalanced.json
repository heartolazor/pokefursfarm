{
   "Changes": [
	   // While most shops update their prices based on the current value of the item, the following "Data/Shops" sections are for special cases where certain shops sell certain items at a set price instead
		// Since these prices won't automatically adjust to any changes to the base value of items set in "pricesBalanced.json", they need to be set here manually
			// Note: Each entry has a comment above it listing the name and Vanilla PURCHASE price (Although some shops have additional multipliers applied to this value, as noted below)
			// Under the comment listing the name and Vanilla price is the actual entry, where the first number inside " "s is the item's object ID, and the second number inside " "s is the new PURCHASE price.
		{
		"Action": "EditData",
		"Target": "Data/Shops",
		"TargetField": [ "SeedShop", "Items" ],
		"Fields": {
				// Sunflower Seeds: 100		(This value is multiplied 2x to get the actual in-game price)
				"SunflowerSeeds_Summer": {
					"Price": "{{Round: {{Query: {{Flower & Honey Value Multiplier}} * 100 }} }}",
				},
				// Sunflower Seeds: 100		(This value is multiplied 2x to get the actual in-game price)
				"SunflowerSeeds_Fall": {
					"Price": "{{Round: {{Query: {{Flower & Honey Value Multiplier}} * 100 }} }}",
				},
				// Basic  Retaining Soil: 50		(This value is multiplied 2x to get the actual in-game price)
				"(O)370": {
					"Price": 50,
				},
				// Quality Retaining Soil: 75		(This value is multiplied 2x to get the actual in-game price)
				"(O)371": {
					"Price": 75,
				},
				// Cherry Sapling: 1700		(This value is multiplied 2x to get the actual in-game price)
				"(O)628": {
					"UseObjectDataPrice": true,		// These settings make the shop automatically use the item's sale value set in the section above
					"Price": -1,
				},
				// Apricot Sapling: 1000	(This value is multiplied 2x to get the actual in-game price)
				"(O)629": {
					"UseObjectDataPrice": true,		// These settings make the shop automatically use the item's sale value set in the section above
					"Price": -1,
				},
				// Orange Sapling: 2000		(This value is multiplied 2x to get the actual in-game price)
				"(O)630": {
					"UseObjectDataPrice": true,		// These settings make the shop automatically use the item's sale value set in the section above
					"Price": -1,
				},
				// Peach Sapling: 3000		(This value is multiplied 2x to get the actual in-game price)
				"(O)631": {
					"UseObjectDataPrice": true,		// These settings make the shop automatically use the item's sale value set in the section above
					"Price": -1,
				},
				// Pomegranate Sapling: 3000	(This value is multiplied 2x to get the actual in-game price)
				"(O)632": {
					"UseObjectDataPrice": true,		// These settings make the shop automatically use the item's sale value set in the section above
					"Price": -1,
				},
				// Apple Sapling: 2000		(This value is multiplied 2x to get the actual in-game price)
				"(O)633": {
					"UseObjectDataPrice": true,		// These settings make the shop automatically use the item's sale value set in the section above
					"Price": -1,
				}
			}
		},
		{
		"Action": "EditData",
		"Target": "Data/Shops",
		"TargetField": [ "Joja", "Items" ],
		"Fields": {
				// Sunflower Seeds: 100		(By default, this value is multiplied 1.25x unless you are a Joja Member)
				"SunflowerSeeds_Summer": {
					"Price": "{{Round: {{Query: {{Flower & Honey Value Multiplier}} * 100 }} }}",
				},
				// Sunflower Seeds: 100		(By default, this value is multiplied 1.25x unless you are a Joja Member)
				"SunflowerSeeds_Fall": {
					"Price": "{{Round: {{Query: {{Flower & Honey Value Multiplier}} * 100 }} }}",
				}
			},
		"When": {
			"HasMod|contains=FlashShifter.SVECode": false
         }
		},
		{
		"Action": "EditData",
		"Target": "Data/Shops",
		"TargetField": [ "Joja", "PriceModifiers" ],
		"Fields": {
				"NonMemberMarkup": {
					"Amount": "{{Query: {{JojaMart Multiplier non-member}} * 1 }}",
				}
			},
		"When": {
			"HasMod|contains=FlashShifter.SVECode": false
         }
		},
		{
		"Action": "EditData",
		"Target": "Data/Shops",
		"TargetField": [ "Joja", "PriceModifiers" ],
		"Entries": {
                "Xen0nex.BetterBalanceCP_MemberMarkup": {
					"Id": "Xen0nex.BetterBalanceCP_MemberMarkup",
					"Condition": "PLAYER_HAS_MAIL Current JojaMember",
					"Modification": 2,
					"Amount": "{{Query: {{JojaMart Multiplier member}} * 1 }}",
					"RandomAmount": null
				}
            },
		"When": {
			"HasMod|contains=FlashShifter.SVECode": false
         }
		},
