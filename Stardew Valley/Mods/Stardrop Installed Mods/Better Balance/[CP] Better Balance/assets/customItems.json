{
   "Changes": [
      // This file is basically a template you can use to adjust the prices for items, including items added by other mods.
	  // You can then save a copy of this file to use with any future updates of Better Balance without having to redo the edits each time (IE, the edits to an item in customItems.json take precedence over the edits to the same item in pricesBalanced.json)
	  // For items added by other mods, you will have to check the other mod's files to see what the ID of the item is. Some examples for some items from other mods are shown below that you can copy, paste & edit.
	  // This file has no effect unless you have both enabled the "Adjust Custom Items" setting in the config and added any items to the list below, using their correct IDs
		
		//NOTE: You will need to use an item's object ID in this file, which is NOT always the same as its Name or DisplayName. For vanilla items you can find the object ID in the decompiled Data/Objects.json file, or searching online. For mod-added items, if you see {{ModId}} in the item's ID, replace {{ModId}} with the "UniqueID" in the mod's manifest.json. For example, Better Balance's "UniqueID" is Xen0nex.BetterBalanceCP
		
		// For convenience, here are the tokens for the various Value Multipliers you can use:
			// {{Crops Value Multiplier}}	{{Farm Forage Value Multiplier}}	{{Flower & Honey Value Multiplier}}	{{Animal Product Value Multiplier}}	{{Late-Game Animal Product Value Multiplier}}	{{Animal Resale Value Multiplier}}	{{Fish Value Multiplier}}	{{Cooked Food Value Multiplier}}	{{Custom Value Multiplier}}	
			
			
			// Note: Each entry should have a comment above it listing the name and default SELLING price (Selling price is usually half of the PURCHASE price).
			// Under the comment listing the name and Vanilla price is the actual entry, where the first number inside " "s is the item's object ID, and the second number inside " "s is the new SELLING price.
		{
         "Action": "EditData",
         "Target": "Data/Objects",
         "Fields": {
				
				//Vanilla items-------------------------------------------------------------------------------
			// Rusty Spoon: 25
            "110": {
               "Price": "{{Round: {{Query: {{Custom Value Multiplier}} * 25 }} }}"
            },
			
				//Mod-added items-------------------------------------------------------------------------------
			// Basil from the "Cornucopia - More Crops" mod: 30
            "Cornucopia_Basil": {
               "Price": "{{Round: {{Query: {{Crops Value Multiplier}} * 30 }} }}"
            },
			// Basil Seeds from the "Cornucopia - More Crops" mod: 10
            "Cornucopia_BasilSeeds": {
               "Price": "{{Round: {{Query: {{Crops Value Multiplier}} * 10 }} }}"
            },
			// Benne Sesame from the "Bonster's Combined Crops" mod: 60
            "BFV.CombinedCrops_BenneSesame": {
               "Price": "{{Round: {{Query: {{Crops Value Multiplier}} * 60 }} }}"
            },
			// Benne Sesame Seeds from the "Bonster's Combined Crops" mod: 60
            "BFV.CombinedCrops_BenneSesameSeeds": {
               "Price": "{{Round: {{Query: {{Crops Value Multiplier}} * 60 }} }}"
            },
		 }
       }
   ]
}