{
  "Changes": [

//SpaceCoreTriggers//
    {
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "When": {
        "HasMod": "spacechase0.SpaceCore"
      },
      "Entries": {
        "{{ModId}}_LegacyAgedRumTrigger": {
          "Id": "{{ModId}}_LegacyAgedRumTrigger",
          "Trigger": "spacechase0.SpaceCore_OnItemEaten",
          "Condition": "ITEM_CONTEXT_TAG Input Seafaring Antique",
          "MarkActionApplied": false,
          "Action": "AddItem 152"
        }
      }
    },
    {
      "Action": "EditData",
      "Target": "Data/TriggerActions",
      "When": {
        "HasMod": "spacechase0.SpaceCore"
      },
      "Entries": {
        "{{ModId}}_SeaCrystalFlaskTrigger": {
          "Id": "{{ModId}}_SeaCrystalFlaskTrigger",
          "Trigger": "spacechase0.SpaceCore_OnItemUsed",
          "Condition": "ITEM_CONTEXT_TAG Input Seafaring Antique magic_flask",
          "MarkActionApplied": true,
          "Actions": [
            "spacechase0.SpaceCore_PlaySound shadowDie local",
"spacechase0.SpaceCore_ShowHudMessage \"{{i18n:Flask-Hud-Message}}\" dreamy.kickitspot_SeaCrystalFlask",
            "AddMail Current essence1 received",
            "AddItem 859",
	    "AddMoney 30",
	    "AddBuff 18",
          ]
        }
      }
    },



//greenraintrigger//
{
      "Action": "EditData",
 "When": {
        "HasMod": "DLX.Bundles"
      },
    "Target": "Data/TriggerActions",
      "Entries": {
"{{ModId}}_greenRainTrigger":
{
  "Id": "{{ModId}}_greenRainTrigger",
  "Trigger": "LocationChanged",
  "Condition": "PLAYER_HAS_SEEN_EVENT Current orb_hint_intro",

  "Actions": [
    "UB_PlaceBundle Cape.SecretOrb",
    "MarkActionApplied Current {{ModId}}_greenRainTrigger true"
  ]
}
}

},
///repeat//
{
  "Action": "EditData",
  "When": {
    "HasMod": "DLX.Bundles"
  },
  "Target": "Data/TriggerActions",
  "Entries": {
    "{{ModId}}_greenRainTriggerRepeat": {
      "Id": "{{ModId}}_greenRainTriggerRepeat",
      "Trigger": "LocationChanged",
      "Condition": "PLAYER_HAS_RUN_TRIGGER_ACTION Current {{ModId}}_greenRainTrigger, PLAYER_STAT Current weedsEliminated 30",
      "Actions": [
        "UB_PlaceBundle Cape.SecretOrb.Repeat",
        "MarkActionApplied Current {{ModId}}_greenRainTriggerRepeat false"
      ]
    }
  }
},

