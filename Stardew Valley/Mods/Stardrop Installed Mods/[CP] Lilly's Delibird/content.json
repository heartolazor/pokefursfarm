{
    "Format": "2.0.0",
	"ConfigSchema": {
		"SurpriseGift": {
			"AllowValues": "true, false",
			"Default": "false",
			"Description": "Choose whether you want to be able to get the Surprise Gift Item. WARNING!!! Opening this will give a random item and might break progression or give an error item."
        }
	},
    "Changes": [  
        //Sprites
        {
            "LogName": "Load shopIcon for Delibird",
            "Action": "Load",
            "Target": "Animals/{{ModId}}_shop_Delibird_icon",
            "FromFile": "assets/DelibirdShop.png"
        },
        {
            "LogName": "Load Sprite for Delibird",
            "Action": "Load",
            "Target": "Animals/{{ModId}}_Delibird",
            "FromFile": "assets/Delibird.png"
        },
		{
            "LogName": "Load Sprite for DelibirdShiny",
            "Action": "Load",
            "Target": "Animals/{{ModId}}_Delibird_shiny",
            "FromFile": "assets/DelibirdShiny.png"
        },
        {
            "LogName": "Load Spritesheet for items",
            "Action": "Load",
            "Target": "TileSheets/{{ModId}}_Delibird_items",
            "FromFile": "assets/DelibirdItems.png"
        },
		{
            "LogName": "Load Spritesheet for Big Craftables",
            "Action": "Load",
            "Target": "TileSheets/{{ModId}}_Delibird_bc",
            "FromFile": "assets/DelibirdBC.png"
        },
		{
            "LogName": "Load shopIcon for Iron Bundle",
