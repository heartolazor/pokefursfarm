		{
            "LogName": "Load Sprite for IronBundleShiny",
            "Action": "Load",
            "Target": "Animals/{{ModId}}_IronBundle_shiny",
            "FromFile": "assets/IronBundleShiny.png"
        },
		//Data
		{
			"LogName": "Load Delibird",
			"Action": "Include",
			"FromFile": "data/Delibird.json"
		},
		{
			"LogName": "Load Items",
			"Action": "Include",
			"FromFile": "data/DelibirdItems.json"
		},
		{
			"LogName": "Load Machines",
			"Action": "Include",
			"FromFile": "data/DelibirdMachines.json"
		},
		{
			"LogName": "Load Present Open Data",
			"Action": "Include",
			"FromFile": "data/PresentOpen.json"
		},


		{
			"LogName": "Load Iron Bundle With Surprise",
			"Action": "Include",
			"FromFile": "data/IronBundleSurprise.json",
			"When": { "SurpriseGift": "true" }
		},
		{
			"LogName": "Load Iron Bundle Without Surprise",
			"Action": "Include",
			"FromFile": "data/IronBundleNoSurprise.json",
			"When": { "SurpriseGift": "false" }
		},


