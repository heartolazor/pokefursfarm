{
  //Config
  "config.Difficulty.Name": "Difficulty",
  "config.Difficulty.Description": "Controls how difficult it is to craft dinosaur eggs. On Normal, recipes require fossil artifacts and some items produced by dinosaurs. On Easy, recipes use fruits, vegetables, or cooked dishes.",
  "config.Donation.Name": "Donation Requirement",
  "config.Donation.Description": "Determines whether donating a Dinosaur Egg to the Museum and receiving Marlon’s letter is required to unlock the Dino Hutch.\n\n• Normal: You must donate a Dinosaur Egg to the Museum to unlock the Dino Hutch.\n• Easy: No donation or letter is required.",
  "config.Requirements.Name": "Progression Requirements",
  "config.Requirements.Description": "Determines the requirements for unlocking recipes and purchasing boots. • Normal: You must build the Dino Hutch and all of its upgrades to unlock recipes and boots through letters and quests. • Easy: Recipes are unlocked at Foraging level 2 and 4, and boots become available at Combat levels 2, 3, and 4. No letters or quests will be received, reducing immersion. • Easy mode is recommended if for some bug, letters do not arrive and progression becomes blocked.",
  "config.Collection.Name": "Dinosaur Items for Perfection",
  "config.Collection.Description": "Determines whether dinosaur products and their artisan goods are required for Perfection.\n\n• Normal: Dinosaur items and their artisan products are required for Perfection.\n• Easy: Dinosaur items are not required for Perfection.",
  "config.IndoorMaps.Name": "Indoor Maps Style",
  "config.IndoorMaps.Description": "Changes the interior style of dinosaur hutchs. Normal keeps the vanilla look with objects, hay on the floor, and damaged walls and floors. Clean removes non-essential objects and repairs floors and walls.",
  "config.BuffBoots.Name": "Buff Boots",
  "config.BuffBoots.Description": "If enabled, dinosaur boots apply an additional buff to defense and immunity. Requires the dependency mod to function.",
  "config.DinoSounds.Name": "Dinosaur Sounds",
  "config.DinoSounds.Description": "Enables or disables the new dinosaur sound effects.",
  "config.SpriteForPaint.Name": "Sprite for Painting",
  "config.SpriteForPaint.Description": "Changes the default Dino Hutch Deluxe sprite to a brighter version so painted colors look clearer. It is recommended to keep this disabled until you plan to paint the building.",
