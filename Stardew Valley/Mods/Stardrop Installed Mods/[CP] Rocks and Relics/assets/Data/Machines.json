{
	"Changes": [
		//LOAD ASSET
		{
			"Action": "Load",
			"Target": "Mods/{{ModId}}/Machines",
			"FromFile": "assets/Resources/Machines.png"
		},
		{
            "Action": "EditData",
            "Target": "Data/AudioChanges",
            "Entries": {
				"{{ModId}}.Transmute": {
					"ID": "{{ModId}}.Transmute",
					"Category": "Sound",
					"FilePaths": [ "{{AbsoluteFilePath: assets/Sounds/transmute.ogg}}", ],
					"StreamedVorbis": true,
                    "Looped": false
				},	
            }
        },
		//VANILLA APPEND
		{
			"Action": "EditData",
			"Target": "Data/Machines",
			"TargetField": [
				"(BC)13",
				"OutputRules"
			],
			"Entries": {
				"{{ModId}}.PrismaticOre.Process": {
					"Triggers": [
					  {
						"Id": "ItemPlacedInMachine",
						"Trigger": "ItemPlacedInMachine",
						"RequiredItemId": "(O){{ModId}}.PrismaticPieces",
						"RequiredCount": 5,
					  }
					],
					"OutputItem": [
					  {
						"PriceModifierMode": "Stack",
						"Id": "(O)74",
						"ItemId": "(O)74",
						"StackModifierMode": "Stack",
						"QualityModifierMode": "Stack",
					  }
					],
					"DaysUntilReady": 4,
					"InvalidCountMessage": null,
					"RecalculateOnCollect": false
				},
			}
		},
