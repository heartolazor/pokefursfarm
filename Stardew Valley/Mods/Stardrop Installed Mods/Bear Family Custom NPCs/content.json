{
  "Format": "2.0.0",

  "ConfigSchema": {

    "IncludeinIntroductionQuest": {
      "AllowValues": "true, false",
      "Default": true,
      "AllowBlank": false,
      "Description": "Determines whether Sig and Sondra count for the introduction quest. Default is true; they will count for the introduction quest when added at the beginning of a new game.",
      "Section": "General"
    },

    "ExcludeFromPerfection": {
      "AllowValues": "true, false",
      "Default": false,
      "AllowBlank": false,
      "Description": "Excludes BearFam items from Perfection tracking. This will not exclude recipes due to the game's code but will exclude the items from the shipping requirements at least. False by default, meaning items/crops count by default.",
      "Section": "General"
    },

    "ExcludeFishFromPerfection": {
      "AllowValues": "true, false",
      "Default": false,
      "AllowBlank": false,
      "Description": "Excludes BearFam fish from Perfection tracking. This means Bearfam fish won't need to be caught for perfection. False by default, meaning the fish count by default.",
      "Section": "General"
    },

    "FarmerJobTitle": {
      "Default": "Farmer",
      "AllowBlank": false,
      "AllowMultiple": true,
      "Description": "Sets the player's job title for more immersive roleplay for users who aren't playing as farmers specifically. Default is 'farmer'.",
      "Section": "General"
    },

    "KrakensWords": {
      "AllowValues": "Wise, Funny, Squidfact",
      "Default": "Wise",
      "AllowBlank": false,
      "Description": "Is the Kraken speaking wisdom, comedy, or facts? Has no effect than whether you get allegedly wise quotes from the internet, allegedly funny jokes, or mostly verified facts about squids. Default is wise.",
      "Section": "General"
    },

    "ProfanityFilter": {
      "AllowValues": "True, False",
      "Default": false,
      "AllowBlank": false,
      "Description": "Changes profanity to mild non-swears for those who prefer a cleaner game. (Think hell becomes heck, damn becomes darn, etc. etc.) False by default, meaning there may be some profanity in the dialogue by default",
      "Section": "General"
    },

    "BearsGiveGifts": {
      "AllowValues": "True, False",
      "Default": true,
      "AllowBlank": false,
      "Description": "Allows the Bear siblings to give extra gifts at Winter Star. True by default; disable if you don't want them to add on to whatever your secret gift-giver is giving you for the year.",
      "Section": "General"
    },

    "BearFamStarterGift": {
      "AllowValues": "true, false",
      "Default": true,
      "AllowBlank": false,
      "Description": "Sends a letter at the start of a new game that welcomes the player with a little starter gift. Default is true, as in you will get a letter within 5 days of starting a new game.",
      "Section": "General"
    },

    "EnableBonusEvents": {
      "AllowValues": "true, false",
      "Default": true,
      "AllowBlank": false,
      "Description": "Enables extra events that are not necessarily plot-mandatory, but add to the story of the NPC and/or their platonic relationships with vanilla characters. True/Enabled by default, meaning you can see the bonus events by default.",
      "Section": "General"
    },

    "NoIntroEvents": {
      "AllowValues": "true, false",
      "Default": false,
      "AllowBlank": false,
      "Description": "Disables the pair of intro events for Sondra + Sigurd and then later Gunnar + Gudrun. Great for if you're adding to an existing save and don't want to feel bombarded with events! False/disabled by default, meaning the intro events will play.",
      "Section": "General"
    },

    "IncludeExtraLetters": {
      "AllowValues": "true, false",
      "Default": true,
      "AllowBlank": false,
      "Description": "Adds some randomized letters from members of BearFam that probably contain gifts. True by default, meaning you may get some random letters",
      "Section": "General"
    },

    "SeasonalOutfits": {
      "AllowValues": "full, lite, vanilla",
      "Default": "full",
      "AllowBlank": false,
      "Description": "Choose how many outfits Bearfam wears in game. Full means Bearfam will have multiple outfits per season, along with unique festival outfits. Lite means they wear a different outfit per season, plus Spirit's Eve and Flower Dance. Vanilla means they wear the same outfit for all of spring + summer + fall, a different outfit for winter, and unique outfits for Spirit's Eve and Flower Dance. Default is full.",
      "Section": "General"
    },

    "SigurdHairColor": {
      "AllowValues": "bluehaired, blackhaired",
      "Default": "bluehaired",
      "AllowBlank": false,
      "Description": "Decide if Sig has black hair like his initial concept or blue hair like his current concept. Default is bluehaired. Note, if you change the configuration while playing, the change takes effect the next day.",
      "Section": "General"
    },
    "GunnarHasFreckles": {
