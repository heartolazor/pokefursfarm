    "jade.movies.after.spring_movie_1": "Ahora solo quiero ir de excursión. ¡Deberíamos ir algún día!$1#$b#Es mucho más bonito en persona.$1",
    "jade.movies.before.summer_movie_1": "Esto parece un poco tonto.$0", // wumbus
    "jade.movies.after.summer_movie_1": "No era realmente lo mío...$0",
    "jade.movies.before.fall_movie_1": "¡Si grito, no te puedes burlar de mí!$1", // howls in the rain
    "jade.movies.after.fall_movie_1": "¡Estuvo bien!$1#$b#Esta noche voy a dejar las luces encendidas...$0",
    "jade.movies.before.winter_movie_1": "He oído cosas buenas sobre esta.$1", // zuzu express
    "jade.movies.after.winter_movie_1": "Hmm... Todavía estoy pensando en la película.$0#$b#Aunque me gustó. Gracias por llevarme.$1",
    //Beatrice
    "movies.beatrice.1": "¿Esta película es un documental? Quizás aprenda algo.$1",
    "movies.beatrice.2": "(Beatrice tiene una sonrisa nostálgica en el rostro.)",
    "movies.beatrice.4": "Merci, @. Qué mundo tan magnifique en el que vivimos, ¿verdad?",
    "movies.beatrice.5": "¿Terror? No disfruto mucho pasando miedo.$2",
    "movies.beatrice.6": "(Beatrice no parece impresionada.)",
    "movies.beatrice.7": "Te agradezco la invitación, @, pero quizá otro género la próxima vez?",
    "movies.beatrice.8": "Tenemos la suerte de tener un cine tan bonito en nuestro pequeño pueblo.",
    "movies.beatrice.9": "Merci, @. Me ha gustado mucho.$1",
    //Corwin
    "movies.CorwinLK.1": "Je, esta parece divertida. ¡Podría ser una buena fuente de inspiración!$1",
    "movies.CorwinLK.2": "(Corwin sonríe, parece estar pasándoselo muy bien.)",
    "movies.CorwinLK.3": "Bueno, ha sido muy divertido. Tendremos que repetirlo alguna vez, ¿no?",
    "movies.CorwinLK.4": "Esto debería ser divertido. ¡No hay muchas películas en el mar!$1",
    "movies.CorwinLK.5": "Ah, sí, fue genial. Tendremos que repetirlo alguna vez, ¿no?",
    //Hart Family
    //Ethan
    "movies.EthanHart.1": "¡Divertido y apropiado para la edad! A mamá le encantaría.",
    "movies.EthanHart.2": "(Ethan se ríe.)",
    "movies.EthanHart.3": "Genial. Gracias por invitarme. Ha sido divertido.$1",
    "movies.EthanHart.4": "Mamá no me ha dejado ir a ver esta. Pero tú eres genial.",
    "movies.EthanHart.5": "(Ethan parece un poco asustado.)",
    "movies.EthanHart.6": "¡Ha sido divertido! Gracias @.#$b#Eh, ¿te importaría acompañarme a casa?$2",
    "movies.EthanHart.7": "Esta es una película para gente mayor.",
    "movies.EthanHart.8": "(Ethan está mirando, pero su mirada está un poco perdida.)",
    "movies.EthanHart.9": "Gracias @, pero la próxima vez deberías invitar a mi madre, ¿vale?",
    "movies.EthanHart.10": "Oye, qué sitio tan guay. Ojalá tuviera dinero para la máquina de gancho.",
    "movies.EthanHart.11": "Ha sido divertido, eres muy guay para ser grande, @.",
    //Edith
    "movies.EdithHart.1": "Me encantan los clásicos, @.$1",
    "movies.EdithHart.2": "(Edith sonríe con nostalgia a la pantalla.)",
    "movies.EdithHart.3": "Solía ver esta película con mis padres, @. Gracias por este viaje al pasado.",
    "movies.EdithHart.4": "Creo que a Ethan le gustaría esta película.",
    "movies.EdithHart.5": "(Edith intenta no parecer divertida y casi lo consigue.)",
    "movies.EdithHart.6": "Gracias por la invitación, @. Ahora tengo que irme, ¡tengo cosas que hacer!",
    "movies.EdithHart.7": "Es un sitio muy bonito, ¿verdad, @? Quizás debería sugerírselo a Michael para nuestra 'cita nocturna'.$1",
    "movies.EdithHart.8": "Gracias por la invitación, @. Ahora tengo que irme, ¡tengo cosas que hacer! Pero quizás podamos repetirlo alguna vez.",
    //Michael
    "movies.MichaelHart.1": "Eh, esto me trae recuerdos, colega. Edith y yo vimos esta película en una de nuestras primeras citas.",
    "movies.MichaelHart.2": "(Michael tiene una pequeña sonrisa nostálgica en su rostro.)",
    "movies.MichaelHart.3": "Gracias, @. Creo que tendré que invitar a Eddy a una 'cita nocturna'.",
    "movies.MichaelHart.4": "Esto debería ser entretenido.",
    "movies.MichaelHart.5": "(Michael parece estar disfrutando enormemente)",
    "movies.MichaelHart.6": "Oye, amigo, gracias por eso. ¡No veo suficientes películas de acción tontas!$1",
    "movies.MichaelHart.7": "Es genial tener un cine en nuestro pequeño pueblo.",
    "movies.MichaelHart.8": "Gracias por la divertida noche, @.",
    //Eyvinder
    "movies.eyvinder.invite": "No sé por qué quieres invitarme, pero sí, supongo que iré.$1",
    "movies.eyvinder.1": "No entiendo por qué me arrastras a esta pequeña caja sofocante para ver lo que nos rodea.$5",
    "movies.eyvinder.2": "(Está mirando fijamente la pantalla.)",
    "movies.eyvinder.3": "Oh, sí, ella es un mundo glorioso.",
    "movies.eyvinder.4.false": "Perdona por dudar de ti, ${chaval^chavala}$. Me ha gustado mucho.",
    "movies.eyvinder.4.true": "Siento haber dudado de ti, @. Me ha gustado mucho.",
    "movies.eyvinder.5": "No entiendo por qué me has arrastrado a esta pequeña caja sofocante en un día tan bonito.$5",
    "movies.eyvinder.6": "Bueno, ha sido una pérdida de tiempo. Las cosas que hace la gente para entretenerse.$2#$b#Te agradezco la invitación, pero no volvamos a hacerlo, ¿vale?",
    "movies.DaleWaede.1": "Me encantan estos clásicos, siempre me hacen pensar en mi abuela.$1#$b#Solíamos verlos juntos, en su pequeña televisión en blanco y negro.",
    "movies.DaleWaede.2": "(Se está esforzando mucho por no llorar.)",
    "movies.DaleWaede.3": "Gracias, @, es bonito recordar a los que hemos querido y perdido. Triste, pero bonito.",
    "movies.DaleWaede.4": "Te lo advierto, @, no soy aficionado a las películas de terror. Estoy empezando a arrepentirme de haber aceptado la invitación...$2",
    "movies.DaleWaede.5": "(No parece feliz; tiene el ceño fruncido y los puños apretados.)",
    "movies.DaleWaede.6": "Gracias por la invitación, @, pero por favor no me invites a ver otra película de terror.#$e#Entiendo por qué a la gente le gusta pasar miedo, pero a mí no me gusta.$2",
    "movies.DaleWaede.7": "¿Valquiria? Oh, está fuera de servicio, fuera. No le gustan las películas, y a algunas personas no les gusta el pelo de perro. Debería estar bien durante unas horas.",
    "movies.DaleWaede.8": "Gracias @, lo he disfrutado. Tendremos que volver a hacerlo alguna vez.",
    //*****************
    //The Animal NPCs
    "movies.littlegruff.invite": "*El pequeño Gruff se come el billete. Obviamente, eso es un 'sí'.*",
    "movies.LittleGruff.1": "*El pequeño Gruff se pregunta si las plantas en maceta son comestibles. Espera que no te olvides de comprarle un aperitivo.*",
    "movies.LittleGruff.2": "(Parece más interesado en comerse el asiento que en ver la película.)",
    "movies.LittleGruff.3": "*El pequeño Gruff te da un cabezazo y te mordisquea suavemente la ropa. No le ha gustado mucho la película, pero ha disfrutado pasando tiempo contigo.*",
    "movies.ladysheba.invite.true": "¿Pe-li? ¿Qué es eso? ¿Es comida? ¿Es ruidoso y da miedo?$2",
    "movies.ladysheba.1.false": "*Lady Sheba parece cautivada por los pájaros.*$1",
    "movies.ladysheba.1.true": "¿Pajaritos? ¡Hay que cazarlos, sí!$1",
    "movies.ladysheba.2": "(¡Oh, no! Se esconde debajo de su silla.)",
    "movies.ladysheba.3.false": "*Lady Sheba todavía parece un poco agotada. Quizás ir al cine no fue la mejor idea.*$2",
    "movies.ladysheba.3.true": "Quédate aquí, caza pajaritos. ¡Nunca más volveré a entrar en una sala ruidosa! ¡No me gusta!$2",
    "movies.theEmperor.invite": "¿Quack? *El Emperador parece confundido, ¡no puede comer esto!*",
    "movies.theemperor.1": "*El Emperador agita sus plumas y se pasea por el vestíbulo. Quiere impresionar a los pájaros que hay aquí.*",
    "movies.theemperor.2": "(Ay, se ha quedado dormido)",
    "movies.theemperor.3": "*Al emperador no le ha impresionado mucho la película. Prefiere los picnics.*",
    "movies.theEmpress.invite": "Cuac... *La emperatriz no parece interesada.*",
    "movies.theempress.1": "*La emperatriz se pregunta si hay algo para comer por aquí.*",
    "movies.theempress.2": "(Está mirando la pantalla hipnotizada. ¿Quizás le gustan los colores?) ",
    "movies.theempress.3": "*La emperatriz parece haber disfrutado de la película y ahora se pregunta si debería entrar en el mundo del espectáculo.*",
    //***********************
    //Spouse Movie Dialogue 
    "movies.jasper.spouse.invite": "¡Qué idea tan estupenda, cariño! Me encantaría ir al cine contigo.#$b#Nos vemos en el cine.",
    "movies.katarynalk.spouse.invite": "¡Cariño, me encantaría! Solo tengo que ocuparme de un par de cosas primero, ¿nos vemos en el cine?",
    "movies.aideen.spouse.invite": "Cariño, qué idea tan maravillosa. Nos vemos allá.",
    "movies.juliet.spouse.invite.a": "¡Suena genial! ¡Noche de cita!$1#$b#Nos vemos allá. ¡No llegues tarde!",
    "movies.juliet.spouse.invite.b": "¡Ooooh, una noche en el pueblo! ¡Es hora de divertirse!$1#$b#Nos vemos allá. ¡Y más te vale comprarme algo de picar!",
    "movies.juliet.spouse.invite.c": "Je, ya sé: podemos besarnos en la última fila como dos adolescentes.$4#$b#Nos vemos en el cine.",
    //Animal Movie Dialogue
    "movies.ladysheba.invite.false": "*Lady Sheba huele el billete. No huele a comida.*",
}