{ //****************************************************************
    // M O V I E S
    //General NPC Movie Dialogue
    // Jacob
    "movies.jacob.1": "Nuestra historia natural seguro que es interesante. Estoy deseando que llegue este momento.$1",
    "movies.jacob.2": "(Jacob está sonriendo)",
    "movies.jacob.3": "Es un mundo maravilloso, ¿verdad?",
    "movies.jacob.4": "Tendré que llevar a Ellie a ver esto alguna vez. Le encantará.",
    "movies.jacob.5": "No soy fan de este tipo de películas.",
    "movies.jacob.6": "(Jacob parece aburrido)",
    "movies.jacob.7": "Sustos baratos y cámaras temblorosas... No, no me asusté en absoluto.",
    "movies.jacob.8": "Esto parece ridículo. Aun así, a todos nos vendría bien un poco de diversión, de vez en cuando, ¿no?",
    "movies.jacob.9": "Oh sí, me divertí. Me pregunto si Ellie lo disfrutaría.",
    "movies.jacob.10": "Oh, esto parece emotivo.",
    "movies.jacob.11": "Jacob se seca una lágrima.",
    "movies.jacob.12": "Son películas como ésta las que me hacen... Bueno, Del la habría odiado y me habría llamado sentimental.$2",
    "movies.jacob.13": "Es bueno tomarse un descanso del trabajo de vez en cuando.",
    "movies.jacob.14": "Gracias por invitarme, @. Lo he disfrutado mucho.",
    // Aideen
    "movies.aideen.0": "No estoy segura de por qué me invitas a esto.$2",
    "movies.aideen.1": "No me siento bien.",
    "movies.aideen.2": "Me gustaría ir a casa ahora.$2",
    "movies.aideen.3": "Esto parece de lo más ridículo.",
    "movies.aideen.4": "(La mirada de Aideen está fija en la pantalla. Y está... ¿sonriendo?)",
    "movies.aideen.5": "Sí, me entretuve, @. No hace falta restregarlo.",
    "movies.aideen.6": "No hay nada como los clásicos.",
    "movies.aideen.7": "(Aideen está absorta en la película.)",
    "movies.aideen.8": "Eso fue absolutamente espléndido, @. Gracias por invitarme.",
    "movies.aideen.9": "Buenos días, @. Espero disfrutar de esta película.",
    "movies.aideen.10": "Gracias por invitarme a las fotos, @. Me lo he pasado muy bien.",
    // Eloise
    "movies.eloise.1": "Esto no parece una película para niños, @.",
    "movies.eloise.2": "Me siento mal del estómago. ¿Puedo ir a casa?",
    "movies.eloise.3": "No quiero volver a ir al cine contigo.$2",
    "movies.eloise.4": "¡Esto parece muy divertido!",
    "movies.eloise.5": "(Eloise está rebotando de emoción.)",
    "movies.eloise.6": "¡Oh, me ha encantado! ¿Podemos volver a verla la semana que viene, por favor?$1",
    "movies.eloise.7": "¡Esto se ve muy bien! Espero que haya muchos pájaros en él.$1",
    "movies.eloise.8": "¿Viste eso, @? ¡Fue impresionante!$1",
    "movies.eloise.9": "¡Muchas gracias! Me ha encantado. Voy a verlo una y otra vez.",
    "movies.eloise.10": "¡Hay pájaros aquí! Eso es realmente genial.",
    "movies.eloise.11": "¡Gracias @! Me gustó mucho ir al cine contigo.",
    // Lexi
    "movies.lexi.1": "No siento que deba estar aquí. La gente se queda mirando.$2",
    "movies.lexi.2": "Pobre planta. Toda sola.",
    "movies.lexi.3": "Me siento rara en mi corazón. ¿Tal vez un poco feliz, un poco triste? ¿Cómo se llama ese sentimiento?",
    "movies.lexi.4": "Este lugar es extraño. Tan lejos del mar. Estoy un poco asustada.$2",
    "movies.lexi.5": "Esto... ¡es maravilloso!",
    "movies.lexi.6": "Sentir, ¿cuál es la palabra? Inspirada. ¡Gracias!",
    "movies.lexi.7": "Este lugar es tan extraño. No me siento cómoda. La gente se queda mirando.",
    "movies.lexi.8": "Es oscuro y tan ruidoso. No lo entiendo.",
    "movies.lexi.9": "No quiero ir allí de nuevo. No fue agradable. Lo siento.$2",
    // Josephine
    "movies.josephine.1": "No estoy muy segura de esto.",
    "movies.josephine.2": "(Los ojos de Josephine están fuertemente cerrados.)",
    "movies.josephine.3": "Realmente no puedo entender por qué alguien vería voluntariamente algo así. Oh, ¿lo disfrutaste?",
    "movies.josephine.4": "Parece muy tonto. Tal vez deberías haberle preguntado a Oliver en su lugar.",
    "movies.josephine.5": "Bueno, no es así como habría elegido pasar unas horas de mi día. Pero gracias por invitarme de todos modos.",
    "movies.josephine.6": "¡Oh, me acuerdo de esta película! Guvvy y yo la vimos en nuestra primera cita.$1",
    "movies.josephine.7": "(Josephine sonríe a la pantalla.)",
    "movies.josephine.8": "Oh, eso me trajo tantos recuerdos. Gracias por invitarme.",
    "movies.josephine.9": "¡Un cine en un pueblo tan pequeño! Qué maravilla. Esto es muy nostálgico.",
    "movies.josephine.10": "Un cine tan acogedor. Me alegro de que me hayas invitado.",
    // Oliver
    "movies.oliver.1": "¡Mamá odia este tipo de cosas! Va a ser increíble.",
    "movies.oliver.2": "(Oliver sonríe.)",
    "movies.oliver.3": "¡Eso fue tan cursi y tonto! Estuvo muy bien. Aunque no da mucho miedo.",
    "movies.oliver.4": "¡Esto va a ser ridículo!",
    "movies.oliver.5": "¡Fue tan divertido! Podría verlo de nuevo. ¡Y otra vez!$1",
    "movies.oliver.6": "Oh, esto parece aburrido. Deberías preguntarle a mi madre en su lugar.",
    "movies.oliver.7": "(Oliver está jugando en silencio en su teléfono.)",
    "movies.oliver.8": "¡Una fiesta total para dormir! Pero al menos he podido dormir un poco.",
    "movies.oliver.9": "Este cine es bastante genial. Debería probar la máquina de la grúa. ¡Apuesto a que podría ganar!$1",
    "movies.oliver.10": "Eso fue genial. Gracias por dejarme pasar el rato contigo. No estás nada mal para ser un adulto.",
    // Rosa
    "movies.rosa.1": "Aww, he oído que esta va a tocar mi fibra sensible.",
    "movies.rosa.2": "(Rosa sonríe a la pantalla.)",
    "movies.rosa.3": "Fue muy dulce. Cursi, pero a veces lo cursi está bien. ¿Quieres ir a comer algo?",
    "movies.rosa.4": "¡Sí, hah! Nunca he jugado a este juego, pero hace tiempo que le tengo ganas a este.",
    "movies.rosa.5": "¡Fue muy divertido! Hagámoslo de nuevo alguna vez.",
    "movies.rosa.6": "El terror no es realmente lo mío, pero ya que preguntaste...",
    "movies.rosa.7": "(Rosa parece tensa.)",
    "movies.rosa.8": "Bien, entonces... vuelvo a mi vieja y chirriante habitación de la posada. Ciertamente no escucharé a los monstruos rascarse esta noche.$2",
    "movies.rosa.9": "¡Este lugar es tan bonito! Aunque apuesto a que la limpiadora se mantiene ocupada raspando los excrementos de los pájaros.",
    "movies.rosa.10": "Gracias por invitarme, @. Es bueno tener una amistad en este pueblo.$1",
    //KatarynaLK
    "movies.katarynalk.1": "Oooh, me pregunto qué podría ser... ¡quizás sea chuck negro!$1",
    "movies.katarynalk.2": "(Kataryna se agarra a los reposabrazos, tensa por la expectación)",
    "movies.katarynalk.3": "Me encanta una buena sorpresa ... ¡Espéralo!",
    "movies.katarynalk.4": "Jaja, un conejo. Bueno, ¡tienen una vena viciosa de una milla de ancho! Gracias por invitarme, @.$1",
    "movies.katarynalk.5": "¿No es una película para niños?",
    "movies.katarynalk.6": "(Kataryna no parece impresionada)",
    "movies.katarynalk.7": "Sí, probablemente deberías invitar a Eloise la próxima vez.$2",
    "movies.katarynalk.8": "Me encanta un buen documental sobre la naturaleza. Ya sabes, había una vez...#$b#%Kataryna vacila, con una mirada melancólica.",
    "movies.katarynalk.9": "Es un mundo extraordinario en el que vivimos, ¿no es así @?",
    "movies.katarynalk.10": "Qué tontería, pero supongo que debe ser entretenido.",
    "movies.katarynalk.11": "(Kataryna sonríe)",
    "movies.katarynalk.12": "No me había reído tanto desde que nos topamos con una guarida de dardos swardle... pero esa es una historia para otro día.",
    "movies.katarynalk.13": "Gracias por invitarme al cine, @. Bonito lugar el que tienes aquí.",
    "movies.katarynalk.14": "Es bueno tomarse un descanso del trabajo por un tiempo. Pero supongo que ahora hay que volver a la rutina. Que tengas un buen día, @.",
    //Vivienne
    "movies.viviennelk.1": "Clem y yo vimos esta una vez en un autoservicio. Bueno, digo *la vimos* pero...#$b#%Vivienne te guiña el ojo.",
    "movies.viviennelk.2": "(¿Esas son lágrimas en los ojos de Vivienne?)",
    "movies.viviennelk.3": " Sí, soy una ton...",
    "movies.viviennelk.4": "Gracias por hacerme recordar una época más feliz, @.",
    "movies.viviennelk.5": "No estoy segura de ser el mercado objetivo para esta...$2",
    "movies.viviennelk.6": "(Vivienne no parece inmersa)",
    "movies.viviennelk.7": "Todo acción, nada de trama. La próxima vez... tal vez lleva a alguien distinto.",
    "movies.viviennelk.8": "¿Crees que a una vieja como yo sólo le gustan las tonterías sentimentales?$2",
    "movies.viviennelk.9": "Bueno, eso fue toda una decepción. Aún así, es bueno recuperar un poco de sueño.",
    "movies.viviennelk.10": "Nada como un buen horror para acelerar el pulso... ¡no hay mucho más que pueda en estos días!$1",
    "movies.viviennelk.11": "(Vivienne parece tensa)",
    "movies.viviennelk.12": "Gracias por una noche de emociones, @.",
    "movies.viviennelk.13": "Qué cine tan mono. Oooh... ¡quizás pruebe la máquina de garra después!$1",
    "movies.viviennelk.14": "Ugh.. ese hombre está acaparando la máquina. Ah bueno, gracias por invitarme, @. Me divertí.",
    //Victoria
    "movies.torilk.1": "Me encantan estos clásicos. Son mis películas de confort.$1",
    "movies.torilk.2": "(A Victoria le brillan los ojos.)",
    "movies.torilk.3": "Oh, me encanta esta parte.",
    "movies.torilk.4": "Gracias @. Agradezco mucho la invitación. La mejor manera de pasar un frío día de invierno, ¿verdad?",
    "movies.torilk.8": "No me malinterpretes, te agradezco que me hayas invitado, @... ¿pero películas de miedo? No son realmente lo mío.$2",
    "movies.torilk.15": "(Victoria parece haberse quedado dormida)",
    "movies.torilk.9": "Bueno... eso fue definitivamente una película... Um, gracias por invitarme... Supongo.$3",
    "movies.torilk.10": "Estoy feliz de ir al cine contigo, @. Gracias por invitarme.",
    "movies.torilk.11": "(Victoria parece muy implicada emocionalmente en esta película.)",
    "movies.torilk.12": "Pensé que sería una película mona y divertida... No esperaba que me hiciera llorar. Oh Yoba, soy tan tonta.$3",
    "movies.torilk.13": "Qué cine tan tierno. Espero que esos pájaros estén bien cuidados.",
    "movies.torilk.14": "Gracias por pensar en mí, @. Te agradezco mucho la invitación.",
    //Juliet
    "movies.juliet.1": "Una película para niños, ¿en serio?",
    "movies.juliet.2": "(Juliet parece frotarse mucho los ojos.)",
    "movies.juliet.3": "Maldita fiebre del heno. Todo el polvo que hay aquí...$s",
    "movies.juliet.4": "¿Qué? No estaba llorando. No en una película infantil ñoña. ¡No seas ridículo!$5^¿Qué? No estaba llorando. No en una película infantil ñoña. ¡No seas ridícula!$5",
    "movies.juliet.5": "¡Oooh espero que haya mucha sangre y gore!",
    "movies.juliet.6": "¿Tienes miedo? ¡Pareces asustado! ¿Necesitas que te coja la mano?$1^¿Tienes miedo? ¡Pareces asustada! ¿Necesitas que te coja la mano?$1",
    "movies.juliet.7": "¡Fantástico! Oye, ¿sabes qué deberíamos hacer ahora? Ir a dar un largo paseo por el bosque oscuro.$1#$b#¡Ja, @, tu cara!$1",
    "movies.juliet.8": "¡Oooh he oído que esta es espeluznante y rara! A. Por. ¡Ello!",
    "movies.juliet.9": "¡Esto es genial!",
    "movies.juliet.10": "Oh, ¡podría ver esa otra vez, y otra vez! ¡Tal vez, con el tiempo, descubra qué diablos estaba sucediendo!",
    "movies.juliet.11": "Bien... si tienes tu corazón puesto en esta savia de las vacaciones, que así sea. Me vendría bien una siesta.",
    "movies.juliet.12": "Juliet parece aburrida.",
    "movies.juliet.13": "*bostezos* Bueno, eso fue una pila humeante de estiércol sentimental. La próxima vez elegiré la película, ¿vale?$5",
    "juliet.movietheater.kevin": "¡Es extraño estar de este lado del mostrador! ¡Hola, Kevin!",
    "juliet.movietheater.claire": "¡Hola, Claire! Se te ve feliz. ¡Te sienta bien!",
    "movies.juliet.14": "Bueno, a mí me entretuvo. ¿Y a ti?",
    //Jessie
    "movies.jessie.1": "Nuestro mundo es ciertamente hermoso. Estoy deseando ver esto.",
    "movies.jessie.2": "(Jessie mira absorta la pantalla.)",
    "movies.jessie.3": "Qué mundo tan extraordinario el que vivimos.",
    "movies.jessie.4": "Juliet estaba delirando con esta. La amo... ¡pero no estoy segura de confiar en sus gustos!",
    "movies.jessie.5": "(Los ojos de Jessie están firmemente cerrados.)",
    "movies.jessie.6": "Oh... eso me va a dar pesadillas...$s",
    "movies.jessie.7": "A Juliet le encantaba esta... Por eso estoy un poco preocupada.$2",
    "movies.jessie.8": "Por favor, no vuelvas a llevarme a una película de terror.$2",
    "movies.jessie.9": "Es un placer pasar tiempo contigo. Espero que los pájaros sean felices aquí.",
    "movies.jessie.10": "Gracias por invitarme, @. La he disfrutado mucho.$1",
    //Jasper
    "movies.jasper.2.1": "Ah, los documentales siempre me intrigan, @. ¡Hay tanto mundo por ver!",
    "movies.jasper.2.2": "(Jasper te sonríe.)",
    "movies.jasper.2.3": "Fascinante, ¿verdad?",
    "movies.jasper.2.4": "Gracias, @. Ha sido toda una experiencia cinematográfica. Espero que tú también la hayas disfrutado.$1",
    "movies.jasper.4.1": "No estoy muy seguro sobre esta, @.$2",
    "movies.jasper.4.2": "(Jasper tiene los ojos bien cerrados.)",
    "movies.jasper.4.3": "(Jasper está pálido.)",
    "movies.jasper.4.4": "Oh... no... lo siento... Creo que tengo que irme a casa ahora.$2",
    "movies.jasper.5.1": "Esto parece divertido.$1",
    "movies.jasper.5.2": "Me ha gustado. Gracias por invitarme.$1",
    "movies.jasper.6.1": "Lo admito, tengo mis reservas sobre esta, pero me abstendré de hacer comentarios por ahora.",
    "movies.jasper.6.2": "Lo siento, @, no disfruté nada de esa película.",
    //Keanu
    "movies.keanu.1.1": "He estado esperando por esto. Nunca he jugado al juego, pero parece genial.",
    "movies.keanu.1.2": "(Keanu está viendo la película con atención.)",
    "movies.keanu.1.3": "Ha sido genial, colega. Gracias por invitarme.",
    "movies.keanu.2.1": "¡Colega! He oído que esta película es muy divertida. ¡Espero que esté a la altura de las expectativas!$1",
    "movies.keanu.2.2": "(Keanu se está riendo)",
    "movies.keanu.2.3": "¡Ja! Ha sido una película épica. Creo que nunca me había reído tanto en mi vida.",
    "movies.keanu.3.1": "Este lugar es increíble. No sé qué tal estará la película, pero estoy encantado de pasar el rato contigo.",
    "movies.keanu.3.2": "Gracias, colega, me lo he pasado genial. Repitamos pronto.$1",
    //Tristan
    "movies.0.tris.1": "Qué bonito es este lugar. ¡Me encantan los pájaros! ¡No te preocupes, no voy a perseguirlos!",
    "movies.0.tris.2": "/message \"Tristan parece estar disfrutando.\"",
    "movies.0.tris.3": "Muy entretenido. Me ha gustado.",
    "movies.1.tris.1": "A Jas le ha encantado, y ella tiene muy buen gusto.",
    "movies.1.tris.2": "pause 500/message \"Tristan parece triste.\"",
    "movies.1.tris.3": "Entiendo su atractivo.$2",
    "movies.1.tris.4": "Bonita, pero sensiblera.#$b#¿Sensiblera? ¿Lo pillas?$1",
    "movies.2.tris.1": "He estado en esos sitios, no sé si necesito verlos.",
    "movies.2.tris.2": "/message \"Tristan está muy concentrado en la pantalla.\"",
    "movies.2.tris.3": "Vale, lo admito, era preciosa.",
    "movies.3.tris.1": "Suena conmovedor y nauseabundo.",
    "movies.3.tris.2": "/message \"Tristan parece aburrido.\"",
    "movies.3.tris.3": "No, no es lo mío. Mmmm, pescado... ¿Podemos ir a comer?",
    "movies.4.tris.1": "Parece entretenida.",
    "movies.4.tris.2": "Esto es ridículo.$1",
    "movies.4.tris.3": "¡Qué película más tonta! Muy divertida.",
    "movies.5.tris.1": "¿Da miedo? Ja, yo era el gato más valiente del pueblo. ¡Me río de tu miedo!",
    "movies.5.tris.2": "/shake MisterGinger 3000/pause 500/",
    "movies.5.tris.3": "No... ¡¡¡No lo hagas...!!!",
    "movies.5.tris.4": "¿Qué? ¿Que tenía miedo? No, te lo estás imaginando.$2",
    "movies.6.tris.1": "Esta va a ser una de esas películas románticas empalagosas que tanto le gustan a Marnie, ¿no?#$b#No es para nada lo mío.$2",
    "movies.6.tris.2": "/message \"¿Son lágrimas las que hay en los ojos de Tristan?",
    "movies.6.tris.3": "No estoy llorando. Tú estás llorando. Probablemente sea por las luces.",
    "movies.7.tris.1": "Abigail hablaba de esta. ¡Seguro que es buena!",
    "movies.7.tris.2": "/message \"Tristan parece ligeramente divertido.",
    "movies.7.tris.3": "Ja, tonto... un poco DEMASIADO tonto.",
    "movies.7.tris.4": "La trama no tenía sentido. Aun así, supongo que fue divertida.$1",
    "movies.8.tris.1": "Mmmm, a Ras le gustó esta. Confío en su criterio.",
    "movies.8.tris.2": "...",
    "movies.8.tris.3": "Nunca confiaré en Ras, no, nunca más.",
    "movies.9.tris.1": "Me encantaría volver a verla, si insistes.$1",
    "movies.10.tris.1": "Sí, claro, ¿por qué no? Estuvo bien.",
    "movies.11.tris.1": "Sigo teniendo pesadillas.",
    //Jade
    // movies
    "jade.movies.before.generic": "Cómprame caramelos.$1", // generic
    "jade.movies.after.generic": "Me ha gustado. Gracias por llevarme.$1",
    "jade.movies.before.spring_movie_0": "¡Esta es un clásico!$1", // brave little sapling
    "jade.movies.during.spring_movie_0.script": "/message \"Jade parece muy interesado en la película.\"",
    "jade.movies.after.spring_movie_0": "Empezaba a pensar que no se convertiría en árbol. ¡Pero lo hizo!$1#$b#¡Menudo subidón!$1",
    "jade.movies.before.summer_movie_0": "Abigail siempre habla de esta.#$b#¡Más vale que sea buena!$1", // prairie king
