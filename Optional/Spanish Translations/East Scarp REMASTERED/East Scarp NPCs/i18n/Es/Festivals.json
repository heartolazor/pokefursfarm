{ //Festival DIalogue
  //*************************************************************************
  // F E S T I V A L   D I A L O G U E
  //**********************************
  // egg festival
  //*************
  "festivals.eloise.spring13": "¿Sabías que una gallina pone alrededor de 530 huevos en su vida?",
  "festivals.eloise.spring13.y2": "¡Este año he ayudado a pintar los huevos! Busca los que tienen pajaritos. Son míos.$1",
  "festivals.jacob.spring13": "Hola @. A Eloise le encantan los pájaros, pero nunca le ha interesado especialmente la búsqueda de huevos. Probablemente porque Abigail siempre gana.",
  "festivals.jacob.spring13.y2": "La primavera es una época del año muy ajetreada, ¿verdad? Me siento culpable por tener un día libre, pero celebrar las fiestas con la familia es más importante.$1",
  "festivals.eloise.spring13.emyn": "¿Crees que las hadas son como los colibríes? ¡¿Pueden batir sus alas cincuenta veces por segundo?! Me pregunto cuántas veces bate las alas un hada.",
  "festivals.josephine.spring13": "¡Qué celebración tan caprichosa! Tendré que hacer una foto a ese conejo; a Guvvie le hará mucha gracia.$1",
  "festivals.josephine.spring13.y2": "Una encantadora tradición de pueblo pequeño. Es una pena que Guvvie no pudiera unirse a nosotros... pero es un hombre muy ocupado.$2",
  "festivals.oliver.spring13.false": "¡Hola! Estoy totalmente aquí por la comida. ¡Y este ponche de huevo! Es muy bueno. Deberías probarlo.#$e#¿Qué quieres decir con que no debería beberlo? ¿Por qué? ¿Qué tiene de malo?$4#$b#Oh... Por favor, no se lo digas a mamá, ¿vale?$2", //
  "festivals.oliver.spring13.true": "Hola @. Lexi se está perdiendo la diversión - así que he sacado a escondidas algunas golosinas para ella. No se lo digas a nadie, ¿vale?#$b#¡Jacob cree que tengo mucho apetito!$1",
  "festivals.oliver.spring13.false.y2": "¡Hola! Estoy aquí por la comida. He comido demasiados de esos pequeños huevos al curry.",
  "festivals.oliver.spring13.true.y2": "Oye @... ¿Qué hay en mis bolsillos? Oh, algunos dulces para Lexi. ¡No se lo digas a nadie!",
  "festivals.ladysheba.spring13.false": "¡Mirrup!$1",
  "festivals.ladysheba.spring13.true": "¡Encuentro huevo de color! Juego con él. ¡Es divertido!$1",
  "festivals.vivienne.spring13": "Oh, por favor, ¿puedes ayudarme a hacer entrar en razón a estos dos? ¡Intentan decirme que soy demasiado mayor para cazar huevos!#$e#¡Y eso es una tontería! ¡Nunca se es demasiado viejo para divertirse, pero sí para saber lo que hay que hacer!$1",
  "festivals.kataryna.spring13": "Hasta ahora, tres personas se han parado a saludar, una ha preguntado por la próxima edición y solo dos me han mirado mal, lo considero una victoria.$1",
  "festivals.abyss.spring13": "*Abismo te mira fijamente. Posiblemente no apruebe la búsqueda de huevos.*",
  "festivals.beatrice.spring13": "Es encantador ver cómo se divierten los niños. Y también a los adultos.",
  "festivals.beatrice.spring13.y2": "Recuerdo cuando Abigail era tan pequeña que apenas podía llevar la cesta. Ahora mírala, ¡es toda una liebre primaveral!$1",
  "festivals.rosa.spring13.false": "¡Hola! ¿Has probado las natillas de Gus? Tiene un sabor interesante. Pero es delicioso.",
  "festivals.rosa.spring13.juliet": "¡Hola! Jules y yo ayudamos a esconder los huevos. Espero que se diviertan encontrándolos.$1",
  "festivals.tori.spring13": "Hola @. ¿Participarás en la búsqueda del huevo hoy?#$e#¡Buena suerte! Creo en ti.$1",
  "festivals.aideen.spring13": "¿No hace un tiempo espléndido para buscar huevos? No es que me vaya a unir a la búsqueda de huevos, por supuesto.#$e#Oh no, ¡no porque sea indigno! El alcalde Lewis me ha descalificado para participar. Aparentemente soy diabólicamente competitiva.$7",
  "festivals.spring13.juliet": "Hey, ${granjero^granjera}$. ¿Vas a salir corriendo detrás de los huevos? ¿Yo? Nah. Creo que prefiero quedarme por aquí y mirar el talento.$1",
  "festivals.spring13.jessie": "Hola, @. ¿Sabes? Sería bonito que los niños ganaran la búsqueda de huevos.$1#$e#Pero Abigail... Esa chica tiene un espíritu competitivo impresionante.",
  "festivals.spring13.jasper": "El Festival del Huevo tiene un profundo significado espiritual; el mundo está renaciendo de nuevo.$1",
  "festivals.spring13.jasper.spouse": "¡Hola, mi amor! Tu sonrisa siempre ilumina mi día.$1#$b#Y debo decir, ¡este ponche está delicioso!$3",
  "festivals.spring13.jade": "Ni siquiera me gustan los huevos...$3",
  "festivals.spring13.kennedy": "¡Qué festival más mono! Nah, no vamos a participar en la búsqueda. Aunque quizá les pase unos cuantos huevos a los críos.$1",
  "festivals.tristan.spring13": "No, no estoy escondido aquí esperando sorprender a competidores desprevenidos. ¡Oye, Jas tiene que conseguir la mayor cantidad de huevos de alguna manera!$1",
  "festivals.spring13.edith": "¿Posarías en el conejo para mí, @? Sería una buena foto para nuestro diario digital.$1",
  "festivals.spring13.ethan": "¿Buscar huevos? No, gracias.$4",
  "festivals.spring13.michael": "Hey, ${amigo^amiga}$, ¡nos has encontrado! Estamos evitando a la multitud. Pero animaré a cualquiera que pase por aquí, eso seguro.$1",
  "festivals.spring13.corwin": "Interesante celebración esta. ¿Algo sobre conejos y gallinas?$3",
  "festivals.spring13.dale": "No sería justo que participáramos: Valkyrie ya olfateó la mitad de los huevos.$1",
  // flower dance
  //*************
  "festivals.aideen.spring24": "¿Danza folclórica? Qué rústica. Esto se parece poco a las danzas a las que asistí en Grampleton. Ahora, esas eran algo sofisticados.",
  "festivals.aideen.spring24.y2": "Por muy rústico que sea este baile... bueno, no me atrevería a rechazar a un posible pretendiente.$4",
  "festivals.beatrice.spring24": "Este festival, siempre me emociona un poco, @.$2#$e#Raoul y yo, solíamos bailar juntos. Ah, para ser joven de nuevo, y en el amor.$1",
  "festivals.eloise.spring24": "¡Hola granjero @! Deberías sacar a bailar a mi padre.^¡Hola granjera @! Deberías sacar a bailar a mi padre.#$e#Nunca baila con nadie más que conmigo. Creo que echa demasiado de menos a mamá.$2",
  "festivals.eloise.spring24.y2": "No veo por qué Vincent no puede ser Reina de las Flores. Si las chicas pueden ser lo que quieran... los chicos también, ¿no?$3",
  "festivals.jacob.spring24": "¿Invitar a alguien a bailar? ¡Oh, no podría!$4",
  "festivals.jacob.spring24.y2": "Eloise sigue intentando convencerme de que elija una pareja y baile... pero en realidad prefiero mirar.$2",
  "festivals.josephine.spring24": "Es encantador ver bailar a los jóvenes, ¿verdad? Recuerdo una época en la que podía hacer girar algunas cabezas en la pista de baile.$1",
  "festivals.oliver.spring24": "¡No, no me escondo! ¡Soy el comité de bienvenida!#$e#Sí, me ofrecí para el trabajo, ¡aunque sólo sea para no bailar!$1",
  "festivals.rosa.spring24": "¡Este aire primaveral es tan fragante! Debería comprar algunas flores para alegrar la posada.",
  "festivals.rosa.spring24.y2": "Es divertido ver a la gente bailar junta, pero Lewis es tan anticuado... Me gustaría bailar con una chica, ¿sabes?$2",
  "festivals.tori.spring24": "¿Invitar a alguien a bailar? Oh, no, no podría... Me quedaré aquí y disfrutaré de la música.$2",
  "festivals.tori.spring24.y2": "¿Invitar a alguien a bailar? Oh, no. ¿Y si dicen 'no'?$2#$b#¡O peor! ¿Y si dicen que sí?$4",
  "festivals.vivienne.spring24": "Sí, es bonito ver bailar a los jóvenes, pero ¿dónde está el baile para nosotros los geriátricos?#$b#¡Podríamos enseñarles un par de cosas, creo!$1",
  "festivals.spring24.juliet": "Qué pintoresco, todos tan bien emparejados... ¿Quieres agitar un poco las cosas, @?$1",
  "festivals.spring24.jessie": "Es precioso ver a todo el mundo reunido... Pero también un poquito abrumador.",
  "festivals.spring24.jasper": "Bailar no es mi fuerte. 'Dos pies izquierdos', así me describía mi querida madre.$4",
  "festivals.spring24.jasper.9914": "Una celebración del amor y la fertilidad. Espero que no esperen que baile.$1#$b#La gente podría reírse. Aunque supongo que siempre puedo hacer... ¡El anti-hip-hop!$3",
  "festivals.spring24.jasper.spouse": "Hola, ${precioso^preciosa}$. La primavera está en el aire y nunca me he sentido tan vivo.$1#$e#Te quiero.$4",
  "accept.spouse": "¡Sería un honor bailar contigo, mi amor! Pero cuidado con tus deditos.$3",
  "festivals.spring24.tristan": "Hey, los gatos no bailan, pero yo quizá sí. ¡Eso sí, no esperes que me sepa los pasos!$1#$b#No te preocupes, me los invento sobre la marcha. ¿Quién se va a dar cuenta?",
  "festivals.spring24.tristan.y2": "Oh, estoy vigilando a Marlon. Quiere invitar a alguien a bailar, pero es demasiado tímido... Así que, como buen héroe, está buscando monstruos en vez de palabras.",
  "festivals.spring24.jade": "Ojalá alguien quisiera bailar conmigo...$3",
  "festivals.spring24.jade.spouse": "¡Me haría feliz bailar contigo!$1",
  "festivals.tristan.spring24": "Si quieres bailar conmigo, ¡más te vale reaccionar rápido!$4",
  "festivals.spring24.Kataryna": "¿Sabías que este festival se basa en una antigua danza ritual?#$b#Ten cuidado con lo que haces, @, podría despertar algo primitivo.",
  "festivals.spring24.kataryna.spouse": "Hola, cariño, ¿listo para que te enamores perdidamente?$1^Hola, cariño, ¿lista para que te enamores perdidamente?$1#$b#Estoy segura de que juntos podremos averiguar los pasos a seguir.$4^Estoy segura de que juntas podremos averiguar los pasos a seguir.$4",
  "festivals.spring24.corwin.CorwinFlirt": "¿Te apetece dar una vuelta por la pista, cielo?$8#$b#Eh, o bailo contigo... O voy a tener que sacar a Roddy.$1",
  "festivals.spring24.corwin.CorwinNoFlirt": "Hey @, ¿me echas una mano?$3#$b#Estoy intentando convencer a Roddy de que invite a Beatrice a bailar... Incluso lo amenacé con bailar yo mismo con ella si no lo hace.$1",
  "spring24.clint.postemily": "¿Sabes? Me alegro de que nadie me saque a bailar. Probablemente haría el ridículo de todos modos.$2", //Clint
  "festivals.spring24.ethan": "¡Me encontraste! No se lo digas a mamá, ¿vale? Me regañará por mancharme el traje.$2",
  "festivals.spring24.edith": "Michael y yo salíamos mucho a bailar en Zuzu. Claro que eso fue antes de que llegara Stella.",
  "festivals.spring24.michael": "Créelo o no, colega, antes podía marcarme unos cuantos pasos.#$e#Ahora... Lo único que consigo es avergonzar a Ethan. ¿Dónde se habrá metido?",
  "festivals.spring24.dale": "Hey @. Reuniones como esta son las que mantienen unida a una comunidad.#$e#La vida no va de riquezas, ¿sabes? Va de conexiones.",
  "festivals.spring24.valkyrie": "*Valkyrie no es muy fan del baile, pero le encantan la atención y los snacks.*$4",
  "festivals.spring24.keanu": "¡Tío! No me importa no bailar, es genial pasar el rato con la gente del pueblo.$1",
  // luau
  //*************
  "festivals.beatrice.summer11": "Mmm, ¡este asado huele délicieuse!",
  "festivals.beatrice.summer11.2": "Willy tiene tantas historias del mar.$1",
  "festivals.eloise.summer11": "¡El baile es tan tonto! Espero que no hayamos espantado a todos los pájaros.",
  "festivals.eloise.summer11.2": "¿Has probado esta comida en miniatura? ¡Todos son del tamaño de un bocado para que puedas comer de todo!$1",
  "festivals.jacob.summer11": "Hola @. Sólo estoy buscando un poco de espacio para mí.",
  "festivals.jacob.summer11.MrG": "Hola @. Sólo pasando el rato aquí con mi buen amigo Coppernicus.",
  "festivals.jacob.summer11.2": "Estoy tratando de ser un poco más social este año, @.",
  "festivals.jacob.summer11.tris": "Hola @. Oh, sólo estamos pasando el rato - dos padres, ¡presumiendo de nuestras chicas!$1",
  "festivals.oliver.summer11.1": "Hola. Eres ${el granjero^la granjera}$, ¿verdad? Soy Oliver. Papá me arrastró hasta aquí para ver este festival patético... Ya estoy aburrido.$2",
  "festivals.oliver.summer11.2": "Me gusta este lugar, es tranquilo... pero creo que será mejor que vaya pronto a probar la sopa. ¿Crees que será buena?$2",
  "festivals.josephine.summer11.1": "¡Oh, hola! Soy Josephine, la esposa del Gobernador. Es un placer conocerte... No has visto a nuestro hijo, Oliver por aquí, ¿verdad?",
  "festivals.josephine.summer11.2": "¡Hola @! Me gustaría que Oliver fuera un poco más social... Necesita algunos amigos que no estén detrás de una pantalla.$2",
  "festivals.oliver.summer11.3005": "Sabes... Me está empezando a gustar este festival. Willy me ha estado contando algunas de sus historias de pesca.$1",
  "festivals.aideen.summer11": "¡Oh, el sol es agobiante! Busco refugio, aquí entre mis amigos, los árboles.",
  "festivals.aideen.summer11.2": "¡Oh, el sol es agobiante! Busco refugio, aquí entre mis amigos, los árboles.",
  "festivals.josephine.summer11.3005": "No has visto a Olly por aquí, ¿verdad? Si lo haces, ¡hazle saber que es mejor que pase un tiempo con sus padres!$1",
  "festivals.kataryna.summer11": "¡Un pequeño gran festival este! Aunque la sopa parece una buena manera de contraer salmonela.#$e#¡Aún así, buena propagación aquí, voy a decir! No voy a tocar esa sopa.$1",
  "festivals.vivienne.summer11": "Hola @. Ellie no quiere bailar conmigo, ¿pero tal vez me harías el honor?$1",
  "festivals.vivienne.summer11.2": "Oh, no nos hagas caso a los viejos, @. Evie me está poniendo al día de cincuenta años de cotilleos.",
  "festivals.rosa.summer11.false": "Gus realmente hace una gran difusión, ¿no? Tendré que pedirle algunas recetas.",
  "festivals.rosa.summer11.juliet": "Oh, no te preocupes por Jules. Estoy segura de que no envenenaría la sopa. Bueno, ¡muy segura!",
  "festivals.rosa.summer11.2.false": "Gus realmente hace una gran difusión, ¿no? Tendré que pedirle algunas recetas.",
  "festivals.rosa.summer11.2.juliet": "Hmm... Es muy, muy tentador aceptar la oferta de Jules, ¿no crees?$1",
  "festivals.tori.summer11": "Oh. Hola, @. ¿Me gusta la música? ¿A ti no? Bailaría pero... Solo soy capaz de hacerlo si nadie está mirando...$3",
  "festivals.tori.summer11.2": "Oh hola @. Los océanos son tan bonitos, ¿verdad, @?",
  "festivals.tori.summer11.2.MrG": "¡@! Mira qué gatito tan adorable. ¿No es el más mono? ¿Crees que me dejará acariciarlo?$1",
  "festivals.tori.summer11.2.tris": "Oh, hola @. Conoces a Tristán, ¿verdad? Es mi vecino. Somos amigos.$1",
  "festivals.summer11.juliet": "¿Has encontrado algo bueno para añadir a la sopa? Yo iba a poner una de esas setas rojas, pero Jessie me convenció de no hacerlo.",
  "festivals.summer11.jessie": "Me alegra que hayas venido. ¡Espero no necesitar mañana mi té especial de jengibre!",
  "festivals.summer11.gremlin": "¡Arf!$4",
  "festivals.summer11.juliet.y2": "Hmm... Hace calor, ¿eh? No entiendo por qué nadie está en el agua. ¿Carrera hasta las olas, @?",
  "festivals.summer11.jessie.y2": "Es encantador ver a los niños divirtiéndose tanto, ¿verdad, @?#$e#Espero que estén bien hidratados.$2",
  "festivals.summer11.jasper": "¿Has tenido el placer de conocer a mi buen amigo Rasmodius?",
  "festivals.summer11.jasper.y2": "Hola @. Oh, Sebastian y yo no estamos hablando; estamos en contemplación silenciosa.#$e#...Creo que está fingiendo que no existo.$1",
  "festivals.summer11.jasper.spouse.y2": "Hola, mi amor. Oh, Sebastian y yo no estamos hablando; estamos en contemplación silenciosa.#$e#...Creo que está fingiendo que no existo.$1",
  "festivals.summer11.jasper.spouse": "Por favor, únete a nosotros, mi amor. Rasmodius y yo estábamos discutiendo los misteriosos caminos del océano profundo.",
  "festivals.summer11.jade": "¡No puedo esperar a probar la sopa!$1",
  "festivals.summer11.jade.spouse": "Espero que les guste lo que he añadido este año...$3",
  "festivals.tristan.summer11": "Aquí hace más fresquito, con el viento en la cara y el sabor a sal en los labios...",
  "festivals.summer11.corwin": "Ah, no es mi estilo ponerme a charlar con los lugareños.#$b#Además, Roddy y yo tenemos mucho con lo que ponernos al día.$1",
  "festivals.summer11.edith": "¡Hola @! ¿Serías un amor y posar con tu contribución, por favor? Me encantaría tomar una foto para mi blog.",
  "festivals.summer11.michael": "Hmm, le pediría a Eddy que baile conmigo... Pero está tan concentrada en captar la foto perfecta... O quizá el chisme perfecto.$1#$b#Las desventajas de tener una esposa extrovertida, ay.",
  "festivals.summer11.ethan": "Bonito festival, pero hace demasiado calor para sopa. Deberían hacerlo de helado, ¿no?$1",
  "festivals.summer11.dale": "Es un día precioso para un festival, ¿verdad, @?#$b#Qué raro que nunca llueva cuando hay uno ahora que lo pienso.$3",
  "festivals.summer11.valkyrie": "*Valkyrie está ocupada protegiendo a Dale de las olas. Preferiría no ser molestada.*",
  "festivals.summer11.keanu": "¡Hey, colega! Este festival está mal enfocado. Debería tratarse de las olas, no de impresionar a un viejo trajeado con sopa.#$b#¿Quieres surfear conmigo más tarde?$3",
  // jellies
  //*************
  "festivals.aideen.summer28": "No me atrevo a acercarme demasiado. Pueden parecer hermosas y misteriosas, ¡pero también son muy venenosas!$2",
  "festivals.eloise.summer28": "¡Las medusas son muy chulas! ¿Sabías que las medusas no tienen cerebro? ¡Y tampoco tienen corazón!#$e#Además, no son peces. En realidad son Medusozoa.",
  "festivals.eloise.summer28.juliet": "¡El sombrero de la Srta. Juliet es tan tonto! ¡Las medusas no tienen ojos!",
  "festivals.jacob.summer28": "¡Hola @! Espero que Ellie no te haya hecho perder la cabeza con datos sobre las medusas. Hay una parte de mí que ama el misterio que las rodea.",
  "festivals.josephine.summer28": "Aprecio mucho cómo tu pequeño pueblo mantiene vivas estas pintorescas tradiciones.$1#$e#¡La naturaleza es realmente fascinante!",
  "festivals.oliver.summer28": "¡Puedo ver algo moviéndose por allí! No, no las medusas, algo... más grande.$1#$b#¿No? Debe ser mi imaginación.",
  "festivals.oliver.summer28.2012": "Lexi también está aquí, ¿puedes verla, @? No quería acercarse demasiado y asustar a las jaleas.#$b#Ojalá no tuviera que esconderse.$2",
  "festivals.lexi.summer28": "Las medusas son muy bonitas, ¿verdad? Sin embargo.$1",
  "festivals.eloise.summer28.2": "Las medusas son muy importantes para la cadena alimentaria. ¡Muchos pájaros las comen, y también ballenas, tortugas y peces!$1",
  "festivals.jacob.summer28.2": "Eloise lleva todo el día leyendo sobre medusas. El pobre Clint se está enterando de todo.",
  "festivals.rosa.summer28.false": "Hola @, estas pequeñas medusas son bastante sorprendentes... Si no tienen cerebro, ¿cómo se acuerdan de la ruta?",
  "festivals.rosa.summer28.juliet": "A veces siento que mi único propósito es evitar que Juliet se tire al agua...$2#$e#Supongo que alguien tiene que ser el adulto responsable, ¿verdad?$1",
  "festivals.tori.summer28": "Estos pequeñines son casi tan adorables como las babas. Me pregunto si estarán emparentados.",
  "festivals.linus.summer28.2": "Pensaba que nadie usaba este muelle, hasta que llegó este barco.#$e#Espero que a nadie le moleste... A mí también me gusta ver las medusas.",
  "festivals.summer28.juliet": "¡Hey, @! Si me tirara al agua ahora mismo, ¿crees que me considerarían una de las suyas?$1#$e#Nah, ¡probablemente solo me picarían hasta matarme!$2",
  "festivals.summer28.gremlin": "¿Arp?#$e#%Gremlin parece estar observando el agua.",
  "festivals.summer28.jessie": "Hay algo místico en las medusas. Son tan insustanciales... Pero viajan tan lejos y aun así nos visitan cada año.",
  "festivals.summer28.jessie.y2": "Ah, hola @. Linus y yo estamos disfrutando de lo tranquilo que es este lado de la playa. Puedes unirte a nosotros si quieres.",
  "festivals.summer28.juliet.sca": "¡Hey, @! Debe ser agradable, ya sabes, flotar por ahí, dejando que la corriente te lleve.#$e#Aunque... Nah, suena un poco aburrido. Creo que preferiría ser un tiburón. O un pulpo...$1",
  "festivals.summer28.jasper": "Ah, fascinantes especímenes estas criaturas. Aunque mi experiencia se centra más en lo subterráneo que en lo acuático.",
  "festivals.summer28.jasper.spouse": "La noche trae tanta belleza, ${amado^amada}$.$4#$e#Y las medusas también son hermosas.$3",
  "festivals.summer28.tristan": "Jas se emociona muchísimo al ver a estos bichos raros. Pero es una buena noche para ello.",
  "festivals.summer28.jade": "Esto va a ser tan bonito... Las medusas son criaturas realmente geniales.#$e#Ellie y yo hemos estado intercambiando datos sobre medusas todo el día.$1",
  "festivals.summer28.jade.spouse": "Esto va a ser tan romántico, cariño.$4",
  "festivals.tristan.summer28.spouse": "¿Romántico? Bueno, supongo que podría serlo si no fuera porque todo el pueblo viene a verlas.#$b#Vale, lo admito, son bastante bonitas.#$b#¿Quizá podamos escaparnos un rato?",
  "festivals.summer28.corwin": "Hay todo tipo de leyendas sobre estas criaturas, @. Algunos dicen que son los espíritus de los ahogados.$2",
  "festivals.summer28.edith": "¡Son tan bonitas! Creo que serían un gran atractivo para visitar el valle, ¿no crees?",
  "festivals.summer28.michael": "Habría preferido un picnic tranquilito en la playa... Pero no se acercan a la costa de East Scarp.#$b#Y Eddy necesita desplegar sus alas de mariposa social.$1",
  "festivals.summer28.ethan": "Oooh ¡${granjero^granjera}$! Creo que ya las veo. Son bastante geniales, ¿verdad?$1",
  "festivals.summer28.dale": "Huh, parece que Clint lleva zapatos nuevos.#$b#Nah, no voy a decirle nada. No quiero que piense que soy raro por fijarme en el calzado de la gente y eso.",
  "festivals.summer28.valkyrie": "*Valkyrie está triste por el final del verano*$2",
  "festivals.summer28.keanu": "A mamá le encantaban las medusas. Íbamos al muelle y las veíamos deslizarse...#$b#Este festival me hace echarla mucho de menos, @.$2",
  "festivals.summer28.kataryna": "¿Hay algo ahí en el agua? Ugh, ¡ojalá no estuviera tan oscuro!$a",
  "festivals.eyvinder.summer28": "Buen festejo este. Siempre es agradable ver a la gente apreciar la naturaleza.",
  // fair
  //*************
  "festivals.aideen.fall16.single": "¿Tienes intención de que te lean la suerte, @?#$e#¡Oh! ¡Ya me han leído la mía! ¡Al parecer, mi búsqueda de un pretendiente se cumplirá antes de que el año llegue a su fin!$4",
  "festivals.aideen.fall16.single.y2": "¿Tienes intención de que te lean el futuro, @?#$e#¡Oh! Estoy intentando convencer a la señorita Victoria, ¡pero no hay manera!",
  "festivals.aideen.fall16.farmer": "¡Mi amor! ¿Has hablado con el espiritista?#$e#¿Yo? Oh, no. Ahora que mi búsqueda de un pretendiente se ha cumplido, he decidido que prefiero la mística.$4",
  "festivals.aideen.fall16.farmer.y2": "¡Mi amor! ¿Has hablado con el espiritista?#$e#¿Yo? Oh, no. Ahora que mi búsqueda de un pretendiente se ha cumplido, he decidido que prefiero la mística.$4",
  "festivals.aideen.fall16.spouse": "Mi amor, ¡no necesitamos un espiritista para revelar nuestro futuro!$1#$e#¿Qué es lo que contiene? Oh, lo verás esta noche.$4",
  "festivals.eloise.fall16": "¿Sabes por qué estas gallinas son tan mansas, granjero @?^¿Sabes por qué estas gallinas son tan mansas, granjera @?#$e#Cuando los pollitos salen del cascarón, creen que lo primero que ven es su madre. Se llama 'impresión'.$3#$e#¡Así que Marnie es su madre gallina!$1",
  "festivals.jacob.fall16": "Estas gallinas parecen muy sanas. Felicitaciones a la Sra. Marnie y a Shane por criarlas bien.#$e#También están bien socializadas.",
  "festivals.eloise.fall16.sve": "¿Sabías que la calabaza es técnicamente una fruta, @? ¡Pero no la pondrías en una ensalada de frutas! ¡Qué asco!$1",
  "festivals.jacob.fall16.sve": "Hola @. Buena suerte con tu exposición de hoy.",
  "festivals.ladysheba.fall16.false": "¿Mirrup?$3",
  "festivals.ladysheba.fall16.true": "Olor dar hambre. ¿Dar comida?$3",
  "festivals.oliver.fall16": "¿Los juegos? No, no es lo mío. Lo siento, no te ofendas: tu feria es bonita... pero no es muy emocionante.$3#$e#¿Crees que Sam y Sebastian me dejarían salir con ellos?$3",
  "festivals.josephine.fall16": "Una pequeña feria tan encantadora. Es casi tan encantadora como el Carnaval de Grampleton.#$e#¿Has asistido alguna vez, @?#$b#¿No? ¡Deberías hacerlo! Es un verdadero festival de maravillas. Una noria, atracciones salvajes... ¡fuegos artificiales! ¡Incluso una vez tuvieron un oso bailarín!$1",
  "festivals.kataryna.fall16": "¿Hay algún monstruo más terrorífico que un payaso? Yo creo que no.$2",
  "festivals.vivienne.fall16": "Buenos días, @. La feria es gloriosamente bulliciosa, ¿no?$1#$e#Caro y yo estamos poniéndonos al día con los últimos chismes.",
  "festivals.beatrice.fall16": "¿Has inspeccionado las exposiciones de las granjas, @? ¡Marnie tiene el queso más magnífico!$1#$e#La competencia será feroz este año.",
  "festivals.aideen.fall16.mateo": "¡Oh @! No habrá necesidad de confiar en Welwick este año.$1#$e#Parece que mi búsqueda se ha cumplido, y realmente no podría estar más encantada.$4",
  "festivals.aideen.fall16.mateo.y2": "¡Oh @! No habrá necesidad de confiar en Welwick este año.$1#$e#Parece que mi búsqueda se ha cumplido, y realmente no podría estar más encantada.$4",
  "festivals.eloise.fall16.y2": "Mira esta cabrita, ¿no es una monada?$1#$e#¿Sabías que a las cabritas se les llamaba 'cabritas' antes que a los jóvenes?$3",
  "festivals.jacob.fall16.y2": "Eloise parece bastante prendada de estas cabras... ¿Yo? ¡Yo he tenido un par de encuentros cercanos con estos tipos astutos!",
  "festivals.oliver.fall16.y2": "¿Los juegos? No, no es lo mío. Lo siento, sin ánimo de ofender: tu feria es bonita... pero no es muy emocionante.$3#$e#¡Sin embargo, la comida está bastante bien!",
  "festivals.vivienne.fall16.y2": "Hah, cosas locas, cabras. Me recuerda a alguien que conocí una vez. Aunque tengo que decir que olía mucho mejor.$1",
  "festivals.tori.fall16": "Mucha suerte con la exposición de las granjas, @.#$e#Me presenté un año, pero Lewis dijo que mis huevos de baba le daban náuseas.$2",
  "festivals.tori.fall16.y2": "¿Me han dicho la buenaventura? Oh, no sé... ¿Y si es mala? Creo que, tal vez, preferiría no saberlo.$3",
  "festivals.rosa.fall16": "Me duelen los brazos de cargar con todos esos barriles para Lewis... pero creo que ha quedado bastante bien, ¿no?",
  "festivals.fall16.juliet": "No es por presumir, pero soy tan buena con el tirachinas que ya no me dejan jugar.$2#$e#¡Es porque me imagino que le disparo a Morris entre ceja y ceja!$5",
  "festivals.fall16.jessie": "Demasiada emoción para mí, ${querido^querida}$. Prefiero quedarme aquí y dejar que Linus me haga compañía.",
  "festivals.fall16.gremlin": "¡Arp!$1#$e#%Gremlin te mira expectante, esperando que le hayas traído una golosina.",
  "festivals.fall16.juliet.y2": "¿La basura? Sí, estoy esquivando mis deberes de limpieza. Bueno, al menos hasta que estos turistas se vayan a su casa.",
  "festivals.fall16.jessie.y2": "Hola, @. Aquí se está más tranquilo, y estas ovejas son una compañía de lo más agradable.#$e#Marnie las cuida muy bien.",
  "festivals.fall16.jasper": "El trabajo de Clint es realmente maravilloso. Se necesita un buen filo para adentrarse en las profundidades del valle.#$e#¿Yo? Prefiero el filo de obsidiana.$1",
  "festivals.fall16.jasper.spouse": "Oh mi amor, yo estoy bien aquí. ¡Pero por favor, diviértete!#$e#Estoy deseando escuchar al alcalde anunciarte ${ganador^ganadora}$.$1",
  "festivals.fall16.tristan": "¿Vas a dejar que te lean la fortuna, @? Ras cree que ella es de las buenas, pero yo no sé...#$b#Creo que habla con otro tipo de espíritus.$2",
  "festivals.fall16.jade": "No quiero que me cuenten mi destino. Me gusta el misterio.$1",
  "festivals.fall16.jade.spouse": "Vas a ganar este año. ¡Estoy segura, cariño!$1",
  "Festivals.tristan.fall16": "Aideen está convencida de las profecías de Welwick, pero yo estoy bastante seguro de que anda en tratos con otro tipo de espíritus.$2",
  "festivals.eyvinder.fall16": "¿Eh? ¿Un Troll de Montaña? Lo han puesto insultantemente fácil. ¿Qué tal eres tú con el viejo ‘golpea y machaca’, @?$1",
  "festivals.fall16.corwin": "$p 5787152#Hola, @, pensé en lucir mis músculos, a ver si llamo la atención de alguien, ¿no? ¡Jajaja!$1|Hey cariño, pensé en demostrar mi fuerza. ¡Avísame si ves algo que te guste!$8",
  "festivals.fall16.corwin.y2": "$p 5787152#Hey @. Unos cuchillos bastante impresionantes, ¿eh? Demasiado elegantes para un rufián como yo. También un poco fuera de mi presupuesto.$11|Hey, ${precioso^preciosa}$ Solo echando un vistazo a estos cuchillos impresionantes. Un poco elegantes para un rufián como yo... Y también un poco fuera de mi presupuesto.$11",
  "festivals.fall16.edith": "Oh, hola cariño. ¡Estas exhibiciones se van a ver maravillosas en nuestra página web!$1#$b#¡No puedo esperar a ver cómo reacciona la gente a la tuya!$1",
  "festivals.fall16.michael": "¡Hey ${amigo^amiga}$! Nosotros los chicos estamos llenando el estómago, mientras que Edith está por ahí reuniendo material para su blog.",
  "festivals.fall16.ethan": "Papá y yo estamos en una competencia de comer hamburguesas. Él va ganando... Pero también tiene una panza más grande.$1",
  "festivals.fall16.dale": "Hey @, este es el lugar ideal, ¿no? Buena comida y poder observar a la gente. ¿Quieres unirte a nosotros?$3",
  "festivals.fall16.valkyrie": "%Valkyrie gime; le encantaría un poco de hamburguesa. Dale le da un pedacito a escondidas.",
  "festivals.fall16.keanu": "Hey @, estoy recargando energía antes de ir a probar los juegos. ¿Te apetece una competencia amistosa?$1",
  "festivals.summer28.stella.sve": "Hola, @. Siempre es divertido ver qué está pasando en el valle.#$b#Imagina cuánta sopa podrías hacer con estas calabazas.$1",
  "festivals.summer28.edith.sve": "Hmm... De esto podría hacer un post impresionante para mi blog, ¿no crees, Stella?",
  "festivals.mrginger.fall16": "Hey @, ¿me pillarías uno de esos peces de Willy? Yo lo intentaría, pero creo que ya me tiene fichado.$1",
  // Spirit's eve
  //*************
  "festivals.eloise.fall27": "¡Oh, por qué no podemos ir al laberinto! Nos cuidaremos mutuamente. Poh favoh, papá.$3",
  "festivals.jacob.fall27": "Lo sé, me veo ridículo. Eloise es extremadamente persuasiva.$2",
  "festivals.marnie.fall27": "El Dr. Jacob won't believe me when I tell him he's looking very smart in that outfit.",
  "festivals.kataryna.fall27": "¿No son estas las bestias más deliciosamente terroríficas que jamás hayas visto?$1#$b#Hmm, ¿crees que son auténticas? ¿O algún tipo de Animatronic?",
  "festivals.kataryna.fall27.y2": "Clint me está contando cómo ayudó a Marlon a reunir a los monstruos para la jaula. Parece que es más valiente de lo que parece.",
  "festivals.aideen.fall27.rvh": "¿No es el disfraz de Mateo absoluta y deliciosamente espantoso?$2#$b#¡Oh, cuando apareció en mi puerta así, mi corazón nunca se había acelerado tanto!$4",
  "festivals.oliver.fall27": "Esto es como el laberinto del minotauro en el Panteón de las Mentiras.#$b#Bueno, excepto que no hay minotauro. Aún así, es divertido, como un LARP.$1",
  "festivals.oliver.fall27.lexi": "Espero que Lexi esté bien con toda esta gente; ¡todos piensan que invité a una amiga de la ciudad!$1",
  "festivals.lexi.fall27": "Toda esta gente, tenía miedo de venir... pero con el amigo Olly a mi lado, me estoy divirtiendo, ¿sí?$3#$b#Comimos galletitas con forma de calabaza y bebimos algo dulce y picante.",
  "festivals.josephine.fall27": "Si ves a Olly, recuérdale que coma, por favor.#$b#Sé que es capaz de cuidar de sí mismo... Pero es trabajo de una madre preocuparse.$2",
  "festivals.vivienne.fall27": "Me quito el sombrero ante Gus, realmente sabe cómo organizar una fiesta. ¡Estoy casi demasiado llena para aventurarme en el laberinto!$1#$b#...pero se lo prometí a Ellie. Bueno, si viene un monstruo, yo seré el noble sacrificio.$2",
  "festivals.rosa.fall27.false": "¡Oh @! ¡Me has asustado! Supongo que mis nervios están un poco tensos esta noche...$2",
  "festivals.rosa.fall27.juliet": "¡Oh @! Me has asustado.$2#$b#Lo siento... Juliet ha estado susurrándome historias de fantasmas al oído toda la noche...#$b#Creo que tiene un motivo oculto...$5",
  "festivals.eloise.fall27.y2": "Oh... vamos papá... Si Jas puede entrar en el laberinto, ¡a mí también deberían permitírmelo!$2#$b#¡Oh! ¿No tienes miedo, verdad, papá?$3",
  "festivals.jacob.fall27.y2": "@, ¡me alegro de verte! ¿Puedes ayudarme a distraer a Ellie, por favor? Quiere entrar en el laberinto pero... mi sentido de la orientación es terrible, y temo que nos pierda a los dos.$2",
  "festivals.tori.fall27": "El Sr. Marlon dice que son monstruos, y por lo tanto peligrosos... pero no puedo evitar sentir lástima por ellos.$2",
  "festivals.fall27.jessie": "Oh... La Víspera de los Espíritus me pone la piel de gallina. La gente de aquí no se da cuenta de que es su felicidad y buen ánimo lo que mantiene a raya el toque reptante del vacío.$2",
  "festivals.fall27.juliet.zombie": "¿Has oído la historia de la Mujer de Blanco, @? ¿No?$1#$b#La leyenda dice que perdió a su hijo hace mucho tiempo y, en su desesperación, se quitó la vida.$2#$b#En la Víspera de los Espíritus, cuando el velo entre nuestro mundo y el de las sombras se vuelve tenue, merodea por el bosque buscando aquello que perdió...#$b#...Un niño inocente al que reclamar como suyo.$3",
  "festivals.fall27.juliet.pirate": "¿Sabías que había una ciudad entera debajo de este pueblo, @?$2#$b#Una vez fue hogar de maleantes, forajidos... Y piratas.#$b#Ahora no queda nada más que sus huesos, y sus espíritus vagan buscando venganza.$1",
  "festivals.fall27.jasper": "Estos esqueletos son criaturas temibles. ¿Imaginas que llegaran a escapar? ¡Sería un desastre!$2",
  "festivals.fall27.jasper.spouse": "Amor mío, ¿no son estas criaturas terriblemente temibles? Imagínate el caos si escaparan.#$b#Oh, pero estoy seguro de que tú nos protegerías a todos, mi amor.$4",
  "festivals.fall27.jasper.y2": "Es un festival bastante aterrador, @. Se necesitarán nervios de acero para atravesar el laberinto este año, me temo.$2",
  "festivals.fall27.tristan.y2": "¿Confío en Shane llevándose a Jas? Claro que sí... Supongo que solo quiero sentirme incluido también.",
  "festivals.fall27.jade": "¡Mira esta arañita tan mona!$1",
  "festivals.fall27.jade.spouse": "Tienes suerte, ¿sabes?$0#$b#Si existieran arañas de este tamaño, ¡te obligaría a tener algunas en la granja!$1",
  "festivals.fall27.jade.y2": "El laberinto da muchísimo más miedo este año...$2",
  "festivals.fall27.jade.spouse.y2": "¡@! ¡Qué alegría verte!$1#$e#Porque me he perido...$2",
  "festivals.tristan.fall27": "No se lo digas a Marnie, pero en cuanto el alcalde la distraiga con sus 'importantes asuntos', Jas y yo nos colaremos en el laberinto.$3#$b#¡La calabaza dorada será nuestra!$1",
  "festivals.tristan.fall27.marmar": "No se lo digas a Marnie, pero en cuanto su guerrero-pirata la distraiga, Jas y yo nos colaremos en el laberinto.$3#$b#¡La calabaza dorada será nuestra!$1",
  "festivals.fall27.corwin": "¿Que hay un tesoro escondido en este laberinto? Ahora sí que estamos hablando el mismo idioma.$1",
  "festivals.fall27.corwin.y2": "Clint es demasiado tímido, espero que después de unas cervezas se suelte un poco.#$b#Aunque no tengo muchas esperanzas.$3",
  "festivals.fall27.ethan": "Rayos... Estoy perdido. ¿Sabes cómo salir?$2",
  "festivals.fall27.edith": "Hola, cariño. ¡Estos bocaditos están deliciosos! Tengo que pedir la receta.",
  "festivals.fall27.michael": "Si ves a Ethan... ¿Puedes decirle que su viejo lo espera aquí afuera? ¡Gracias, ${amigo^amiga}$!$1",
  "festivals.fall27.dale.y2": "Valkyrie no le quita ojo a esas momias... Le encanta jugar con tiras de tela.$2#$b#Así que nos vamos a quedar bien atrás, ¿verdad, chica?",
  "festivals.fall27.eyvinder": "Un Festival raro este. La gente sigue halagando mis cuernos.#$b#Les digo: gracias, ¡los hice crecer yo mismo!$1",
  "festivals.fall27.ethan.sve": "¡Boo! Jajaja, te asusté, ¿a que sí?$1",
  "festivals.fall27.keanu": "No estoy muy seguro de que este festival vibre conmigo. Un poco inquietante, ¿no? ¡Pero la comida está buenísima!",
  "festivals.fall27.dale": "Esos monstruos... Da la sensación de que alguien intenta decirnos algo, encerrándolos así.$2",
  "festivals.fall27.valkyrie": "*¿De dónde ha sacado ese hueso?*$4",
  "festivals.fall27.corwin.sve": "Leah ha sido un encanto y me está poniendo al día con todo lo que pasa por aquí.$1",
  "festivals.fall27.vivienne.sve": "¡Oh no! Nos encontraste. No pensé que nadie más llegaría hasta aquí.$4",
  "festivals.fall27.eyvinder.sve": "Solo dilo, Vivi, y los hago desaparecer a todos.$a.#$b#Oh, ¡no me mires así, @! Sabes que soy puro ladrido y nada de mordida. ¿Verdad?$1",
  "festivals.fall27.michael.sve.3": "Oh, querida Eddy, ¡creo que nos hemos perdido!$2",
  "festivals.fall27.edith.sve.3": "¡Tonterías! Sé exactamente dónde estamos... Lo que no entiendo es de dónde ha salido este seto.$a",
  "festivals.fall27.ethan.sve.3": "¡Mamá, papá! ¡Mirad esta calabaza increíble!$1#$e#Oh, hola @. Está guapa, ¿verdad?",
  // ice festival
  //*************
  "festivals.aideen.winter8": "Oh, hola @. Sí, confieso que me colé para ver las esculturas de hielo.$4",
  "festivals.aideen.winter8.rvh": "Ah, hola @. Mateo me animó a unirme a ellos. Y debo decir que el entorno es notablemente romántico.$4#$b#Sugerí que nos mantuviéramos contra el viento de los peces, por supuesto.$1",
  "festivals.beatrice.winter8": "No me gusta pescar. Creo que todos seríamos más felices si los dejáramos en paz.",
  "festivals.eloise.winter8": "¿Vas a participar en el concurso, granjero @? No me gusta la pesca. Los peces también tienen sentimientos, ¿sabes?$2^¿Vas a participar en el concurso, granjera @? No me gusta la pesca. Los peces también tienen sentimientos, ¿sabes?$2",
  "festivals.eloise.winter8.false": "¿Vas a participar en el concurso, granjero @? No me gusta la pesca. Los peces también tienen sentimientos, ¿sabes?$2^¿Vas a participar en el concurso, granjera @? No me gusta la pesca. Los peces también tienen sentimientos, ¿sabes?$2",
  "festivals.eloise.winter8.sve": "Quería hacer un pájaro, pero la nieve no me sentaba bien.",
  "festivals.jacob.winter8.sve": "¿Cómo deberíamos llamar a nuestra chica de las nieves, @?",
  "festivals.jacob.winter8": "Hola @. Estamos aquí por la compañía y los muñecos de nieve, no por la competencia.#$b#Lo siento, pero la pesca de captura y liberación me parece algo bárbaro.",
  "festivals.jacob.winter8.false": "Hola @. Estamos aquí por la compañía y los muñecos de nieve, no la competencia.#$b#Lo siento, pero la pesca con devolución me parece algo bárbaro.",
  "festivals.josephine.winter8": "Oh, espero que Olly siga abrigado... ¡Odiaría que se resfriara!$2",
  "festivals.oliver.winter8": "¡Hola @! Sí, lo has adivinado, me estoy escondiendo de mi madre.$2#$b#Además, esta isla es muy bonita. Me pregunto qué profundidad tiene el agua.$5",
  "festivals.oliver.winter8.y2": "¡Hola @! Sí, lo has adivinado, me escondo de mi madre.$2",
  "festivals.oliver.winter8.3005": "¡Hola @! Sí, Ellie quería acompañarme.#$b#No me importa, ella es genial. Y es como tener una hermana pequeña.$1",
  "festivals.eloise.winter8.3005": "¡Hey Olly! Creo que he visto un bacalao marino. ¡Espero que no se trague a todos los demás peces!$3",
  "festivals.rosa.winter8.juliet": "¡Brrr! Estamos pensando en colarnos en una de esos iglús. Tiene que ser más cálido allí, ¿verdad?$1",
  "festivals.rosa.winter8.false": "Se está tranquilo aquí fuera, ¿verdad? Aunque me gustaría que hiciera más calor.$2",
  "festivals.rosa.winter8.sve": "Si hubieras venido antes, @, habrías visto a Robin y a Leah tallando las esculturas de hielo.#$b#Mujeres con motosierras - ¡una combinación formidable!$1",
  "festivals.vivienne.winter8": "No dejes que el malhumor de George te engañe, @. Era todo un encanto en su juventud.$1#$b#No es que tuviera ojos para nadie excepto Evie, por supuesto.",
  "festivals.vivienne.winter8.2": "Pobre Clint... Clem nunca fue de las que fomentaban la creatividad.$2",
  "festivals.tori.winter8": "Pensé en hacer una baba de nieve... Pero no estoy seguro de que sea buena.$3",
  "festivals.tori.winter8.false": "Nunca me ha gustado mucho pescar. Pero hacer un muñeco de nieve parece divertido. Quizá el año que viene...$3",
  "festivals.tori.winter8.sve": "¿Qué te parece nuestra chica de las nieves, @? Es mona, ¿verdad?$1#$b#¿El gorrito? Oh, mi madre los teje para niños pequeños. Me regaló este. Nunca le han gustado las indirectas.$3#$e#Le dije que no creía que a las babas les gustara. No le hizo gracia.$2",
  "festivals.winter8.juliet": "¿También te aburres, eh? Quiero decir, los muñecos de nieve son geniales y todo eso...#$b#Jajaja, ¿lo pillas? Sí, a veces solo queremos un poco de espacio para nosotras mismas, ¿sabes?$3",
  "festivals.winter8.jessie": "Espero que estés bien ${abrigado^abrigada}$ hoy, @. Los festivales siempre son una buena oportunidad para ponernos al día con todos.",
  "festivals.winter8.gremlin": "¡Arp!#$b#%Gremlin te lame la nieve de las manos. Su lengua está muy calentita.",
  "festivals.winter8.jasper": "Ah, ¡hola, @! ¡Linus está contando historias sobre los habitantes de la tundra!$1",
  "festivals.winter8.jasper.y2": "Ah, ¡hola, @! Linus y yo estamos apreciando el cambio de estación. Puedes acompañarnos si lo deseas.",
  "festivals.winter8.jasper.spouse": "Buenas, mi amor, ¿te gustaría unirte a nosotros? ¡Linus está contando historias sobre los habitantes de la tundra!",
  "festivals.winter8.jade": "Qué cosa tan rara para esculpir...$3",
  "festivals.winter8.jade.spouse": "No sé nada de pesca, ¡pero estoy segura de que tú atraparás todos los peces este año!$1",
  "festivals.winter8.jade.y2": "No puedo esperar a volver a casa y estar bajo las mantas...",
  "festivals.winter8.jade.spouse.y2": "Sé que ganarás este año, cariño.$1#$b#Y tu premio será...$4#$b#¡Recolectar leña para la chimenea!$1#$b#Eso te pasa por hacerme salir al frío~$1",
  "winter8.clint.postemily": "Emily no se equivoca - este pobre muñeco de nieve realmente necesita ayuda. La nieve es más difícil de trabajar que el metal.$1", //Clint
  "festivals.tristan.winter8": "Ven, únete a nosotros, Linus conoce algunas historias bastante buenas.",
  "festivals.tristan.winter8.y2": "¡El pelaje era más calentito en un día como este!",
  "festivals.winter8.edith": "Brrr, hace frío, ¿verdad? No es mi festival ideal, pero no puedo perderme una oportunidad para socializar.",
  "festivals.winter8.michael": "Jaja, ${amigo^amiga}$, ¡buena suerte pescando hoy! Quizá atrapes algo que nos sirva de cena.$1",
  "festivals.winter8.ethan": "¡Hola ${granjero^granjera}$! Papá me tiene repartiéndole café a la gente. ¡Hasta ahora me han dado 50g y dos plumas!$1",
  "festivals.winter8.ethan.2": "¿Por qué hay peces ahí dentro? ¿No era esto césped ayer?$3",
  "festivals.winter8.corwin": "Me uniría a la pesca... Pero nada puede compararse con atrapar un atún rojo.$1",
  "festivals.winter8.dale.2": "¿Crees que Clint apreciaría algo de ayuda con su muñeco de nieve?$3",
  "festivals.winter8.eyvinder": "Heh, siempre me ha gustado este festival. Quizás podríamos hacer un muñeco de nieve, ¿eh, Vivi? Algo feroz.$1",
  "festivals.winter8.valkyrie": "%Valkyrie está pensando en jugar en la nieve, pero está demasiado bien entrenada para eso.",
  "festivals.vivienne.winter8.rvh": "¡Oh, nos encontraste! Y nosotros aquí, escapándonos al bosque. ¡Como en los viejos tiempos!$4",
  "festivals.winter8.ethan.sve": "¡Un lago congelado! ¡Qué genial! Me pregunto si habrá algo más que peces bajo el hielo...$2",
  "festivals.winter8.dale.sve": "Espero que estés ${calentito^calentita}$, @. Deberían servir sopa, o chocolate caliente. Algo que nos caliente por dentro.$5",
  "festivals.winter8.keanu": "A Pops le encantaba pescar. ¡Era el rey de esta competición, @! A veces olía tan mal que mamá lo hacía dormir en el sofá.",
  // winter star
  //*************
  "festivals.aideen.winter25": "¿Estás disfrutando del festival, @? La tradición de dar regalos secretos es muy pintoresca, ¿no crees?#$b#Espero recibir un regalo bien pensado este año.",
  "festivals.beatrice.winter25": "Hoy es un día para las familias, @. Aquellas en las que nacimos y aquellas que hemos encontrado.",
  "festivals.eloise.winter25.false": "¡Feliz estrella de invierno! ¿Qué crees que hay en esta? Es REALMENTE grande. ¡Y pesada!",
  "festivals.eloise.winter25.sve": "¿Quieres ayudarme a arreglar este muñeco de nieve? Alguien lo tumbó.$2",
  "festivals.eloise.winter25.y2": "¡Feliz estrella de invierno! ¿Qué crees que hay en esta? Es REALMENTE grande. ¡Y pesada!",
  "festivals.jacob.winter25": "Hola @. Feliz Estrella de Invierno. Jodi ha tenido la amabilidad de invitarme a unirme a su familia.#$b#¡Ahora si pudiera arrastrar a Ellie lejos de los regalos!",
  "festivals.jacob.winter25.y2": "Hola @. Feliz estrella de invierno. Te deseo a ti y a tus seres queridos un maravilloso y próspero año nuevo.",
  "festivals.josephine.winter25": "¡Feliz Estrella de Invierno, @! Hoy le hago compañía al alcalde Lewis.#$b#*susurra* Cree que estoy aquí representando a mi marido, pero en realidad es por la empresa.$1",
  "festivals.oliver.winter25": "Hola @. Sí, papá no pudo venir... está ayudando en una obra de caridad en Zuzu.$2#$b#Aún así, la comida es buena, y el Dr. Jacob dijo que podía acompañarlo, así que está bien. Literalmente.$1",
  "festivals.ladysheba.winter25.false": "¿Mirrup?$3",
  "festivals.ladysheba.winter25.true": "Es mucha gente. Asustada. Quédate aquí, ¿vale? Trae un regalo, ¿sí?$3",
  "festivals.clint.winter25": "*suspiro*... Todas estas familias felices. Tal vez sea hora de hacer las paces con la mía.$2",
  "festivals.vivienne.winter25": "Se supone que La estrella de invierno trata de familias... aunque me pregunto si cuenta cuando son tan disfuncionales como la nuestra.$2",
  "festivals.kataryna.winter25": "Puede que creas que el invierno es una época de celebraciones, pero hay fuerzas más oscuras en juego.#$b#¿Has oído hablar de Jólakötturinn, el gato de Yule, @? ¡Espero que lleves ropa nueva!$3",
  "festivals.kataryna.winter25.visit": "¿Sorprendido de verme aquí, @? Gunther me envió una invitación.#$b#Y simplemente no pude resistirme. ¿Quién sabe lo que podría encontrar?$1",
  "festivals.rosa.winter25": "Gus realmente prepara una buena comida, ¿no? Puede que tenga que pedirle algunas de estas recetas.$1",
  "Festivals.tori.winter25": "Oh... Realmente espero que a mi regalado secreto le guste su regalo. Debería haberme abstenido... pero a veces hay que salir de la zona de confort, ¿no?$3",
  "festivals.winter25.juliet": "¡Hey, @! Feliz Estrella de Invierno. Espero que este año te den algo súper guay.",
  "festivals.winter25.juliet.spouse": "¡Hey, cariño! Hace frío, ¿eh? ¿Quieres que nos acurruquemos para entrar en calor? Toma, te he traído un detallito.[459]",
  "festivals.winter25.jessie": "Es tan bonito ver a todo el mundo reunido.",
  "festivals.winter25.jasper": "Los regalos secretos siempre me ponen un poco incómodo. Pero bueno, ¿a quién no le gustan los diamantes?$4",
  "festivals.winter25.gunther": "Hola, @. Normalmente no vengo a estos eventos. Pero alguien metió mi nombre en lo del intercambio secreto de regalos...#$b#Así que pensé que era mejor que viniera.",
  "festivals.winter25.cameron": "Oh, hola, @. ¿Vienes a unirte a las festividades? Sinceramente, yo preferiría estar esquiando.$2",
  "festivals.winter25.jasper.spouse": "Mi amor, siempre es un placer verte. Familia y amigos... Hay tanto por lo que estar agradecido.$1",
  "festivals.winter25.tristan.y2": "Mmm, ¿por qué te sientes ${agradecido^agradecida}$ este año, @? ¿Yo? Oh, por tantas cosas...$1",
  "festivals.winter25.jade": "¡Espero que me toque un regalo increíble!$1",
  "festivals.winter25.jade.spouse": "Jeje, ¡Pero si tú ya eres mi regalo, ${tontito^tontita}$!$1",
  "festivals.tristan.winter25": "$1 Tristan_JasFirstPresent#Espero que a Jas le guste el regalo que le compré... Nunca antes había podido comprarle libros.$k#Espero que a Jas le guste el regalo que le hice.",
  "festivals.winter25.edith": "Estoy captando las expresiones de la gente al abrir sus regalos.#$b#A mis lectores les encantan las celebraciones invernales tiernas... Especialmente si incluyen un poquito de drama, jeje.$1",
  "festivals.winter25.ethan": "¿La pila de regalos? Nah, no estoy pensando en eso. Ya no soy un niño.$4",
  "festivals.winter25.michael": "Hola, @. Estoy aquí pasando el rato con mi crío, empapándonos del espíritu del solsticio.$1#$e#¿Edith? Seguro que anda por ahí, buscando alguna historia para su blog.",
  "festivals.winter25.dale": "¿Este traje? Ah, soy el duendecillo de la Estrella de Invierno. A los críos les encanta.$1",
  "festivals.winter25.valkyrie": "*Valkyrie le echa el ojo al asado de la Estrella de Invierno, pero es demasiado educada para robarlo.*",
  "festivals.winter25.corwin": "¡Feliz Estrella de Invierno, @! En L’Artemis solíamos montar una fiesta increíble. En comparación esto es mucho más tranquilo.#$b#No me quejo, ¿eh?. ¡Está bien! Se siente muy familiar y todo eso.$1",
  "festivals.winter25.eyvind": "¿Qué puedo decir? Vivi me convenció para bajar de mi montaña. Es muy persuasiva.$4#$e#Buena compañía, buena comida y mucha hidromiel... Hace que el invierno sea menos solitario.$1",
  "festivals.gremlin.winter25": "¡Arp!$1",
  "festivals.pepperpup.winter25": "(Para un perrito tan pequeño, Pimienta tiene MUCHÍSIMA energía.)",
  "festivals.winter25.keanu": "¡Feliz Estrella de Invierno, colega! Estoy fluyendo con estas vibras tranquilas de pueblo.$3",
  "festivals.winter25.stella": "Hola @, mamá me estuvo poniendo al día con todos los chismes del pueblo... Y tú apareces un montón.$1",
  // fireworks festival
  //*******************
  "festivals.eloise.summer20": "¡Va a haber tantos colores! El cielo va a parecer un ave del paraíso.$1",
  "festivals.jacob.summer20": "Me encantan estos espectáculos organizados; son preciosos, pero los fuegos artificiales me ponen nervioso.#$b#Esta noche he encerrado a todos los animales en el granero, por si acaso.$2",
  "festivals.rosa.summer20": "Hola @, una tarde preciosa ¿verdad? ¿Has probado los fideos? ¡Están muy buenos!$1",
  "festivals.vivienne.summer20": "Hah, Jake me ha aparcado junto a este banco, como si fuera tan vieja y decrépita que voy a necesitar sentarme.#$b#Bueno, puede que no tenga una idea equivocada...$2",
  "festivals.oliver.summer20": "Tienen una extravanganza masiva de fuegos artificiales en Zuzu. ¡Es una locura!#$b#Aunque estoy seguro de que esta también será genial.$1",
  "festivals.aideen.summer20.madeen": "Oh Teo, la emoción, las luces brillantes... Confieso que me siento un poco mareada.$2#$b#Aunque quizás eso no tenga nada que ver con la noche... y todo que ver contigo.$4#$b#¡Oh, hola @! No te había visto.$7",
  "festivals.mateo.summer20.madeen": "Me enamoro más cada vez que un petardo ilumina su cara...$4",
  //RSV Gathering 
  "festivals.eloise.fall20": "Yuuma iba a presentarme a Torts hoy - pero aparentemente tengo que quedarme aquí, en el lado de las chicas.$2#$e#¡Bueno, creo que es una tradición tonta!$3",
  "festivals.jacob.fall20": "Eloise ha estado intentando animarme a socializar más... pero hay bastante gente aquí - y no estoy seguro de por dónde empezar.$2",
  "festivals.rosa.fall20": "Chicas contra chicos ¿eh? Es como volver al colegio otra vez.#$b#Oh, creo que ya sabes de qué lado estoy, @. En todos los sentidos.$1",
  "festivals.aideen.fall20": "Hola @. Confío en que estés disfrutando de las festividades.$1#$b#Oh sí, así es, aunque la competición es decididamente poco sofisticada. ¿Supongo que los niños establecieron el tema?$3",
  "festivals.vivienne.fall20": "¡Lenny es tan divertida! Disfruto mucho de su compañía.$1",
  "festivals.pepperpup.fall20": "(¡Pimienta está llena de ánimo!)$1",
  "festivals.fall20.jessie": "Hola, @, veo que tú también has hecho el viaje hasta aquí. Pensé en hacer un poco de recolección más tarde.#$b#Hay flora única en esta cresta.",
  "festivals.fall20.juliet": "¡Hola @! Chicos contra chicas, la vieja disputa tradicional de género. Todo esto es un poco binario, ¿no crees?#$b#Hmm, ¿a qué equipo estoy animando? Bueno, todos tienen sus ventajas.$1",
  "festivals.fall20.es.juliet": "¡Hola @! Chicos contra chicas, la vieja disputa tradicional de género. Todo esto es un poco binario, ¿no crees?#$b#Hmm, ¿a qué equipo estoy animando? Bueno, supongo que por ahora, tiene que ser a las chicas, ¿verdad, Rosie?$4",
  "festivals.fall20.jasper": "Este pueblo arrastra una herencia interesante, @. Debería visitarlo más a menudo.",
  "festivals.fall20.jasper.spouse": "¡${Amado mío^Amada mía}$! Solo estoy tomando un poco de tiempo para disfrutar la vista... Y el aire fresco de la montaña.$1",
  "festivals.fall20.gunther": "Buen día, @.#$b#Un pueblito encantador, ¿no? Aunque no estoy seguro de entender muy bien el propósito de este festival.",
  "festivals.fall20.tristan": "Es bueno ver que las viejas batallas todavía se libran... Por supuesto, creo que Jacob y yo estaríamos de acuerdo en que nuestras chicas definitivamente están en el equipo ganador.$1",
  //RSV Embers
  "festivals.aideen.winter28": "¿No es éste el más pacífico de los festivales, @?#$b#Adoro la música... aunque el ambiente es un poco sombrío, ¿no crees?",
  "festivals.eloise.winter28": "Papá dice que en este festival se trata de fijarse metas para el año nuevo, @.#$b#Mi meta es hacerme amiga de esta tortuga. ¡Es mono!$1",
  "festivals.jacob.winter28": "Feliz año nuevo, @. Supongo que Eloise querrá que adoptemos una tortuga a continuación.$2",
  "festivals.vivienne.winter28": "Hola @... cuando llegas a mi edad, el Año Nuevo es agridulce... Es más difícil mirar hacia adelante y más fácil mirar hacia atrás.$2",
  "festivals.rosa.winter28": "¡Hola @! Hace frío, ¿verdad? ¡Estoy deseando que enciendan esto!$1",
  "festivals.oliver.winter28": "Este pueblo es bastante bonito. Y Blair y Sean parecen bastante majos.#$b#Me han invitado a visitarlo alguna vez.$1#$b#Espero que lo digan en serio.$2",
  "festivals.winter28.juliet": "No te voy a mentir, @, estoy aquí por la fogata.$1#$b#¿Propósitos de año nuevo? Bueno, están hechos para romperse.",
  "festivals.winter28.jessie": "Hola, @. Te deseo un año nuevo lleno de abundancia y belleza, repleto de alegría y de sonrisas.$1",
  "festivals.winter28.jasper": "¿No es acaso este el festival más encantador, @?#$b#Hmm... Ahora, ¿qué noble propósito debería fijar para el año nuevo?",
  "festivals.winter28.jasper.spouse": "Hmm... ¿Qué propósito debería fijar para el año nuevo, mi amor?#$b#¡Ya sé! Me propondré hacerte sentir ${amado y apreciado^amada y apreciada}$ durante todo el año... Y siempre.$4",
  "festivals.winter28.tristan": "Hey, @... Estoy aquí para mantener a Shane fuera de problemas... O quizá para animarlo a meterse en ellos... Tendremos que esperar y ver.$1",
  "festivals.eyvinder.winter28":"Año nuevo, vida nueva, solían decir.#$b#Ja, me gusta mucho cómo era antes. No voy a cambiar por nadie.$1",
  //Fashion Show
  "festivals.aideen.spring19": "¿Has echado un vistazo a los puestos, @? Algunas de las modas que se exponen son bastante atrevidas, ¿no te parece?$1",
  "festivals.eloise.spring19": "¡Vamos a montar nuestro propio desfile de moda más tarde!#$b#¡Vamos a poner a Vinny el vestido más mono de la historia!$1",
  "festivals.jacob.spring19": "Hola @. Bueno, yo no soy realmente uno para la moda, estoy aquí sobre todo para el apoyo a la comunidad.",
  "festivals.josephine.spring19": "Buenos días. Aunque este pequeño festival carezca del estilo y la pompa del Artes de vestir de Zuzu, no carece de encanto.",
  "festivals.vivienne.spring19": "¡Oooh, @! Estoy intentando convencer a Jacob para que amplíe su armario... ¿Quieres ayudar?",
  "festivals.lexi.spring19": "Pica mucho. Pero me hace sentir guapa, sí. ¿Qué te parece?$3",
  "festivals.oliver.spring19": "Oye @, ¿festivales un poco demasiado para ti también? Lexi tenía curiosidad, así que les hice algunas compras.#$b#Creo que Lexi está preciosa, ¿verdad?",
  //Scarpe Festivals
  "festival.spiritsevescarpinn.name": "Víspera de los Espíritus en la Posada Scarp",
  "festival.spiritsevescarpinn": "La Víspera de los Espíritus en Scarp ha comenzado",
  //Additional Festivals
  "festivals.desert.kataryna.1": "Ah, hola. Estoy bastante intrigada por este tipo de aspecto sombrío. He intentado hablar con ellos, pero parece que me ignoran...",
  "festivals.desert.kataryna.2": "Clint parecía un poco solo, así que pasé a hacerle unas preguntas.",
  //PASSIVE FESTIVALS
  //Spirit's Eve at Scarp Inn
  "ES_SpiritsEve_Invite_1": "Horror, horror, sudor y quebranto;^Arda el fuego y que la caldera burbujee.^Un llamado a duendes, espectros y fantasmas;^La posada de East Scarp será vuestra anfitriona.^Vístete para impresionar... O para engañar.^Cuando el reloj marque las trece el día de la Víspera de los Espíritus.^^¡Espero verte allí! - Rosa ^PD: Debido a las festividades del pueblo, tendrás que venir por el sendero de la montaña. ¡Cuidado con los monstruos! (¡Y con Marlon!)",
  "ES_SpiritsEve_Invite.Title_1": "Invitación a una fiesta en East Scarp",
  "spiritsevescarp.rosa.0": "¿A que la Víspera de los Espíritus es genial? ¡Es mi fiesta favorita, @!",
  "spiritsevescarp.jacob.1": "Sé que no hay mucha gente aquí, y que son todos mis vecinos... Pero socializar es difícil.$2",
  "spiritsevescarp.jacob.2": "¡Hola, @! Justo le estaba contando a Marnie el encontronazo que tuve con un toro el otro día.$2#$b#Solo era un análisis de sangre rutinario, pero... Digamos que no sabía que podía saltar una valla tan rápido.$4#$b#En fin, ¿cómo va tu ganado, @?",
  "spiritsevescarp.eloise.1": "¡Estoy escribiendo una historia de fantasmas, ${granjero^granjera}$ @! ¡Va a dar muchísimo miedo!$1",
  "spiritsevescarp.eloise.2": "He dibujado un cocatriz. ¡Es un pájaro monstruo que mata con la mirada! ¿Da miedo, verdad?$3",
  "spiritsevescarp.eloise.3": "¡Hola, ${granjero^granjera}$ @! No, no soy un cardenal, ¡soy un fénix!$1",
  "spiritsevescarp.aideen.1": "Buen día, @. ¿Conoces a Madame Welwick?#$b#Aparentemente, esta posada irradia energías de otro mundo. ¿No es absolutamente fabuloso?$1#$b#¡Quizá podamos organizar una sesión espiritista más tarde!$7",
  "spiritsevescarp.aideen.2": "¡Oh, el disfraz de Mateo me dio un buen susto! ¡Tengo los nervios alborotados!$4",
  "spiritsevescarp.lexi.1": "¡Hay mucha gente aquí! Quizá haga nuevos amigos, ¿sí?$1#$b#Pero da un poquito de miedo... Me alegra tener a Olly cuidando.$2",
  "spiritsevescarp.lexi.2": "¿Por qué Olly golpea la bola blanca y la hace rebotar en los lados? ¿No debe entrar en el agujero?#$b#Creo no es muy buen jugador.$2",
  "spiritsevescarp.lexi.3": "Esta Madame... ¿me suena? ¿Creo que la vi en la tele?",
  "spiritsevescarp.oliver.lexi.1": "Oye, ¿crees que podamos convencer a Rosa de darle un premio al mejor disfraz? Lexi ganaría de calle.$1",
  "spiritsevescarp.oliver.1": "Hey @. ¿Qué tal? Sam y yo estamos en una pequeña competencia amistosa. Sí... Él va ganando.$2",
  "spiritsevescarp.oliver.2": "Le pedí los números ganadores de la lotería... Se negó a dármelos...",
  "spiritsevescarp.josephine.1": "No estoy segura de qué hay en esta olla, pero ciertamente huele muy fragante.",
  "spiritsevescarp.shane.1": "¿Has probado los pastelitos de calabaza, @? Jas y yo estuvimos toda la mañana horneándolos.$1#$b#Los míos son los terroríficamente deformes. Err... No, no era intencional.$2",
  "spiritsevescarp.jas.1": "Ssssh, ¡estamos contando historias de miedo! ¿Quieres contar una tú?$1",
  "spiritsevescarp.marnie.1": "El Dr. Jacob no será muy hablador... Pero si le sacas el tema del ganado, se vuelve todo un narrador.$1",
  "spiritsevescarp.sam.1": "Esto es buen entrenamiento para enfrentarme a Sebastian.",
  "spiritsevescarp.vincent.1": "¿Has oído hablar del hombre mocos? Es como el hombre del saco... ¡pero te hurga la nariz en la oscuridad!$1",
  "spiritsevescarp.tristan.1": "Estos mini pastelitos están deliciosos. Me he comido como una docena ya.$1",
  "spiritsevescarp.juliet.1": "¡Bienvenido a la casa de la diversión, @! ¡Es el lugar ideal para la Víspera de los Espíritus!$1#$b#A Rosa le encanta esta canción... Pero si te hartas de escucharla en bucle, hay una jukebox en la sala de juegos.",
  "spiritsevescarp.jessie.1": "¿Qué puedo decir? Rosa quería un caldero de bruja: Es zumo de uva, canela y una mezcla de otras especias. ¿A que huele bien?",
  "spiritsevescarp.jasper.1": "Los niños y yo estamos trabajando en un volumen recopilatorio de historias espeluznantes.$3#$b#¿Te gustaría aportar una historia propia?$1",
  "spiritsevescarp.rosa.1": "Espero que todo se vea lo suficientemente espeluznante. Estuve casi toda la noche decorando.$1#$b#No creo que logre mantenerme despierta para las festividades de esta noche...$2",
  "spiritsevescarp.rosa.2": "Espero que todo se vea lo suficientemente espeluznante. Estuve casi toda la noche decorando.$1#$b#Quizá me cueste mantenerme despierta para esta noche… pero le prometí a Jules.$4",
  "spiritsevescarp.kataryna.1": "¿Quieres escuchar historias de miedo, @? Oh, ¡tengo algunas que te pondrían los pelos de punta!$1",
  "spiritsevescarp.jade.0": "¿A que esta arañita es la criatura más adorable que has visto?$1",
}