  "98890007/t 800 1500/f Olina 250": "50s/7 8/farmer 7 14 0 Olina 7 6 0/skippable/playSound doorClose/move farmer 0 -6 0/pause 500/emote Olina 16/pause 500/faceDirection Olina 2/pause 500/speak Olina \"¡Oh, eres tú!$1#$b#Es tu primera vez dentro de mi casa, ¿verdad?$0#$b#¡Bienvenido!$1\"/pause 500/speak Olina \"Acababa de meter un pastel en el horno.$0#$b#Siéntete libre de tomar una rebanada cuando esté listo~.$1\"/pause 500/emote farmer 32/pause 500/speak Olina \"Entonces, ¿qué opinas de mi casa?$0#$b#Traté de hacerla lo más linda posible.$1\"/question fork1 \"#¡Me encanta!#No es realmente mi estilo.\"/fork style/pause 500/emote Olina 32/pause 500/speak Olina \"¡Me alegra tanto escuchar eso!$1\"/pause 500/speak Olina \"Sé que mi estilo no es para todos.$3#$b#De hecho, a Jinx no le gusta este tipo de estilo. ¡Pero seguimos siendo buenos amigos de todos modos~.$0\"/pause 500/speak Olina \"¡Incluso me da muchos cumplidos sobre mi decoración aunque sé que en realidad no le gusta!$0#$b#Simplemente siempre es muy amable conmigo~.$1\"/pause 500/emote farmer 28/pause 500/speak Olina \"¿Oh? ¿Jinx no es tan amable contigo?$3#$b#Sí, generalmente es un poco grosero con todos.$3#$b#Bueno, con todos excepto conmigo por alguna razón.$3\"/pause 500/speak Olina \"Siempre me da cumplidos y regalos, lo cual aprecio mucho.$0#$b#Pero los demás siempre dicen que hay una razón por la que lo hace...?$3#$b#No estoy segura de qué quieren decir con eso, pero bueno.$0\"/pause 500/emote Olina 16/pause 500/speak Olina \"¡Oh! ¡Lo recordé!$3\"/pause 500/move Olina 2 0 2/move Olina 0 7 1/faceDirection farmer 2/move Olina 1 0 1/pause 500/speak Olina \"¡Ven aquí!$0\"/pause 500/move farmer 2 0 2/move farmer 0 3 1/move farmer 2 0 2/pause 500/speak Olina \"@, conoce a mi conejito mascota!$1#$b#Su nombre es Love Bunny, pero puedes llamarlo simplemente Love.$0\"/pause 500/speak Olina \"¡Jeje, creo que le gustas!$1\"/pause 500/emote farmer 20/pause 500/faceDirection Olina 0/speak Olina \"Lo encontré atrapado en una planta cerca del lago hace unos años.$3#$b#Estaba herido, así que lo recogí y lo cuidé hasta que se recuperó.$2\"/pause 500/speak Olina \"Mi plan era liberarlo de nuevo en la naturaleza una vez que se recuperara.$3#$b#¡Pero se negó a salir de mi casa!$3#$b#Así que decidí quedármelo como mascota.$0\"/pause 500/faceDirection Olina 1/speak Olina \"Creo que simplemente le gusta que le dé mucha comida, jeje.$0\"/pause 500/playSound crystal/pause 300/emote Olina 16/pause 500/speak Olina \"¡Oh! ¡El pastel está listo!$3#$b#¡Vamos a comer~!.$1\"/pause 1000/end",
  "style": "pause 500/speak Olina \"Eso es justo.$0#$b#Después de todo, cada uno tiene sus gustos.$0\"/pause 500/speak Olina \"Jinx también tiene un estilo muy diferente al mío, pero seguimos siendo grandes amigos.$0#$b#De hecho, siempre me elogia por mi decoración aunque sé que en realidad no le gusta.$0#$b#¡Simplemente siempre es muy amable conmigo de esa manera~.$1\"/pause 500/emote farmer 28/pause 500/speak Olina \"¿Oh? ¿Jinx no es tan amable contigo?$3#$b#Sí, generalmente es un poco grosero con todos.$3#$b#Bueno, con todos excepto conmigo por alguna razón.$3\"/pause 500/speak Olina \"Siempre me da cumplidos y regalos, lo cual aprecio mucho.$0#$b#Pero los demás siempre dicen que hay una razón por la que lo hace...?$3#$b#No estoy segura de qué quieren decir con eso, pero bueno.$0\"/pause 500/emote Olina 16/pause 500/speak Olina \"¡Oh! ¡Lo recordé!$3\"/pause 500/move Olina 2 0 2/move Olina 0 7 1/faceDirection farmer 2/move Olina 1 0 1/pause 500/speak Olina \"¡Ven aquí!$0\"/pause 500/move farmer 2 0 2/move farmer 0 3 1/move farmer 2 0 2/pause 500/speak Olina \"@, conoce a mi conejito mascota!$1#$b#Su nombre es Love Bunny, pero puedes llamarlo simplemente Love.$0\"/pause 500/speak Olina \"¡Jeje, creo que le gustas!$1\"/pause 500/emote farmer 20/pause 500/faceDirection Olina 0/speak Olina \"Lo encontré atrapado en una planta cerca del lago hace unos años.$3#$b#Estaba herido, así que lo recogí y lo cuidé hasta que se recuperó.$2\"/pause 500/speak Olina \"Mi plan era liberarlo de nuevo en la naturaleza una vez que se recuperara.$3#$b#¡Pero se negó a salir de mi casa!$3#$b#Así que decidí quedármelo como mascota.$0\"/pause 500/faceDirection Olina 1/speak Olina \"Creo que simplemente le gusta que le dé mucha comida, jeje.$0\"/pause 500/playSound crystal/pause 300/emote Olina 16/pause 500/speak Olina \"¡Oh! ¡El pastel está listo!$3#$b#¡Vamos a comer~!.$1\"/pause 1000/end"

//Jinx Six Heart Event
  "98890020/t 900 1600/f Jinx 1500": "playful/7 8/farmer -500 -500 0 Jinx 4 7 1 Olina 7 6 2/skippable/pause 500/speak Olina \"¿Qué te gustaría, Jinx?$0#$b#Podría hacer macarrones con queso, lasaña, espagueti...$0\"/pause 500/speak Jinx \"Los macarrones con queso suenan bien.$0#$b#¿Pero estás segura de que no quieres mi ayuda?$3\"/pause 500/speak Olina \"¡Sí, estoy segura!$1#$b#¡Eres mi invitado, así que siéntate y relájate~.$0\"/pause 500/speak Jinx \"Está bien...$3#$b#Pero si alguna vez necesitas manos extras, avísame.$0\"/pause 500/emote Olina 56/pause 500/speak Olina \"Eres tan dulce, Jinx.$1\"/pause 500/emote Jinx 60/pause 500/speak Jinx \"Olina piensa que soy dulce...$3\"/pause 500/playSound doorClose/warp farmer 7 14/move farmer 0 -6 0/pause 500/emote Olina 16/pause 500/speak Olina \"¡Hola, @!$1\"/pause 500/speak Olina \"Tienes suerte, estaba a punto de cocinar algunos macarrones con queso.$0#$b#Estoy segura de que habrá suficiente para los tres si quieres un poco.$0\"/pause 500/emote farmer 56/pause 500/speak Jinx \"No te comas demasiado, discípulo.$0#$b#Tengo bastante hambre en este momento.$0\"/pause 500/speak Olina \"¿Así que realmente has estado llamando a @ tu 'discípulo'?$3#$b#¿Les gusta siquiera que los llamen así?$3\"/pause 500/speak Jinx \"Bueno, se supone que deberían ayudarme con mis hechizos y pociones, así que en cierto modo son mi discípulo, ¿no?$0#$b#Y estoy seguro de que si no les gustara, ya lo habrían dicho.$0\"/pause 500/speak Jinx \"Además, no hay nada de malo en ser un discípulo.$0#$b#Yo mismo fui uno hace algún tiempo.$0\"/pause 500/speak Olina \"¿Oh, de verdad?$3#$b#¿De quién?$3\"/pause 500/emote Jinx 40/pause 500/speak Jinx \"Verás, eso no lo recuerdo muy bien...$3#$b#Mis recuerdos de esa época están bastante borrosos.$3\"/pause 500/speak Jinx \"Pero era una persona muy poderosa, eso no lo olvido.$0\"/pause 500/speak Olina \"Eso tiene sentido.$0#$b#Eres bastante poderoso tú mismo, así que por supuesto que aprendiste de los mejores, ¿verdad?$1\"/pause 500/emote Jinx 60/pause 500/speak Jinx \"S-sí...$0\"/pause 500/speak Olina \"Debería empezar a hacer los macarrones con queso ahora.$0#$b#¿Por qué no salen a jugar un rato?$1\"/pause 500/speak Olina \"Jeje, acabo de sonar como una mamá~.$1\"/pause 500/speak Jinx \"Estoy seguro de que serías una gran madre.$0\"/pause 500/faceDirection Jinx 2/textAboveHead Jinx \"...Y esposa...\"/pause 1500/speak Olina \"¿Qué fue esa última parte?$3\"/pause 500/faceDirection Jinx 1/jump Jinx 5/speak Jinx \"¡N-nada!!$3\"/pause 1500/end",

//Olina Ten Heart Event
  "98890071/t 600 1900/f Olina 2500/n OlinaMemories": "none/7 8/farmer 7 10 0 Olina 7 8 2 Jinx -200 -200 0 Lulu -200 -199 0/changeSprite Jinx HumanPast/changePortrait Jinx HumanPast/changeSprite Lulu Shalise/pause 1500/speak Olina \"Hola, @...$2#$b#Gracias por venir como te pedí.$2#$b#Realmente necesito estar con alguien ahora mismo...$2#$b#Pero tampoco quería contarles a los otros axolotes sobre esto.$2#$b#Después de todo, están bastante asustados con todo esto de 'recuperar recuerdos de una vida pasada', así que pensé que decirles solo empeoraría las cosas.$2\"/pause 500/speak Olina \"Um... sí, he recordado una buena parte de cómo era mi vida como humana.$2#$b#Y honestamente, era una vida bastante agradable.$3#$b#Es solo que...$3#$b#Parece haber tenido un final abrupto que todavía me confunde.$3\"/pause 500/emote farmer 8/pause 500/speak Olina \"Supongo que podría explicar un poco más....$3#$b#Pero esto podría tomar un tiempo, así que siéntete libre de sentarte.$3\"/pause 500/fade/viewport -500 -500/warp farmer -200 -197/warp Olina -200 -196/pause 1000/message \"Los recuerdos que están más frescos en mi mente ahora comienzan en un día de primavera en 1974...\"/pause 1000/changeSprite Olina HumanPast/changePortrait Olina HumanPast/changeLocation otohime.AV_OlinaRoom/fade/viewport 8 9/playMusic OldMemories/pause 2500/message \"Radio: ....Y ahí lo tienen, esa fue la canción más popular 'Waterloo' de ABBA!\"/pause 500/message \"¡Bastante divertida, ¿verdad?\"/pause 500/message \"A continuación, vamos a relajarnos un poco con 'The Way We Were' de Barbra Streisand.\"/pause 500/speak Olina \"Maldita sea...$2\"/pause 1000/playSound doorClose/warp Jinx 8 16/faceDirection Jinx 0/changeName Jinx Jax/pause 500/speak Jinx \"Hola, 'Lina.$0\"/pause 500/move Jinx 0 -5 0/pause 500/speak Jinx \"...¿Has estado escuchando la radio todo el día?$3\"/pause 500/message \"Este es Jaxon Seok.\"/pause 500/message \"Él era mi mejor amigo cuando era humana.\"/pause 500/message \"La gente solía confundirse con cómo dos personas tan diferentes podían estar tan cerca...\"/pause 500/message \"Pero simplemente lo estábamos. Nos llevábamos tan bien de forma natural.\"/pause 500/speak Olina \"Sí...$2#$b#He estado esperando a que pusieran 'Goodbye Yellow Brick Road'.$2\"/pause 500/speak Jinx \"Ya han pasado a esa canción.$0#$b#Ahora todo es sobre 'Bennie And The Jets'.$0\"/pause 500/speak Olina \"Lo sé, pero 'Goodbye Yellow Brick Road' sigue siendo mi favorita...$2\"/pause 500/speak Jinx \"¿Qué tal si simplemente olvidas la radio y vienes a ver una película conmigo?$0#$b#He estado muriendo por ver 'Don't Open the Door'.$0\"/pause 500/speak Olina \"¿No es una película de terror?$3#$b#Sabes que no puedo manejar el terror...$3\"/pause 500/speak Jinx \"No te preocupes.$0#$b#Riley la vio y dijo que no era tan aterradora.$0\"/pause 500/speak Jinx \"Además, es la primavera.$0#$b#Deberíamos salir y divertirnos, ¿no?$0\"/pause 500/speak Olina \"Sí, es verdad...$3#$b#Está bien, me has convencido.$0#$b#Pero vamos a conseguir un montón de dulces.$1\"/pause 500/speak Jinx \"Por supuesto.$0\"/pause 500/fade/viewport -500 -500/pause 1000/message \"Unas horas después...\"/pause 500/changeLocation otohime.AV_CityStreet/warp Olina 0 9/warp Jinx 0 10/faceDirection Olina 1/faceDirection Jinx 1/fade/viewport 17 10/pause 2000/move Olina 16 0 2 Jinx 16 0 0/pause 500/speak Jinx \"¿Cómo estuvo?$0#$b#¿No fue demasiado aterradora, verdad?$0\"/pause 500/speak Olina \"Y-yeah... ¡No estaba asustada en absoluto!$3\"/pause 500/speak Jinx \"Sí, igual.$0#$b#Esa película en realidad apestaba, de hecho.$0\"/pause 500/jump Olina 5/pause 200/speak Olina \"Jax, no estaba en serio cuando dije eso!$5#$b#¡Estuve totalmente aterrorizada todo el tiempo!!$2\"/pause 500/emote Jinx 28/pause 500/speak Jinx \"O-oh... Bueno, yo también estaba bromeando.$3#$b#Esa película en realidad fue súper intensa.$3\"/pause 500/warp Lulu 34 10/faceDirection Lulu 3/move Lulu -5 0 3/pause 200/emote Lulu 16/pause 500/jump Lulu 5/pause 200/textAboveHead Lulu \"¡Hey, chicos!!\"/pause 1500/faceDirection Olina 1/faceDirection Jinx 1/speed Lulu 5/move Lulu -11 0 3/pause 500/message \"Shalise: ¡Jax, Olina!\"/message \"¡Qué sorpresa encontrarlos a ustedes dos!\"/pause 500/speak Olina \"Oh, hola Shalise.$0#$b#¿Haciendo algunas compras?$0\"/pause 500/message \"Shalise: En realidad, estaba repartiendo invitaciones para una fiesta que estoy organizando este fin de semana.\"/message \"...Bueno, también estaba comprando.\"/pause 500/message \"Shalise: Pero por suerte los encontré, ¡aquí están sus invitaciones!\"/pause 500/speak Jinx \"¿Otra fiesta, Shalise?$3#$b#¿No es esta la tercera que has organizado este mes?$3\"/pause 500/message \"Shalise: ¡Nunca se pueden organizar demasiadas fiestas!\"/message \"Además, es la primavera, ¡así que tenemos que celebrar a lo grande!\"/pause 500/speak Olina \"Ella tiene un punto, sabes.$1\"/pause 500/speak Jinx \"Tú dirías eso, animal de fiesta...$0\"/pause 500/speak Olina \"¡Hey!$5\"/pause 500/message \"Shalise: De todos modos, tengo como 20 personas más que invitar, así que tengo que irme.\"/message \"¡Nos vemos en la fiesta!\"/pause 500/faceDirection Lulu 1/speed Lulu 5/move Lulu 16 0 0/warp Lulu -200 -199/faceDirection Olina 2/faceDirection Jinx 0/speak Olina \"Definitivamente vamos a la fiesta.$0\"/pause 500/speak Jinx \"¿No te cansas de ellas?$3\"/pause 500/speak Olina \"¡No, por supuesto que no!$3#$b#Estamos a punto de graduarnos, así que no nos queda mucho tiempo para festejar tanto como queremos.$2\"/pause 500/speak Jinx \"Pero, ¿no se trata también de hacer fiestas en la universidad?$3\"/pause 500/speak Olina \"....Cierto.$3\"/pause 500/speak Olina \"Pero no importa.$0#$b#Vive mientras eres joven, ¿no?$1\"/pause 500/speak Jinx \"Sí, sí.$0\"/pause 500/fade/viewport -500 -500/stopMusic/warp Olina -200 -100/warp Jinx -200 -99/pause 1000/message \"La fiesta fue divertida, aunque no vi mucho a Jax durante ella.\"/message \"También parecía un poco extraño después, pero no pensé mucho en eso.\"/pause 500/message \"Él me estaba llevando a casa y todo parecía estar bien...\"/pause 1000/playSound CarCrash/pause 10000/changeLocation otohime.AV_OlinaHouse/fade/viewport 7 8/pause 2000/speak Olina \"...Y ahí es donde terminan todos mis recuerdos.$2\"/pause 500/speak Olina \"No puedo evitar pensar que ocurrió lo peor... pero desearía saberlo con seguridad.$2\"/pause 500/speak Olina \"El coche... chocó, ¿no?$2#$b#Entonces... ¿morí?$2#$b#Eso explicaría por qué no puedo recordar nada después de eso.$2\"/pause 500/speak Olina \"Pero si es así... ¿qué pasó entre entonces y ahora?$3#$b#¿Cómo terminé aquí?$3\"/pause 500/speak Olina \"Solo me quedan tantas preguntas.$2\"/pause 500/speak Olina \"Pero algo que no puedo evitar preguntarme es...$3#$b#¿Dónde está Jax ahora?$3\"/pause 500/end",


//Jinx and Olina Event 
  "98890073/t 600 2000/e 98890072": "Reunión/7 8/farmer 7 10 0 Jinx 6 8 1 Olina 8 8 3/pause 1000/emote Olina 40/pause 500/speak Olina \"Wow... ¡así que eres Jax!$3#$b#Sí, eso tiene mucho sentido ahora que lo pienso.$3\"/pause 500/jump Olina 7/pause 400/speak Olina \"¡Pero... estoy tan feliz!$1\"/pause 500/emote Jinx 8/pause 500/speak Jinx \"...¿Feliz?$3#$b#¿Por qué?$3\"/pause 500/speak Olina \"¡Porque he estado tan preocupada por dónde terminaste!$3#$b#Además... eres mi mejor amigo.$0#$b#¡Por supuesto que estaría feliz de verte!$1\"/pause 500/speak Jinx \"Pero... yo soy la razón por la que nosotros-$2\"/speak Olina \"Lo sé.$2#$b#Pero no estoy enojada contigo por eso.$0\"/pause 500/speak Jinx \"...¿No lo estás?$3\"/pause 500/speak Olina \"Quizás lo estuve en algún momento, pero definitivamente ya no.$3#$b#Después de todo, solo fue un accidente.$3\"/pause 500/speak Jinx \"Sí, pero...$2#$b#Hay una razón tonta por la que terminó ocurriendo.$2\"/pause 500/speak Olina \"Te emborrachaste, ¿verdad?$3#$b#Vamos, no puedo culparte por beber en una fiesta organizada por un grupo de estudiantes de secundaria.$3#$b#Eso es lo normal.$3\"/pause 500/speak Jinx \"Cierto, pero... no bebí solo por hacerlo.$2#$b#Sabes que normalmente trataba de evitar ese tipo de cosas en ese entonces.$2\"/pause 500/speak Olina \"Es verdad...$3#$b#Entonces, ¿por qué lo hiciste?$3#$b#¿Pasó algo?$3\"/pause 500/speak Jinx \"Sí, bueno... realmente fue muchas cosas.$2#$b#Pero la principal tenía que ver con... contigo.$2\"/pause 500/speak Olina \"¿Conmigo?$3#$b#¿Hice algo mal?$3\"/pause 500/speak Jinx \"No, no... por supuesto que no.$2\"/pause 500/speak Jinx \"Lo que quiero decir es, uh...$2#$b#Realmente quería decirte algo esa noche.$2\"/pause 500/speak Jinx \"Pero me di cuenta de que no tenía sentido decírtelo.$2\"/pause 500/speak Olina \"¿De verdad?$3#$b#¿Qué querías decirme?$3\"/pause 500/speak Jinx \"Como dije, no tiene sentido-$2\"/speak Olina \"Puedes decírmelo, Jax.$3\"/pause 500/emote Jinx 40/pause 500/faceDirection Jinx 3/pause 300/emote Jinx 28/pause 700/speak Jinx \"Lo que quería decirte es que...$2\"/pause 500/faceDirection Jinx 1/pause 400/speak Jinx \"Te amo.$2\"/pause 500/speak Jinx \"Aún te amo, Olina.$2\"/pause 500/emote Olina 16/pause 800/emote Olina 40/pause 1000/jump Olina 7/pause 400/speak Olina \"¡Yo también te amo!$1\"/pause 500/emote Jinx 16/pause 500/speak Jinx \"...¿E-espera, qué?$3#$b#¿Tú... lo haces?$3\"/pause 500/speak Olina \"Lo hago...$3#$b#Tuve esa realización muchas veces en ese entonces, pero siempre aparté esos sentimientos.$2#$b#Pensé que no sentías lo mismo y no quería arruinar nuestra amistad, así que...$2\"/pause 500/jump Jinx 7/pause 400/speak Jinx \"¡T-también sentí eso!$3#$b#¡Por eso nunca pude decírtelo durante todos esos años...$2\"/pause 500/speak Jinx \"Vaya... y aún así, todo el tiempo, ambos sentimos lo mismo.$3\"/pause 500/speak Jinx \"Estoy tan...$1\"/pause 500/speak Olina \"¿Feliz?$1\"/pause 500/jump Jinx 7/pause 500/speak Jinx \"¡Sí, feliz!$1\"/pause 500/emote Jinx 20/emote Olina 20/pause 500/emote farmer 32/pause 1000/end",

