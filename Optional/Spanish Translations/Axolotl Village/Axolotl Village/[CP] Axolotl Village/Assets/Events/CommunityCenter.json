
             {
        //Hiro Six Heart Event
  "98890005/t 1000 1600/f Hiro 1500": "playful/14 13/farmer 22 14 3 Hiro 13 13 0 Lala 14 13 0/skippable/pause 500/move farmer -7 0 0/move farmer 0 1 2/move farmer -1 0 0/pause 500/emote Lala 12/pause 500/jump Lala 5/pause 500/textAboveHead Lala \"¡Argh!!!\"/pause 500/speak Lala \"¡Perdí de nuevo!$5#$b#¡Este juego es demasiado difícil, lo juro!$5\"/pause 500/emote Hiro 56/pause 500/jump Hiro 5/pause 500/textAboveHead Hiro \"¡Sí!!\"/pause 500/speak Hiro \"¡Acabo de superar mi récord personal!$1\"/pause 500/faceDirection Lala 3/speak Lala \"¿¡Qué?!$3#$b#¿¡Cómo lo lograste?!$3#$b#¡Tu récord anterior era el más alto que se haya conseguido!$3\"/pause 500/faceDirection Hiro 1/speak Hiro \"No sé, supongo que la práctica hace al maestro.$0\"/pause 500/speak Lala \"Pero tú prácticamente nunca 'practicas'...$3#$b#Creo que debes ser simplemente naturalmente talentoso para los juegos o algo así.$3\"/pause 500/faceDirection Lala 0/speak Lala \"¡Quiero decir, ni siquiera puedo superar tu puntuación más baja en este juego!$3\"/pause 500/speak Hiro \"Quizás tienes razón.$3\"/pause 500/faceDirection Hiro 2/pause 500/emote Hiro 16/pause 500/speak Hiro \"¡Oye, @!$0#$b#¿Cuánto tiempo has estado ahí?$3\"/pause 500/emote farmer 60/pause 500/speak Hiro \"Lala y yo hemos estado pasando el día jugando a estos juegos de arcade.$0#$b#Aunque creo que Lala realmente está empezando a frustrarse...$3\"/pause 500/emote Lala 12/pause 500/jump Lala 5/pause 500/textAboveHead Lala \"¡No otra vez!\"/pause 500/speak Lala \"¡Ugh, morí de la misma manera que la última vez!$5\"/pause 500/faceDirection Lala 2/pause 500/emote Lala 16/pause 500/speak Lala \"Oh, hola @!$0#$b#¿Has estado aquí todo el tiempo?$3\"/pause 500/speak Hiro \"Sí, solo estaba hablando con ellos... ¿No oíste eso?$3\"/pause 500/speak Lala \"Oh, ups, supongo que estaba distraído.$3#$b#Pero no importa cuánto enfoque le dé a este estúpido juego, ¡todavía no puedo superar tu puntuación más baja!$5\"/pause 500/emote farmer 40/pause 500/speak Hiro \"Nunca has visto a Lala tan enojado antes, ¿verdad?$3#$b#Sí, solo se pone así con los juegos.$3\"/pause 500/emote Lala 28/pause 500/speak Lala \"Lo siento, ¿estoy exagerando otra vez?$3#$b#¡Simplemente no puedo evitar sudar tanto con los juegos, ¡sabes?!$5#$b#Desearía poder ser la mitad de bueno que Hiro.$2\"/pause 500/faceDirection Hiro 1/speak Hiro \"Te lo estoy diciendo, con práctica mejorarás.$3#$b#¿Verdad, @?$0\"/pause 500/emote farmer 56/pause 500/speak Lala \"¡Está bien, entonces voy a pasar el resto del día practicando!$5#$b#¡Empezando ahora!$5\"/pause 500/faceDirection Lala 0/pause 500/emote Lala 52/pause 500/faceDirection Hiro 2/speak Hiro \"Bueno, definitivamente tiene el espíritu.$0\"/pause 1000/end",
        
        //Olina Six Heart Event
  "98890010/t 1000 1600/f Olina 1500": "playful/25 16/farmer 39 16 3 Olina 28 16 2 Jinx 28 18 3/skippable/pause 500/move farmer -10 0 2/pause 500/speak Jinx \"Mira esto, Olina.$0#$b#¡Esta vez voy a ganar el juego seguro.$0\"/pause 500/speak Olina \"Hmm, no estoy segura de que sepas jugar al billar, Jinx...$3\"/pause 500/speak Jinx \"Claro que sé, querida.$0#$b#Solo tienes que, eh, meter las bolas en los agujeros.$3\"/pause 500/speak Olina \"Está bien, pero ¿no se supone que se juega con otra persona?$3\"/pause 500/speak Jinx \"...¿Se supone?$3#$b#Solo he jugado esto solo.$3\"/pause 500/emote Olina 28/pause 500/faceDirection Olina 1/faceDirection farmer 3/speak Olina \"¡Hey, @! No pienses que no te he notado~!$0\"/pause 500/speak Olina \"Jinx y yo solo íbamos a pasar un rato aquí antes de ir a la tienda de bebidas.$0#$b#¿Quieres venir con nosotros?$0\"/pause 500/emote farmer 56/pause 500/emote Jinx 16/pause 500/textAboveHead Jinx \"¡Ay!!!\"/pause 1000/speak Jinx \"¡Me clavé el palo en el ojo!$3\"/pause 500/faceDirection Olina 2/faceDirection farmer 2/emote Olina 16/pause 500/move Olina 0 1 2/speak Olina \"¡Oh no! ¿Estás bien?$3\"/pause 500/speak Jinx \"No, duele mucho...$2#$b#¡Maldita sea! ¡Maldito palo!$5\"/pause 500/speak Olina \"Tu ojo está empezando a llorar...$3#$b#Pobrecito.$2#$b#Probablemente te saldrá un ojo morado...$2\"/pause 500/speak Jinx \"Bueno, al menos no podrías decir si tengo uno, jajaja...ouch.$3\"/pause 500/speak Olina \"Deberíamos ponerte algo de hielo en ese ojo.$3\"/pause 500/faceDirection Olina 0/speak Olina \"Lo siento, @, pero creo que vamos a tener que cancelar nuestros planes.$2#$b#Voy a llevar a Jinx a mi casa y a ponerle hielo en el ojo en su lugar.$3\"/pause 500/speak Jinx \"Oh, no tienes que hacer eso, Olina...$3#$b#Pero, si insistes...$0\"/pause 500/faceDirection Olina 2/speak Olina \"¡Por supuesto que insisto!$3#$b#¡Me aseguraré de que te sientas mejor en poco tiempo~.$0\"/pause 500/faceDirection Olina 0/pause 500/speak Olina \"@, vamos todos a la tienda de bebidas mañana, ¿de acuerdo?$0\"/pause 500/emote farmer 56/pause 500/speak Olina \"¡Gracias por ser tan comprensivo!$1\"/pause 1000/end",
       
        //Lala Six Heart Event
  "98890015/t 1000 1600/f Lala 1500/d Wed": "playful/33 13/farmer 32 22 0 Lala 32 12 0 Noa 32 10 2 Lulu 33 10 2/skippable/pause 500/playSound doorClose/move farmer 0 -5 0/move Lala -6 0 0/move Lala 0 -3 0/faceDirection Lulu 3/faceDirection Noa 3/speak Lala \"Estoy pensando que las banderitas podrían ir aquí y al otro lado.$0\"/pause 500/move Lala 0 3 0/move Lala 5 0 0/move Lala 0 -3 0/faceDirection Lulu 0/faceDirection Noa 0/speak Lala \"Los globos pueden ir aquí atrás.$0\"/pause 500/move Lala 0 3 2/move Lala 2 0 2/faceDirection Lulu 2/faceDirection Noa 2/speak Lala \"Y luego las máquinas de llamas pueden ir...¡en todas partes!$1\"/pause 500/speak Lulu \"¿Máquinas de llamas?$0#$b#No tenemos máquinas de llamas.$0\"/pause 500/faceDirection Lala 0/speak Lala \"Sí, lo sé, pero deberíamos conseguir algunas.$0#$b#Simplemente se verían muy geniales.$0\"/pause 500/speak Lulu \"¿Pero dónde las conseguiríamos?$0#$b#Nadie produce máquinas de llamas en esta isla.$0\"/pause 500/speak Lulu \"Esto es como cuando querías 'fuegos artificiales interiores' el año pasado.$0#$b#Quiero decir, ¿qué es eso?$0#$b#No existen fuegos artificiales interiores.$0\"/pause 500/speak Lala \"¿Vamos a debatir sobre esto de nuevo?$5#$b#¡Definitivamente EXISTEN fuegos artificiales interiores!$5#$b#Y por cierto, también se verían geniales.$5#$b#SI LOS HUBIÉRAMOS CONSEGUIDO.$5\"/pause 500/speak Noa \"Chicos, ¿podemos reconocer al granjero en la sala antes de que me duerma?$3\"/pause 500/emote Lala 8/pause 500/faceDirection Lala 2/pause 200/emote Lala 16/pause 500/speak Lala \"¡@! ¿Cuánto tiempo has estado aquí?$3\"/pause 500/emote farmer 60/pause 500/speak Lala \"Jeje, supongo que estaba demasiado concentrado en esto para darme cuenta.\"/pause 500/emote farmer 8/pause 500/speak Lala \"¿Qué estamos haciendo, preguntas?$3#$b#Esa es una buena pregunta.$0\"/pause 500/speak Lulu \"Estamos planeando dónde vamos a poner las decoraciones para el gran evento.$0\"/pause 500/speak Lala \"Básicamente, cada año organizamos una espectacular actuación de circo aquí en el centro comunitario.$0#$b#Es algo importante.$0\"/pause 500/emote farmer 56/pause 500/speak Lala \"Lo sé, ¿no es emocionante?$0\"/pause 500/speak Lala \"Dado que este evento es tan importante para mí, solo quiero que todo sea, como...super genial.$0#$b#¿No agregarían las máquinas de llamas a toda la experiencia?$0\"/question fork1 \"#¡Absolutamente!#Eh, suena un poco peligroso.\"/fork flames/pause 500/speak Lala \"¡Ves, @ entiende!$1\"/pause 500/speak Lulu \"Ustedes son unos tontos.$0#$b#No vamos a hacer lo de las máquinas de llamas, punto.$0\"/pause 500/emote Lala 12/pause 500/speak Lala \"Está bien, está bien...$5\"/pause 500/speak Lala \"Pero ¿qué tal esto...$3#$b#Robots.$0\"/pause 1500/emote Lulu 40/pause 500/speak Lulu \"¿Qué?\"/pause 500/speak Lala \"Podemos tener robots en el evento.$0#$b#Pueden repartir bocadillos, hacer los globos...$0#$b#Todo el trabajo pequeño que estaremos demasiado ocupados para hacer.$0#$b#Es genial.$0\"/pause 1000/emote Lulu 40/pause 500/speak Lulu \"Ves, @, esto es lo que tengo que soportar.$0#$b#Cada. Día.$0\"/pause 500/emote farmer 60/pause 1000/end",
  "flames": "pause 500/speak Lulu \"Exactamente. Lo serían.$0\"/pause 500/jump Lala 5/speak Lala \"¡Pero el peligro es de lo que tratan los circos!$2\"/pause 500/speak Lulu \"Simplemente olvídalo, Lala.$0#$b#Las máquinas de llamas no van a suceder.$0\"/pause 500/speak Lala \"Está bien, está bien...$2\"/pause 500/speak Lala \"Pero ¿qué tal esto...$3#$b#Robots.$0\"/pause 1500/emote Lulu 40/pause 500/speak Lulu \"¿Qué?\"/pause 500/speak Lala \"Podemos tener robots en el evento.$0#$b#Pueden repartir bocadillos, hacer los globos...$0#$b#Todo el trabajo pequeño que estaremos demasiado ocupados para hacer.$0#$b#Es genial.$0\"/pause 1000/emote Lulu 40/pause 500/speak Lulu \"Ves, @, esto es lo que tengo que soportar.$0#$b#Cada. Día.$0\"/pause 500/emote farmer 60/pause 1000/end",

       //Puka Six Heart Event
  "98890025/t 1000 1500/f Puka 1500": "playful/33 13/farmer -500 -500 0 Puka 33 12 2 Ipo 33 13 3/skippable/move Ipo -8 0 2/jump Ipo 5/pause 500/move Ipo 0 2 2/emote Ipo 56/pause 500/move Ipo 14 0 2/jump Ipo 5/pause 500/move Ipo 0 1 2/emote Ipo 56/pause 500/move Ipo 0 -2 1/move Ipo 12 0 0/faceDirection Puka 1/pause 500/warp farmer 33 22/playSound doorClose/move farmer 0 -8 0/pause 500/faceDirection Puka 2/speak Puka \"Oh, hola humano.$0\"/pause 500/speak Puka \"Solo estaba dejando que Ipo explorara el centro comunitario.$0#$b#Es su primera vez aquí.$0\"/pause 500/faceDirection Puka 1/emote Puka 56/pause 500/speak Puka \"Parece que realmente le gusta también~.$1\"/pause 500/faceDirection Puka 2/speak Puka \"Los Littles rara vez vienen a esta parte de la isla.$3#$b#Así que la mayoría nunca ha estado dentro de los edificios.$3#$b#Es bastante triste, ¿verdad?$2#$b#Creo que todos nos divertiríamos mucho más si los Littles decidieran visitarnos más a menudo.$2\"/pause 500/speak Puka \"Pero entiendo que prefieren quedarse en el lago.$3#$b#Además, no pueden obtener tanto oxígeno en tierra, así que no pueden estar fuera del agua por mucho tiempo de todos modos.$2\"/pause 500/speak Puka \"Ah, pero aún así...$3#$b#Cada vez que llega una fiesta como Halloween o Navidad, siempre me siento triste porque no podemos pasarla realmente con los Littles.$2\"/pause 500/emote farmer 28/pause 500/speak Puka \"Está bien, sin embargo.$3#$b#Sé que los Littles están más felices cuando nadan.$0#$b#Y si ellos están felices, entonces yo también lo estoy~.$1\"/pause 500/move Ipo -17 0 3/faceDirection farmer 1/pause 500/jump Ipo 5/pause 500/emote Ipo 56/pause 500/speak Puka \"Parece que Ipo está feliz de verte~.$1\"/pause 500/emote farmer 32/pause 500/speak Puka \"Jeje, me alegra que se lleven bien.$1#$b#Ipo es uno de los miembros más extrovertidos de los Littles, así que tiene sentido que te hicieras amigo de él tan rápido.$0\"/faceDirection farmer 0/pause 500/emote Puka 28/pause 500/speak Puka \"Oh, pero ha pasado un buen rato...$3#$b#Probablemente debería llevar a Ipo de vuelta al lago.$2#$b#Sería peligroso para él quedarse en tierra más tiempo.$2\"/pause 500/move Puka 1 0 2/move Puka 0 1 2/faceDirection Ipo 0/emote Puka 40/pause 500/emote Ipo 40/pause 500/emote Ipo 28/pause 500/speak Puka \"Ipo está muy triste de irse.$2#$b#Le encantaría poder pasar más tiempo contigo.$2\"/pause 500/emote Puka 40/pause 500/emote Ipo 40/pause 500/jump Ipo 5/emote Ipo 56/pause 500/speak Puka \"Le hice saber que habrá muchas oportunidades de verte en el futuro.$0\"/pause 500/faceDirection farmer 1/faceDirection Ipo 3/emote farmer 32/emote Ipo 32/pause 1000/end",

       //Noa Eight Heart Event
  "98890031/t 1100 1700/f Noa 2000/e 98890030": "jaunty/33 13/farmer 32 22 0 Noa 26 9 0/skippable/playSound doorClose/move farmer 0 -8 0/emote farmer 16/pause 500/emote Noa 56/pause 500/move Noa 0 4 1/move Noa 13 0 0/move Noa 0 -4 0/pause 500/emote farmer 8/pause 500/move farmer 7 0 0/move farmer 0 -3 0/pause 500/emote farmer 40/pause 500/emote Noa 16/pause 500/faceDirection Noa 2/speak Noa \"Oh, realmente me sorprendiste, @.$3#$b#¿Has estado aquí todo el tiempo o algo así?$3\"/pause 500/speak Noa \"Perdón por no haberme dado cuenta antes.$3#$b#He estado muy concentrado en mi trabajo aquí.$0\"/pause 500/emote farmer 8/pause 500/speak Noa \"¿Acaso Lala o Lulu no te lo dijeron ya?$3#$b#Voy a estar trabajando aquí en el centro comunitario como una especie de 'conserje'...persona.$3#$b#Limpio cualquier desorden que dejen los otros axolotls, quito el polvo de todo...$3#$b#En general, manteniendo todo bonito y ordenado.$0\"/pause 500/emote farmer 40/pause 500/speak Noa \"¿Qué, piensas que me opondría a hacer algo así?$3#$b#Sé que soy bastante perezoso, pero me he dado cuenta de que no me importa hacer limpieza.$0#$b#De hecho, he estado disfrutando un poco de limpiar por aquí.$0#$b#Es relajante, pero también me impide dormirme de repente.$0\"/pause 500/speak Noa \"Solo pensé que sería un buen comienzo para hacerme más productivo.$3#$b#Quiero hacer bien las cosas con Lala y Lulu, así que tengo que cumplir la promesa que les hice.$3#$b#Además...al hacer esto, también estoy haciendo bien conmigo mismo.$0\"/pause 500/emote farmer 56/pause 500/speak Noa \"Gracias por estar feliz por mí.$1\"/pause 500/speak Noa \"Este también sería un buen momento para disculparme contigo.$3\"/pause 500/emote farmer 8/pause 500/speak Noa \"Has estado tratando tan duro de ser amigo mío, ¿verdad?$3#$b#Pero todo este tiempo solo te he mostrado mi peor lado.$3#$b#Me da vergüenza que solo hayas visto las peores partes de mí.$2#$b#Desearía haber causado una mejor primera impresión, y por eso lo siento.$2\"/pause 500/speak Noa \"Pero...a pesar de cómo me he mostrado, todavía quisiste ser amigo mío.$3#$b#Estoy agradecido por eso...porque ahora tengo un buen amigo en ti~.$1\"/pause 500/emote farmer 32/pause 500/speak Noa \"Oye, ¿qué te parece si vamos a tomar algo cuando termine aquí?$0#$b#Y la bebida correrá por mi cuenta.$0#$b#Considera esto tanto mi disculpa como mi agradecimiento en forma líquida deliciosa, jeje.$1\"/pause 500/emote farmer 56/pause 1000/end",

       //Lulu Six Heart Event
  "98890041/t 1000 1600/f Lulu 1500/d Wed": "playful/13 15/farmer 35 14 3 Lulu 15 13 3 Lala 14 13 0 Hiro 13 13 0 Puka 12 13 1/skippable/pause 500/speak Lulu \"Lala, estás siendo demasiado imprudente.$0#$b#Estás a punto de perder de nuevo.$0\"/pause 500/jump Lala 5/pause 300/speak Lala \"¡Agh, pero estoy en pánico!$3#$b#¡No puedo evitarlo!$3\"/pause 500/jump Lala 5/pause 300/speak Lala \"¡Noooo!!$3\"/pause 500/faceDirection Lala 2/emote Lala 12/pause 500/speak Lala \"Perdí de nuevo...$2\"/pause 500/speak Lulu \"Está bien.$0#$b#Quizás lo consigas la próxima vez.$0\"/pause 500/jump Hiro 5/pause 500/emote Hiro 32/pause 500/speak Hiro \"¡Nuevo récord!$1\"/pause 500/faceDirection Hiro 3/speak Hiro \"¿Viste eso, Puka?$0\"/pause 500/speak Puka \"Mmmhmm.$0#$b#Buen trabajo, Hiro~.$1\"/pause 500/emote Hiro 60/pause 500/move farmer -19 0 0/move farmer 0 1 0/move farmer -1 0 0/pause 200/faceDirection Lulu 2/faceDirection Lala 2/speak Lulu \"Hola, @.$1\"/pause 500/speak Lala \"¡Ugh, @!$3#$b#¡No viste cómo perdí justo ahora, verdad?!$3\"/pause 500/emote farmer 36/pause 500/speak Lala \"Menos mal...$3\"/pause 500/faceDirection Lala 3/speak Lala \"¡Hiro, deja de superar tu récord!$3#$b#¿Cómo se supone que voy a alcanzarte si sigues subiendo la barra?!$3\"/pause 500/faceDirection Hiro 1/speak Hiro \"Lo siento, no estoy tratando de hacer las cosas más difíciles para ti.$3#$b#Simplemente disfruto mucho jugar a este juego.$0\"/pause 500/speak Puka \"Hiro, ¿por qué no me consigues un peluche de la máquina de garra?$3#$b#Así estarás distraído de obtener otro récord nuevo.$0\"/pause 500/faceDirection Hiro 3/jump Hiro 5/pause 200/speak Hiro \"¡Claro, Puka!$1#$b#Te conseguiré ese narval que has estado queriendo.$0\"/pause 500/emote Puka 56/move Hiro 0 1 0/move Hiro -2 0 0/move Hiro 0 -1 0/faceDirection Puka 3/faceDirection Lala 2/pause 500/speak Lala \"Ese chico...$3#$b#¿Cómo siempre es tan bueno en estos juegos?$3\"/pause 500/speak Lulu \"Algunas personas simplemente son naturalmente mejores en las cosas que otras.$0#$b#En este caso, Hiro es naturalmente mejor en los juegos que tú.$1#$b#¿Verdad, @?$1\"/pause 500/jump Lala 5/speak Lala \"¡@, no estés de acuerdo con eso!$5#$b#Sé que puedo alcanzar a Hiro...¡solo necesito tiempo!$3\"/pause 500/faceDirection Lala 0/emote Lala 52/pause 500/emote Lulu 40/pause 500/speak Lulu \"No sabe cuándo rendirse, ¿eh?$3#$b#Supongo que así es mi hermano.$1\"/pause 1000/end",

       //Captain Four Heart Event
  "98890045/t 900 2000/f Captain 1000": "distantBanjo/52 14/farmer 7 20 0 Captain 52 14 0/skippable/pause 1500/move Captain 3 0 2/move Captain 0 2 1/pause 2000/move Captain -2 0 2/move Captain 0 2 2/pause 500/warp farmer 35 14/move farmer 18 0 0/move farmer 0 2 2/pause 500/emote farmer 40/pause 500/emote Captain 16/pause 500/faceDirection Captain 0/speak Captain \"¡Oh! Hola, @.$0\"/pause 500/speak Captain \"¿Qué te parece el lugar?$0#$b#Acabo de reorganizar y limpiar un poco, así que espero que se vea bien.$0\"/pause 500/faceDirection farmer 1/pause 500/faceDirection farmer 0/pause 500/faceDirection farmer 3/pause 500/faceDirection farmer 2/pause 500/emote farmer 56/pause 500/speak Captain \"¡Ay, me alegra que lo pienses así!$1\"/pause 500/speak Captain \"Verás, esta sala es en realidad algo así como una oficina para mí.$0#$b#Es donde hago todo el papeleo relacionado con la aldea y sus residentes.$0\"/pause 500/emote farmer 8/pause 500/speak Captain \"Oh ho, ¿te sorprende que en realidad hagamos papeleo por aquí?$0#$b#No es muy frecuente, pero hay veces en que pido a los residentes que completen ciertos formularios.$0#$b#Estos formularios suelen estar relacionados con sus casas y cualquier mejora que deseen hacer.$0#$b#Así que, si alguna vez quieres vivir aquí, ¡asegúrate de venir a verme para obtener tu formulario primero!$1\"/pause 500/speak Captain \"Pero en fin, me gusta mantener todo aquí bonito y ordenado por esa razón.$0#$b#Bueno, en realidad, me gusta mantener todo el centro comunitario en las mejores condiciones.$0#$b#Este lugar es mi orgullo y alegría... junto con mi barco, por supuesto.$1\"/pause 500/speak Captain \"De hecho, fui yo quien propuso la idea para este lugar.$0#$b#¡Vaya, incluso construí la mayor parte de él yo mismo!$1\"/pause 500/speak Captain \"Pensé que debería haber un lugar al que los residentes pudieran ir a reunirse y relacionarse, relajarse, divertirse... todo eso.$0#$b#Y seguro que fue una buena idea crear este lugar, porque parece que a todos les encanta.$1\"/pause 500/emote farmer 32/pause 500/speak Captain \"¿A ti también te gusta?$0#$b#Estoy encantado de oírlo.$1\"/pause 500/speak Captain \"Aunque, este lugar siempre podría beneficiarse de algunas ampliaciones...$3#$b#Siento que deberían haber más salas, pero no estoy seguro de cuáles.$3#$b#¿Tienes alguna idea?$0\"/question fork1 \"#¿Qué tal una cocina?#...¿Dónde está el baño?\"/fork roomidea/pause 500/jump Captain 5/pause 200/speak Captain \"¡Una cocina, por supuesto!$1#$b#¡Esa es una gran idea, @.$0\"/pause 500/emote farmer 32/pause 500/speak Captain \"Pero oye, como tú pensaste en la idea, seguro que no te importaría ayudar a construir la sala de la cocina, ¿verdad?$0#$b#¡De hecho, podríamos empezar de inmediato!$1\"/pause 500/emote farmer 28/pause 1000/end",
  "roomidea": "pause 500/emote Captain 8/pause 500/speak Captain \"¿Un baño?$3#$b#¿Para qué necesitaríamos un baño?$3\"/pause 500/speak Captain \"Ah, ya entiendo.$3#$b#¡Era una broma, verdad?$0#$b#¡Eres un bromista, @!$1\"/pause 500/emote farmer 28/pause 1000/end",

