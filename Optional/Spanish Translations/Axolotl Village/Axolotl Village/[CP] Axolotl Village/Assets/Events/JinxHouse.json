  "98890072/t 600 2000/f Jinx 2500/e 98890071": "none/7 8/farmer 5 10 0 Jinx 5 8 2 Olina -200 -200 0 Captain -200 -199 0 Lulu -200 -198 0/pause 1000/message \"...Pasó un tiempo, pero le explicaste todo lo que Olina había compartido contigo sobre sus recuerdos a Jinx.\"/pause 500/message \"Parece que lo piensa por un momento.\"/pause 500/speak Jinx \"Sí...recuerdo todo esto también.$2\"/pause 500/speak Jinx \"Estoy seguro de que ya te diste cuenta, pero soy la persona llamada Jax de la que ella habló.$2\"/pause 500/emote farmer 60/pause 500/speak Jinx \"Por la expresión en tu cara, era bastante obvio para ti.$2\"/pause 500/speak Jinx \"Curiosamente, parece que recuperé mis recuerdos alrededor del mismo tiempo que Olina.$2#$b#Supongo que es debido a que estábamos conectados en nuestro pasado.$2\"/pause 500/speak Jinx \"Y el accidente de coche...sí, eso es lo que pasó.$2#$b#Todo fue mi culpa...$2#$b#La culpa que siento por ello quema más en mi mente que cualquiera de mis recuerdos antiguos.$2\"/pause 500/emote farmer 28/pause 500/speak Jinx \"Probablemente se pregunten cómo ocurrió el accidente de coche en primer lugar.$2#$b#¿Cómo pude haber sido tan descuidado, verdad?$2\"/pause 500/speak Jinx \"Honestamente, había muchas cosas pasando en mi vida que llevaron a ese horrible accidente...$2\"/pause 500/fade/viewport -500 -500/warp farmer -200 -197/warp Jinx -200 -196/warp Lulu 17 15/faceDirection Lulu 3/warp Captain 15 15/faceDirection Captain 1/pause 1000/changeSprite Captain JinxDad/changeSprite Lulu JinxMom/changeSprite Jinx HumanPast/changePortrait Jinx HumanPast/changeName Jinx Jax/changeLocation otohime.AV_JinxHousePast/message \"El viernes, el día antes de la fiesta...\"/pause 500/fade/viewport 22 15/pause 1000/warp Jinx 27 13/faceDirection Jinx 2/playSound doorClose/pause 200/speak Jinx \"¡Ya llegué-$2\"/pause 500/emote Jinx 16/pause 200/faceDirection Jinx 3/pause 1000/emote Jinx 40/pause 500/emote Lulu 12/pause 200/message \"Mamá: ¡ERES la raíz de todos nuestros problemas, Tae!\"/message \"¡No yo!\"/pause 500/emote Captain 12/pause 500/message \"Papá: ¿Estás bromeando?\"/message \"Estás lleno de eso.\"/pause 500/jump Lulu 5/pause 400/message \"Mamá: No, ¿te estás burlando de MÍ?\"/message \"¡He estado matándome trabajando para traer todo el dinero mientras tú te sumerges en autocompasión por tu estúpido 'bloqueo del escritor'!\"/pause 500/message \"Papá: No puedo creer que acabas de decir eso.\"/message \"No, espera, en realidad puedo porque SIEMPRE has sido así.\"/pause 500/faceDirection Captain 3/pause 200/message \"Papá: Dios, sabía que nunca debí haber dejado Corea.\"/pause 600/jump Lulu 5/pause 400/message \"Mamá: ¡Desearía que te hubieras quedado en Corea también!\"/message \"¡Dios sabe que mi vida habría sido mucho mejor sin ti en ella!\"/pause 500/emote Jinx 40/pause 500/speak Jinx \"(... Ellos están en eso de nuevo.)$2#$b#(Debería ir a mi habitación y evitar ser arrastrado a esto.)$2\"/pause 500/move Jinx 0 5 3 true/fade/changeName Jinx Jinx/changePortrait Jinx/viewport -500 -500/warp Lulu -200 -195/warp Captain -200 -194/pause 1000/speak Jinx \"Mis padres discutían bastante a menudo.$2#$b#Ya estaba bastante acostumbrado a esto en este punto, pero aún podía perturbarme un poco a veces.$2\"/pause 500/speak Jinx \"Siempre deseé tener una familia normal en su lugar.$2\"/pause 500/speak Jinx \"...Pero suficiente de eso.$2\"/pause 500/speak Jinx \"Cuando llegué a mi habitación, recordé que la fiesta a la que Olina y yo habíamos acordado ir era al día siguiente.$2#$b#No estaba muy interesado en la idea de ir a esa fiesta, pero tuve una realización repentina...$2\"/pause 500/speak Jinx \"La fiesta podría ser un buen momento para decirle a Olina algo.$2#$b#Algo que había querido decirle durante mucho tiempo...$2\"/pause 500/speak Jinx \"Eh, los detalles de eso no son importantes!$3\"/pause 500/speak Jinx \"De todos modos, la fiesta finalmente llegó y alrededor de una hora después sentí una oleada de confianza empujándome a decírselo.$2\"/pause 500/warp Jinx 21 16/faceDirection Jinx 2/warp Olina 30 26/faceDirection Olina 1/warp Captain 31 26/faceDirection Captain 3/pause 1000/changeSprite Captain Chad/changeSprite Jinx HumanPast/changeSprite Olina HumanPast/changePortrait Jinx HumanPast/changePortrait Olina HumanPast/changeLocation otohime.AV_PartyHouse/changeName Jinx Jax/fade/viewport 21 28/pause 1000/speed Jinx 5/move Jinx 0 8 2/pause 200/textAboveHead Jinx \"¡Olina!\"/pause 1500/move Jinx 0 2 1/pause 100/speak Jinx \"Hey, 'Lina-\"/pause 500/emote Jinx 16/pause 1000/emote Olina 56/pause 500/textAboveHead Olina \"¡Jeje~ Eres tan divertido!\"/pause 2500/emote Captain 56/pause 500/speak Jinx \"....$2\"/pause 1000/message \"Había perdido toda mi confianza.\"/pause 500/faceDirection Jinx 2/pause 500/message \"En ese momento, todo lo que podía notar eran las bebidas en la mesa frente a mí.\"/pause 500/emote Jinx 40/pause 500/speak Jinx \"Sé que no debería...$2\"/pause 500/speak Jinx \"Pero...ugh.$2#$b#Cualquier cosa para aliviar el estrés.$2\"/pause 500/move Jinx 0 4 2 true/fade/viewport -500 -500/pause 1000/changeName Jinx Jinx/changePortrait Jinx/changeSprite Jinx/warp Jinx 5 8/faceDirection Jinx 2/warp farmer 5 10/faceDirection farmer 0/warp Olina -200 -193/warp Captain -200 -192/changeLocation otohime.AV_JinxHouse/viewport 7 8/pause 1000/speak Jinx \"Todavía me odio por esa decisión.$2#$b#Costó la vida de la persona que más me importaba.$2\"/pause 500/emote farmer 28/pause 500/speak Jinx \"Ahora, ¿qué voy a hacer...$2#$b#Tengo que decirle que soy Jax, ¿verdad?$2\"/pause 500/emote farmer 40/pause 500/speak Jinx \"...Tu cara lo dice todo.$2\"/pause 500/speak Jinx \"Está bien... Es lo correcto.$2\"/pause 500/speak Jinx \"Voy a decírselo ahora.$2#$b#Pero... ¿te importaría venir conmigo?$3#$b#Tu presencia me hará sentir un poco mejor.$2\"/pause 500/emote farmer 32/pause 500/speak Jinx \"Gracias, @.$2\"/pause 500/end",

