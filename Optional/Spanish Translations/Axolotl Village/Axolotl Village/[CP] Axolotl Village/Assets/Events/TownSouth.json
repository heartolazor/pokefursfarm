
             {
        //Start of Project
  "98890056/t 600 2000/n CaptainProject": "distantBanjo/31 21/farmer 31 21 2 Captain 32 21 2/pause 2000/speak Captain \"...Así que como puedes ver, esta parte de la isla está bastante vacía.$3\"/pause 500/faceDirection Captain 3/faceDirection farmer 1/speak Captain \"Pero he estado pensando en arreglarla desde hace tiempo.$0#$b#Agregar más casas, tiendas y lo que sea que pueda darle vida al lugar.$0#$b#¡Y con tu ayuda, creo que eso definitivamente podría suceder!$0\"/pause 500/speak Captain \"Siempre y cuando tú quieras, por supuesto.$0\"/pause 500/emote farmer 32/pause 500/jump Captain 5/pause 200/speak Captain \"¡Eso es genial!$1\"/pause 500/speak Captain \"Así que para comenzar, creo que deberíamos construir una casa.$0#$b#En uno de mis viajes recientes, conocí a una axolotl grande llamada Bonbon.$0#$b#Ella parecía entusiasmada con venir a vivir al pueblo, pero dijo que tenía algunos asuntos que atender primero.$0#$b#Así que pensé que ahora sería el momento perfecto para preparar una casa para ella antes de que venga a la isla!$0\"/pause 500/emote farmer 56/pause 500/speak Captain \"Ay, es bastante emocionante que tengamos un nuevo axolotl en el pueblo.$0#$b#¡Y piensa, una vez que terminemos de arreglar este lugar, probablemente tengamos aún más axolotls viviendo aquí!$1\"/pause 500/speak Captain \"Ya tengo un diseño y un plano para la casa de Bonbon.$0#$b#Todo lo que realmente necesito son los materiales... y ahí es donde entras tú.$0#$b#¿Podrías conseguir 350 piedras y 150 maderas duras?$3#$b#Eso debería ser suficiente para la casa.$0\"/pause 500/emote farmer 56/pause 500/speak Captain \"¡Perfecto!$1#$b#Una vez que me traigas los materiales, puedo pedirle a Nimue que me ayude a construir la casa.$0\"/pause 500/faceDirection Captain 2/speak Captain \"¡Ay, estoy tan emocionado solo de pensar en el futuro!$1\"/pause 500/emote Captain 56/pause 1000/addQuest 98880018/end",

        //Bonbon Moves In
  "98890058/t 600 2400/n CaptainProject2": "playful/31 36/farmer 50 41 2 Bonbon 30 41 0 Nimue 31 41 0 Captain 32 41 0/pause 2000/jump Bonbon 5/pause 200/speak Bonbon \"¡Vaya, hicieron un trabajo increíble!$1#$b#¡No podría haber pedido una casa más perfecta.$0\"/pause 500/speak Captain \"¡Me alegra que te guste!$1#$b#Aunque no podríamos haberlo hecho sin la ayuda de @.$0\"/pause 500/speak Bonbon \"¿Quién es ese?$3\"/pause 500/move farmer -17 0 3/emote Captain 16/pause 500/faceDirection Captain 1/faceDirection Nimue 1/faceDirection Bonbon 1/speak Nimue \"Hablando del rey de Roma.$0\"/pause 500/speak Captain \"¡Ah, @!$0#$b#¿Decidiste venir a ver la casa, eh?$0#$b#¿Qué te parece?$0\"/pause 500/faceDirection farmer 0/pause 500/emote farmer 40/pause 500/emote farmer 56/pause 500/faceDirection farmer 3/speak Captain \"¡Parece que a ti y a Bonbon les gusta entonces!$1\"/pause 500/speak Captain \"Hablando de Bonbon...$3\"/pause 500/faceDirection Captain 3/speak Captain \"Bonbon, este es @!$1#$b#Es un buen amigo del pueblo.$0#$b#¡Ellos trajeron los materiales que necesitábamos para construir tu casa!$0\"/pause 500/speak Bonbon \"¡Bueno, seré el tío de un mono!$3#$b#¡No he visto a un humano desde... bueno, nunca!$3\"/pause 500/faceDirection Nimue 3/speak Nimue \"Normalmente no permitiríamos humanos en el pueblo...$3#$b#Pero este ha demostrado ser bastante aceptable.$0\"/pause 500/speak Bonbon \"¡Lo diré!$3#$b#@, has ayudado a estos amables habitantes a construir mi casa, así que diría que estás bastante bien en mi libro.$1\"/pause 500/emote farmer 32/pause 500/speak Captain \"Bueno, deberíamos dejar que Bonbon se acomode en su nueva casa ahora.$0\"/pause 500/faceDirection Captain 1/speak Captain \"De nuevo, @, gracias por toda tu ayuda!$0#$b#Esto es solo el comienzo de las mejoras que vamos a hacer en este lugar.$0#$b#Te avisaré cuando necesite ayuda nuevamente, ¿de acuerdo?$0\"/pause 500/emote farmer 56/pause 500/end",

       //Bonbon Two Heart Event
  "98890060/t 800 1800/f Bonbon 500/w sunny": "jaunty/34 32/farmer -200 -200 0 Bonbon 34 32 0 Olina 35 32 0/skippable/addTemporaryActor \"Vaca Marrón\" 32 32 32 29 0 false Animal cow1/addTemporaryActor \"Vaca Marrón\" 32 32 35 30 1 false Animal cow2/addTemporaryActor \"Vaca Marrón\" 32 32 39 29 0 false Animal cow3/move cow2 1 0 0/move cow2 0 -1 0/pause 500/speak Olina \"¡Awww, son tan lindos!$1#$b#¿Cuáles son sus nombres?$3\"/move cow1 0 1 0/move cow1 2 0 3/pause 400/speak Bonbon \"Esa es Coffee, esta aquí es Coconut, y aquella es Pecan.$0\"/pause 500/speak Olina \"¡Awww, incluso sus nombres son adorables!$1\"/pause 500/faceDirection Bonbon 1/speak Bonbon \"Tu Love Bunny también es realmente adorable.$0#$b#¡Te juro, cuando ese pequeño saltó hacia mí, mi corazón casi se derrite!$1\"/move cow3 0 2 0/move cow3 0 1 3/pause 400/faceDirection Olina 3/speak Olina \"Hehe, realmente le gustaste.$0#$b#¡Puede decir cuándo alguien es genial con los animales!$0\"/pause 500/speak Bonbon \"Aw, shucks.$1#$b#Qué cumplido.$0\"/pause 500/speak Bonbon \"Mi papá estaría feliz de escuchar eso.$0#$b#Me crió con la regla de oro de siempre tratar a los animales con amabilidad y respeto.$0\"/speak Bonbon \"Crecí en la granja, ya ves, así que siempre estuve rodeada de animales.$0\"/pause 500/speak Olina \"¡Tu papá parece un gran hombre!$1#$b#Y crecer en una granja rodeada de animales... parece un sueño hecho realidad para mí, hehe.$0\"/move cow2 0 2 2/pause 400/speak Bonbon \"Realmente lo fue.$0#$b#No recuerdo demasiado de mi tiempo como niña, pero los recuerdos de jugar con las gallinas y acariciar las vacas siempre estarán conmigo.$1\"/pause 500/faceDirection Bonbon 0/speak Bonbon \"Ah, lo que daría por volver a esos momentos...$0\"/faceDirection Bonbon 1/speak Bonbon \"Pero también es bonito recordar.$0\"/pause 500/emote Olina 56/pause 1000/end",

       //Second Part of Project
  "98890061/t 600 2000/n CaptainProject3": "distantBanjo/87 23/farmer 87 22 1 Captain 88 22 3/pause 2000/speak Captain \"Recibí una carta recientemente.$3#$b#Era de una gran axolote que quiere mudarse al pueblo!$3#$b#No estoy muy seguro de cómo supo contactarme, pero lo hizo.$3\"/pause 500/speak Captain \"Su nombre es Kandi y aparentemente es una 'sensation pop'.$3#$b#Sus palabras, no las mías.$3#$b#De todos modos, quiere mudarse aquí y actuar semanalmente para los aldeanos.$0#$b#¿Qué tan genial es eso?$1\"/pause 500/emote farmer 56/pause 500/speak Captain \"Pero para hacer sus actuaciones, dijo que necesitará un escenario.$3#$b#Así que además de construir una casa para ella, también necesitamos construir un escenario para conciertos.$3#$b#Es mucho trabajo, ¡pero sé que podemos hacerlo!$0\"/pause 500/faceDirection Captain 2/faceDirection farmer 2/speak Captain \"Pensé que este área sería un buen lugar para poner el escenario.$0#$b#¿Qué opinas?$0\"/pause 500/emote farmer 32/pause 500/faceDirection Captain 3/faceDirection farmer 1/speak Captain \"¡Genial, entonces definitivamente lo pondremos aquí!$0\"/pause 500/speak Captain \"Ya he determinado la cantidad de materiales que necesitaremos para todo esto.$0#$b#Unos 10 lingotes de hierro, 150 piedras y 350 maderas deberían ser suficientes.$0\"/pause 500/faceDirection Captain 3/faceDirection farmer 1/speak Captain \"¿Podrías encargarte de eso?$3\"/pause 500/emote farmer 56/pause 500/speak Captain \"¡Fantástico!$1#$b#Al igual que la última vez, trae los materiales a mi casa una vez que los hayas reunido todos.$0\"/pause 1000/addQuest 98880019/end",

       //Third Part of Project
  "98890066/t 600 2000/n CaptainProject5": "distantBanjo/87 49/farmer 86 49 1 Captain 87 49 3/pause 2000/speak Captain \"...Como mencioné en la carta, creo que necesitamos empezar a añadir algunas tiendas en esta área.$0\"/pause 500/faceDirection Captain 2/faceDirection farmer 2/speak Captain \"Creo que debería haber cuatro pequeñas tiendas en este lugar en particular.$0#$b#Ya tengo ideas sobre qué tipo de tiendas serían.$0\"/pause 500/speak Captain \"Una sería una tienda de accesorios, porque he oído a Olina y Puka mencionar varias veces cómo les gustaría una tienda así.$0\"/pause 500/speak Captain \"Otra sería una tienda de peluches porque a los aldeanos realmente les gustan los peluches.$0#$b#Sé que ya tenemos un bote que vende peluches, pero siento que una tienda completa también sería una adición bienvenida.$0\"/pause 500/faceDirection Captain 3/faceDirection farmer 1/speak Captain \"Y para las demás... bueno, las dejaré como sorpresa por ahora.$0\"/pause 500/speak Captain \"Creo que en total necesitaremos 550 piedras y 150 maderas para construir estas tiendas.$0\"/pause 500/speak Captain \"Estoy seguro de que ya sé cuál es la respuesta, pero... ¿crees que puedes encargarte de eso?$3\"/pause 500/emote farmer 56/pause 500/speak Captain \"¡Como esperaba!$1\"/pause 500/speak Captain \"Como siempre, trae los materiales a mi casa una vez que los hayas reunido todos.$0\"/pause 1000/addQuest 98880020/end",

             }
               