al como siempre.$0#$b#He estado haciendo pequeñas golosinas parecidas a pastel de zanahoria para él y le encantan.$1\"/pause 500/speak Lotus \"Oooh, suena bien.$3#$b#¡Deberías hacer algunas para mí también!$1\"/pause 500/speak Olina \"Claro.$0#$b#De hecho, haré algunas para ti y para @!$1\"/pause 500/emote Lotus 56/pause 500/emote farmer 56/pause 1000/end"

