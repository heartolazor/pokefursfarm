
             {
        //Meeting the Axolotls
  "98890001/t 600 2400/e 98890000/a 14 104": "none/32 93/farmer 32 93 0 Captain 31 77 2 Nimue 32 77 2 Hiro 37 78 2 Puka 38 79 2 Jinx 28 77 2 Olina 27 78 2 Noa 35 77 2 Lala 34 77 2 Lulu 36 77 2/pause 500/viewport move 0 -3 5000/move farmer 0 -13 0/pause 300/emote Lala 16/jump Olina 5/pause 500/textAboveHead Olina \"¡OMG!\"/pause 500/textAboveHead Hiro \"¡Ese es el humano!\"/pause 1500/jump Captain 4/pause 500/speak Captain \"¡Todos, cálmense!$3\"/pause 500/speak Nimue \"¡Ah, humano! Es un gusto verte en persona.$0#$b#Rasmodius habló tan... bien de ti, después de todo.$0\"/pause 500/emote farmer 32/pause 500/speak Nimue \"Y según él, ¿te hiciste amigo de Kin, verdad?$0\"/pause 500/emote farmer 56/pause 500/speak Olina \"Aún no puedo creer que él era un humano todo el tiempo.$3\"/pause 500/speak Lala \"¡Un príncipe humano, además!$3\"/pause 500/speak Nimue \"Sí, sí, eso también me sorprendió.$3#$b#Claro, él parecía bastante... diferente, pero nunca pude imaginar que no era realmente un axolote.$3\"/pause 500/speak Captain \"Bueno, me alegra que haya podido recuperar sus recuerdos y regresar a su reino.$0#$b#Después de todo, era un buen muchacho.$0\"/pause 500/speak Nimue \"Es cierto.$0#$b#Pero nos estamos desviando un poco... volvamos al humano.$3\"/pause 500/speak Nimue \"Tengo que preguntarme por qué querías venir aquí.$0#$b#¿Solo tenías curiosidad? ¿Querías conocer a grandes axolotes que hablan? ¿O... algo más?$0\"/pause 500/speak Puka \"Si se han hecho buenos amigos de Kin, entonces tal vez también quieran hacerse amigos de nosotros?$0\"/pause 500/speak Hiro \"¡Sí! O tal vez les gusta explorar diferentes lugares, así que este es solo uno de esos lugares?$0\"/pause 500/emote farmer 32/pause 500/speak Nimue \"¿Ambas razones, dices?$3#$b#Bueno... eso está bien entonces.$0#$b#Solo quiero que te asegures de que no tengas motivos ocultos.$0\"/pause 500/emote farmer 36/pause 500/speak Lala \"Entonces, ¿significa que ahora tenemos un amigo humano?$3#$b#¡Eso es genial!$1\"/pause 500/speak Noa \"Sí... nunca he tenido un amigo humano antes...zzz....\"/pause 500/speak Jinx \"¡Ninguno de nosotros lo ha tenido!$0#$b#Pero ahora que eres mi 'amigo', humano, estoy seguro de que no te importará ayudarme a probar mis pociones y hechizos...$0\"/pause 500/speak Hiro \"Si te gusta explorar, ¡quizás puedas acompañarme en mis aventuras!$1\"/pause 500/speak Olina \"¡Oooh, tal vez podríamos intercambiar recetas de postres?!$1\"/pause 500/jump Captain 4/pause 500/speak Captain \"¡Todos, por favor!$5#$b#No abrumemos al humano.$5\"/pause 500/speak Olina \"Oh, lo siento...$2\"/pause 500/speak Hiro \"Sí, mi culpa.$3\"/pause 500/speak Jinx \"No me siento ni un poco arrepentido.$0\"/pause 500/emote farmer 28/pause 500/speak Nimue \"Buen trabajo haciendo una buena primera impresión, todos.$3\"/pause 500/speak Nimue \"De todos modos, esta es toda la bienvenida que vas a recibir.$0#$b#Siéntete libre de pasear o interactuar con los demás.$0#$b#O no, no me importa.$3\"/pause 500/emote Captain 12/pause 500/speak Captain \"No escuches a Nimue, puede ser un poco grosera a veces.$5\"/pause 500/speak Captain \"De todos modos, espero que disfrutes tu tiempo aquí, humano... En realidad, espera, ¿cuál es tu nombre?$3\"/pause 500/message \"Les dices a todos cuál es tu nombre.\"/pause 500/speak Lala \"¡Hola, @!$0\"/pause 500/speak Captain \"Entonces @, espero que disfrutes tu tiempo aquí, sea cual sea la duración.$0\"/pause 500/emote farmer 32/pause 500/speak Captain \"En cuanto a los demás, pueden volver a lo que estaban haciendo.$0\"/pause 1000/end position 32 80",
    
         //Hiro Two Heart Event
  "98890003/t 800 1000/f Hiro 500/w sunny": "jaunty/15 67/farmer 15 67 0 Hiro 10 56 1/skippable/pause 500/viewport move 0 -2 5000/move farmer 0 -7 0/move Hiro 5 0 2/emote Hiro 16/pause 500/speak Hiro \"¡Hola! ¡Es @!$1\"/pause 500/emote farmer 32/pause 500/move Hiro 0 2 2/pause 500/speak Hiro \"¿Qué has estado haciendo?$0#$b#Acabo de regresar de una inmersión.$0\"/pause 500/emote farmer 8/pause 500/speak Hiro \"¿Te sorprende que pueda nadar?$3#$b#¡Nosotros, los grandes axolotes, podemos nadar igual que los más pequeños, sabes!$0\"/pause 500/speak Hiro \"Aunque la mayoría de los demás aquí no se preocupan mucho por eso.$3#$b#De hecho, Puka y yo parecemos ser los únicos que realmente vamos a nadar.$3#$b#...Bueno, en realidad, Puka solo 'flota'.$3#$b#En aguas poco profundas.$3\"/pause 500/speak Hiro \"¡Así que creo que soy el único que va a bucear en el agua!$3\"/pause 500/emote farmer 56/pause 500/speak Hiro \"Es bastante genial, ¿verdad?$1\"/pause 500/speak Hiro \"Cuando buceo, me gusta explorar diferentes áreas en el mar.$0#$b#¡Hay tantas cosas inusuales y únicas para ver, es casi de otro mundo allá abajo!$1\"/pause 500/speak Hiro \"Además, a menudo encuentro algunos tesoros increíbles.$0#$b#¡Usualmente los traigo de vuelta y se los doy a mis amigos!$1\"/pause 500/speak Hiro \"A Puka le encantan todas las perlas y cristales que he encontrado para él.$0#$b#Y a Olina le gusta prácticamente cualquier cosa rosa que pueda encontrar allá abajo... y créeme, ¡hay muchas cosas rosas en el mar!$1\"/pause 500/speak Hiro \"Aunque Lulu puede ser bastante difícil de complacer.$3#$b#Pero creo que es solo su disposición natural a no impresionarse por la mayoría de las cosas.$3\"/pause 500/jump Hiro 4/pause 500/speak Hiro \"¡Oye, la próxima vez que vaya a bucear, puedo conseguir algo para ti también!$1#$b#¿Te gustaría eso?$0\"/pause 500/emote farmer 32/pause 500/speak Hiro \"¡Genial!$1#$b#Entonces conseguiré algo que puedas atesorar para siempre.~$0\"/pause 1000/end"

         //Hiro Four Heart Event
  "98890004/t 1000 1500/f Hiro 1000/w rainy": "rain/31 21/farmer 20 25 0 Hiro 31 21 1 Puka 32 21 3/skippable/pause 500/move farmer 0 -2 1/move farmer 3 0 0/move farmer 0 -2 1/emote Hiro 12/pause 500/speak Hiro \"¿Cuántas veces te he dicho esto, Puka?$5#$b#¡No deberías andar en la lluvia todo el día!$5\"/pause 500/speak Puka \"Pero me gusta.$3#$b#La lluvia se siente bien... y es tan tranquila...$3\"/pause 500/speak Hiro \"¡Pero, ¿no tienes frío?!$3\"/pause 500/speak Puka \"No...$3\"/pause 500/speak Hiro \"¡Puka! ¡Puedo verte temblando!$5\"/pause 500/speak Puka \"Eso es solo cómo reacciona mi cuerpo...$3#$b#Pero mi alma realmente ama la lluvia~.$0\"/pause 500/speak Hiro \"?????$3#$b#A veces no te entiendo...$3\"/pause 500/speak Puka \"Espera un momento.$3\"/pause 500/move Puka 0 1 3/pause 500/speak Puka \"¿Pensaste que no podía verte, humano?$3\"/pause 500/faceDirection Hiro 3/emote farmer 16/pause 500/emote farmer 60/pause 500/move farmer 6 0 1/pause 500/speak Hiro \"¡Qué bueno que estás aquí, @!$0#$b#Tal vez podrías convencer a Puka de que entre.$3\"/pause 500/speak Puka \"Pero me estoy divirtiendo mucho aquí afuera...$2#$b#Además, estaba a punto de visitar a los Littles.$3\"/pause 500/faceDirection Hiro 2/speak Hiro \"Sé que te gusta visitarlos, pero ¿no puedes esperar a hacerlo cuando no esté lloviendo?$3\"/pause 500/faceDirection Puka 0/speak Puka \"Ellos prefieren salir del lago cuando está lloviendo.$3\"/pause 500/speak Puka \"Pero... si te molesta tanto, entonces simplemente iré adentro.$3\"/pause 500/speak Hiro \"Gracias, Puka.$0\"/pause 500/speak Hiro \"Y no lo hago para arruinar tu diversión ni nada, solo estoy preocupado.$3#$b#No quiero que te enfermes o incluso que te congeles hasta morir, ¿sabes?$3\"/pause 500/speak Puka \"Sí, lo sé.$3#$b#Siempre estás tratando de protegerme.$3#$b#Aprecio eso.$0\"/pause 500/speak Hiro \"Claro~.$0#$b#Eres mi mejor amigo, después de todo.$1\"/pause 500/speak Puka \"Igualmente contigo.$1\"/pause 500/emote Hiro 32/emote Puka 32/pause 500/faceDirection Hiro 3/speak Hiro \"Entonces, ¿qué tal si los tres vamos a hacer algo divertido en el interior?$0#$b#¡Podríamos hacer palomitas de maíz y ver una película!$1\"/pause 500/faceDirection Puka 3/speak Puka \"Creo que es una buena idea.$1#$b#¿Y tú, humano?$0\"/pause 500/emote farmer 56/pause 1500/fade/viewport -500 -500/warp farmer 27 54/warp Olina 26 55/faceDirection farmer 2/faceDirection Olina 1/fade/viewport 31 55/pause 1500/emote Olina 20/pause 500/speak Olina \"¡Mmmm, el helado de Pinky es el mejor!$4#$b#...No le digas a Bluey que dije eso.$3#$b#Simplemente me encanta el sabor a melón del helado de Pinky~.$1\"/pause 500/speak Olina \"Sabes, @, estoy feliz de que hayas decidido venir al pueblo.$0#$b#Has sido un gran amigo para mí.$1\"/pause 500/emote farmer 32/pause 500/speak Olina \"Solo piensa, tal vez dentro de un año seremos... ¿¡BFFs?!$3\"/pause 500/speak Olina \"Espero que sí.$1\"/pause 500/emote Olina 56/pause 500/emote farmer 56/pause 1000/end",

         //Olina Four Heart Event
  "98890009/t 1000 1500/f Olina 1000/w sunny": "playful/60 34/farmer 66 34 3 Olina 58 33 0/skippable/pause 500/move farmer -7 0 0/pause 500/emote Olina 16/pause 500/faceDirection Olina 2/speak Olina \"¡Hola, @!$1#$b#¿Viniste aquí para comprar algunos peluches también?$0\"/pause 500/speak Olina \"Esta es una de mis tiendas favoritas.$0#$b#¡Tienen los peluches más adorables!$1#$b#Pero tienes que agarrarlos rápido antes de que alguien más lo haga.$3#$b#¡Son muy populares!$3#$b#Pero tengo bastantes peluches que pude conseguir en esta tienda en días de suerte.$0\"/pause 500/speak Olina \"En general, me gusta mucho coleccionar peluches.$0#$b#¡Me traen alegría como nada más lo hace!$1#$b#Bueno, además de los postres, por supuesto.$3\"/pause 500/speak Olina \"Pero desearía poder hacer mis propios peluches.$3#$b#Intenté hacer uno hace un tiempo, pero salió bastante, eh... mal.$3#$b#Y realmente lo intenté con todas mis fuerzas...$2\"/pause 500/emote farmer 8/pause 500/speak Olina \"No, créeme. No quieres verlo.$3#$b#Todavía lo tengo en algún lugar... pero no lo voy a sacar.$3#$b#Es demasiado horrible.$2\"/pause 500/emote farmer 56/pause 500/speak Olina \"¿Aún crees que se vería bien porque lo hice yo?$3#$b#¡Es tan amable de tu parte decir eso!$1\"/pause 500/speak Olina \"Pero no, en serio, no voy a mostrártelo.$3#$b#Te estoy haciendo un favor.$3\"/pause 500/speak Olina \"De todos modos, ¿quieres ir a comer un helado?$0\"/pause 500/emote farmer 56/pause 1500/fade/viewport -500 -500/warp farmer 27 54/warp Olina 26 55/faceDirection farmer 2/faceDirection Olina 1/fade/viewport 31 55/pause 1500/emote Olina 20/pause 500/speak Olina \"¡Mmmm, el helado de Pinky es el mejor!$4#$b#...No le digas a Bluey que dije eso.$3#$b#Simplemente me encanta el sabor a melón del helado de Pinky~.$1\"/pause 500/speak Olina \"Sabes, @, estoy feliz de que hayas decidido venir al pueblo.$0#$b#Has sido un gran amigo para mí.$1\"/pause 500/emote farmer 32/pause 500/speak Olina \"Solo piensa, tal vez dentro de un año seremos... ¿¡BFFs?!$3\"/pause 500/speak Olina \"Espero que sí.$1\"/pause 500/emote Olina 56/pause 500/emote farmer 56/pause 1000/end",

         //Olina Eight Heart Event
  "98890011/t 1000 1500/f Olina 2000/w sunny": "breezy/88 81/farmer 87 88 0 Olina 88 82 0/skippable/pause 500/move farmer 0 -6 0/pause 500/emote Olina 16/pause 500/faceDirection Olina 3/speak Olina \"Hola, @.$0#$b#Estaba pensando en mi prima.$0\"/pause 500/faceDirection farmer 1/emote farmer 8/pause 500/speak Olina \"Oh, es cierto.$3#$b#Aún no la has conocido, ¿verdad?$3\"/pause 500/faceDirection Olina 0/speak Olina \"Mi prima, Lotus, es la que vive aquí.$0#$b#Ha estado viajando por otras islas por un tiempo.$0\"/pause 500/speak Olina \"Realmente la extraño.$2\"/pause 500/faceDirection Olina 3/speak Olina \"Pero ella volverá pronto, así que está bien.$0\"/pause 500/speak Olina \"Creo que se llevarán muy bien.$0#$b#Ella es súper divertida y amable, ¡igual que tú~!$1\"/pause 500/emote farmer 32/pause 500/faceDirection Olina 0/emote Olina 40/pause 500/speak Olina \"Um, antes de que llegaras, en realidad estaba pensando en algo...$3\"/pause 500/speak Olina \"Me preguntaba cómo he logrado atraer a las personas hacia mí como lo he hecho.$3\"/pause 500/emote farmer 8/pause 500/faceDirection Olina 3/speak Olina \"Lo que quiero decir es, como... tanto Jinx como Lotus se esforzaron por ser mis amigos.$3#$b#Parecían muy interesados en mí desde el principio, pero siempre me pregunto... ¿por qué?$3\"/pause 500/speak Olina \"Soy tan... normal, realmente.$2#$b#¿Qué es lo que encuentran atractivo en mí?$2\"/pause 500/emote farmer 28/pause 500/speak Olina \"Todos los demás son tan únicos, divertidos y geniales y-$2#$b#Bueno, podría seguir hablando sobre lo increíble que son los demás.$3\"/pause 500/speak Olina \"Pero yo... solo soy normal.$2#$b#Solo soy 'amable' y eso es todo.$2#$b#¿Sabes a lo que me refiero?$2\"/question fork1 \"#Eres más que solo tu amabilidad.#No hay nada de malo en ser normal.\"/fork normal/pause 500/speak Olina \"¿Pero qué más hay, realmente?$3#$b#Solo desearía poder ser un poco más interesante, eso es todo.$2\"/pause 500/speak Olina \"Pero no quiero bajar el ánimo ni nada.$3#$b#Solo sentí la necesidad de expresar mis pensamientos contigo.$3#$b#Eres tan fácil de hablar, @.$0\"/pause 500/speak Olina \"Y, sabes, has sido un gran amigo para mí todo este tiempo.$0#$b#Aprecio eso mucho.$0\"/pause 500/speak Olina \"Gracias, @.$0\"/pause 500/speak Olina \"Cuando Lotus vuelva, vamos a encontrarnos con ella juntos, ¿de acuerdo?$0#$b#Puedo imaginar toda la diversión que tendremos los tres~.$1\"/pause 500/emote Olina 32/pause 500/emote farmer 32/pause 1000/end",
  "normal": "pause 500/speak Olina \"Lo sé, y tienes razón.$3#$b#Solo desearía poder ser un poco más interesante, eso es todo.$2\"/pause 500/speak Olina \"Pero no quiero bajar el ánimo ni nada.$3#$b#Solo sentí la necesidad de expresar mis pensamientos contigo.$3#$b#Eres tan fácil de hablar, @.$0\"/pause 500/speak Olina \"Y, sabes, has sido un gran amigo para mí todo este tiempo.$0#$b#Aprecio eso mucho.$0\"/pause 500/speak Olina \"Gracias, @.$0\"/pause 500/speak Olina \"Cuando Lotus vuelva, vamos a encontrarnos con ella juntos, ¿de acuerdo?$0#$b#Puedo imaginar toda la diversión que tendremos los tres~.$1\"/pause 500/emote Olina 32/pause 500/emote farmer 32/pause 1000/end"

         //Lala Two Heart Event
  "98890013/t 1000 1300/f Lala 500/d Wed/w sunny": "distantBanjo/17 32/farmer 17 41 0 Lala 17 32 3 Noa 1 0 0/skippable/pause 500/move farmer 0 -7 0/pause 500/emote Lala 16/pause 500/faceDirection Lala 2/speak Lala \"¡Hola, @!$0#$b#Solo estoy esperando a que Noa despierte.$0\"/pause 500/speak Lala \"Aunque he estado esperando lo que parece horas...$3#$b#De hecho, creo que HE estado esperando durante horas.$3\"/pause 500/emote farmer 28/pause 500/speak Lala \"Esto es algo normal en Noa.$3#$b#...Dormir en exceso durante horas, quiero decir.$3\"/pause 500/speak Lala \"Probablemente deberíamos ir a despertarlo.$3#$b#No le va a gustar, pero es necesario.$3\"/pause 500/speak Lala \"Vamos, entremos.$3\"/pause 500/move Lala 0 -1 0/move Lala -1 0 0/warp Lala 0 0/move farmer 0 -3 0/move farmer -1 0 0/warp farmer 0 1/fade/viewport -500 -500/changeLocation otohime.AV_NoaHouse/warp Noa 8 6/warp Lala 9 6/warp farmer 11 7/faceDirection Noa 0/faceDirection Lala 3/faceDirection farmer 3/fade/viewport 7 8/pause 1000/jump Lala 5/pause 500/speak Lala \"¡Vamos Noa, despiértate!$3\"/pause 500/textAboveHead Noa \"Zzzzz....\"/pause 1000/emote Lala 12/pause 500/speak Lala \"¡NOAAAA!!!!!!!!!!!!!$3\"/pause 500/emote Noa 40/pause 500/faceDirection Noa 1/speak Noa \"Nnnn...¿qué...qué?$3#$b#¿Qué está pasando...$3\"/pause 500/speak Lala \"¡Oh, bien, ya estás despierto!$0#$b#Tardaste un buen rato.$3\"/pause 500/speak Noa \"Ugh...¿por qué me despertaste...$5\"/pause 500/speak Lala \"¡Porque he estado esperando todo el día para pasar el rato contigo!$3#$b#¿Sabes, pasar el rato? ¿Lo que hacen los amigos?$3#$b#Sí, no podemos realmente hacer eso si estás dormido todo el día.$3\"/pause 500/speak Noa \"Está bien, está bien...No hace falta que te pongas así...Lo entiendo.$3\"/pause 500/speak Noa \"@, ¿también estabas esperando a que me levantara?$3\"/pause 500/emote farmer 56/pause 500/speak Noa \"Está bien...supongo que puedo levantarme, entonces.$3#$b#Solo por ti, @.$0\"/pause 500/jump Lala 5/pause 500/speak Lala \"¡Hey! ¿¡Qué quieres decir solo por @?!$3#$b#¿¡Qué pasa conmigo?!$5\"/pause 500/speak Noa \"Jeje...Siempre quieres mi atención con tantas ganas, Lala.$0#$b#Por supuesto que me levantaré también por ti...$0\"/pause 500/emote Lala 12/pause 500/speak Lala \"¿¡Por qué siempre tienes que burlarte de mí así, Noa?!$5\"/pause 500/faceDirection Lala 0/textAboveHead Lala \"Este tipo...\"/pause 1000/faceDirection farmer 2/animate farmer false true 200 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103/pause 2000/end",

         //Lala Eight Heart Event
  "98890016/t 1000 1500/f Lala 2000/d Wed/w sunny": "desolate/31 40/farmer 47 41 0 Lala 32 40 3 Lulu 31 40 1/skippable/pause 1500/jump Lala 5/pause 200/speak Lala \"¿Por qué no puedes intentar ver las cosas desde mi perspectiva?$5\"/pause 500/speak Lulu \"Porque somos demasiado diferentes.$5#$b#Siempre quieres que yo sea tan alegre como tú, pero no puedo.$5#$b#¿Por qué no puedes simplemente aceptarlo?$5\"/pause 500/speak Lala \"Tal vez no tienes que estar 'alegre' todo el tiempo, ¡pero ciertamente no necesitas estar siempre en modo pesimista tampoco!$5#$b#Si apenas podemos ponernos de acuerdo, ¿cómo vamos a continuar con nuestro negocio?$5\"/pause 500/speak Lulu \"¡Quizás no deberíamos!$5#$b#¡Quizás haga presentaciones en solitario!$5\"/pause 500/jump Lala 5/pause 200/speak Lala \"¡Bueno, está bien! ¡Dos pueden jugar a ese juego!$5#$b#¡Yo también iré en solitario!$5#$b#¡No es como si te necesitara de todos modos!$5\"/pause 500/emote Lulu 12/pause 500/speak Lulu \"¡Está bien, mira si me importa!$5\"/pause 500/move Lulu -2 0 0/move Lulu 0 -1 0/warp Lulu 0 0 0/pause 500/emote Lala 12/pause 500/speak Lala \"Sí, lo que sea.$5\"/pause 500/faceDirection Lala 2/move farmer -10 0 0/move farmer 0 -1 3/move farmer -3 0 3/pause 500/faceDirection Lala 1/pause 200/speak Lala \"Oh. Hola, @.$5\"/pause 500/speak Lala \"Lo siento. Estoy realmente alterada en este momento.$5#$b#Acabo de tener una gran discusión con mi hermana.$5\"/pause 500/emote farmer 28/pause 500/speak Lala \"...Sí, apesta.$2\"/pause 500/faceDirection Lala 2/pause 200/speak Lala \"No me gusta cuando chocamos, pero simplemente pasa a veces.$2#$b#Somos personas muy diferentes, después de todo.$2\"/pause 500/speak Lala \"Las personas...han esperado que seamos similares porque somos gemelas, pero así no funcionan las cosas.$2#$b#Somos individuos por derecho propio.$2#$b#Individuos incluso opuestos.$2\"/pause 500/speak Lala \"No...no es necesariamente cierto.$3#$b#En realidad tenemos muchas similitudes entre nosotros, créaselo o no.$3\"/pause 500/speak Lala \"Ugh...$2#$b#Ahora solo me siento mal.$2\"/pause 500/speak Lala \"Siempre dijimos que sin importar qué, siempre estaríamos juntas.$2#$b#Juntas, somos felices. Juntas, estamos seguras.$2#$b#Recuerdo esas palabras de la infancia...$2#$b#Pero por alguna razón eso es todo lo que recuerdo de esa época.$2\"/pause 500/emote farmer 8/pause 500/pause 200/speak Lala \"Um, de todos modos...$2#$b#Mantenernos juntas siempre ha sido nuestra prioridad número uno.$2#$b#No debí decir que no la necesito...$2#$b#Eso simplemente no es verdad.$2\"/pause 500/emote Lala 28/pause 500/faceDirection Lala 1/speak Lala \"Probablemente debería ir a disculparme con ella.$2#$b#Dije demasiadas cosas que lamento.$2\"/pause 500/speak Lala \"Lo siento si querías pasar el rato...$2#$b#Pero podemos hacerlo más tarde, ¿de acuerdo?$2\"/pause 500/speak Lala \"Nos vemos luego.$2\"/pause 500/move Lala -3 0 0/move Lala 0 -1 0/warp Lala 0 1 0/pause 500/faceDirection farmer 2/emote farmer 28/pause 1500/end",

         //Jinx Four Heart Event
  "98890019/t 1500 2000/f Jinx 1000/w sunny": "jaunty/45 20/farmer 51 29 0 Jinx 44 19 1 Puka 46 19 3/skippable/pause 1000/speak Puka \"Creo que voy a hacer una publicación pidiendo algo de pescado.$0#$b#Yummy, pescado sabroso...$1\"/pause 500/speak Jinx \"¿No podrías simplemente comprar algo de pescado en el puesto de pescado?$3\"/pause 500/speak Puka \"Claro, pero prefiero el sabor del pescado recién capturado~.$1\"/pause 500/speak Jinx \"Ya veo.$3#$b#Supongo que solo pediré algunos ingredientes para una poción en la que estoy trabajando.$0\"/pause 500/speak Puka \"Sabes, siempre dices que estás trabajando en todas estas pociones diferentes, pero ¿exactamente QUÉ son?$3#$b#Siempre he tenido curiosidad.$3\"/pause 500/speak Jinx \"Bueno, hasta ahora solo he podido hacer pociones de curación.$3#$b#He, eh, fallado en todo lo demás.$3#$b#¡Pero no le digas a los demás sobre eso!$5#$b#Especialmente a Olina.$3\"/pause 500/speak Puka \"Jeje, realmente te importa mucho lo que piensa Olina de ti, ¿eh?$0\"/pause 500/move farmer 0 -8 3/move farmer -6 0 0/move farmer 0 -1 0/pause 200/faceDirection Puka 2/faceDirection Jinx 2/pause 200/speak Jinx \"Hola, mi discípulo.$0#$b#Puka y yo estábamos solo poniendo algunas solicitudes en el tablón.$0\"/pause 500/speak Puka \"Y hablando de cuánto te gusta Olina~.$1\"/pause 500/jump Jinx 5/speak Jinx \"¡No estábamos haciendo eso!$5#$b#Siempre eres un bromista, Puka.$5\"/pause 500/emote farmer 40/pause 500/speak Jinx \"¿Te sorprende vernos juntos?$3#$b#Puka y yo en realidad somos grandes amigos.$0\"/pause 500/speak Puka \"Es verdad.$0#$b#Jinx a veces se siente como un hermano para mí.$0#$b#O tal vez como un abuelo, en realidad.$1\"/pause 500/jump Jinx 5/speak Jinx \"¡Odio que digas eso!$5#$b#¡No actúo en nada como un abuelo!$5\"/pause 500/speak Puka \"Jeje, solo te estoy molestando~.$0\"/pause 500/emote Jinx 12/pause 500/speak Jinx \"Como siempre...$5\"/pause 500/speak Jinx \"De todos modos, discípulo, ¿estás aquí para cumplir una solicitud?$3#$b#Si es así, deberías elegir la mía.$0\"/pause 500/speak Puka \"No, elige la mía.$0#$b#Tendrá un resultado más satisfactorio.$0\"/pause 500/speak Jinx \"¿Cómo es eso?$3\"/pause 500/speak Puka \"Si el humano hace la mía, entonces podré disfrutar de pescado delicioso con alegría.$0#$b#Pero si hacen la tuya, los ingredientes que recojan probablemente se desperdiciarán en una poción fallida.$0\"/pause 500/jump Jinx 5/textAboveHead Jinx \"¡Puka!!!!\"/pause 1000/faceDirection farmer 2/animate farmer false true 200 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103/pause 1000/end",

         //Puka Four Heart Event
  "98890024/t 1000 1500/f Puka 1000/w sunny": "playful/32 28/farmer 31 18 2 Puka 32 26 2 Hiro 31 26 2/skippable/pause 1000/jump Hiro 5/speak Hiro \"¡Oh, mira allá!$3#$b#¡Esa nube parece una tortuga, ¿no?$0\"/pause 500/emote Puka 56/pause 500/speak Puka \"Tienes razón, parece una tortuga~.$1\"/pause 500/move farmer 0 6 2/pause 500/emote farmer 40/pause 500/emote Hiro 16/pause 500/faceDirection Hiro 0/faceDirection Puka 0/speak Hiro \"¡Oh, hola @!$0\"/pause 500/speak Puka \"Hola humano.$0#$b#¿Te gustaría observar las nubes con nosotros?$0\"/pause 500/speak Hiro \"¡Sí, únete a nosotros! ¡Es muy divertido!$1#$b#Hasta ahora hemos visto nubes en forma de cometa, de concha marina y de tortuga.$0\"/pause 500/faceDirection Hiro 2/jump Hiro 5/speak Hiro \"¡Oh wow, mira eso!$3#$b#¡Esa nube parece una estrella fugaz!$1\"/pause 500/faceDirection Puka 2/speak Puka \"Vaya, realmente lo parece.$3#$b#Parece tan real que podrías pedir un deseo.$0\"/pause 500/faceDirection Puka 3/speak Puka \"¿Qué deseo pedirías, Hiro?$0\"/pause 500/faceDirection Hiro 1/speak Hiro \"Hmm...$3#$b#No creo que necesite pedir deseos.$0#$b#¡Tengo todo lo que podría desear aquí mismo!$1\"/pause 500/emote Puka 60/pause 500/speak Puka \"Yo siento lo mismo...$3#$b#Jeje.$1\"/pause 500/emote Hiro 60/pause 500/faceDirection Hiro 0/speak Hiro \"@, ¿ves alguna forma en las nubes?$0\"/faceDirection Puka 0/pause 500/emote farmer 40/pause 500/emote farmer 16/pause 500/question fork1 \"#Veo un héroe con su capa ondeando detrás de él.#Veo una sirena sentada en una roca.\"/fork cloudshape/pause 500/faceDirection Hiro 2/faceDirection Puka 2/jump Hiro 5/speak Hiro \"¡Qué genial!!$1#$b#¿Dónde lo ves?$3\"/pause 500/speak Puka \"Creo que lo veo justo allí.$0\"/pause 500/speak Hiro \"¡Oh sí, allí está!$0#$b#Eso realmente se ve genial.$0\"/pause 500/faceDirection Hiro 0/speak Hiro \"¡Buena vista, @!$1\"/pause 500/emote farmer 56/pause 500/emote Puka 16/pause 500/speak Puka \"Ah, mira allí!$3#$b#¡Hay un pececito pasando!~$1\"/pause 500/faceDirection Hiro 2/speak Hiro \"¡Lo veo!$0#$b#¿Qué lindo es eso?$1\"/pause 500/emote Puka 56/emote Hiro 56/emote farmer 32/pause 1000/end",
  "cloudshape": "pause 500/faceDirection Hiro 2/faceDirection Puka 2/speak Hiro \"¡Oh sí, creo que lo veo!$1\"/pause 500/emote Puka 28/pause 500/speak Puka \"Nnnn...$2#$b#Ay...$2\"/pause 500/faceDirection Hiro 1/emote Hiro 16/pause 500/speak Hiro \"¿Puka, qué te pasa?!$3#$b#¿Estás teniendo esos dolores de cabeza otra vez?$3\"/pause 500/speak Puka \"Sí, creo que sí...$2#$b#Es muy doloroso esta vez...$2\"/pause 500/speak Hiro \"Oh no, Puka...$2\"/pause 500/faceDirection Hiro 0/speak Hiro \"@, creo que voy a llevar a Puka a casa.$2#$b#Es mejor que descanse cuando tiene dolores de cabeza como este.$2\"/pause 500/emote farmer 28/pause 500/speak Hiro \"Está bien, estará bien.$2#$b#Podemos continuar observando las nubes en otro momento, ¿vale?$3\"/pause 500/faceDirection Hiro 1/speak Hiro \"Vamos, Puka. Vamos a llevarte a casa.$2\"/pause 1000/end"

         //Noa Four Heart Event
  "98890029/t 1900 2400/f Noa 1000/w sunny": "distantBanjo/51 55/farmer 47 68 0 Noa 60 55 3/skippable/move Noa -13 0 0/pause 500/move farmer 0 -6 0/emote farmer 8/pause 500/move farmer 0 -5 0/textAboveHead Noa \"Zzzz....\"/pause 2000/emote farmer 40/pause 500/jump farmer 5/emote farmer 16/pause 500/textAboveHead Noa \"Whuh...\"/pause 2000/faceDirection Noa 2/speak Noa \"Oh...hola, @.$3\"/pause 500/faceDirection Noa 1/pause 300/faceDirection Noa 0/pause 300/faceDirection Noa 3/pause 300/faceDirection Noa 2/speak Noa \"Oh, no...¿me quedé dormido otra vez?$3\"/pause 500/speak Noa \"He estado tratando de llegar a casa durante la última hora, pero parece que me duermo cada pocos pasos.$3\"/pause 500/emote farmer 28/pause 500/speak Noa \"Eh, esto es normal para mí.$3#$b#Pero es un poco molesto.$5#$b#Preferiría dormir en mi cama acogedora que en medio de la calle.$3\"/pause 500/speak Noa \"Aunque eso es mejor que quedarme dormido en el agua.$3#$b#Sí, eso lo he hecho antes.$3\"/pause 500/speak Noa \"Hiro tuvo que sacarme.$2\"/pause 500/speak Noa \"Je, apuesto a que te estás preguntando '¿Qué le pasa a este tipo?'$0#$b#'¿Por qué nunca puede mantenerse despierto?'$0\"/pause 500/speak Noa \"A veces me pregunto eso yo mismo, pero luego recuerdo lo celestial que es dormir.$0#$b#Sin preocupaciones, solo felicidad y nada.$0#$b#Bueno, hasta que tengas un sueño extraño o una pesadilla horrible.$3#$b#Podría vivir sin esas.$3\"/pause 500/speak Noa \"Probablemente no lo entiendas...$3#$b#Después de todo, eres un granjero, ¿verdad?$3#$b#Supongo que te levantas temprano y pasas la mayor parte del día trabajando duro.$3#$b#Me pregunto cómo es eso.$3\"/pause 500/emote farmer 28/pause 500/speak Noa \"No es que realmente me importe.$0#$b#Estoy feliz de dormir la mayor parte del día.$0#$b#Es mi vocación, ¿sabes?$1\"/pause 500/speak Noa \"De todos modos, voy a intentar finalmente llegar a mi casa.$0#$b#Se va a sentir tan bien acurrucarme en mi cama suave~.$1\"/pause 500/speak Noa \"Nos vemos.$0\"/pause 500/faceDirection Noa 2/move Noa 0 -10 0/end",

         //Lulu Two Heart Event
  "98890039/t 800 1000/f Lulu 500/d Mon Tue Thu Fri Sat Sun/w sunny": "jaunty/32 40/farmer 47 53 0 Lulu 31 40 1 Lala 32 40 3/changeSprite Lulu Clown/changeSprite Lala Clown/changePortrait Lulu Clown/changePortrait Lala Clown/skippable/pause 1000/speak Lulu \"Creo que empezaré con el malabarismo y tú enfócate en hacer los animales de globos.$0\"/pause 500/speak Lala \"¡Claro, claro, sin problema!$0#$b#De todas formas, soy una experta en hacer animales de globos.$0\"/pause 500/speak Lulu \"Mmmm... pero la última vez que intentaste hacer un ratón, terminó pareciendo una pila de excremento.$3\"/pause 500/jump Lala 5/pause 200/speak Lala \"¡Hey, dame un respiro!$3#$b#¡Era la primera vez que hacía un ratón!$3\"/move farmer 0 -11 0/move farmer -6 0 0/move farmer 0 -1 0/move farmer -4 0 0/move farmer 0 1 0/move farmer -6 0 0/pause 500/faceDirection Lala 2/faceDirection Lulu 2/speak Lala \"¡Hola! ¿Qué pasa, @?$0#$b#¿Viniste a ver nuestro espectáculo?$0\"/pause 500/speak Lulu \"Todavía estamos preparándonos.$3#$b#Deberías volver en un rato.$0\"/pause 500/speak Lala \"Nah, quédate, @!$0#$b#Puedes charlar con nosotros mientras practicamos.$0\"/pause 500/speak Lulu \"No es una buena idea.$0#$b#Su presencia será demasiado distractora.$0\"/pause 500/speak Lala \"Oh, no seas tan aguafiestas, Lulu.$3#$b#@ ni siquiera habla mucho de todos modos.$0\"/pause 500/speak Lulu \"...Bueno, es verdad.$0\"/pause 500/speak Lala \"Sabes, pensarías que tú y @ se llevarían súper bien, Lulu.$3\"/pause 500/speak Lulu \"¿Por qué dices eso?$3\"/pause 500/speak Lala \"Porque, como dije, @ no habla mucho.$3#$b#Te molesta cuando la gente habla demasiado, ¿verdad?$3#$b#Nunca tendrías ese problema con @.$0\"/pause 500/speak Lulu \"¿A qué te refieres con 'gente'...$3#$b#Eres la única persona que 'habla demasiado'.$3\"/pause 500/speak Lulu \"Pero, sí... supongo que esa es una buena cualidad que tiene @.$0\"/pause 500/emote farmer 56/pause 500/speak Lala \"¡Ves! Lo sabía.$0#$b#Probablemente ustedes dos se convertirán en los mejores amigos en poco tiempo.$0\"/pause 500/emote Lulu 60/pause 500/speak Lulu \"No sé si tanto...$3\"/pause 500/speak Lulu \"Pero supongo que tenemos el potencial de ser buenos amigos.$1\"/pause 500/emote farmer 32/pause 1000/end",

         //Lulu Four Heart Event
  "98890040/t 1300 1800/f Lulu 1000/d Wed/w sunny": "distantBanjo/106 39/farmer 102 54 0 Lulu 109 39 1/skippable/pause 1000/emote Lulu 40/pause 1000/move farmer 0 -17 0/move farmer 7 0 1/pause 1000/emote farmer 40/pause 500/faceDirection Lulu 0/faceDirection farmer 2/speak Lulu \"Oh. Hola, @.$0\"/pause 500/speak Lulu \"Estoy aquí para relajarme.$0\"/pause 500/speak Lulu \"Realmente me gusta la playa, en realidad.$3#$b#Me hace sentir tranquila.$1\"/pause 500/faceDirection Lulu 1/speak Lulu \"Vengo aquí siempre que necesito alejarme de la alta energía del pueblo.$3#$b#Y a veces solo para...pensar.$0\"/pause 500/faceDirection Lulu 0/speak Lulu \"Todos necesitamos un buen lugar para pensar, ¿no crees?$0\"/pause 500/faceDirection Lulu 1/faceDirection farmer 1/speak Lulu \"De todos modos...$0#$b#Si no te importa, ¿podemos simplemente...sentarnos aquí en silencio?$0#$b#Y solo ver el movimiento de las olas y las nubes en el cielo...$0\"/pause 500/emote farmer 56/pause 500/speak Lulu \"Genial.$1\"/pause 2000/end",

         //Lotus Return
  "98890046/t 800 1700/f Olina 2250/e 98890011/w sunny": "playful/32 92/farmer 31 92 1 Olina 32 92 3 Lotus 0 0 0 Shiso 0 1 0 MissLily 0 2 0/pause 1500/emote Olina 56/pause 500/speak Olina \"¡Lotus debería llegar en cualquier momento!$0#$b#¡Estoy tan emocionada!$1\"/pause 500/speak Olina \"¡Ustedes dos se llevarán genial, lo sé!~$1\"/pause 500/faceDirection Olina 2/pause 200/emote Olina 16/pause 500/jump Olina 5/speak Olina \"¡Mira, ahí está ella!$1\"/pause 500/faceDirection farmer 2/warp Lotus 33 107/warp Shiso 31 107/warp MissLily 32 107/move Lotus 0 -13 0 true/move Shiso 0 -13 0 true/move MissLily 0 -13 0 true/pause 3500/speak Lotus \"¡Olina!!!$1\"/pause 500/speak Olina \"¡Lotus!$1#$b#¡No puedo creer que tú y Miss Lily finalmente hayan vuelto!$1#$b#¡Parece que ha pasado una eternidad!$3\"/pause 500/speak Lotus \"¡Lo sé! ¡Y estábamos tan tristes sin ti!$2#$b#¡Pero aún así me divertí mucho!$0#$b#¡Vi muchos lotos diferentes allá afuera, tal como había esperado!$1\"/pause 500/speak Olina \"¡Eso es genial de escuchar!$1\"/pause 500/speak Olina \"En realidad, han pasado muchas cosas mientras estabas fuera.$3\"/pause 500/speak Lotus \"¿Es por eso que hay un humano de pie a tu lado?$3\"/pause 500/speak Olina \"¡Oh, cierto!$3#$b#Lotus, este es @.$0#$b#@ es un buen amigo del pueblo.$0\"/pause 500/speak Lotus \"¿Oh, de verdad?$3#$b#¿Qué pasó con todo eso de 'todos los humanos son malos' de lo que todos siempre hablaban?$3\"/pause 500/speak Olina \"Bueno, no todos los humanos son malos, por supuesto.$3#$b#Solo que @ tuvo que demostrarlo.$0\"/pause 500/speak Olina \"Confía en mí, @ ha sido un gran amigo para mí.$0#$b#¡Y estoy segura de que ustedes dos también se llevarán bien!$1\"/pause 500/speak Lotus \"Bueno, si tú lo dices, entonces lo creo.$0\"/pause 500/jump Lotus 5/pause 200/speak Lotus \"¡Encantada de conocerte, @!!$1\"/pause 500/emote farmer 32/pause 500/emote Olina 8/pause 500/speak Olina \"Espera, ¿quién es ese pequeño que está al lado de Miss Lily?$3\"/pause 500/speak Lotus \"¡Oh, ese es Shiso!$0#$b#Lo conocí en una de las selvas que exploré.$0#$b#¡Mi primera impresión al verlo fue '¿Es eso un gigantesco trozo de sushi que camina?'$3#$b#Estaba muy confundida y un poco perturbada.$3\"/pause 500/speak Lotus \"¡Pero luego me di cuenta de que solo era un axolote!$0#$b#Parecía perdido y solo, así que no quería simplemente dejarlo allí.$3\"/pause 500/speak Lotus \"Tan pronto como le dije que había un pueblo lleno de axolotes como él, aceptó venir a casa conmigo.$0#$b#¿Verdad, Shiso?$0\"/pause 500/speak Shiso \"Sí, es cierto.$0#$b#Antes de que Lotus viniera, yo era el único axolote en toda la selva.$3#$b#¡Estaba muy triste por eso...$2#$b#¡Pero ahora que estoy con otros axolotes, me siento muy feliz!$1\"/pause 500/speak Olina \"Aww, me pregunto por qué estabas solo en primer lugar, pobrecito...$2#$b#Pero no te preocupes, ahora tienes un hogar aquí con nosotros.$1\"/pause 500/emote Shiso 56/pause 500/faceDirection Lotus 3/speak Lotus \"Shiso, vamos directo a mi casa primero.$0#$b#¡Quiero que veas lo genial que es!$1\"/pause 500/faceDirection Lotus 0/speak Lotus \"Olina, ¿qué te parece si nos encontramos más tarde?$0#$b#¡Y luego podemos presentar a Shiso a todos!$1\"/pause 500/speak Olina \"¡Creo que es una gran idea!~$1#$b#¡Nos vemos entonces!$0\"/pause 500/fade/viewport -200 -200/warp Lotus 0 0/warp Shiso 0 1/warp MissLily 0 2/faceDirection Olina 3/faceDirection farmer 1/fade/viewport 32 92/pause 1500/speak Olina \"¿No es genial, @?$0#$b#¡Lotus ha vuelto y tenemos un nuevo axolote en el pueblo!$1\"/pause 500/speak Olina \"Estoy emocionada por ver qué depara el futuro.$0\"/pause 1000/end",

         //Halloween
  "98890050/t 1900 2350/z winter spring summer/u 28/n Halloween": "playful/32 54/farmer 32 65 0 Captain 39 57 3 Hiro 25 57 1 Puka 26 57 3 Olina 29 51 1 Jinx 30 51 2 Lala 28 55 1 Lulu 35 55 3 Noa 28 54 1 Nimue 37 52 2/skippable/pause 1000/move farmer 0 -8 0/pause 500/emote Captain 16/pause 500/move Captain -5 0 3/speak Captain \"¡Ah, @!$1#$b#¡Has venido!$1\"/pause 500/jump Captain 5/pause 200/speak Captain \"¡Todos, @ está aquí!$0\"/pause 500/faceDirection Puka 1/faceDirection Hiro 1/faceDirection Olina 2/faceDirection Lulu 2/faceDirection Lala 2/faceDirection Noa 2/move Puka 4 0 1/speak Puka \"Hola, humano.$0#$b#¡Bienvenido a nuestra divertida celebración de Halloween~.$1\"/pause 500/move Lala 4 0 2/speak Lala \"¡Qué bueno tenerte aquí!$1#$b#Pero, eh... ¿es ese realmente tu disfraz de Halloween?$3\"/pause 500/speak Noa \"Yawn...$3#$b#No puedes juzgarlos, Lala.$0#$b#Después de todo, solo estás usando tu mismo viejo disfraz de payaso.$0\"/pause 500/jump Lala 5/pause 200/speak Lala \"¡Oye, si no está roto, no lo arregles!$3\"/pause 500/speak Olina \"Estoy feliz de ver a @ aquí.$0#$b#Es agradable tener a alguien nuevo celebrando un divertido holiday con nosotros, ¿verdad?$1\"/pause 500/faceDirection Jinx 3/speak Jinx \"Por supuesto que tienes razón, Olina.$0\"/pause 500/faceDirection Jinx 2/speak Jinx \"Pero discípulo, deberías saber cómo funciona este holiday...$0#$b#¡Si no tienes caramelos para nosotros, te haremos una broma!$0\"/pause 500/jump Hiro 5/pause 200/speak Hiro \"No escuches a Jinx, @.$0#$b#No habrá trucos malvados por aquí.$0#$b#¡No con el héroe alrededor, por supuesto!$1\"/pause 500/speak Captain \"Exacto, solo relájate y diviértete con nosotros.$0#$b#No es necesario que le des caramelos a nadie si no tienes.$0#$b#Pero si estás buscando conseguir algunos para ti, Pinky y Bluey siempre tienen algunos para vender en este día.$1\"/pause 500/speak Olina \"¡Es cierto, y sus caramelos son súper sabrosos!$1\"/pause 500/speak Nimue \"Si los caramelos no son lo tuyo, también puedes comer algo de la comida que tenemos aquí.$0#$b#Pero la tarta de calabaza está estrictamente prohibida.$5\"/pause 500/speak Lulu \"Sí, y ni te molestes en intentar probarla a escondidas...$3#$b#Nimue te rasgará los ojos.$0\"/pause 500/speak Captain \"...De todos modos, ¡suficiente charla y vamos a festejar!$1\"/pause 1000/end position 32 65",

         //Christmas
  "98890051/t 1100 1900/z fall spring summer/u 25/n Christmas": "playful/32 54/farmer 32 65 0 Captain 32 56 2 Hiro 36 54 1 Puka 36 55 1 Olina 29 51 1 Jinx 30 51 2 Lala 27 54 3 Lulu 27 55 3 Noa 25 52 2 Nimue 38 52 2/skippable/pause 1000/move farmer 0 -7 0/pause 500/emote Captain 16/pause 500/speak Captain \"¡Ho ho ho!$1#$b#¡Feliz Navidad, @!$1\"/pause 500/faceDirection Lala 2/faceDirection Lulu 2/faceDirection Puka 2/faceDirection Hiro 2/faceDirection Olina 2/speak Lala \"¡@, lo lograste!$1#$b#¡Ven, siéntate con nosotros y únete a la fiesta!$0\"/pause 500/jump Hiro 5/pause 200/speak Hiro \"¡No, ven a sentarte aquí con nosotros!$3\"/pause 500/speak Puka \"Sí, nuestra mesa es mucho más divertida...~$0\"/pause 500/speak Olina \"No, no.$3#$b#¡@ debería ir a ver qué están vendiendo Pinky y Bluey!$0#$b#¡Sus bastones de caramelo y pastelitos de frutas son deliciosos.$1\"/pause 500/jump Captain 5/pause 200/speak Captain \"¡Por favor, todos!$3#$b#¡Van a abrumar a @!$3\"/pause 500/speak Lala \"Oh, lo siento.$3#$b#Supongo que todos están muy emocionados porque es Navidad, ¿sabes?$3\"/pause 500/speak Captain \"Lo sé.$3#$b#Pero antes de que @ haga cualquier otra cosa, ¡deberíamos darle su regalo!$0\"/pause 500/speak Olina \"¡Oh, cierto!$0#$b#¡Tenemos un regalo de Navidad para ti, @!$1\"/pause 500/speak Lulu \"¡Todos trabajamos en él juntos!$1\"/pause 500/speak Captain \"Exacto, así que esperamos que te guste.$0#$b#Aquí tienes.$0\"/pause 500/move Captain 0 1 2/addCraftingRecipe otohime.AV_Rainbow_Futan_Axolotl/message \"El Capitán te da un pequeño regalo de color arcoíris.\"/pause 500/message \"¡Revisa tus recetas de artesanía después del evento!\"/pause 500/speak Captain \"Ahí tienes.$0#$b#¡Ahora puedes unirte a las festividades con nosotros!$1\"/pause 500/emote farmer 32/pause 1000/end position 32 65",

         //Shiso One Heart Event
  "98890052/t 800 1500/f Shiso 250/w sunny": "playful/88 83/farmer 87 87 0 Shiso 89 83 1 Lotus 89 84 1/skippable/pause 1000/speak Lotus \"Hmm, tengo algo de hambre...$3\"/pause 500/jump Lotus 5/pause 200/faceDirection Lotus 0/speak Lotus \"¡Oye, Shiso! ¿Quieres ver un truco genial que puedo hacer?$0\"/pause 500/faceDirection Shiso 2/speak Shiso \"¡Claro, por supuesto!$0\"/pause 500/faceDirection Lotus 1/speak Lotus \"Mira esto.$0#$b#Siempre que tengo hambre, solo meto mi cabeza en un cuerpo de agua...$0#$b#¡Y absorbo un pez en mi boca como una aspiradora!$1#$b#Es mucho más fácil que pescar.$0\"/pause 500/jump Shiso 5/pause 200/speak Shiso \"¿¡Qué?!$2#$b#¡Eso es terrible!$2\"/pause 500/faceDirection Lotus 0/speak Lotus \"¿Eh? ¿Por qué?!$3\"/pause 500/speak Shiso \"Esos pobres pececitos no merecen eso...$2\"/pause 500/emote Lotus 8/pause 500/speak Lotus \"Shiso... ¿tú no comes peces?$3\"/pause 500/speak Shiso \"¡No, por supuesto que no!$2\"/pause 500/speak Lotus \"Eh, pero...$3#$b#Es algo natural para los axolotls comer peces, ¿sabes?$3\"/pause 500/speak Shiso \"¿Entonces... todos ustedes comen peces?$2\"/pause 500/speak Lotus \"Sí...$3\"/pause 500/speak Lotus \"Um, pero podría intentar comer otras cosas si eso te haría sentir mejor!$3\"/pause 500/speak Shiso \"...No, está bien.$2#$b#Solo considero a los pececitos como amigos... así que me sorprende saber que los axolotls los comen.$2\"/pause 500/speak Lotus \"Bueno, piensa en esto.$3#$b#¡Los peces en mi barriga están teniendo una fiesta juntos!$0#$b#Así que al final, siguen tan felices como siempre.$0\"/pause 500/speak Lotus \"¿Eso ayuda en algo?$3\"/pause 500/speak Shiso \"No exactamente...$3#$b#Pero agradezco que estés tratando de animarme de todos modos.$0\"/pause 500/emote Lotus 60/pause 1000/end",

         //Shiso Two Heart Event
  "98890053/t 1000 1500/f Shiso 500/w sunny": "jaunty/87 30/farmer -200 -200 0 Shiso 87 27 2 Hiro 86 26 2 Puka 87 26 2/skippable/pause 500/move Shiso 0 2 0/move Shiso 2 0 0/move Shiso 0 2 0/move Shiso 2 0 0/pause 500/jump Shiso 5/pause 200/emote Shiso 56/pause 500/move Shiso -2 0 0/move Shiso 0 -2 0/move Shiso -5 0 0/move Shiso 0 2 0/move Shiso -2 0 0/pause 500/jump Shiso 5/pause 200/emote Shiso 56/pause 500/speak Shiso \"¡Estas cositas son realmente geniales!$1\"/pause 500/speak Hiro \"¿Verdad?$1#$b#Se llaman 'cometas'.$0#$b#La gente normalmente las vuela en el aire, especialmente en días ventosos.$0\"/pause 500/speak Shiso \"Cometas...$0#$b#¡Me gustan mucho!$1\"/pause 500/move Shiso 2 0 0/move Shiso 0 -2 0/move Shiso 3 0 0/move Shiso 0 -1 0/speak Puka \"¿No son también muy lindas?$0#$b#Me encanta que parezcan peces.$1\"/pause 500/jump Shiso 5/pause 200/speak Shiso \"¡Yo también!$1#$b#¡Se parecen a los amiguitos peces que solía tener en la jungla!$0\"/pause 500/warp farmer 73 31/move farmer 11 0 0/move farmer 0 -2 0/move farmer 2 0 0/move farmer 0 -1 0/pause 500/faceDirection Shiso 3/pause 200/emote Shiso 16/pause 500/speak Shiso \"¡Hola, @-amigo!$0\"/pause 500/speak Hiro \"¡Hola, @!$0#$b#¿Estás aquí para unirte a nosotros en la observación de cometas?$0\"/pause 500/faceDirection Shiso 0/speak Shiso \"Hmm...$3#$b#¿Son estos los únicos cometas aquí?$3\"/pause 500/speak Hiro \"Lamentablemente, sí.$3#$b#Podríamos realmente usar más, ¿eh?$3\"/pause 500/speak Shiso \"¡Sí!$3#$b#¡Quiero ver como... ¡cientos de ellos!$0\"/pause 500/speak Puka \"¿Cientos es un poco exagerado, no?$3#$b#Probablemente no podríamos vernos entre tanto cometa, jeje.$0\"/pause 500/speak Shiso \"Está bien, entonces solo quiero ver... ¡al menos veinte cometas!$0\"/pause 500/speak Hiro \"Veinte... Eso es un poco más factible, jeje.$0\"/pause 500/speak Hiro \"Estaba planeando pedirle al Capitán que trajera más cometas de sus viajes.$0#$b#De allí vinieron estos tres.$0\"/pause 500/speak Hiro \"Shiso, ¿qué tal si tú y yo le decimos al Capitán qué cometas te gustaría ver?$0#$b#¡Él se asegurará de conseguir todos los que quieras!$1\"/pause 500/jump Shiso 5/pause 200/speak Shiso \"¡Yay! ¡Hagámoslo!$1\"/pause 500/emote Puka 56/pause 500/emote farmer 32/pause 1000/end",

         //Tanabata
  "98890054/t 1900 2350/z winter fall spring/u 7/w sunny/n Tanabata": "junimoStarSong/31 78/farmer 32 81 0 Captain 29 81 0 Hiro 31 79 1 Puka 32 79 3 Olina 37 79 3 Jinx 37 78 3 Lala 25 79 1 Lulu 25 81 1 Noa 25 80 1 Nimue 34 81 0/skippable/pause 2500/emote Puka 20/pause 500/speak Puka \"Hikoboshi...$0#$b#Estoy tan feliz de verte de nuevo.$1\"/pause 500/emote Hiro 20/pause 500/speak Hiro \"Yo también estoy feliz de verte.$0#$b#Pasé todos los días de este año pensando en ti, al igual que los años anteriores.$0\"/pause 500/speak Hiro \"Estás radiante como siempre, Orihime.$1\"/pause 500/emote Puka 60/pause 500/speak Puka \"Oh, Hikoboshi...~$0\"/pause 500/faceDirection Puka 2/pause 300/emote Puka 28/pause 500/speak Puka \"Ah, pero...$2\"/pause 500/faceDirection Puka 1/move Puka 2 0 1/pause 500/emote Hiro 8/pause 500/move Hiro 2 0 1/speak Hiro \"¿Orihime?$3#$b#¿Qué pasa?$3\"/pause 500/speak Puka \"Solo el hecho de poder encontrarnos una vez al año...$2#$b#Es simplemente cruel, ¿no?$2\"/pause 500/speak Puka \"Y recordar todos los momentos en los que no pudimos encontrarnos debido a la lluvia?$2#$b#Todavía lloro pensando en todos esos años desperdiciados...$2\"/pause 500/emote Hiro 28/pause 500/speak Hiro \"Sé exactamente lo que sientes.$2#$b#Pero...tenemos que mantenernos positivos.$3\"/pause 500/speak Hiro \"Prefiero tener un día para poder encontrarte que ningún día en absoluto.$0#$b#Y todos los días que hemos pasado juntos siempre han sido los más mágicos.$0\"/pause 500/speak Hiro \"Además, tener este día para esperar me da la fuerza para seguir adelante durante el año.$0\"/pause 500/emote Puka 40/pause 500/faceDirection Puka 3/pause 300/speak Puka \"Sí, supongo que tienes razón...$3#$b#Como siempre.$0\"/pause 500/speak Puka \"Ah, en qué estaba pensando...$3#$b#No debería desperdiciar nuestro día especial sintiéndome tan triste.$0\"/pause 500/speak Puka \"¡Enfocémonos en pasar el mejor tiempo juntos mientras podamos!$1\"/pause 500/jump Hiro 5/pause 300/speak Hiro \"¡Ese es el espíritu!$1\"/pause 500/emote Puka 56/pause 500/emote Hiro 56/viewport move 0 -1 8000/pause 1000/fade/viewport -200 -200/warp Captain 31 77/warp Nimue 32 77/warp Hiro 31 79/warp Puka 32 79/warp Jinx 26 78/warp Olina 27 78/warp Lala 26 80/warp Lulu 27 81/warp Noa 38 80/warp farmer 30 79/faceDirection Captain 2/faceDirection Nimue 2/faceDirection Hiro 0/faceDirection Puka 0/faceDirection Jinx 1/faceDirection Olina 1/faceDirection Lala 1/faceDirection Lulu 1/faceDirection Noa 3/faceDirection farmer 0/fade/viewport 31 78/pause 1000/jump Captain 5/pause 300/speak Captain \"¡Gracias a todos por ver la obra!$1#$b#Y, por supuesto, gracias a Hiro y Puka por interpretar los papeles principales.$0#$b#¡Lo hicieron fantástico!$1\"/pause 500/speak Puka \"¡Fue un placer~.$1\"/pause 500/speak Lala \"¡Chicos...CHICOS!$3#$b#¡Eso fue tan...hermoso...!!!$3\"/pause 500/speak Lala \"Creo que lloré al menos tres veces durante la obra.$3\"/pause 500/speak Lulu \"Sí, no está bromeando.$0\"/pause 500/speak Olina \"Oh, ¿no fue tan romántico?$1#$b#Me pregunto si alguna vez tendré un amor tan fuerte como Hikoboshi y Orihime.$0\"/pause 500/speak Jinx \"Ja...sí...$3\"/pause 500/speak Captain \"Bueno, no podríamos haber tenido la obra o la celebración sin Hiro.$0#$b#¡Así que gracias a Hiro por presentarnos a la maravillosa festividad de Tanabata!$1\"/pause 500/speak Hiro \"¡Me alegra compartirlo con todos ustedes!$1#$b#Los recuerdos más fuertes que tengo de mi infancia fueron celebrando esta festividad.$0#$b#¡Significa mucho para mí, así que me alegra que todos ustedes lo hayan disfrutado!$1\"/pause 500/emote Hiro 56/pause 1000/fade/viewport -200 -200/pause 1000/changeLocation otohime.AV_NightSky/fade/viewport 50 15/pause 2500/message \"Las hojas de bambú se están moviendo\"/pause 300/message \"Y balanceándose en los aleros\"/pause 300/message \"Las estrellas están parpadeando\"/pause 300/message \"Como oro y plata brillante\"/pause 300/message \"En papeles coloridos\"/pause 300/message \"Escribí mis deseos\"/pause 300/message \"Las estrellas están parpadeando\"/pause 300/message \"Y mirándome desde el cielo.\"/pause 2000/end position 30 79",

         //The Truth
  "98890055/t 800 1900/e 98890032/e 98890031/e 98890021/e 98890006/e 98890042/e 98890037/e 98890026/e 98890011/e 98890016": "desolate/31 78/Nimue 32 78 2 Puka 31 78 2 Captain 32 80 0 farmer 31 80 0 Olina 30 80 0 Jinx 33 80 0 Lala 35 78 3 Lulu 35 79 3 Hiro 28 78 1 Noa 28 79 1 Kekoa 37 77 3 Aukai 37 78 3 Lilia 37 79 3 Mamo 37 80 3 Nico 26 78 1 Hau 26 80 1/pause 1500/speak Nimue \"Entonces, estoy segura de que todos están confundidos sobre por qué los llamé aquí.$3\"/pause 500/jump Lala 5/pause 200/speak Lala \"¡Sí!$3#$b#¿Qué está pasando?$3\"/pause 500/speak Nimue \"Bueno...$3#$b#Tengo información muy seria que deberían conocer.$3\"/pause 500/emote Mamo 8/textAboveHead Nico \"¿Qué es...?\"/pause 1500/speak Nimue \"Verán...$3#$b#Um, ¿cómo decirlo...$3#$b#Supongo que seré directa.$3\"/pause 500/speak Nimue \"Ninguno de nosotros es realmente un axolote.$3#$b#De hecho, todos somos humanos que se han transformado en axolotes.$3\"/pause 500/emote Captain 16/pause 200/textAboveHead Hau \"¿¡Qué!?\"/pause 1000/textAboveHead Lala \"¿Esto es una broma, verdad?\"/pause 2500/speak Nimue \"Sé que puede ser difícil de creer, pero es verdad.$3\"/pause 500/speak Nimue \"Quiero decir, piensen en esto.$3#$b#¿Por qué somos tan diferentes de los axolotes normales?$3\"/pause 500/speak Nimue \"Simplemente es porque no somos axolotes reales para empezar.$3\"/pause 500/speak Puka \"Es verdad...$2#$b#Recientemente he recuperado mis recuerdos de mi vida antes de venir aquí.$2#$b#Pensé que tal vez yo era el único que no era un axolote real, pero Nimue me ha dicho lo contrario.$2\"/pause 500/speak Nimue \"Sí. Desde el principio supe que ninguno de nosotros era realmente un axolote.$3#$b#Pensé que nunca tendría que informarles de este hecho, pero que Puka recuperara sus recuerdos cambia todo.$3\"/pause 500/speak Olina \"Entonces, ¿tenías recuerdos de ser humano, Puka?$3\"/pause 500/speak Puka \"En realidad era una sirena.$2\"/pause 500/speak Lala \"Está bien, eso tiene mucho sentido, para ser justo.$3\"/pause 500/speak Lulu \"Shhh, Lala.$0\"/pause 500/speak Puka \"No disfruté la vida que tenía en ese entonces.$2#$b#Estaba muy solo...$2#$b#No tenía amigos en absoluto.$2#$b#Así que después de descubrir este lugar, decidí transformarme en un axolote para poder vivir aquí y finalmente hacer amigos.$2\"/pause 500/move Hiro 2 0 1/speak Hiro \"Puka...$2\"/pause 500/faceDirection Puka 3/speak Puka \"No te sientas triste por mí, Hiro.$3#$b#Venir aquí me ha permitido conocerte.$3#$b#Ahora soy tan feliz como puedo ser.$0\"/pause 500/emote Hiro 32/pause 500/speak Nimue \"Ves, esa es probablemente la razón por la que todos están aquí ahora.$3#$b#Sus vidas como humanos eran insatisfactorias y solitarias, así que terminaron aquí.$3#$b#Sé que yo misma tuve pensamientos similares sobre mi propia vida.$2\"/pause 500/speak Captain \"Supongo que todo está empezando a tener sentido...$3#$b#Siempre tuve la sensación de que olvidaba algo sobre mí.$3\"/pause 500/speak Jinx \"Yo también...$3\"/pause 500/textAboveHead Hau \"Yo también.\"/pause 1000/textAboveHead Mamo \"Sí...\"/pause 1500/speak Nimue \"Quería informarles de esto porque, al igual que Puka, existe la posibilidad de que también puedan recuperar sus recuerdos.$3#$b#Rasmodius mismo teoriza esto, y por más que odie admitirlo, sus teorías casi nunca están equivocadas.$3\"/pause 500/jump Lala 5/pause 200/speak Lala \"¿Qué??$3#$b#¡Si mi vida pasada realmente apestaba, no quiero saber los detalles!$3\"/pause 500/speak Jinx \"Tampoco creo que quiera recuperar mis recuerdos.$2\"/pause 500/speak Noa \"Yo tampoco...$2\"/pause 500/speak Nimue \"Bueno, no sabemos con certeza si sucederá.$3#$b#Pero es mejor estar advertidos por adelantado en caso de que sí, ¿verdad?$3\"/pause 500/speak Captain \"Ella tiene razón.$3#$b#Y además, tal vez sería mejor para nosotros saber sobre nuestras vidas antes del Pueblo Axolote.$3\"/pause 500/emote Aukai 40/textAboveHead Olina \"Tal vez...\"/pause 1500/speak Nimue \"Por ahora, todos deberían tomarse su tiempo para procesar lo que les he contado.$3#$b#Sé que es mucho para asimilar.$3\"/pause 500/speak Nimue \"Por favor, acérquense a mí si sienten que están empezando a recordar algo y podemos trabajar en ello juntos.$3\"/pause 1000/end position 31 80

        //Kandi Arrival
  "98890063/t 600 2400/n CaptainProject4/d Sat": "playful/32 92/farmer 31 92 2 Captain 32 92 2 Nimue 33 92 2 Kandi 0 0 0 Aukai 0 1 0 Lilia 0 2 0/pause 2000/emote Captain 16/pause 500/speak Captain \"¡Ah, esa debe ser ella!$0\"/pause 500/warp Kandi 32 107/warp Aukai 31 107/warp Lilia 33 107/move Kandi 0 -13 0 true/move Aukai 0 -13 0 true/move Lilia 0 -13 0 true/pause 3500/speak Kandi \"¡Helllooooo~!$0\"/pause 500/speak Kandi \"¡He llegado~.$0\"/pause 500/speak Nimue \"Ciertamente has llegado.$3#$b#¿Y esos dos a tu lado son...?$3\"/pause 500/speak Kandi \"Oh, ellos son mis compañeros de banda.$0#$b#Se llaman Chewi y Chompi.$0\"/pause 500/changeName Aukai Chewi/changeName Lilia Chompi/speak Aukai \"Hola.$0\"/pause 500/speak Lilia \"Hola.$0\"/pause 500/speak Nimue \"Interesante...$3\"/pause 500/speak Kandi \"¡Así que! ¿Está lista mi casa?$3#$b#Tenemos mucho equipaje en el barco que necesita ser guardado ¡Ya!$0\"/pause 500/speak Captain \"¡Sí, sí, está lista!$0#$b#¡Estoy seguro de que te encantará, así que vamos a verla!$1\"/fade/viewport -500 -500/changeLocation otohime.AV_AxolotlTownSouth/warp Kandi 100 86/warp Aukai 99 87/warp Lilia 101 87/warp farmer 100 89/warp Captain 101 89/warp Nimue 99 89/faceDirection Kandi 0/faceDirection Aukai 0/faceDirection Lilia 0/faceDirection farmer 0/faceDirection Captain 0/faceDirection Nimue 0/fade/viewport 100 85/pause 1000/jump Kandi/pause 200/speak Kandi \"¡Eeee, es perfecto!$1\"/pause 500/speak Captain \"¿De verdad?$0\"/pause 500/faceDirection Kandi 2/speak Kandi \"Bueno, podría ser un poco más grande.$3#$b#Pero podemos hablar de expansiones más tarde.$0\"/pause 500/speak Kandi \"El escenario también fue fabuloso.$0#$b#¡Todos ustedes lo hicieron bien al servir a la Mejor Idol de la Isla!$1\"/pause 500/speak Nimue \"'Mejor Idol de la Isla', eh...$3\"/pause 500/speak Kandi \"De todos modos, vamos a empezar a desempacar.$0#$b#¡Tengo que dar una actuación increíble esta noche para celebrar mi llegada!$1\"/pause 500/speak Captain \"¡Qué emocionante!$1#$b#Estoy seguro de que a los aldeanos les encantaría verlo.$0\"/pause 500/speak Kandi \"Por supuesto que lo harían~.$0#$b#¡Después de todo, estoy hablando de mí!$1\"/emote Kandi 56/pause 1000/end",

        //Kandi Two Heart Event
  "98890065/t 800 1700/f Kandi 500/w sunny/d Sat Sun": "playful/31 55/farmer 31 55 2 Kandi 32 56 3 Bonbon 31 56 1 Lulu -200 -200 0/skippable/pause 1000/speak Bonbon \"Sabes, yo también soy algo así como cantante.$0\"/pause 500/speak Kandi \"¿De verdad...$3\"/pause 500/jump Bonbon 5/pause 200/speak Bonbon \"¡Sí! ¡Escucha esto!$1\"/pause 500/faceDirection Bonbon 2/textAboveHead Bonbon \"Ahem...\"/pause 1500/speak Bonbon \"EAsTboUnd aNd dOwN, loAdEd uP anD tRuCkin'...~$1\"/pause 500/speak Bonbon \"Y Vamos a hacer lo que dicen que no se puede hacer.~$1\"/pause 500/faceDirection Bonbon 1/speak Bonbon \"¿Cómo estuvo?$0\"/pause 1000/emote Kandi 40/pause 1000/speak Kandi \"Um, eso fue...um...$3\"/pause 500/speak Kandi \"Como, wow.$3\"/pause 500/emote Bonbon 56/pause 500/speak Bonbon \"¿Tan bueno, eh?$1\"/pause 500/emote farmer 28/pause 500/warp Lulu 32 64/move Lulu 0 -7 0/pause 200/speak Lulu \"Hola chicos.$0#$b#Perdón por llegar tarde.$0#$b#Hubo un problema con Lala y explosivos y... sí.$0\"/pause 500/faceDirection Bonbon 2/faceDirection Kandi 2/speak Kandi \"¡Lu!$1#$b#¡Llegaste en el momento justo.$0\"/pause 500/speak Bonbon \"¡Así es!$0#$b#¿Quieres escucharme cantar, Lulu?$0\"/pause 500/jump Kandi 5/pause 200/speak Kandi \"¡No, no!$3\"/pause 500/speak Kandi \"Quiero decir, um...$3#$b#¡Deberíamos escuchar a Lulu cantar!$3#$b#¡Sí, sí, nunca he oído cantar a Lulu!$3\"/pause 500/speak Lulu \"¿Yo? ¿Cantar?$3#$b#No canto.$0\"/pause 500/speak Bonbon \"¿De verdad?$3#$b#¿Nunca has cantado en toda tu vida?$3\"/pause 500/speak Lulu \"Bueno, no, he cantado antes...$3#$b#Solo que no creo que sea muy buena en eso.$0\"/pause 500/speak Kandi \"¡Eso es lo que diría alguien que canta bien!$0\"/pause 500/speak Lulu \"¿De verdad?$3\"/pause 500/speak Kandi \"¡Sí!$0#$b#Siempre son las personas que son demasiado confiadas en su canto las que no cantan bien, ¿sabes?$0\"/pause 500/faceDirection Bonbon 1/speak Bonbon \"¿Por qué me miraste así, Kandi?$3\"/pause 500/faceDirection Kandi 3/speak Kandi \"Uh, no es por nada...$3\"/pause 500/faceDirection Bonbon 2/faceDirection Kandi 2/speak Kandi \"De todos modos, ¡deberías cantar para nosotros, Lu!$0#$b#Estoy curiosa por escuchar cómo suena tu voz cantando.$0\"/pause 500/speak Lulu \"Um, no sé...$3#$b#Creo que estaría demasiado nerviosa para eso.$0\"/pause 500/speak Kandi \"Oh, ¿pero por qué?$3#$b#¿No te presentas a menudo frente a la gente?$3\"/pause 500/speak Lulu \"Sí, pero eso es diferente...$0#$b#Cantar simplemente no es lo mío.$0\"/pause 500/speak Lulu \"¿Qué tal si escuchamos a @ cantar en su lugar?$3\"/pause 500/faceDirection Bonbon 0/faceDirection Kandi 0/pause 100/jump Kandi 5/pause 200/speak Kandi \"¡Oh, sí!$1#$b#¡Vamos a escucharte cantar, @!$1\"/pause 500/jump farmer 5/pause 200/emote farmer 16/pause 500/emote farmer 60/pause 1000/end",

        //Meeting Bunni
  "98890069/t 600 2000/f Kandi 250/w sunny/d Mon Tue Wed Thu Fri Sun": "ragtime/32 79/farmer 32 91 0 Kandi 32 79 2/changeSprite Kandi Bunni/changeName Kandi Bunni/pause 200/move farmer 0 -6 0/emote Kandi 16/pause 500/speak Kandi \"¡Oye, tú!$0\"/pause 500/move Kandi 0 5 2/pause 200/speak Kandi \"¡Mi nombre es Bunni!$0\"/pause 500/speak Kandi \"¡Eso es Bunni con 'i', no con 'y'!$3#$b#¡No lo olvides!$3\"/pause 500/speak Kandi \"¿Has oído hablar de Kandi, verdad?$0\"/pause 500/speak Kandi \"¿A quién quiero engañar, por supuesto que sí!$1\"/pause 500/speak Kandi \"¡Ella se presenta en el lado sur de la isla todos los domingos!$0#$b#¡Así que asegúrate de pasar por allí y darle toda tu atención!$0#$b#Quizás incluso compres algo de merchandising mientras estás allí, jeje.$0\"/pause 500/speak Kandi \"De todos modos, ¡eso es todo lo que quería decir!$0#$b#¡Hasta luego~!$1\"/pause 500/move Kandi 0 -4 0/move Kandi 11 0 0/pause 1000/emote farmer 40/pause 1000/end",

        //Birth of Flowers
  "98890070/t 800 2000/z winter fall summer/u 21": "playful/31 78/farmer 31 86 0 Captain 31 77 2 Hiro 36 80 2 Puka 36 81 0 Olina 27 78 3 Jinx 26 78 1 Lala 26 80 1 Lulu 27 81 0 Noa 28 80 3 Nimue 32 77 2/skippable/pause 1500/move farmer 0 -7 0/pause 300/jump Captain 5/pause 300/speak Captain \"¡Ah, bienvenido, bienvenido @!$1#$b#¡Me alegra que pudieras venir para una, um...festividad...especial!$3\"/pause 500/speak Nimue \"Vaya, no podrías ser más obvio sobre cuánto no te importa esta festividad, ¿eh?$3\"/pause 500/jump Captain 5/pause 200/faceDirection Captain 1/pause 500/speak Captain \"¡Oye, tú siempre mencionas cuánto odias esta festividad también!$5\"/pause 500/speak Nimue \"No la ODIO...$3#$b#Simplemente no me gusta.$0\"/pause 500/faceDirection Olina 1/pause 200/emote Olina 12/pause 500/move Olina 3 0 1/speak Olina \"¿Qué les dije a ustedes dos sobre todas las quejas innecesarias?$5#$b#Esta es una festividad perfectamente encantadora con una vibra agradable que no necesita ser arruinada por las dos personas que simplemente no lo entienden.$5#$b#Si no tienen nada bonito que decir, entonces no digan nada.$5\"/pause 500/faceDirection Captain 2/emote Captain 28/pause 500/speak Captain \"Tienes razón...$3\"/pause 500/emote Nimue 28/pause 500/speak Nimue \"Sí, lo siento...$3\"/pause 500/speak Olina \"¡Bien! Me alegra que hayamos llegado a un entendimiento.$0\"/pause 500/faceDirection Olina 2/speak Olina \"@, ¡no escuches a esos dos!$3#$b#Ellos pueden no preocuparse por ello, pero esta festividad es especial para nosotros axolotls.$0#$b#Es un momento para celebrar la existencia de las flores y la naturaleza misma.$0#$b#Después de todo, las flores no solo son importantes para nosotros, ¡sino para el mundo en su conjunto!$0#$b#¡Además, son realmente bonitas, jeje.$1\"/pause 500/speak Olina \"Así que ponte una corona de flores y únete a nosotros en las festividades florales, ¿por qué no?$1\"/pause 500/emote farmer 56/pause 1000/end",
             }          