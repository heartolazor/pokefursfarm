//Lala Four Heart Event
  "98890014/t 1000 1500/f Lala 1000/d Wed": "50s/8 8/farmer 8 14 0 Lala 2 6 2 Lilia 0 0 2/skippable/playSound doorClose/move farmer 0 -1 3/move farmer -2 0 0/move farmer 0 -5 0/pause 500/emote Lala 16/pause 500/move Lala 0 2 1/move Lala 3 0 1/speak Lala \"¡Hola, @!$0\"/pause 500/faceDirection farmer 3/pause 500/speak Lala \"Qué sorpresa verte aquí.$0#$b#¿Estás viniendo por una bebida, verdad?$0\"/pause 500/speak Lala \"Claro que sí.$0#$b#¿Qué otra cosa podrías estar haciendo en una tienda de bebidas?$0\"/pause 500/emote farmer 60/pause 500/speak Lala \"Vale, lo siento, estoy siendo molesta porque estoy aburrida.$3#$b#Estoy esperando a que mi hermana llegue, pero está tardando una eternidad...$3\"/pause 500/speak Lala \"Pero sentí que la habitación se iluminó cuando entraste!$3#$b#...No es cierto, pero me emocioné al verte.$0\"/pause 500/emote farmer 32/pause 500/speak Lala \"Entonces, tengo curiosidad...$3#$b#¿Cuál es tu bebida favorita de aquí?$3#$b#¿Rainbow Colada o Cotton Candy Cocktail?$3\"/question fork1 \"#Definitivamente Rainbow Colada.#¡Cotton Candy Cocktail, sin duda!\"/fork drinktaste/pause 500/speak Lala \"¡Oh, buen gusto!$1#$b#Ese es mi favorito también, de hecho.$0\"/pause 500/speak Lala \"Cada sorbo es como una EXPLOSIÓN de sabor, ¿sabes?$1#$b#No me canso de eso.$0\"/pause 500/speak Lala \"Aquí, ¿qué tal si te invito a unos Rainbow Coladas?$3#$b#Como compensación por hacerte esperar frente al mostrador durante cinco minutos.$0\"/pause 500/emote farmer 56/pause 500/faceDirection Lala 0/speak Lala \"¡Queremos dos Rainbow Coladas, buen señor!$0\"/pause 500/changeName Lilia Shop_Owner/speak Lilia \"Lo siento, pero actualmente estamos fuera de los ingredientes para esa bebida.$3\"/pause 500/jump Lala 5/textAboveHead Lala \"¿¡Qué?!\"/pause 1300/faceDirection Lala 1/speak Lala \"¡Qué mala suerte!$3#$b#Esto casi nunca pasa...$3\"/pause 500/emote farmer 32/pause 500/speak Lala \"¿Eh?$3#$b#¿No necesitas compensación?$3#$b#¿Simplemente...estás feliz de pasar el rato conmigo?$3\"/pause 500/speak Lala \"¡Ay, qué bonito!$1#$b#Sabes cómo halagar a alguien, @.$0\"/pause 500/speak Lala \"Yo también me alegro cuando paso tiempo contigo.$0#$b#Eres, como...super divertido y genial.$0#$b#Incluso aunque casi nunca hables.$0\"/pause 500/speak Lala \"¿Qué tal si dejamos este lugar y encontramos algo más que hacer?$0\"/pause 500/emote farmer 56/pause 1000/end",
  "drinktaste": "pause 500/speak Lala \"Entiendo, entiendo.$0#$b#Personalmente prefiero el Rainbow Colada, pero el Cotton Candy Cocktail también es bueno.$0#$b#Simplemente parece el tipo de bebida que compartirías con alguien especial, ¿sabes?$3#$b#Como, pones esas pajitas en forma de corazón y las bebes al mismo tiempo que alguien con quien estás saliendo...$3#$b#Ese tipo de cosas.$0\"/pause 500/emote farmer 40/pause 500/speak Lala \"¿Qué, no lo crees?$3#$b#Bueno, lo que sea.$0\"/pause 500/speak Lala \"Aquí, ¿qué tal si te invito a unos Cotton Candy Cocktails?$3#$b#Como compensación por hacerte esperar frente al mostrador durante cinco minutos.$0\"/pause 500/emote farmer 56/pause 500/faceDirection Lala 0/speak Lala \"Queremos dos Cotton Candy Cocktails, buen señor!$0\"/pause 500/changeName Lilia Shop_Owner/speak Lilia \"Lo siento, pero actualmente estamos fuera de los ingredientes para esa bebida.$3\"/pause 500/jump Lala 5/textAboveHead Lala \"¿¡Qué?!\"/pause 1300/faceDirection Lala 1/speak Lala \"¡Qué mala suerte!$3#$b#Esto casi nunca pasa...$3\"/pause 500/emote farmer 32/pause 500/speak Lala \"¿Eh?$3#$b#¿No necesitas compensación?$3#$b#¿Simplemente...estás feliz de pasar el rato conmigo?$3\"/pause 500/speak Lala \"¡Ay, qué bonito!$1#$b#Sabes cómo halagar a alguien, @.$0\"/pause 500/speak Lala \"Yo también me alegro cuando paso tiempo contigo.$0#$b#Eres, como...super divertido y genial.$0#$b#Incluso aunque casi nunca hables.$0\"/pause 500/speak Lala \"¿Qué tal si dejamos este lugar y encontramos algo más que hacer?$0\"/pause 500/emote farmer 56/pause 1000/end",

//Jinx Eight Heart Event
  "98890021/t 1500 2200/f Jinx 2000": "breezy/8 8/farmer -500 -500 0 Jinx 13 6 2/skippable/pause 500/playSound doorClose/warp farmer 8 14/move farmer 0 -1 0/emote farmer 16/pause 500/move farmer 2 0 0/move farmer 0 -1 0/move farmer 2 0 0/move farmer 0 -4 0/move farmer 1 0 0/pause 500/emote Jinx 40/pause 500/speak Jinx \"Oh. Hola, discípulo.$2\"/pause 500/emote farmer 8/pause 500/speak Jinx \"No, estoy bien...$2#$b#No soy el tipo de persona que se pone triste, por supuesto.$2\"/pause 500/emote farmer 36/pause 500/speak Jinx \"...Supongo que no puedo ocultar nada de ti.$3#$b#Está bien, admitiré que me siento un poco decaído hoy.$2\"/pause 500/speak Jinx \"Pero no, no quiero hablar de eso.$5#$b#Es mejor mantener estas cosas guardadas, ¿verdad?$3\"/pause 500/emote farmer 36/pause 500/speak Jinx \"¿Qué, no es así?$3#$b#Así es como siempre he hecho las cosas...$3\"/pause 500/emote farmer 28/pause 500/speak Jinx \"Supongo que estoy triste porque he estado teniendo una avalancha de pensamientos negativos.$2#$b#Es solo uno de esos días, ¿sabes?$2\"/pause 500/speak Jinx \"Eso es todo lo que voy a explicar.$5#$b#No voy a compartir todos los detalles de mi tristeza contigo.$5\"/pause 500/emote farmer 40/pause 500/speak Jinx \"¿Dices que somos...amigos? ¿Y los amigos se comparten cosas entre sí?$3#$b#Amigos, ¿eh? Supongo que eso es técnicamente cierto a estas alturas.$3#$b#Simplemente nunca me di cuenta hasta ahora.$3\"/pause 500/speak Jinx \"Pero tienes razón...Supongo que también te considero un amigo ahora.$3#$b#Así que supongo que es justo ser más abierto contigo.$3\"/pause 500/speak Jinx \"Bueno...ni siquiera puedo explicar realmente mis pensamientos.$3#$b#Supongo que simplemente sigo pensando que las personas merecen algo mejor que...yo.$2\"/pause 500/speak Jinx \"Quiero decir, piensa en ello.$2#$b#Olina y yo somos mejores amigas, pero ¿cómo puede ser?$2#$b#Ella es mucho mejor que yo.$2\"/pause 500/speak Jinx \"Ella es dulce, pura, inocente...$2#$b#Todas las cosas que yo no soy.$2#$b#Simplemente no quisiera mancharla de ninguna manera.$2\"/pause 500/speak Jinx \"No puedo recordar mucho sobre mi pasado.$2#$b#Pero siempre estoy preocupado de que pueda haber sido una mala persona.$2#$b#Si ese es el caso...entonces Olina definitivamente merece algo mejor.$2#$b#Todos mis amigos lo hacen.$2\"/question fork1 \"#Tus amigos te quieren por quien eres ahora.#No pareces el tipo de persona que habría sido mala.\"/fork notbad/pause 500/speak Jinx \"¿Lo hacen?$3#$b#Si eso es lo que piensas...entonces eso es reconfortante.$0\"/pause 500/speak Jinx \"Supongo que mi pasado no debería importar, entonces.$3#$b#Si quien soy ahora es alguien con quien la gente puede llevarse bien felizmente...entonces eso es lo que importa.$0\"/pause 500/speak Jinx \"Um. Gracias por esta pequeña charla.$3#$b#En realidad fue muy útil.$3#$b#Supongo que debería hacer esto de 'abrirse' más a menudo, ¿no?$3\"/pause 500/emote farmer 56/pause 1000/end",
  "notbad": "pause 500/speak Jinx \"¿Realmente lo piensas?$3#$b#Espero que tengas razón.$3\"/pause 500/speak Jinx \"Supongo que solo estoy siendo demasiado duro conmigo mismo.$3#$b#Y preocupándome demasiado.$3#$b#Definitivamente preocupándome demasiado.$3\"/pause 500/speak Jinx \"Y...aunque hubiera sido malo en mi pasado, eso ya no es el caso.$3#$b#Si quien soy ahora es alguien con quien la gente puede llevarse bien felizmente...entonces eso es lo que importa.$0\"/pause 500/speak Jinx \"Um. Gracias por esta pequeña charla.$3#$b#En realidad fue muy útil.$3#$b#Supongo que debería hacer esto de 'abrirse' más a menudo, ¿no?$3\"/pause 500/emote farmer 56/pause 1000/end",

//Noa Two Heart Event
  "98890028/t 1300 1800/f Noa 500/d Wed": "playful/8 8/farmer 14 8 2 Noa 15 10 3 Lala 12 10 1/skippable/pause 1000/jump Lala 5/speak Lala \"¡Noa, ten cuidado!$3#$b#Veo que apenas te mantienes despierta, pero si te duermes, ¡vas a derramar tu bebida!$3\"/pause 500/speak Noa \"¡Ups...$3\"/pause 500/speak Lala \"Dios mío, Noa...$3#$b#¿No tiene cafeína esa bebida?$3#$b#¿Por qué sigues tan cansada?$3\"/pause 500/speak Noa \"Te dije, la cafeína no tiene efecto en mí...$3\"/pause 500/speak Lala \"De todas formas...es la mitad del día, estamos en una tienda de bebidas, y sigues luchando por mantenerte despierta.$3#$b#¿No es una locura, @?$3\"/pause 500/emote farmer 28/pause 500/speak Lala \"Es difícil pasar tiempo contigo cuando estás al borde de quedarte dormida o ya estás dormida.$3#$b#¿Sabes?$3\"/pause 500/speak Noa \"Te oigo...claro y nítido...$0\"/pause 500/jump Lala 5/speak Lala \"¡Estás a punto de quedarte dormida otra vez!$3#$b#¡Ni siquiera creo que realmente me estés escuchando!$3\"/pause 500/speak Noa \"Sí, no mucho...$3#$b#Pero oye, tú eres la que siempre quiere pasar el rato.$3#$b#Sabes en lo que te estás metiendo conmigo.$3\"/pause 500/speak Lala \"Supongo que tienes razón.$3#$b#Pero eres mi mejor amiga, así que es difícil alejarse de ti.$0\"/pause 500/speak Noa \"Claro...$0#$b#Sabía que no podrías resistirte a mí.$0\"/pause 500/jump Lala 5/speak Lala \"¡Ugh! ¡Ahí vas otra vez con las bromas!$5\"/pause 500/speak Noa \"Jeje, solo me gusta ver tu cara enojada.$1\"/pause 500/emote farmer 56/pause 500/speak Lala \"¿Y de qué te ríes, @?!$5#$b#¿Se están juntando contra mí o algo así?$3\"/pause 500/speak Noa \"Quizás un poco~.$0\"/pause 500/emote Lala 12/pause 500/speak Noa \"Deja de hacer pucheros y termina tu bebida.$0\"/pause 500/speak Lala \"Sí, sí...$3#$b#Afortunadamente, esta es la mejor bebida del mundo.$0#$b#¡Nada puede deprimirme después de solo un sorbo de un Rainbow Colada!$1\"/pause 500/speak Noa \"Me pregunto si esa bebida es lo que te da tu energía abrumadora y caótica.$0\"/pause 500/jump Lala 5/speak Lala \"...¿¿Aplastante??$3#$b#¿¡Caótica?!$3\"/pause 500/animate farmer false true 200 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103 102 103/pause 1500/end",

//Nimue Four Heart Event
  "98890035/t 1200 1700/f Nimue 1000": "50s/8 8/farmer 8 14 0 Nimue 7 8 0 Lilia 16 0 2/skippable/playSound doorClose/emote farmer 16/pause 500/move farmer 0 -1 3/move farmer -3 0 0/move farmer 0 -5 1/pause 500/emote farmer 40/pause 500/faceDirection Nimue 3/pause 200/speak Nimue \"¿Qué...$3#$b#¿Me estás siguiendo o algo?$3#$b#¿Por qué siempre tienes que aparecer cerca de mí?$3\"/pause 500/emote farmer 28/pause 500/speak Nimue \"Hmm...$3#$b#Creo que fui un poco dura.$3#$b#No eres la PEOR compañía que podría tener, supongo.$3\"/pause 500/speak Nimue \"Y podrías estar aquí simplemente para tomar algo...$3#$b#Aunque debo decirte que este es mi lugar.$3#$b#Vengo aquí más que cualquier otra persona.$0\"/pause 500/speak Nimue \"...Bueno, más que cualquier otra persona, excepto el Capitán.$3#$b#Pero juro que ese tipo tiene un problema con el alcohol, así que no puede evitar venir aquí.$3\"/pause 500/speak Nimue \"Yo, tengo mucho más autocontrol que él.$0#$b#Solo me gusta el ambiente de este lugar.$0\"/pause 500/speak Nimue \"De todos modos...$3#$b#¿Te has familiarizado bien con los otros axolotes?$3\"/pause 500/speak Nimue \"Espero que los estés tratando bien.$3#$b#Porque si no...me aseguraré de que Rasmodius se entere.$5#$b#O mejor aún, me encargaré de ti yo misma.$5\"/pause 500/speak Nimue \"No subestimes mis habilidades solo porque soy pequeña.$5#$b#Sé lo que se necesita para hacer que alguien se rompa.$3\"/pause 500/emote farmer 28/pause 500/speak Nimue \"...Por supuesto, solo usaría tácticas como esas cuando fuera necesario.$3#$b#Solo lastimaría a alguien si me lastiman a mí y a mi gente primero.$3#$b#Solo quiero que entiendas eso.$3\"/pause 500/emote farmer 36/pause 500/speak Nimue \"¿Dices que no tienes intenciones de lastimar a nadie?$3#$b#Sí, sigues diciendo eso.$3#$b#Pero solo el tiempo dirá si estás mintiendo o no.$3\"/pause 500/speak Nimue \"Me voy.$3#$b#Supongo que nos veremos por ahí, humano.$3\"/pause 500/faceDirection farmer 2/move Nimue 0 1 3/move Nimue -1 0 2/move Nimue 0 4 1/move Nimue 2 0 2/move Nimue 0 1 2/playSound doorOpen/warp Nimue 0 0/pause 500/emote farmer 40/pause 500/changeName Lilia Shop_Owner/speak Lilia \"Oye...$3\"/pause 500/emote farmer 16/pause 500/faceDirection farmer 0/speak Lilia \"No tomes las palabras de Nimue demasiado en serio.$3#$b#Ella solo está manteniendo su guardia alrededor de ti porque eres humano.$3#$b#Estoy segura de que una vez que te conozca mejor, se relajará.$3\"/pause 500/speak Lilia \"Nimue puede ser un poco difícil de llevar al principio, pero tiene un buen corazón.$3#$b#Espero que lo llegues a comprender con el tiempo.$0\"/pause 1000/end",

//Captain Two Heart Event
  "98890044/t 1000 2200/f Captain 500/n CaptainMeet": "distantBanjo/8 8/farmer 15 10 3 Captain 12 10 1/skippable/pause 500/speak Captain \"Gracias por reunirte conmigo, @.$0#$b#Pensé que sería bueno darte una bienvenida adecuada a nuestro pueblo, especialmente ya que no estoy seguro si los demás lo han hecho todavía.$0\"/pause 500/emote farmer 32/pause 500/speak Captain \"Personalmente, no tengo razones para desconfiar de un humano, así que estoy bien con que vengas a nuestro pueblo de vez en cuando.$0#$b#Me encuentro con humanos con frecuencia en mis viajes, así que estoy bastante acostumbrado a verlos.$0\"/pause 500/emote farmer 8/pause 500/speak Captain \"¿Tienes curiosidad por mis viajes, verdad?$3#$b#Bueno, tengo muchas historias que me encantaría compartir.$1#$b#Algunas involucran piratas, otras sirenas... ¡Incluso me he encontrado con flamencos zombis en un momento!$3\"/pause 500/emote farmer 16/pause 500/speak Captain \"Sí, fue bastante salvaje.$0#$b#Pero creo que deberíamos guardar las historias para más tarde.$3#$b#Por ahora, solo quiero darte una cálida bienvenida al pueblo.$0\"/pause 500/speak Captain \"Lo que significa... ¡beber hasta saciarnos!$1\"/pause 500/speak Captain \"Ah, sí... es difícil pasar un día sin tomar algo de aquí.$0#$b#El barman es un dios en lo que hace, se lo tengo que reconocer.$0\"/pause 500/emote farmer 60/pause 500/speak Captain \"¿A veces me paso un poco?$3#$b#Nah, sé cómo mantener las cosas bajo control.$0#$b#A pesar de lo que pueda decir Nimue...$5\"/pause 500/speak Captain \"Pero no hablemos de Nimue.$3#$b#Porque apuesto a que si dices su nombre tres veces, aparecerá detrás de ti.$3#$b#Y no creo que queramos eso ahora mismo, ¡je!$1\"/pause 500/speak Captain \"De todos modos, ¿qué tal si brindamos?$0\"/pause 500/jump Captain 5/pause 200/speak Captain \"¡Por ser humano en un pueblo lleno de axolotes!$1\"/pause 500/emote farmer 60/pause 500/speak Captain \"...¿Fue eso demasiado específico?$3\"/pause 1000/end",
