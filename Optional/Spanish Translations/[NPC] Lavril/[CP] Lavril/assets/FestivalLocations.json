    //Festival Dialogue
    {
      "Action": "EditData",
      "Target": "data/festivals/spring13",
      "Entries": {
        "Lavril": "No sabía que los conejos podían poner huevos...#$b#¿Los conejos nacen de huevos?$7#$b#¿Significa esto que Vacío también puede poner huevos?$13",
        "Void": "No, Lavril. No soy un conejo de verdad. Por lo tanto, no puedo poner huevos.#$e#Suspiro."
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/spring24",
      "Entries": {
        "Lavril": "Vincent dijo que quería convertirse en la próxima reina de las flores. Espero que gane algún día.$16",
        "Void": "Si yo fuera la reina de las flores, haría que todos se inclinaran y me adoraran.#$b#Mis fieles súbditos se arrastrarían ante mí, alabando la misma tierra que piso.#$e#'Todos saluden, Dunn Nemecia.'$u#$b#%Vacío comienza a cacarear maníacamente."
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/summer11",
      "Entries": {
        "Lavril": "Umm... Recogimos algunas cerezas antes y las añadimos a la olla. Espero que a todos les gusten...$3",
        "Void": "Será mejor que no añadas nada raro a la olla. Te estoy vigilando."
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/summer28",
      "Entries": {
        "Lavril": "Las medusas lunares brillan en la oscuridad, ¿verdad?$4?#$b#Si las estrellas vuelven a perderse en la orilla, quizá las medusas puedan ayudar a guiarlas de nuevo hacia el cielo nocturno.$4",
        "Void": "...Supongo que hay pocas vistas que merezcan la pena en este mundo."
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/fall16",
      "Entries": {
        "Lavril": "Me acaban de leer la suerte... *hip*$9",
        "Void": "Esa adivina... Recuerdo lo que le dijeron a Lavril.#$b#'Vas a conocer a un sinfín de personas que te tendrán en cuenta. En poco tiempo, conocerás a los amigos que estabas esperando.'"
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/fall27",
      "Entries": {
        "Lavril": "Vacío... ¡Vuelve aquí ahora mismo!$5#$b#¡No quiero meterme en problemas!$5",
        "Void": "¡Espeluznantes esqueletos de miedo...! ¡Que te dan escalofríos!"
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/winter8",
      "Entries": {
        "Lavril": "¡E-Está resbaladizo! Casi me caigo...$13",
        "Void": "Ten cuidado de no caerte. Sería un dolor de cabeza pescarte de nuevo cuando eres una literal paleta."
      }
    },

    {
      "Action": "EditData",
      "Target": "data/festivals/winter25",
      "Entries": {
        "Lavril": "Desde que nos conocimos, tengo una sensación de calor en mi interior aunque haga frío. No sé cómo describirlo...$4#$b#Sólo quería darte las gracias. Por estar en nuestra vida.$h",
        "Void": "Lavril es mucho más feliz contigo... y supongo que yo también.#$b#Que la Estrella de Invierno te guíe.#$e#Sé que puedo ser difícil la mayor parte del tiempo. Gracias por aguantarme."
      }
    }
