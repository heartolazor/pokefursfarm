  //Object Descriptions
  "LASV_Dewdrop_Fish_Description": "Un antiguo pez llamado así por su forma.",
  "LASV_Purple_Spotted_Trout_Description": "Un pez de agua dulce que no se encuentra en el mundo humano.",
  "LASV_Relicantlette_Description": "Un pez común que se encuentra en lagos antiguos.",
  "LASV_Serafin_Description": "Un bonito pez con aletas parecidas a alas.",
  "LASV_Umuwi_Carp_Description": "Un raro pez que se encuentra en Umuwi. Parece irradiar magia.",

  "LASV_Umuwi_Aster_Description": "Una flor otoñal local que florece en Umuwi. Viene en muchos colores.",
  "LASV_Umuwi_Badak_Description": "Un ñame ovalado de color naranja. Tiene un sabor dulce con un toque de castaña.",
  "LASV_Umuwi_Calamansi_Description": "Un pequeño cítrico redondo que se encuentra en los campos de Umuwi durante todo el año.",
  "LASV_Umuwi_Makahiya_Description": "Una flor espinosa con hojas que se cierra cada vez que se toca.",
  "LASV_Umuwi_Olive_Description": "¡Una variante de la aceituna que tiene un regusto picante!",
  "LASV_Umuwi_Poinsettia_Description": "Una flor que florece en la fría tierra de Umuwi. Popular entre las mujeres de las sombras y los hombres lobo.",
  "LASV_Umuwi_Sampaguita_Description": "Una flor local de verano que florece en Umuwi. Tiene una ligera fragancia.",

  "LASV_Eggroot_Description": "Cultivo de raíz con forma de huevo que tiene un sabor rico y sabroso.",
  "LASV_Ghost_Cabbage_Description": "Casi se puede ver a través de sus hojas.",
  "LASV_Pale_Berry_Description": "Una baya de color púrpura pálido que tiene un regusto dulce calmante.",
  "LASV_Sour_Potato_Description": "Variante de la patata cultivada en Umuwi. Tiene un sabor agrio.",
  "LASV_Thorn_Pepper_Description": "Especie de pimiento espinoso y amargo.",

  "LASV_Umuwi_Lanzones_Description": "Pequeño fruto rico en antioxidantes, vitaminas y proteínas.",
  "LASV_Umuwi_Rambutan_Description": "Una fruta roja, del tamaño de una ciruela, con espinas suaves y un sabor ligeramente ácido.",

  "LASV_EmbraceFruit_Description": "Una fruta tan cálida como la presencia de Bianka. Parece reducir el dolor durante unos segundos.",
  "LASV_HastePill_Description": "Una píldora mágica aceleradora formulada por Raphael y tú. Proporciona velocidad extrema durante unos segundos.",
  "LASV_LuckyMint_Description": "Un caramelo de menta imbuido con la magia ancestral de Lunna. Aumenta la suerte de forma espectacular durante un breve periodo de tiempo.",

  "LASV_Pale_Berry_Pie_Description": "Pastel relleno de bayas pálidas de Umuwi. ¡Tiene un regusto muy dulce!",
  "LASV_Sour_Hashbrown_Description": "¡Una patata de sabor único hecha croqueta!",
  "LASV_Umuwi_Mash_Description": "¡Un puré picante y rico en almidón bueno para un frío día de invierno!",
  "LASV_Umuwi_Salad_Description": "Una ensalada hecha con productos de Umuwi. ¡Tiene un sabor dulce y salado!",

  "LASV_Eggroot_Seeds_Description": "Plantar en primavera. Tarda 14 días en producir una Raíz de huevo.",
  "LASV_Ghost_Cabbage_Seeds_Description": "Plantar en otoño. Tarda 8 días en producir una col fantasma.",
  "LASV_Pale_Berry_Seeds_Description": "Plantar en primavera. Tarda 6 días en producir bayas pálidas y vuelve a crecer después de la cosecha.",
  "LASV_Sour_Potato_Seeds_Description": "Plantar en verano. Tarda 8 días en producir una patata ácida.",
  "LASV_Thorn_Pepper_Seeds_Description": "Plantar en verano. Tarda 10 días en producir pimientos espinosos y vuelve a crecer después de la cosecha.",

  "LASV_Umuwi_Lanzones_Sapling_Description": "Tarda 28 días en producir un Lanzón maduro. Listo para cosechar en verano. Sólo crece si los 8 espacios de alrededor están vacíos.",
  "LASV_Umuwi_Rambutan_Sapling_Description": "Tarda 28 días en producir un árbol de Rambután maduro. Listo para cosechar en primavera. Sólo crece si los 8 espacios de alrededor están vacíos.",

