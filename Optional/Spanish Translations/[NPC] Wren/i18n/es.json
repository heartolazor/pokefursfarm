    "tiakall.wren.gift.neutral": "Gracias por pensar en mí, @.",
    "tiakall.wren.gift.dislike": "Aprecio la intención, pero esto no es realmente lo mío.",
    "tiakall.wren.gift.hate": "@, siento que realmente te esforzaste por encontrar algo que me disgustara tanto. Esto no es apropiado para regalar a nadie, ¿sabes?",

    //Special order
    "Wren.backyard.Name": "Manteniéndome al Nivel de los Haddad",
    "Wren.backyard.Ordertext": "Todos mis vecinos tienen jardines tan lindos, y luego estoy yo. ¡Necesito mejorar el mío para no avergonzarlos! ¿Alguien podría ayudarme a reunir algunos materiales? Y, eh, ¿quizás darme algunas ideas bonitas?",
    "Wren.backyard.Objective1": "Coloca 50 de madera en el buzón de Wren.",
    "Wren.backyard.Objective2": "Coloca 100 de piedra en el buzón de Wren.",
    "Wren.backyard.Objective3": "Dona 1 árbol de cerezo.",
    "Wren.backyard.Objective4": "Dona 12 semillas de verónica.",
    "Wren.backyard.Objective5.597": "Dona 3 plantas de Allium azul.",
    "Wren.backyard.Objective5.Wildflour.AtelierGoods_Lavender": "Dona 3 plantas de Lavanda del Bosque.",
    "Wren.backyard.Objective6.591": "Dona 6 plantas de Tulipán.",
    "Wren.backyard.Objective6.Lumisteria.SereneMeadow_ForgetMeNot": "Dona 6 plantas de Nomeolvides.",
    "Wren.backyard.rewardletter.title": "Haddad: ¡A la Altura!",
    "Wren.backyard.rewardletter": "@,^^¡Gracias por tu ayuda con mi jardín! No estaba muy seguro de qué hacer, pero me diste un montón de buenos materiales para trabajar. Amina me dio grandes ideas, y Maia{{andRipley}}vino a ayudar {{andMia}}. Realmente me hizo sentir más cerca de mis vecinos. ¡Ven a verlo cuando tengas un momento!^^--Wren",
    "Wren.backyard.andRipley": "--Ripley también--",
    "Wren.backyard.andMia": ", y Mia trajo bocadillos y bebidas para todos",


    //Map names and strings
    "tiakall.wren.freecandy": "Un pequeño letrero está adherido al cuenco con un garabato que dice 'DULCES GRATIS'.",
