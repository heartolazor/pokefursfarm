  //Deep Dark Map Strings. I wonder who Owl Boy is?
  "Strings.DeepDark.DDLakeSign0": "'¡${Bienvenido^Bienvenida}$ a Tierra de lagos! Es un lugar encantador, si puedes superar la plaga de monstruos.'#'Busca un punto de teletransporte al final de la sala para avanzar. Usa el punto de teletransporte inicial para salir de las cavernas.'#'He instalado todas estos puntos de teletransporte personalmente. ¡De nada, hoot! - Chico búho",
  "Strings.DeepDark.DDLakeSign1": "'¿Cómo DEMONIOS se supone que alguien va a llegar a ese ascensor? Aquí hay una plataforma de escape. Considera dejarme una propina.' - Chico búho",
  "Strings.DeepDark.DDLakeSign2": "'El premio por llegar al final de esta habitación es tu próximo fallecimiento. Regresa, bufón.' - Chico búho",
  "Strings.DeepDark.DDLakeSign3": "'Si te detuviste a leer esto, espero que no estés siendo ${atacado^atacada}$ por monstruos.' - Chico búho",
  "Strings.DeepDark.DDLakeSign4": "'¡¿CÓMO SALGO DE AQUÍ?! ¿¿¿DÓNDE ESTÁ LA SALIDA??? ¡HOOT! ¡HOOT!' - Chico búho",
  "Strings.DeepDark.DDLakeSign5": "'Qué hermosa vista... Cómo me gustaría compartirla con alguien...' - Chico búho",
  "Strings.DeepDark.DDLakeSign6": "'¿Por qué puntos de teletransporte cuando hay pasillos? Tú... no quieres ir por los pasillos, confía en mí.' - Chico búho",
  "Strings.DeepDark.DDLakeSign7": "'A menudo vengo aquí a pensar... Por desgracia, los monstruos hacen que sea un poco difícil en estos días.' - Chico búho",
  "Strings.DeepDark.DDLakeSign8": "'A veces tienes que parar y preguntarte...'#'Ah, maldita sea, olvidé lo que iba a escribir.' - Chico búho",
  "Strings.DeepDark.DDLakeSign9": "'¿Qué dice el búho cuando se lo está pasando bien?'#'¡Qué divertido!' - Chico búho",
  "Strings.DeepDark.DDLakeSign10": "'Jaja, ¡te he hecho mirar! ¡Hooty hoot HOOT!' - Chico búho",
  "Strings.DeepDark.DDTipTable": "Te planteas dejar propina, pero hay demasiadas plumas en la bolsa.",
  "Strings.DeepDark.DDSecretSign": "'¡Hoot HOOT! ¿¿¿Qué estás haciendo en mi casa???' - Chico búho",
  "Strings.DeepDark.DDSecretChest": "El cofre está cerrado con plumas.",
  "Strings.DeepDark.DDOwlBoySeat": "Un asiento digno de un Chico búho.",
  "Strings.DeepDark.DDDeadGuy": "Te tomas un momento de silencio para presentar tus respetos.",
  "Strings.DeepDark.DDBackpack": "La mochila está vacía, salvo por una nota que dice 'vuelve atrás'.",

