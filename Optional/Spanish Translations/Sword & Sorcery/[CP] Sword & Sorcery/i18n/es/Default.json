  // NAME & INTRO 
  "Core.Mateo.Name.Mateo": "Mateo",
  "Core.Mateo.Name.Val": "Val",
  "Core.Mateo.Name.Tay": "Tay",
  "Core.Mateo.Introduction": "Hola, granjero. ¿Por qué quebró el arqueólogo?$0^Hola, granjera. ¿Por qué quebró el arqueólogo?$0#$b#Porque su carrera estaba en las ruinas.$1",

  // COMMUNITY CENTER BUNDLES  
  "Core.Mateo.JojaBegin": "No puedo creer que Joja esté derribando el Centro Cívico, esos traidores capitalistas.$11#$b#Dejando que pisoteen pequeñas comunidades como esta es exactamente como siguen creciendo.$9",
  "Core.Mateo.CCBegin": "¿Estás empezando a revitalizar el Centro Cívico, granjero? Ese es un noble esfuerzo. Buena suerte.$32^¿Estás empezando a revitalizar el Centro Cívico, granjera? Ese es un noble esfuerzo. Buena suerte.$32",
  "Core.Mateo.CCBus": "El autobús hará que sea mucho más fácil llegar al desierto.$1#$b#Es un camino tan largo de otra manera... ¡Buen trabajo en eso, @! Realmente estás restaurando el pueblo a su antigua gloria.$32",
  "Core.Mateo.CCMinecart": "Ahora que has vuelto a poner en marcha las vagonetas, las cosas deben ser mucho más fáciles para ti.$14#$b#Incluso con un caballo, todavía tienes mucho terreno que cubrir. Gran trabajo, @.$1",
  "Core.Mateo.CCComplete": "¡El Centro Cívico tiene un aspecto fantástico! Y todo ha sido obra tuya, @?$1#$b#Increíble. ¡Has hecho un trabajo increíble! Es genial ver que se utiliza de nuevo.$80",
  "Core.Mateo.MovieTheater": "¿Quieres ir a ver una peli, @? Yo invito, ya que fuiste tú quien se tomó la molestia de reconstruir esas ruinas.$1#$b#¡Nada hace tan bien a tus arterias como una tarde llena de palomitas Flavacol!$32",

  // BIRTHDAYS
  "Core.Mateo.Winter12": "Hoy es el cumpleaños de Gunther. Es el tipo de persona a la que no tengo ni idea de cómo comprarle...$34#$b#¿Qué le regalas al tipo de persona que se regala todo? Su lista de 'por leer' es kilométrica.$21",
  "Core.Mateo.Winter19": "¡Hoy es el cumpleaños de Marlon! No tengo ni idea de lo que querría el viejo.$8#$b#Tiene acceso a todo el mejor equipo, así que quizá algo que le ayude a mantenerlo... quizá le haga una buena cena.$32",

  // END OF SEASON
  "Core.Mateo.SpringEnd": "Ya se ha acabado la primavera, ¿eh? ¿Has tenido un comienzo de año productivo?$1#$b#Supongo que estarás ocupado preparando los campos para el Verano, ¿eh?$14^Supongo que estarás ocupada preparando los campos para el Verano, ¿eh?$14",
  "Core.Mateo.SummerEnd": "¿Supongo que tus cultivos de verano están a punto de morir, @? No pasa nada. Sólo significa que es hora de cambiar; no es nada malo.$0",
  "Core.Mateo.FallEnd": "Se acerca el invierno, ¿eh? No puedo decir que lo esté deseando, pero la primavera volverá a nosotros eventualmente.$23",
  "Core.Mateo.WinterEnd": "Menos mal que ya casi hemos acabado con esta mierda de tiempo. El sol volverá a brillar pronto.$10",
  "Core.Mateo.WinterEnd.Filtered": "Menos mal que ya casi hemos terminado con este tiempo basura. El sol volverá a brillar pronto.$10",

  // SVE COMMUNITY DAY
  "Core.Mateo.CommunityCenter4": "Me alegro mucho de que todo el mundo se esfuerce por pasar tiempo juntos aquí. Es un gesto tan sano.$0",
  "Core.Mateo.CommunityCenter6": "Es tan agradable estar aquí, pasando tiempo con la gente del pueblo. Me siento tan bienvenido, y hay tanta alegría en el aire.$32",
  "Core.Mateo.CommunityCenter8": "Sinceramente, es agradable poder ponerme al día con Marlon.$11#$b#El viejo y yo no salimos mucho fuera del trabajo.$1#$b#Esta es la única vez que no me dan un sermón sobre cómo explorar mazmorras de forma segura.$1",
  "Core.Mateo.CommunityCenter10": "Me alegro de verte por aquí, @. Sólo haciendo la ronda y poniéndome al día con todo el mundo.$14#$b#A veces es difícil sacar tiempo para ver a tus amigos, así que me alegro de que la gente del pueblo se comprometa a reunirse así una vez por temporada.$1",

  // FESTIVALS
  "Core.Mateo.EggFestival": "¡El festival del huevo es mañana! El primer gran evento para dar la bienvenida al nuevo año, ¿eh?$15#$b#Espero que tus habilidades para buscar huevos estén afiladas, @, he oído que tienes una competencia bastante dura.$14",
  "Core.Mateo.FlowerDance": "Me encanta bailar, en realidad. Yo era grande en la escena del club de vuelta en la universidad, pero -$12#$b#Bueno, eso es un tipo muy diferente de baile, por lo general con mucho más licor.$13",
  "Core.Mateo.Luau": "Realmente aprecio el sentimiento del festival de mañana - la tradición es una cosa muy importante, por supuesto -$10#$b#¿Pero no parece realmente una falta de visión tirar a ciegas un montón de cosas diferentes en una sopa? Me encanta tomar riesgos, pero eso parece un poco demasiado.$9",
  "Core.Mateo.MoonlightJelly": "La celebración de mañana es mi segunda favorita, junto a la Víspera de los Espíritus.$0#$b#Puedo ver las Medusas desde la cala. Es impresionante.$12",
  "Core.Mateo.SDVFair": "¡La feria es mañana, @! ¿Vas a llevar calabazas?$11#$b#¿Y...Otros...productos...importantes?$21#$b#Sólo digo que si yo votara y todo fueran calabazas, ganarías.$15",
  "Core.Mateo.SpiritsEve": "Por lo tanto, hay algunas reglas a seguir en la víspera de los Espíritus, de cuando yo era un niño.$1#$b#Uno, siempre revisa tus dulces. Dos, llevar siempre un disfraz. Tres, ten siempre golosinas a mano para repartir.$13#$b#Por último, nunca apagues una linterna antes de medianoche. Esa es la más importante.$14",
  "Core.Mateo.IceFestival": "Festival del Hielo mañana, ¿eh?$14#$b#No soy de los que pescan, ni mucho menos. Pero puedo lanzar una bola de nieve - y, oye, si puedes esquivar un murciélago de iridio...$15",
  "Core.Mateo.NightMarket": "Oh, es verdad. El Mercado Nocturno está en marcha.$3#$b#Se me olvidaba. A lo mejor me paso a ver si tienen algo de Gotoro a la venta. Seguro que alguien ha metido algo interesante de contrabando, ¿no?$36",
  "Core.Mateo.WinterStar": "Hay tanta presión para la Fiesta de la Estrella de Invierno.$22#$b#¡No sé qué regalarle a nadie! Excepto a ti, Marlon y Gunther... Supongo que no es sólo los regalos, pero el espíritu de la temporada.$23",

  // ROMANTIC (POSITIVE) 
  "Core.Mateo.GiveFlowersA": "...¿Somos novios, Cielo? ¡Sí! La respuesta es un sí rotundo.$27#$b#Eres la luz que me guía, @, y me considero afortunado por haberme ganado tu afecto.$4",
  "Core.Mateo.GiveFlowersB": "Demonios, @. Te me has adelantado.$30#$b#Por supuesto que seré tuyo, mientras tú seas mío igualmente.$31^Por supuesto que seré tuyo, mientras tú seas mía igualmente.$31#$b#Gracias, Cielo. No me había sentido así en... bueno, en mucho tiempo.$4",
  "Core.Mateo.GivePendant": "%Mateo mira fijamente el colgante, te lo quita con mano temblorosa y se lo pone en el cuello.#$b#Sí quiero.$4#$b#%Te tira de un beso, sumergiéndote con un toque dramático.$18#$b#Te he robado el corazón, pero te prometo, @ - que cuidaré bien de él.$31",
  "Core.Mateo.StardropGiftA": "¡Buenos días, Cielo! No te vas a creer lo que he encontrado en las profundidades de la oscuridad.$1#$b#Sé que te dará un empujón extra, y trabajas tan duro - te lo mereces.$32#$b#Ten un día increíble, ¿vale?$11#$b#%Mateo se inclina hacia delante y te besa en la frente.",
  "Core.Mateo.StardropGiftB": "¡Buenos días, Cielo! No te vas a creer lo que he encontrado en la Caverna Calavera.$1#$b#Sé que te va a dar un empujón extra, y tú que trabajas tan duro te lo mereces.$32#$b#Ten un día increíble, ¿vale?$11#$b#%Mateo se inclina hacia delante y te besa en la frente.",

  // ROMANTIC (NEGATIVE)
  "Core.Mateo.DanceRejection": "Lo siento @, prefiero no avergonzar a ninguno de los dos.$21",
  "Core.Mateo.Divorced": "...Yo estaba comprometido contigo. Eras mi todo. Y lo has tirado todo por la borda, ¿y para qué? ¿Para seguir enemistándote conmigo después de que todo está dicho y hecho?$6#$b#Por favor, solo mantente fuera el resto de mi vida.$5",
  "Core.Mateo.BreakUp": "Oh... supongo que no leí bien la habitación, ¿eh? Lo siento, cieli- @.$16#$b#Te dejaré en paz, sólo pensé que, después de todo, teníamos algo real.$19",
  "Core.Mateo.DumpedGirls": "Supongo que no eres la persona que pensé que eras, @.$8#$b#Esperaba algo mejor. Todo el mundo tiene su equipaje. Simplemente me niego a cargarlo por ti.$9",
  "Core.Mateo.SecondChanceGirls": "...Considérate afortunado de que no suelto fácilmente lo que es mío, @.$4^...Considérate afortunada de que no suelto fácilmente lo que es mío, @.$4#$b#Sólo no lo estropees de nuevo, ¿de acuerdo? Mi corazón sólo puede soportar hasta cierto punto.$28",
  "Core.Mateo.Reject2HA": "No gracias, granjero. No quiero que el pueblo venga a por ti con antorchas y horcas.$24^No gracias, granjera. No quiero que el pueblo venga a por ti con antorchas y horcas.$24",
  "Core.Mateo.Reject2HB": "Granjero, ¿sabes lo que es una mala idea? Esto, se parece a esto de aquí.$10^Granjera, ¿sabes lo que es una mala idea? Esto, se parece a esto de aquí.$10",
  "Core.Mateo.Reject4HA": "@, aprecio esto, y te aprecio, pero es un no por ahora - Tengo que trabajar en mí primero.$21",
  "Core.Mateo.Reject4HB": "Lo siento, @. No puedo. Será un lío para los dos. No estoy listo para una relación y lo último que quiero hacer es lastimar a mi mejor amigo.^Lo siento, @. No puedo. Será un lío para los dos. No estoy listo para una relación y lo último que quiero hacer es lastimar a mi mejor amiga.$16",
  "Core.Mateo.EngageA": "...¿No estás prometido? No me va esto. Y no pensé que fueras del tipo poco sincero.$34^...¿No estás prometida? No me va esto. Y no pensé que fueras del tipo poco sincera.$34",
  "Core.Mateo.EngageB": "Tu boda es en unos días, ¿y así es como actúas? Debería decírselo a tu cónyuge, no sea que le rompas el corazón.$22",
  "Core.Mateo.MarriedA": "Este tipo de cosas vuelven a perseguirte, @. Lo que se repite, se repite. Tu cónyuge se merece algo mejor.$23",
  "Core.Mateo.MarriedB": "¿Qué demonios te pasa, @? Tu pareja se merece algo mejor. No esperaba un infiel de ti.$33",
  "Core.Mateo.RefusalNoHeartsA": "La tradición del colgante de sirena se remonta siglos atrás. Bueno para quien se lo regales.$32",
  "Core.Mateo.RefusalNoHeartsB": "Tenemos una tradición bastante diferente en las Islas Helecho. Esto es muy bonito, sin embargo - ¡buena suerte!$32",
  "Core.Mateo.RefusalKnownA": "Esto sería mono si no fuera tan raro. Gracias pero no gracias, supongo?$34",
  "Core.Mateo.RefusalKnownB": "¿Realmente quieres meterte en problemas, eh? Me siento halagado, más o menos. Pero no.$37",
  "Core.Mateo.RefusalBotherA": "No fue gracioso o lindo la primera vez, ¿qué te hace pensar que esto es mejor?$22",
  "Core.Mateo.RefusalBotherB": "Basta ya, @. Cuesta mucho llegar hasta aquí pero estás cruzando la línea de hacerme sentir incómodo.$23",

  // RESORT
  "Core.Mateo.ResortEntering": "¡Este lugar es increíble! Me hace sentir como si estuviera de vuelta en las Islas Helecho. Tío, qué nostalgia.$1",
  "Core.Mateo.ResortLeaving": "Hoy ha sido un buen día, pero ya he tenido suficiente. Nada mejor que una ducha después de la playa. Hay que quitarse toda la crema solar.$0",
  "Core.Mateo.ResortShore": "He visitado un montón de diferentes islas, @. Pero una cosa a tener en cuenta: todas ellas comparten el mismo cielo.$4",
  "Core.Mateo.ResortUmbrella": "Sólo tomándome un pequeño descanso de correr por ahí, @. Asegúrate de ponerte crema solar si vas a pasar mucho tiempo fuera.$32",
  "Core.Mateo.ResortWander": "Sé que vivo en una playa, pero todavía hay algo especial acerca de visitar una diferente.$1",
  "Core.Mateo.ResortWander.2": "Necesito unas buenas gafas de sol. Los grandes, que las chicas de ciudad con clase llevan.$35",
  "Core.Mateo.ResortChair": "Probablemente podría dormirme aquí, pero me duermo como una piedra y probablemente perdería el barco de vuelta.$6",
  "Core.Mateo.ResortBar": "Deberíamos brindar por tu duro trabajo, @. Sin ti, esto no se habría montado.$12",
  "Core.Mateo.ResortTowel": "%Mateo parece completamente relajado.",
  "Core.Mateo.ResortTowel.2": "Pasé muchos días en la universidad bebiendo en la playa en lugar de escribir trabajos...$15",
  "Core.Mateo.Resort_Towel.3": "Este sería un gran lugar para hacer una fiesta.$13",
  "Core.Mateo.Resort": "¿Construiste una casa aquí, @? Un hogar lejos de casa. ¡Muy bonito!$1",

  // ADDITIONAL LOCATIONAL DIALOGUE
  "Core.Mateo.Saloon.4h": "Es tan agradable estar de vuelta aquí, @. Me encanta estar rodeado de gente. Todo el mundo es tan jovial y es tan fácil sentirse relajado junto a ellos. Me siento bienvenido, y lleno.$4",
  "Core.Mateo.Saloon.6h": "Me encanta pasar el tiempo aquí porque es una gran manera de ver a todo el mundo a la vez. Ver a la gente es muy divertido...$0#$b#Demetrius tiene dos pies izquierdos, y Marnie es demasiado buena para Lewis. Ojalá Marlon se armara de valor para hacer un movimiento.$36",
  "Core.Mateo.Saloon.8h": "No hay mejor manera de pasar una noche que entre amigos. Me alegro mucho de que me convencieras de que merecía la pena volver a integrarme, @. Me encanta salir con todo el mundo.$12#$b#Te debo una copa. Demonios, te debo unas cuantas.$14",
  "Core.Mateo.Saloon.10h.Platonic": "Oye, @. ¿Qué tal si tú y yo salimos un rato? Probablemente necesites un poco de descanso y relajo después de un largo día. Algo de tiempo para descansar se gana.$1",
  "Core.Mateo.Saloon.10h.Romantic": "Oye, Cielo. ¿Qué tal si tú y yo nos tomamos unas copas y nos desmelenamos un poco? Menos mal que la granja no está tan lejos, si es que llegamos.$31",

  "Core.Mateo.ArchaeologyHouse.4h": "Es tan nostálgico aquí... es como pasar el tiempo en la casa de mi infancia.$12#$b#No me di cuenta de lo mucho que echaba de menos este lugar hasta que volví a él.$32",
  "Core.Mateo.ArchaeologyHouse.6h": "Hace mucho tiempo que no leo por ocio, así que vuelvo a empezar con algunos de mis favoritos.#$b#Tener que leer para el colegio realmente le quita la gracia.",
  "Core.Mateo.ArchaeologyHouse.8h": "Me encanta ver a todo el mundo entrar y salir, aprendiendo, leyendo, relajándose. Nada me hace más feliz que ver a la gente comprometerse con la academia.$32#$b#Especialmente los niños; todos están tan ansiosos por aprender, y eso me encanta. Bendita sea Penny y su interminable paciencia.$1",
  "Core.Mateo.ArchaeologyHouse.10h.Platonic": "Sé que estás ocupado @, pero vale la pena sacar tiempo para un buen libro. Estoy releyendo El Gran Gatsbish, es uno de mis favoritos.$4^Sé que estás ocupada @, pero vale la pena sacar tiempo para un buen libro. Estoy releyendo El Gran Gatsbish, es uno de mis favoritos.$4",
  "Core.Mateo.ArchaeologyHouse.10h.Romantic": "Estoy releyendo El Gran Gatsbish; es mi libro de cabecera. Siempre me he identificado profundamente con él, como si fuera el guión de cómo debía transcurrir mi vida, pero...$2#$b#Gats quedó atrapado en la marea de su propia visión equivocada y no pudo remar hacia adelante. Pero ya no me identifico tanto con su lucha, porque pude dejar el pasado donde pertenecía.$12#$b#Eso no significa que la novela me guste menos. Pero quizá debería empezar a buscar una nueva favorita.$32",

  "Core.Mateo.AdventureGuild.4h": "¡Salve y bien hallado, aventurero! Cielos, suena cursi, ¿no?$1^¡Salve y bien hallado, aventurera! Cielos, suena cursi, ¿no?$1",
  "Core.Mateo.AdventureGuild.6h": "¡Salve y bien hallado, aventurero!$1^¡Salve y bien hallado, aventurera!$1#$b#Hah, eso me está gustando. Aunque quizá debería dejarle los saludos a Marlon.$32",
  "Core.Mateo.AdventureGuild.8h": "¡Hola, @! Saludos y bien hallado. ¿Vienes a por equipo nuevo? ¿O tal vez descargar algo viejo?$36#$b#Marlon te tiene cubierto. Mantente a salvo abajo, ¿de acuerdo?$32",
  "Core.Mateo.AdventureGuild.10h.Platonic": "Hola, @, salve y bien hallado. ¿Estás explorando un poco? ¿Tienes todo lo que necesitas?$32#$b#¿Tienes tus armas a buen recaudo? Sólo mantente a salvo ahí abajo, ¿de acuerdo? Ten cuidado.$1",
  "Core.Mateo.AdventureGuild.10h.Romantic": "¡Salve y bien hallado, Cielo! ¿Tienes todo lo que necesitas? ¿Tienes tus armas a buen recaudo?$31#$b#Mantente a salvo si vas a bajar a las minas, ¿de acuerdo? Te amo.$29",

  // PLAYER DEATH
  "Core.Mateo.PlayerKilled.Mines.01": "¡Cielo!",
  "Core.Mateo.PlayerKilled.Mines.02": "Cielo, ¿qué ha pasado? ¡Lo siento mucho!",
  "Core.Mateo.PlayerKilled.Mines.03": "¡Por favor, ten más cuidado! Incluso los aventureros expertos como tú pueden resultar gravemente heridos!$2^¡Por favor, ten más cuidado! Incluso las aventureras expertas como tú pueden resultar gravemente heridas!$2#$b#Tal vez deberías irte a casa y descansar un poco antes de volver a bajar, ¿vale?$21",

  "Core.Mateo.PlayerKilled.Skull.01": "¿...@?",
  "Core.Mateo.PlayerKilled.Skull.02": "Tranquilo, ahora... tómatelo con calma.^Tranquila, ahora... tómatelo con calma.",
  "Core.Mateo.PlayerKilled.Skull.03": "¡Estás despierto! Gracias a Dios. ¡Mateo te encontró en la Cueva de la Calavera!$2^¡Estás despierta! Gracias a Dios. ¡Mateo te encontró en la Cueva de la Calavera!$2",
  "Core.Mateo.PlayerKilled.Skull.04": "¡Cielo!$18#$b#¡Estaba tan preocupado, que te hicieran daño era mi peor pesadilla!$19",
  "Core.Mateo.PlayerKilled.Skull.05": "¿Estarás bien, Harv?$29",
  "Core.Mateo.PlayerKilled.Skull.06": "Estarás bien, pero debes tener más cuidado la próxima vez.$2",
  "Core.Mateo.PlayerKilled.Skull.07": "Los dejo para que hablen; avísenme si necesitan algo.$2",
  "Core.Mateo.PlayerKilled.Skull.08": "Tenía tanto miedo de perderte, @. No sé qué haría sin mi mejor amigo, el amor de mi vida.$17^Tenía tanto miedo de perderte, @. No sé qué haría sin mi mejor amiga, el amor de mi vida.$17#$b#¡Por favor, pide ayuda si la necesitas la próxima vez, Cielo! ¡Prefiero correr peligro contigo a que vayas solo a la Caverna Calavera!$19^¡Por favor, pide ayuda si la necesitas la próxima vez, Cielo! ¡Prefiero correr peligro contigo a que vayas sola a la Caverna Calavera!$19",

  // GREEN RAIN
  "Core.Mateo.GreenRain": "Nunca había visto llover así, ni siquiera con todo el tiempo que pasé en Pueblo Pelícano de niño. Espero que sea un buen presagio.$37",
  "Core.Mateo.GreenRainFinished": "La lluvia fue bastante intensa, pero no pareció tener efectos secundarios negativos. ¡Todo está tan exuberante ahora mismo!$1",
  "Core.Mateo.GreenRain2": "Algo me dice que Hector tiene algo que ver con la lluvia extraña. ¿Qué piensas, @?$14",

  // POLYAMORY 
  "Core.Mateo.MarriedMonogamousNPC": "¡Lo siento, @! Me siento halagado, pero estás con una pareja monógama, así que estaría entrometiéndome en las reglas de su relación.$16",

