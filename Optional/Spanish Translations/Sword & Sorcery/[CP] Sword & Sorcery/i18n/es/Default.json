  // SUMMIT DIALOGUE 
  "CFD.Cirrus.ExtraDialogue_SummitEvent_Intro_Cirrus": "Oh Estrella de Rock, mi Estrella de Rock.$4",
  "CFD.Cirrus.ExtraDialogue_SummitEvent_Intro2_Cirrus": "De todas las cosas increíbles que he visto viajando por el mundo, ésta es la mejor.$6",
  "CFD.Cirrus.ExtraDialogue_SummitEvent_Dialogue1_Cirrus": "Han pasado %year años, ¿no? ¿Desde que llegaste aquí?$1",
  "CFD.Cirrus.ExtraDialogue_SummitEvent_Dialogue2_Cirrus": "Gracias por amarme y por pasar algunos de ellos conmigo - y, espero, el resto de ellos.$6",
  "CFD.Cirrus.ExtraDialogue_SummitEvent_Dialogue3_Cirrus": "Te amo, multiplicado por infinito, por cada estrella que hay en el cielo.
  $4",
  "CFD.Cirrus.ExtraDialogue_SummitEvent_Dialogue4_Cirrus": "¡Te amo, te amo, te amo, te amo, te amo...!$26",
  "CFD.Cirrus.ExtraDialogue_SummitEvent_closingmessage": "Ha sido un largo camino para ti y Cirrus...",

  // MOVIE INVITATION - SPOUSE 
  "MovieInvite_Spouse_Cirrus": "¡Por supuesto, Estrella de rock! Espero que hayas elegido algo bueno. Si no, estoy segura de que podemos descubrir algo más que hacer en la oscuridad.$24",


  // CUSTOM WEDDING
  "CFD.Cirrus.Utility.cs.5371": "@, Cirrus - cuyo pelo juraría que ayer era de otro color... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Cirrus.Utility.cs.5373": "@, Cirrus - cuyo pelo juraría que ayer era de otro color... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Cirrus.Utility.cs.5375": "@, Cirrus - cuyo pelo juraría que ayer era de otro color... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Cirrus.Utility.cs.5377": "@, Cirrus - cuyo pelo juraría que ayer era de otro color... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Cirrus.Utility.cs.5367": "Llega un momento en la vida de todos en que nos cruzamos con alguien de forma inesperada.#$b#Cuando eso ocurre, todo parece ralentizarse para que puedas apreciar a la persona que amas por primera vez.$h#$b#Dicho esto, es un honor para mí en este día {0} de {1}, unir a @ y Cirrus en los lazos del matrimonio, para que puedan apreciarse el uno al otro para siempre.",
  "CFD.Cirrus.Utility.cs.5369": "Llega un momento en la vida de todos en que nos cruzamos con alguien de forma inesperada.#$b#Cuando eso ocurre, todo parece ralentizarse para que puedas apreciar a la persona que amas por primera vez.$h#$b#Dicho esto, es un honor para mí en este día {0} de {1}, unir a @ y Cirrus en los lazos del matrimonio, para que puedan apreciarse el uno al otro para siempre.",

