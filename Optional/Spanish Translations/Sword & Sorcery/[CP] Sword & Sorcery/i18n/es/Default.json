  // BUILDING THE COASTAL GUILD & ES SPECIAL ORDER BOARD 
  "Quests.Mateo.SpecialOrders.BuildGuild.Name": "Petición de Mateo",
  "Quests.Mateo.SpecialOrders.BuildGuild.Text": "¡Marlon y yo necesitamos algunos suministros para el tablero de construcción y de pedidos!",
