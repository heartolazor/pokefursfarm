  // MATEO WEDDING 
  "MateoWedding.1": "Gracias a todos por estar aquí.$0#$b#Agradezco que me hayan dado la oportunidad de oficiar la boda de uno de mis mejores miembros del gremio, @.$1",
  "MateoWedding.2": "Y de un querido amigo, Mateo.$1",
  "MateoWedding.3": "Gracias Marlon.",
  "MateoWedding.4": "¿Listo, sol?",
  "MateoWedding.5": "Como Maestro del Gremio de Aventureros, es un placer para mí declarar a Mateo y a @ como cómplices en el crimen.$0#$b#Ahora pueden besarse.$1",

  // HECTOR WEDDING
  "HectorWedding.1": "Sí.",
  "HectorWedding.2": "No.",
  "HectorWedding.3": "¡Demasiado! Estás atrapado conmigo ahora.$13",
  "HectorWedding.4": "¡Eli, baja el volumen!",
  "HectorWedding.5": "Rosa, ¿tienes alguna idea de quién es?$2",
  "HectorWedding.6": "Ni idea, nunca he visto a {{HPN2}} antes...$3#$b#¿Aparentemente residente de East Scarp?$3",
  "HectorWedding.7": "Es raro que nunca antes hayamos visto a esta Abeja Pícara.$1#$b#Me pregunto si alguien más tiene...'",
  "HectorWedding.8": "¡Ese es Biróg, {{HPN1}} trabaja en la clínica veterinaria con mi padre!$1#$b#¡{{HPN1}} es un lobo muy amable!$0",
  "HectorWedding.9": "¿Lobo?",
  "HectorWedding.10": "¡Sí!$1",
  "HectorWedding.11": "Deja que el niño imagine.",
  "HectorWedding.12": "Hola, Eloise, ¿estás lista para esta boda?$6",
  "HectorWedding.13": "¡Sí! ¿Deberíamos empezar?$1",
  "HectorWedding.14": "Yo y mi amado ciervo, están preparados para esto, ¡llévatelo!$6",
  "HectorWedding.15": "¡Ejem!",
  "HectorWedding.16": "¡Todos! ¡Atención por aquí!",
  "HectorWedding.17": "¡Estamos todos reunidos aquí hoy para celebrar la boda de Biróg y @!#$b#¡Empecemos!$1",
  "HectorWedding.18": "Biróg, ¿tomas a @ como tu ${marido^esposa^cónyuge}$?$1",
  "HectorWedding.19": "Mira a mi Eloise...",
  "HectorWedding.20": "@, ¿consideras a Biróg como tu lobo desposado?$1",
  "HectorWedding.21": "Entonces, como tu mejor amigo, es un placer unir a @ y a Biróg en los lazos del matrimonio.$0#$b#¡Ahora los declaro socios!$1",
  "HectorWedding.22": "¿Es esta la parte en la que nos besamos?$9",
  "HectorWedding.23": "¡Sí!",
  "HectorWedding.24": "Entonces hagamos eso.$8",

  // CIRRUS WEDDING
  "CirrusWedding.1": "¿Están listos, tortolitos, para casarse finalmente?$0^¿Están listas, tortolitas, para casarse finalmente?$0",
  "CirrusWedding.2": "¡No podría estar más preparada!",
  "CirrusWedding.3": "¡No están listos para la sorpresa especial!$1^¡No están listas para la sorpresa especial!$1",
  "CirrusWedding.4": "¿Sorpresa especial?",
  "CirrusWedding.5": "¡Ejem!",
  "CirrusWedding.6": "¡Gracias a todos por asistir a esta boda!$1#$b#Es un honor para mí estar aquí y tener la oportunidad de oficiar esta increíble y perfecta boda.$0",
  "CirrusWedding.7": "Pero antes de pasar a la parte principal, me gustaría presentarle mi regalo a esta encantadora pareja.$0#$b#Cirrus, @, ¡espero que lo disfruten!$1",
  "CirrusWedding.8": "Me gustaría tocar una de las canciones de Cirrus para todos los presentes, ¡pero especialmente para @ y Cirrus!$1",
  "CirrusWedding.9": "Libro...",
  "CirrusWedding.10": "Gracias, Libro.",
  "CirrusWedding.11": "¡Cirrus, de nada!",
  "CirrusWedding.12": "¡Espero que ustedes dos lo hayan disfrutado! ¡Pasé tanto tiempo aprendiendo a tocar el keytar sólo por este momento!$0",
  "CirrusWedding.13": "*sollozo* ¡Fue perfecto!",
  "CirrusWedding.14": "Seca esas lágrimas, Cirrus, es tu gran día, ¡deberías estar sonriendo!$0",
  "CirrusWedding.15": "¡Y hablando de tu gran día!$0#$b#¡Estoy orgullosa de poder declararlos a los dos como tortolitos por toda la eternidad!$0^¡Estoy orgullosa de poder declararlas a las dos como tortolitas por toda la eternidad!$0",
  "CirrusWedding.16": "¡Ahora pueden besarse!$1",

  // VIOLET MOON
  "DN.SnS_Violet_Moon_Shop_Mateo": "¡Salve y ${bienvenido, aventurero^bienvenida, aventurera}$! ¿Buscas protegerte?",
  "DN.SnS_Violet_Moon_Shop_Hector": "Tienes dos manos. Una de ellas es para la regadera y la otra para la bolsa de semillas.",
  "DN.SnS_Violet_Moon_Shop_Cirrus": "Déjame adivinar, ¿alguien te 'robó' tu dulce panecillo?",
  "DN.SnS_Violet_Moon_Shop_RnD": "Solía ​​ser una aventurera como tú, hasta que Dandelion golpeó a un Behemot Duskspire en la rodilla.",
  "DN.SnS_Violet_Moon_Shop_HatMouse": "Hola, empuja. ¿Ganaste juegos? Dios. Yo vendo sombreros.",
  "VioletMoon.Mateo.1": "Recuerda, ¡solo tú puedes prevenir los incendios forestales! ¡Apaga tus cigarrillos en el receptáculo designado!$1",
  "VioletMoon.Mateo.2": "Me encanta el concurso de fuerza en la Feria del Valle, pero definitivamente prefiero lucirme en el campo de tiro con arco.$14",
  "VioletMoon.Mateo.3": "Me siento bastante hechizado por la luz de la luna, @. ¿Y tú?$15",
  "VioletMoon.Hector.1": "De hecho, las raíces del Árbol Madre llegan hasta aquí. Su influencia es bastante sustancial, @.$6",
  "VioletMoon.Hector.2": "Sí, sí. Es muy bonito aquí arriba. Aunque es una mierda si tienes miedo a las alturas.$8",
  "VioletMoon.Hector.3": "Al compartir estas semillas con todos los interesados, tienen más posibilidades de volver a estar en circulación ecológica regular.$23",
  "VioletMoon.Cirrus.1": "Apuesto a que este lugar se ve tan bonito al amanecer como al atardecer.$13",
  "VioletMoon.Cirrus.2": "¿Dónde encontramos todos esos caballos? ¿Son Jacobs?$16",
  "VioletMoon.Cirrus.3": "¡Come, bebe y cásate con un imitador medieval de Elvis!$14",
  "VioletMoon.Dandelion.1": "Mi peso máximo para un arco bajo es 84 kilos, ¿qué tal el tuyo?$18",
  "VioletMoon.Dandelion.2": "Es tremendamente agradable que la gente haya venido desde Pueblo Pelícano para esto. ¡Esperamos que disfruten del espectáculo!$13",
  "VioletMoon.Dandelion.3": "Llevar las botellas de pociones montaña arriba fue un ejercicio excelente.$1",
  "VioletMoon.Roslin.1": "No me gustan mucho los festivales, pero con este soy parcial. Buenos recuerdos de bodas y lo que sea.$7",
  "VioletMoon.Roslin.2": "Por última vez, no es mercadotecnia multinivel, ¡estas esencias y pociones REALMENTE funcionan!$5.",
  "VioletMoon.Roslin.3": "Hay excelentes componentes de hechizos escondidos en lo profundo del bosque.$10",
  "VioletMoon.Solomon.1": "Me comeré todos los huevos escoceses y luego tomaré una siesta en una caja.$6.",
  "VioletMoon.Solomon.2": "¡Una vez más, todos estos tontos humanos piensan que estoy usando un disfraz! Creo que dejaron sus células cerebrales en Pueblo Pelícano.$3",
  "VioletMoon.Solomon.3": "Krobus está siendo productivo y eso es genial, pero lo que más quiero es causar problemas ya que estoy rodeado de gente.$10",
  "VioletMoon.Aideen.1": "Quizás el año que viene tenga mi propio puesto de arreglos florales... Creo que las coronas de flores no deberían limitarse a la primavera sólo cuando el otoño tiene sus propias flores encantadoras.",
  "VioletMoon.Aideen.2": "Esperaba ver esta zona repleta de zarzas y basura, pero creo que está bastante limpia. Al alcalde Lewis debe resultarle una agradable sorpresa que sus deberes cívicos no sean necesarios aquí.",
  "VioletMoon.Aideen.3": "Colores tan extraños y vívidos... Son casi demasiado atrevidos para mi gusto pero tal vez... ¿Quizás llamarían la atención de algún vizconde que pasara?",
  "VioletMoon.Beatrice.1": "¿Sabes... de dónde soy? Lo real solía suceder. Esta es una versión mucho más amable.$1",
  "VioletMoon.Beatrice.2": "Nos vendría bien más sopas. El año que viene, me llevaré a Cirrus y le enseñaré a hacer una sopa tan reconfortante, traerá a la gente desde Gotoro para disfrutar.",
  "VioletMoon.Beatrice.3": "Ah... Esa luna es tan bonita. Deberías disfrutarla con alguien especial... si mi marido siguiera con nosotros, esta noche estaríamos juntos mirando la luna.$1",
  "VioletMoon.Eloise.1": "¿Crees que quizás el año que viene hagan exhibiciones de cetrería? ¡Creo que algún día me gustaría conocer a un cetrero de rehabilitación de vida silvestre y a sus amigos!",
  "VioletMoon.Eloise.2": "¡Hector me hizo una corona mágica de flores sólo por hoy! ¿Mmm? ¿No puedes verla? ¡Quizás no seas lo suficientemente mágico!^¡Hector me hizo una corona mágica de flores sólo por hoy! ¿Mmm? ¿No puedes verla? ¡Quizás no seas lo suficientemente mágica!",
  "VioletMoon.Eloise.3": "Ojalá papá me deje elegir un escudo de juguete... Mateo tiene uno con una tórtola pintada, ¡me queda perfecto!",
  "VioletMoon.Eyvinder.1.true": "Hay una historia secreta oculta para aquellos que se atreven a buscarla. No dejes que la cobardía te detenga.",
  "VioletMoon.Eyvinder.2.true": "Nadie parece estar interesado en disfrazarse de mi gente y por eso estoy agradecido. No creo que me guste ver los fantasmas de mis antepasados.",
  "VioletMoon.Eyvinder.3.true": "El aguamiel fluye libremente y eso es todo lo que puedo pedir - Mira a esa muchacha Cirrus si buscas algo menos alcohólico.",
  "VioletMoon.Eyvinder.1.false": "¿Un disfraz? ¡Bah, has bebido demasiado hidromiel!",
  "VioletMoon.Eyvinder.2.false": "Las atracciones están cerca del barco y yo no soy una de ellas.",
  "VioletMoon.Eyvinder.3.false": "Mi gente conocía esta tierra mucho antes de que ese barco atracara aquí... No estoy hablando de 'farfulla'.",
  "VioletMoon.Jacob.1": "No puedo decir que los caballos de carreras sean mis pacientes habituales, pero me complace informar de que los reunidos hoy aquí se encuentran en unas condiciones maravillosas y bien cuidados.",
  "VioletMoon.Jacob.2": "Ojalá Eloise no empiece de repente a luchar con espadas... No sé si estoy lista para que ella vaya a la escuela armada con una espada de madera. Está creciendo demasiado rápido.",
  "VioletMoon.Jacob.3": "He hecho algunos paseos a caballo - Por supuesto, viviendo aquí, ¿quién no lo ha hecho? Pero no sé si tengo madera de jockey.",
  "VioletMoon.ToriLK.1": "Me pregunto si hay algún truco para realizar babas aquí... He visto ratas actuar en otras ferias de ren, ¿por qué no babas?",
  "VioletMoon.ToriLK.2": "Debí haberme disfrazado para la ocasión pero tenía miedo de parecer tonta. Supongo que debería haberme arriesgado, siento que ahora destaco más con mi ropa normal.",
  "VioletMoon.ToriLK.3": "Me aseguré de hacer un presupuesto para hoy para no sentirme tentada por algo sofisticado que nunca usaría. Aunque hay muchas opciones de comida para probar, por lo que de todos modos podría terminar gastando más dinero del que planeé.",
  "VioletMoon.Rosa.1": "No creo haber visto nunca una luna como esta... hace que el aire se sienta absolutamente mágico. Podría extender la mano y tocarla, si quisiera.",
  "VioletMoon.Rosa.2": "Mucha gente se acercó y felicitó a Juliet por su disfraz. Sigo pensando que debería haber elegido el traje de pirata, pero esto sigue siendo bonito y acorde con el tema.#$b#...Quise decir bonita*en*tema.$4",
  "VioletMoon.Rosa.3": "Nadie ofreció pastel de embudo este año - Ya presenté una 'queja' ante Cirrus y Gus para el próximo año. Creo que haré algunos yo misma.",
  "VioletMoon.Juliet.1": "¡Voy a arrancar esa gran luna violeta del cielo y dársela a alguien especial! ¿OMS? Bueno, ¡eso es un secreto!",
  "VioletMoon.Juliet.2": "A Gremlin no le gustan los caballos. Lo cual, lo entiendo totalmente - Si me enfrentara a algo que se pareciera a un humano pero que fuera diez veces más grande que yo, ¡yo también me asustaría!",
  "VioletMoon.Juliet.3": "Lewis ya sugirió que pudiera ser parte del equipo de limpieza, pero Mateo entró en acción y me eximió de ser voluntaria.",
  "VioletMoon.Jessie.1": "Linus y yo hemos visto todo tipo de amigos lejanos hoy. Amigos *muy* lejanos, además. Es agradable ver a esos amigos sentirse libres de ser parte de la celebración.",
  "VioletMoon.Jessie.2": "Hay muchos lugares que ver y cosas que hacer, pero recuerda centrarte en la experiencia y no preocuparte por intentar inmortalizarla con medios materiales.",
  "VioletMoon.Jessie.3": "Disfruté el paseo en bote, pero de alguna manera la vista desde tierra es incluso más impresionante que la que se ve desde el agua. Espero poder volver a verlo pronto.",
  "VioletMoon.Jasper.1": "En mi opinión, este es posiblemente uno de los conjuntos de Smoluanu con mayor precisión histórica que he visto en mi vida. Ojalá el tendero me dejara hablar con ellos después del festival.",
  "VioletMoon.Jasper.2": "Hay una interesante selección de productos disponibles; No puedo decir que necesite bombas muy a menudo, pero disfruto navegando para ver al menos qué hay disponible.",
  "VioletMoon.Jasper.3": "En festivales como este, siempre hay un poco de fantasía ligada a lo mundano - un barniz fantástico sobre la historia que la hace quizás más emocionante, aunque no del todo precisa.",
  "DN.SnS.Festival.Name": "Feria del Renacimiento de la Luna Violeta",
  "DN.SnS.Festival.Speak.Abigail": "Tan pronto como mamá y papá no miren, me inscribiré en una carrera de equitación.#$b#¡Me veo TAN BIEN con armadura! Tal vez incluso pueda demostrar algunas técnicas con la espada... ¡Oh, tal vez pueda batirme en duelo con alguien!$1#$b#¿Qué dices tú, @?",
  "DN.SnS.Festival.Speak.Robin": "¿Crees que hay algún negocio en el emplumado de flechas? Es muy tentador, ¿no crees, mi apuesto caballero Demetrius?$1",
  "DN.SnS.Festival.Speak.Demetrius": "Creo que sería más un historiador del castillo que un caballero - mi encantadora dama Robin. Y cualquier cosa que te propongas puede convertirse en un negocio, ¡eres brillante, cariño!$1",
  "DN.SnS.Festival.Speak.Maru": "La Luna de la Cosecha suele ser la luna llena más brillante al comienzo del otoño.#$b#¡Los agricultores de antaño podían cosechar hasta bien entrada la noche gracias a lo brillante que era la luna!$3#$b#... Desafortunadamente, no son típicamente violetas. Quizás el año que viene ~$1",
  "DN.SnS.Festival.Speak.Sebastian": "¡Esto es EXACTAMENTE como las Crónicas Solarianas! Estaría disfrazado si me hubiera dado cuenta de que podría haberme salido con la mía... tal vez el año que viene le pediré uno a Emily.",
  "DN.SnS.Festival.Speak.Pierre": "Mmm, debería adaptar mis productos para esta ocasión - ¡Quizás ofrezca algunas de las mejores calabazas y manzanas de la tienda de Pierre! Se venderán como pan caliente.$1",
  "DN.SnS.Festival.Speak.Caroline": "Oh, simplemente no puedo localizar a Abby por ninguna parte... ¡Y sé que se acercará a uno de esos caballeros a caballo y le pedirá un turno!$2#$b#Creo que en su lugar sería un buen abanico con un pañuelo, ¿no? Y es mucho más seguro...",
  "DN.SnS.Festival.Speak.Linus": "Todos los puestos de comida ofrecen amablemente muestras gratis. Después de todo, la generosidad ha sido una tradición eterna a través de los siglos.",
  "DN.SnS.Festival.Speak.Alex": "Debería haber algo en lo que realmente pueda mostrar mi destreza física. Las carreras de caballos son geniales, pero el caballo es el fuerte en eso, ¿verdad? No el jinete.",
  "DN.SnS.Festival.Speak.George": "Bah. En mis tiempos, corríamos a pie, cuesta arriba por toda la maldita pista, ¡y nos gustaba!",
  "DN.SnS.Festival.Speak.Evelyn": "Ha sido tan encantadora la cantidad de gente que me ha llamado 'Señora Evelyn' hoy... ¡Qué divertido ser noble por un día!$1",
  "DN.SnS.Festival.Speak.Lewis": "Este tipo de evento no es mi velocidad... por ejemplo, ¿dónde están los granges para juzgar? ¿Dónde está el ganado que todos podemos acariciar?",
  "DN.SnS.Festival.Speak.Clint": "Históricamente, mi profesión es una de las más valiosas... Fácilmente podría servir a un rey o a un ejército, en lugar de forjar las necesidades básicas de una pequeña ciudad.",
  "DN.SnS.Festival.Speak.Emily": "¡Es un ambiente tan inspirador! Tengo tantas ideas que quiero darles vida ahora, atuendos, tal vez pedirle a Gus que haga una noche temática de 'comidas de la historia' - ¡Esto es muy divertido!",
  "DN.SnS.Festival.Speak.Penny": "Hmm... ¡Me estoy divirtiendo mucho! Creo que algunas partes de esto son un poco más exageradas de lo que era real, pero para eso están los días como hoy, ¿verdad? Soltándose y divirtiéndose...#$b#Y puede que alguien me acompañe hasta la cima para contemplar la luna de forma romántica...$4",
  "DN.SnS.Festival.Speak.Pam": "¡Este es el tipo de banquete que puedo respaldar! ¡Me he estado divirtiendo tanto, niño, que ni siquiera he tenido la oportunidad de probar el hidromiel!$1",
  "DN.SnS.Festival.Speak.Haley": "Es mejor dejar las modas de la historia A la historia, ¿no crees? Aunque... un lindo caballero de brillante armadura ES bueno sin importar el año que sea.$4",
  "DN.SnS.Festival.Speak.Jodi": "Bueno, con suerte Vincent se olvidará por completo de las espadas de madera que vimos... Oh, ya lo creo.*hacer*Espero que los olvide pronto...$2",
  "DN.SnS.Festival.Speak.Kent": "El aguamiel fluye, los niños se divierten... la noche es joven y hermosa, y mi esposa Jodi también. Necesitábamos esto.",
  "DN.SnS.Festival.Speak.Sam": "Me gustaría tocar el laúd. Quiero decir, ¿qué tan difícil puede ser tocar el laúd si ya toco la guitarra? ¿Qué es esa canción sobre la Feria Baya Escarlata?",
  "DN.SnS.Festival.Speak.Leah": "Casi deseé tener una cámara porque no creo que pueda hacer el boceto del paisaje a tiempo para pintarlo más tarde. Además, Elliott dijo que la comida en el carrito de Cirrus es para morirse, ¡y no quiero perdérmela!$1",
  "DN.SnS.Festival.Speak.Shane": "Si escucho a un idiota más decir 'mi dama', lo arrojaré al río. Es mi responsabilidad como padrino de Jas mantener ese tipo de idiotas alejados de ella.",
  "DN.SnS.Festival.Speak.Marnie": "Oh, Marlon me llamó 'mi dama', ¡no puedo dejar de reírme!$2#$b#Es bastante romántico bajo esa luna, ¿no?",
  "DN.SnS.Festival.Speak.Elliott": "¡Cirrus seguro que sabe cocinar un festín! Me siento como un señor menor, perdiendo el tiempo mientras ella ofrece otra cerveza helada de jengibre. Creo que debería conseguir un sombrero. Sería apuesto, ¿no?$1",
  "DN.SnS.Festival.Speak.Gus": "He ofrecido mi mano en lo que puedo para ayudar, pero tienen las cosas bajo control. Seguro que es agradable tomarse un descanso de la cocina y disfrutar de las cosas. ¡Prácticamente me están tratando como a un rey con este descanso de las cocinas!$1",
  "DN.SnS.Festival.Speak.Wizard": "Ahh sí, esto me transporta a los buenos viejos tiempos. No importa cuánto tiempo hace que ESO fue, mortal.",
  "DN.SnS.Festival.Speak.Harvey": "Y aquí estoy sin mi reserva de sanguijuelas...#$b#Sólo un poco de humor médico medieval para ti, @. Recuerda no asustar a los caballos, pueden lastimarse.",
  "DN.SnS.Festival.Speak.Jas": "¡Quiero ser una princesa! O un dragón...#$b#¡O una princesa dragón!$1",
  "DN.SnS.Festival.Speak.Vincent": "No puedo esperar hasta ser lo suficientemente grande para blandir una espada... Aunque mamá dice que eso no será hasta dentro de cincuenta años.#$b#¿Pensé que una vez grande podría hacer lo que quisiera?$3",
  "DN.SnS.Festival.Speak.Willy": "Las aguas aquí son tan limpias y claras que creo que podría pescar un pez con mis propias manos, ¡je!$3",
  "DN.SnS.Festival.Speak.Leo": "No... no me gusta la charla tonta. La comida es buena y el cielo nocturno se siente como en casa.",
  "DN.SnS.Festival.Speak.Dwarf": "Qué pasatiempo tan interesante han preparado ustedes... ¿No pueden simplemente dejar la historia en el polvo?",
  "DN.SnS.Festival.Speak.Sandy": "Vale la pena el viaje para llegar tan lejos. ¿Emily no se ve bonita a la luz de la luna? Me alegro de que me haya invitado.$1",


  "DN.SnS.Festival.Dialogue.Lewis1": "Vaya, esa Feria seguro que puede ser renacer.",
  "DN.SnS.Festival.Dialogue.Lewis2": "Bien dicho, yo.",
  "DN.SnS.Festival.End1": "No estaban bromeando, esa Feria seguro que renació.",

  "DN.SnS.Festival.Question": "¿Deberíamos Violeta en esa Luna hasta el Renacimiento de la Feria?",
  "DN.SnS.Festival.YesAnswer": "Sí.",
  "DN.SnS.Festival.NoAnswer": "No.",
  "DN.SnS.Festival.StartFaire": "La Feria del Renacimiento de la Luna Violeta ha comenzado. Dirígete a East Scarp para unirte a la diversión.",

  "DN.SnS.SpaceCoreCategory.FaireFood": "Comida de feria",
  "DN.SnS.Steak_on_a_Stake": "Filete en una estaca",
  "DN.SnS.Steak_on_a_Stake.Description": "No irá directamente A TRAVÉS de tu corazón, pero irá directo A tu corazón.",
  "DN.SnS.ScotchEgg": "Huevo escocés",
  "DN.SnS.ScotchEgg.Description": "Un huevo cocido con una yema gomosa envuelta en chorizo ​​y frito. Perfecto para las primeras horas de la mañana en la Feria.",
  "DN.SnS.Fruit_Hand_Pie": "Pastel de frutas",
  "DN.SnS.Fruit_Hand_Pie.Description": "Un pastel de frutas mixtas muy caliente en la porción perfecta para evitar compartir.",
  "DN.SnS.Hand_Pressed_Apple_Cider": "Sidra de manzana prensada a mano",
  "DN.SnS.Hand_Pressed_Apple_Cider.Description": "Esta sidra te calentará desde la coronilla hasta la punta de los pies en un fresco día de otoño.",
  "DN.SnS.Smoked_TurkeyLeg": "Muslo de pavo ahumado gigante",
  "DN.SnS.Smoked_TurkeyLeg.Description": "Ahumados sobre astillas de madera de nogal americano y manzano durante más de doce horas, ¡estos muslos de pavo son dignos de la realeza!",
  "DN.SnS.AnyFruit": "Cualquier fruta",
  "DN.SnS.AnyEgg": "Cualquier huevo",

  // MEEP 
  "MEEP.BookOutside.1": "¡Hola querido @! ¿Cómo estás en este buen día? Espero que tu lista de tareas sea corta y tu barriga esté llena de deliciosos bocadillos.$1^¡Hola querida @! ¿Cómo estás en este buen día? Espero que tu lista de tareas sea corta y tu barriga esté llena de deliciosos bocadillos.$1",
  "MEEP.BookOutside.2": "¡@! Que placer verte. ¿No es hermoso hoy? ¡Disfruta del sol mientras lo tenemos! Nunca se sabe cuándo vendrán las nubes de lluvia.$0",
  "MEEP.BookOutside.3": "¡Dios mío, Dios mío! @, debes ser terriblemente fuerte para caminar hasta aquí con tanta frecuencia. ¿O tal vez te deformas con magia?$1",
  "MEEP.BookOutside.4": "Siempre eres lo más hermoso que veo cuando deambulo afuera, @. Es todo un placer.$0",
  "MEEP.BookOutside.5": "¡Ah, sí! ¡Es mi visitante favorito! ¿Cómo estás, @? Nada menos que excelente, espero. Que tengas un hermoso día, ${querido^querida}$. A mantenerse seguro.$1",

  "MEEP.BookInside.1": "No puedes identificarlo, pero hay algo en Libro que parece reconfortante y sincero. Mirarla te trae tanta alegría como a ella tu visita.$0",
  "MEEP.BookInside.2": "¡Libro parece muy emocionado hoy! Ella está volando ocupada por la habitación. Quizás algo de magia esté en marcha.$1",
  "MEEP.BookInside.3": "Parece que Book está enojado con cierto druida. ¡Es mejor dejarla con sus dispositivos, no sea que descargue alguna agresión mágica contra ti!$3",
  "MEEP.BookInside.4": "¡El libro está increíblemente feliz de verte! Ella vuela alegremente a tu alrededor en círculos por un momento antes de volver a sus tareas.$1",
  "MEEP.BookInside.5": "El grimorio mágico aprecia tu compañía y flota detrás de ti por un momento mientras navegas por la torre.$0",

  "MEEP.EmeritusOutside.1": "¡Emeritus está ocupado protegiendo al gremio de la amenaza del cangrejo! Le das una palmadita afectuosa por su arduo trabajo.",
  "MEEP.EmeritusOutside.2": "Emeritus te da un beso grande y baboso. Ahora estará ligeramente pegajoso con la saliva del Pimienta Rex. Huele a fogata.",
  "MEEP.EmeritusOutside.3": "Emeritus está masticando ruidosamente un cangrejo. Mateo parece haber transmitido su odio a los crustáceos.",
  "MEEP.EmeritusOutside.4": "Emeritus está ligeramente húmedo y cubierto de arena, lo que probablemente será excelente para los pisos de madera del gremio.",
  "MEEP.EmeritusOutside.5": "Emeritus parece llevar una vida muy feliz, comiendo cangrejos, durmiendo siestas y recibiendo cariño de cualquiera que pase por allí.",

  "MEEP.EmeritusInside.1": "Emeritus te mira expectante, así que le das un besito en el hocico. ¡El Pimienta Rex te mueve la cola con aprecio!",
  "MEEP.EmeritusInside.2": "Emeritus casi ha quemado el gremio una vez esta semana, lo que probablemente sea un récord de algún tipo.",
  "MEEP.EmeritusInside.3": "Emeritus se mueve de lado a lado, como si bailara al ritmo de sus propias melodías. Muévete, hermano lagarto.",
  "MEEP.EmeritusInside.4": "El peluche de Emeritus se llama Ducky y él la cuida muy bien. De hecho, parece absolutamente protector.",
  "MEEP.EmeritusInside.5": "Emeritus golpea su cabeza contra tus piernas cuando te acercas. No puede abrazarte debido a sus piernas rechonchas, ¡pero seguro que lo intentará!",

  "MEEP.EmeritusFarmhouse.1": "¡Emeritus estornuda una pequeña bola de fuego! Entras en pánico momentáneamente, pero está bien. Por ahora.",
  "MEEP.EmeritusFarmhouse.2": "Emeritus huele como si se hubiera metido en el cubo de la basura otra vez.",
  "MEEP.EmeritusFarmhouse.3": "Emeritus intenta darte un abrazo con sus miembros rechonchos. Agradeces que lo intente.",
  "MEEP.EmeritusFarmhouse.4": "Emeritus está haciendo un excelente trabajo protegiendo la granja de la amenaza de los cangrejos.",
  "MEEP.EmeritusFarmhouse.5": "Emeritus aún no ha quemado nada hoy, ¡qué bien!",
  "MEEP.EmeritusFarmhouse.6": "Emeritus ronca más fuerte que nadie, o nada, que hayas conocido.",
  "MEEP.EmeritusFarmhouse.7": "Emeritus te está babeando el pie.",
  "MEEP.EmeritusFarmhouse.8": "Emeritus dice 'groar', que es 'te quiero' en Pimienta Rex (probablemente).",

