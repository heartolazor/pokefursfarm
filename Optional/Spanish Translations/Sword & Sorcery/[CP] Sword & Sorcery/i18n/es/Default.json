  // GENDER NEUTRAL MARRIAGE EDITS
  "CFD.Hector.Utility.cs.5371": "@... persona extraña que nunca he conocido antes... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Hector.Utility.cs.5373": "@... persona extraña que nunca he conocido antes... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Hector.Utility.cs.5375": "@... persona extraña que nunca he conocido antes... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Hector.Utility.cs.5377": "@... persona extraña que nunca he conocido antes... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro pareja! ¡Felicidades!$h",
  "CFD.Hector.Utility.cs.5367": "Llega un momento en la vida de todos en que nos cruzamos con alguien de forma inesperada.#$b#En este caso, parece que de forma EXTREMADAMENTE inesperada.$h#$b#¿Es mi gran? Honor en este día {0} of {1}, unir a @ y - ¿Cuál era su nombre de nuevo? - En los lazos del matrimonio.",
  "CFD.Hector.Utility.cs.5369": "Cuando @ llegó a Pueblo Pelícano, nadie sabía si encajaría en nuestra comunidad...#$b#Y supongo que estamos a punto de aprender cómo esta OTRA persona nueva encaja en la comunidad.$h#$b#Es para mí un gran honor en este día {0} de {1}, unir a @ y uh, como se llame, en los lazos del matrimonio.",

  // GENDER NEUTRAL SOCIAL PAGE EDITS 
  "CFD.Hector.SocialPage.cs.11635": "(soltero)",
  "CFD.Hector.SocialPage.cs.11636": "(cónyuge)",
  "CFD.Hector.SocialPage.cs.11637": "(cónyuge)",
  "CFD.Hector.SocialPage.cs.11639": "(pareja)",
  "CFD.Hector.SocialPage.cs.11640": "(pareja)",
  "CFD.Hector.SocialPage.cs.11642": "(ex-cónyuge)",
  "CFD.Hector.SocialPage.cs.11643": "(ex-cónyuge)",

  // SUMMIT DIALOGUE 
  "CFD.Hector.ExtraDialogue_SummitEvent_Intro_Hector": "Mi ciervo amado.",
  "CFD.Hector.ExtraDialogue_SummitEvent_Intro2_Hector": "Yo diría que esta es la segunda mejor vista en el valle, después de mirarte.",
  "CFD.Hector.ExtraDialogue_SummitEvent_Dialogue1_Hector": "Han pasado un par de años largos. %year, ¿verdad?$14",
  "CFD.Hector.ExtraDialogue_SummitEvent_Dialogue2_Hector": "Ha sido un viaje bien recorrido. Y aún no ha terminado. Sólo acaba de empezar, en realidad.$13",
  "CFD.Hector.ExtraDialogue_SummitEvent_Dialogue3_Hector": "Gracias por todo, @. Te amo.$15",
  "CFD.Hector.ExtraDialogue_SummitEvent_Dialogue4_Hector": "Más que el cielo arriba y la tierra abajo.$11",
  "CFD.Hector.ExtraDialogue_SummitEvent_closingmessage": "Ha sido un largo camino para ti y Biróg...",

  // MOVIE INVITATION - SPOUSE 
  "MovieInvite_Spouse_Hector": "¡Seguro! Siempre estoy feliz de pasar tiempo contigo en un lugar oscuro y frío...$9",


