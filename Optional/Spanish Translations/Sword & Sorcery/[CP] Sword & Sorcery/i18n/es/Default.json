  // NAME & INTRO 
  "Core.Cirrus.Name": "Cirrus",
  "Core.Cirrus.Introduction": "Gracias por salvarme en el salón, @. A veces me agobia bastante la gente, aunque sé que no lo hacen con mala intención.",

  // COMMUNITY CENTER BUNDLES  
  "Core.Cirrus.JojaBegin": "Qué pena lo de Joja, ¿verdad? También intentaron instalarse en Puerto Drake, pero la gente de allá era más reticente...$3",
  "Core.Cirrus.CCBegin": "Ese viejo edificio debe de ser muy importante para la comunidad si te han encargado su restauración. ¡Buena suerte!$17",
  "Core.Cirrus.CCBus": "Doy gracias por tener mi propio coche, pero utilizar el autobús para ir a la ciudad sería mucho más fácil si no me reconocieran todo el tiempo.$3",
  "Core.Cirrus.CCMinecart": "¿Qué? ¿Realmente puedes subirte a una vagoneta y montarte en ella para ir a algún sitio? ¡Qué locura! ¡Quiero ir!$14",
  "Core.Cirrus.CCComplete": "¡Felicitaciones por terminar ese proyecto de construcción, @! Parece que significa mucho para los lugareños, eso fue genial de tu parte.$4",
  "Core.Cirrus.MovieTheater": "¡Oh! ¡Amo las películas, deberíamos irnos! ¡Yo invito! [809]",

  // BIRTHDAYS
  "Core.Cirrus.Fall25": "¡Hoy es el cumpleaños de Mateo! Algo de comida casera le vendrá bien. ¡Me pondré a ello!$1",
  "Core.Cirrus.Winter21": "¡Hoy es el cumpleaños de Biróg! Apuesto a que {{HPN1}} agradecería un poco de cariño hoy, aunque {{HPN1}} finja no querer recibir atención.$1",

  // END OF SEASON
  "Core.Cirrus.SpringEnd": "No pretendo saber nada de agricultura, pero puedo decir que estoy deseando cocinar cosas con tu reserva de verano.$4",
  "Core.Cirrus.SummerEnd": "Echaré de menos el tiempo de playa, pero no pasa nada. ¡Es la hora del tiempo de las sudaderas!$1",
  "Core.Cirrus.FallEnd": "¿Estás listo para el frío, @? Espero que tengas un buen abrigo. ¿Lo tomas con calma durante el invierno?$17^¿Estás lista para el frío, @? Espero que tengas un buen abrigo. ¿Lo tomas con calma durante el invierno?$17",
  "Core.Cirrus.WinterEnd": "Finalmente, ¡es casi la primavera de nuevo! No odio el frío, pero me encanta la primavera.$1",

  // SVE COMMUNITY DAY
  "Core.Cirrus.CommunityCenter4": "¡Es tan agradable ver a todos reunidos! Gracias de nuevo por hacer que esto suceda, @. La vida en un pueblo pequeño es tan nueva para mí.$1",
  "Core.Cirrus.CommunityCenter6": "La próxima vez, creo que cocinaré algo. ¡Esa despensa es tan espaciosa y está tan bien surtida!$1",
  "Core.Cirrus.CommunityCenter8": "Lo único que le falta a este lugar - y al salón - es un pequeño escenario.$14",
  "Core.Cirrus.CommunityCenter10": "Abigail dijo que le costó arrastrar a Sebastian hasta aquí, pero creo que le encanta mientras esté con ella y Sam..$4",

  // FESTIVALS
  "Core.Cirrus.EggFestival": "Para ser honesta, no estaba interesada en el Festival del Huevo hasta que Gus mencionó que estaba haciendo el banquete. Los niños pueden tener su búsqueda de huevos.$17",
  "Core.Cirrus.FlowerDance": "¡Estoy emocionada por mañana! ¿Vas a pedirle a alguien que baile contigo, @?$4",
  "Core.Cirrus.Luau": "Realmente no estoy segura de qué echar a una sopa que podría tener literalmente cualquier cosa...$16",
  "Core.Cirrus.MoonlightJelly": "No tenemos lunaloos en Puerto Drake, pero sí tenemos... bueno, drakes, supuestamente.$1",
  "Core.Cirrus.SDVFair": "Apuesto a que sería divertido hacer un espectáculo en la feria, o tal vez tener un puesto de comida. Sin embargo, no querría ser juzgada.$1",
  "Core.Cirrus.SpiritsEve": "Mateo ha estado emocionado sin cesar por lo de mañana, es muy dulce.$0",
  "Core.Cirrus.IceFestival": "Biróg parece a punto de poner a Lewis a través de una ventana sobre este festival de mañana...$16",
  "Core.Cirrus.NightMarket": "Me pregunto si podré encontrar alguna chuchería de ZuZu o Puerto Drake en el Mercado Nocturno. Me encantan las baratijas.$1",
  "Core.Cirrus.WinterStar": "Puede que me haya pasado un poco con los regalos. He estado cocinando SIN. PARAR.$15",

  // ROMANTIC (POSITIVE) 
  "Core.Cirrus.GiveFlowersA": "¡Oh, @! Estas son muy dulces, ¿es esto algo de Pueblo Pelícano?$1",
  "Core.Cirrus.GiveFlowersB": "¡Oh, interesante! En Puerto Drake, hacemos algo completamente diferente. ¡Buena suerte con tus esfuerzos, @!",
  "Core.Cirrus.GivePendant": "¡Oh, interesante! En Puerto Drake, se propone con plumas de 'Fénix'. ¡Buena suerte con tus esfuerzos, @!",
  "Core.Cirrus.StardropGiftA": "He encontrado esto para ti, @ - Quería demostrarte mi amor con un gran gesto. ¡Espero que lo aceptes!$23",
  "Core.Cirrus.StardropGiftB": "He tenido esto durante mucho tiempo, @ - Pero creo que tú y la granja lo necesitan más que yo.$23",

  // ROMANTIC (NEGATIVE)
  "Core.Cirrus.DanceRejection": "¡Estoy halagada, pero no, gracias! Creo que me sentaré y me limitaré a mirar.$1",
  "Core.Cirrus.Divorced": "Déjame en paz, @. Si puedo cortar a mi propia madre, puedo cortarte a ti también.$5#$b#Soy una muesca en el poste de tu cama, pero tú eres sólo una línea en una canción.",
  "Core.Cirrus.BreakUp": "Oh - Uhm, bueno. Gr-Gracias por todo, @... Yo... me voy a... Me voy a ir, ¿vale? Voy a ir a procesarlo. Esta fue una relación que tengo que lamentar.$13",
  "Core.Cirrus.DumpedGirls": "...No puedo creer que confiara en que me tratarías de forma diferente a los cientos de miles de personas para las que he actuado. ¿Fue todo esto sólo una actuación para ti?$12",
  "Core.Cirrus.SecondChanceGirls": "Realmente no estoy segura de esto, pero... supongo que vale la pena intentarlo dos veces, ¿verdad?$16",
  "Core.Cirrus.Reject2HA": "¡Oh, interesante! En Puerto Drake, hacemos algo completamente diferente. Buena suerte con tus esfuerzos, @!",
  "Core.Cirrus.Reject2HB": "¡Oh, interesante! En Puerto Drake, hacemos algo completamente diferente. Buena suerte con tus esfuerzos, @!",
  "Core.Cirrus.Reject4HA": "¡Oh, interesante! En Puerto Drake, hacemos algo completamente diferente. Buena suerte con tus esfuerzos, @!",
  "Core.Cirrus.Reject4HB": "¡Oh, interesante! En Puerto Drake, hacemos algo completamente diferente. Buena suerte con tus esfuerzos, @!",
  "Core.Cirrus.EngageA": "Oye, esto es... un poco incómodo, teniendo en cuenta que estás comprometido. Tengo límites y estándares, lo siento, no lo siento.$2^Oye, esto es... un poco incómodo, teniendo en cuenta que estás comprometida. Tengo límites y estándares, lo siento, no lo siento.$2",
  "Core.Cirrus.EngageB": "Ofensa completa, esto es extraño y craso teniendo en cuenta que estás comprometido. No, no estoy interesada.$5^Ofensa completa, esto es extraño y craso teniendo en cuenta que estás comprometida. No, no estoy interesada.$5",
  "Core.Cirrus.MarriedA": "No absolutamente no. Debería contárselo a tu pareja.$5",
  "Core.Cirrus.MarriedB": "Estás a segundos de ser cortado, @.$5",
  "Core.Cirrus.RefusalNoHeartsA": "Esta no es una película para niños, @ - ¡nos acabamos de conocer!$3",
  "Core.Cirrus.RefusalNoHeartsB": "Uh, ¿gracias? Pero como que, ¡no gracias!$3",
  "Core.Cirrus.RefusalKnownA": "¿Me... halaga? ¿Supongo? ¿Pero no?$17",
  "Core.Cirrus.RefusalKnownB": "Esto me pasa mucho y no se vuelve menos extraño.$20",
  "Core.Cirrus.RefusalBotherA": "Voy a tener que establecer algunos límites si no te detienes, @. Por favor.$18",
  "Core.Cirrus.RefusalBotherB": "Para, @. No quiero tener que cortarte como he hecho con tantos otros.$18",

  // RESORT
  "Core.Cirrus.ResortEntering": "¡Hora de un día de playaaa!$15",
  "Core.Cirrus.ResortLeaving": "Eso fue muy divertido, espero poder volver pronto.$15",
  "Core.Cirrus.ResortShore": "¡No puedo ver nada en el horizonte! ¡Estamos tan lejos de casa!$1",
  "Core.Cirrus.ResortUmbrella": "Podría quedarme dormida aquí. ¡Es tan acogedor!$1",
  "Core.Cirrus.ResortWander": "Me pregunto qué hay en el resto de la isla. ¿Has explorado mucho, @?$1",
  "Core.Cirrus.ResortWander.2": "Debo estar loca, pensé que vi un barco pirata en el horizonte.$20",
  "Core.Cirrus.ResortChair": "Vendría aquí todos los días si pudiera. Es diferente a la playa que tenemos nosotros.$28",
  "Core.Cirrus.ResortBar": "Ya no bebo, pero Gus hace estupendos cócteles.$22",
  "Core.Cirrus.ResortTowel": "Podría empaparme de crema solar y aun así tener probabilidades de quemarme...$20",
  "Core.Cirrus.ResortTowel.2": "Oh, estu es lo mejor. ¿Vas a relajarte conmigo por un tiempo, @?$15",
  "Core.Cirrus.Resort_Towel.3": "Me pregunto si podría aprender a surfear. ¿Será difícil? Tal vez. Probablemente me comprometería mucho durante un mes y luego olvidaría que empecé a aprender.$15",
  "Core.Cirrus.Resort": "¿Es esa una montaña allá atrás? ¿O un volcán? Me pregunto si es seguro explorar, quiero acercarme...$14",

  // PLAYER DEATH
  "Core.Cirrus.PlayerKilled.Mines.01": "¡@!",
  "Core.Cirrus.PlayerKilled.Mines.02": "No no no no no NO ¡NO-!$12",
  "Core.Cirrus.PlayerKilled.Mines.03": "¡Por favor que estés bien, @! ¡¡¡Por favor que estés bien!!!$21",

  "Core.Cirrus.PlayerKilled.Skull.01": "¿...@?",
  "Core.Cirrus.PlayerKilled.Skull.02": "Fácil, ahora... tómalo con calma.",
  "Core.Cirrus.PlayerKilled.Skull.03": "¡Estas despierto! Gracias a dios. ¡Biróg te encontró agotado en la Caverna Calavera!$2^¡Estas despierta! Gracias a dios. ¡Biróg te encontró agotada en la Caverna Calavera!$2",
  "Core.Cirrus.PlayerKilled.Skull.04": "Estaba tan asustada, @, mierda...$21",
  "Core.Cirrus.PlayerKilled.Skull.04.Filtered": "Estaba tan asustada, @, santo cielo...$21",
  "Core.Cirrus.PlayerKilled.Skull.05": "¡No me vuelvas a hacer esto, @! ¡Si lo haces, te daré algo por lo que asustarte!#@21",
  "Core.Cirrus.PlayerKilled.Skull.06": "{{CPPN1}} estará bien, pero {{LPPN1}} tendrá que tener más cuidado la próxima vez.",
  "Core.Cirrus.PlayerKilled.Skull.07": "Los dejaré a los dos para que hablen; Hazme saber si necesitas algo.$2",
  "Core.Cirrus.PlayerKilled.Skull.08": "No me hagas seguir sin ti, @. No te atrevas.$21",

  "Core.Cirrus.GreenRain": "Ya tengo bastantes problemas con la lluvia, ¿por qué ahora es VERDE?$19",
  "Core.Cirrus.GreenRainFinished": "Oh, menos mal que ha terminado. Al menos no hubo truenos...$18",
  "Core.Cirrus.GreenRain2": "Supongo que como no hay truenos, el tiempo raro no es tan malo. Y todas las plantas se ven muy bien después.$17",

  // POLYAMORY 
  "Core.Cirrus.MarriedMonogamousNPC": "Tu pareja es monógama, @. Así que no me siento cómoda comprometiéndome en nada romántico contigo.$16",

  // EPILOGUE 
  "Core.Cirrus.Epilogue.1": "Mi madre está bien, ¡gracias por preguntar! Ella está realmente luchando, pero en esa especie de película-montaje antiguo. Tengo fe en ella.$1",
  "Core.Cirrus.Epilogue.2": "En este momento, mi mamá y yo estamos haciendo una llamada telefónica a la semana. No estoy segura de estar preparada para volver a verla en persona; no hasta que se haya secado un poco.$17",
  "Core.Cirrus.Epilogue.3": "¡He estado escribiendo música! Lo cual, hay que reconocerlo, no había hecho en mucho tiempo... pero me ha venido la inspiración de todo lo que ha pasado.$1",
  "Core.Cirrus.Epilogue.4": "Sinceramente, he estado tocando mucho el piano. No el keytar. Es que... pega diferente, representa mejor mi dirección hacia adelante.$4",
  "Core.Cirrus.Epilogue.5": "Cada día que mi madre pasa sin beber es una pequeña bendición. Estoy tan orgullosa de ella.$1",
  "Core.Cirrus.Epilogue.6": "Va a ser tan agradable conocer a la persona que era mi mamá antes del alcoholismo. Y la persona en la que se convertirá, después.$1",
  "Core.Cirrus.Epilogue.7": "¡Voy a ir, ir, ir, no hay quien me pare! Voy a quemar el cielo, sí, 93 grados, ¡por eso me llaman Señora Centígrado!$29",
  "Core.Cirrus.Epilogue.8": "¡El sol brilla en el cielo, no hay ni una nube a la vista! Ha dejado de llover, todo el mundo está en la obra... ¡y no sabes que es un nuevo y hermoso día!$29",
  "Core.Cirrus.Epilogue.9": "¿Qué pasa? ¿No te sientes bien? ¿No te sientes bien, nene? Salve, oh sí, cógelo de la parra principal, de acuerdo...$29^¿Qué pasa? ¿No te sientes bien? ¿No te sientes bien, nena? Salve, oh sí, cógelo de la parra principal, de acuerdo...$29",
  "Core.Cirrus.Epilogue.10": "No lo hagas, olvídate de mí, no lo hagas, no lo hagas, no lo hagas...$29",


