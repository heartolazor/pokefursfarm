  // NAME & INTRO 
  "Core.Hector.Name": "Hector",
  "Core.Biróg.Name": "Biróg",
  "Core.Hector.Introduction": "No tienes ni idea de lo que soy capaz, granjero. Ni de lo que tengo pensado para ti.^No tienes ni idea de lo que soy capaz, granjera. Ni de lo que tengo pensado para ti.",

  // DYNAMIC PRONOUNS 
  "Core.HectorPN.M.1": "Él",
  "Core.HectorPN.M.2": "De él",
  "Core.HectorPN.M.3": "De él",
  "Core.HectorPN.M.4": "Él mismo",

  "Core.HectorPN.F.1": "Ella",
  "Core.HectorPN.F.2": "De ella",
  "Core.HectorPN.F.3": "De ella",
  "Core.HectorPN.F.4": "Ella misma",

  // COMMUNITY CENTER BUNDLES  
  "Core.Hector.JojaBegin": "¡Eres un traidor! Te necesitaba, ¿y te has ido y te has rendido a Morris? ¡Claro que sé que fuiste tú, todos los demás ya habrían comprado una membresía!$27^¡Eres una traidora! Te necesitaba, ¿y te has ido y te has rendido a Morris? ¡Claro que sé que fuiste tú, todos los demás ya habrían comprado una membresía!$27#$b#¡No eres quien yo creía! No puedo confiar en ti, sal de mi vista.$21",
  "Core.Hector.CCBegin": "¡Buen trabajo, @! Morris y su almacén pueden irse a comer unas piedras.$1#$b#¿Qué? ¿Quieres ayuda con el centro cívico? No. Confío en que puedas manejarlo.$8#$b#Además, tengo OTROS planes para nosotros.$9",
  "Core.Hector.CCBus": "El transporte público accesible es inestimable para mantener una comunidad respetuosa con el medio ambiente. Buen trabajo, @.$7#$b#Y, como extra, tienes a Pam conduciendo. Eso mantendrá las cosas emocionantes, ¿eh?$9",
  "Core.Hector.CCMinecart": "Voy a causar muchos problemas usando esas vagonetas. ¡Gracias, @!$9",
  "Core.Hector.CCComplete": "El Centro cívico tiene muy buena pinta, @. Y lo has hecho todo tú solo. Has trabajado muy duro.$7#$b#... Estoy muy orgulloso de ti, y de las decisiones que tomas.$12",
  "Core.Hector.MovieTheater": "¿¡Un cine!? Eso es genial, ¡vamos!$9#$b#Prometo no hablar hasta el final. Me ENCANTA el cine.$17",

  // BIRTHDAYS
  "Core.Hector.Fall25": "Hoy es el cumpleaños de Mateo.$14#$b#¡Molesta extra a ese bastardo!$9",

  // END OF SEASON
  "Core.Hector.SpringEnd": "En primavera, la única época bonita para sonar, cuando los pájaros cantan, ¡eh ding! A ding a ding; dulces amantes aman... ¡la Primavera!$3",
  "Core.Hector.SummerEnd": "¡Tengo esa tristeza de verano, de verano! tri-tri-tristeza, tristeza de verano-$3",
  "Core.Hector.FallEnd": "¡Escondido del tiempo, té y tostadas! Bollos de grosella con mantequilla, ¡no pueden compensar la falta de sol porque el verano se ha ido...!$3",
  "Core.Hector.WinterEnd": "¡Y el cielo es una brumosa sombra de invierno! Aférrate a tus esperanzas, amigo mío. Es fácil decirlo, pero si tus esperanzas se desvanecen, ¡imagina que puedes construirlas de nuevo!$3^¡Y el cielo es una brumosa sombra de invierno! Aférrate a tus esperanzas, amiga mía. Es fácil decirlo, pero si tus esperanzas se desvanecen, ¡imagina que puedes construirlas de nuevo!$3",

  // SVE COMMUNITY DAY
  "Core.Hector.CommunityCenter4": "Mateo dijo que esto sería una buena idea. No estoy de acuerdo.$24",
  "Core.Hector.CommunityCenter6": "Estar aquí me hace sentir ganas de vomitar, pero también, es algo agradable. Supongo, tal vez.$8",
  "Core.Hector.CommunityCenter8": "Todo el mundo está tan involucrado con tantas actividades diferentes. El arte de Leah es genial, y siento que la brillantez de Maru está siendo ignorada-$6#$b#¿Qué? No, me lo estoy pasando fatal. ¡Seguro!$5",
  "Core.Hector.CommunityCenter10": "De acuerdo, de acuerdo. Picaré. Esto está bien. ¿Esto está bien? Esto es bonito.$14#$b#Sólo soy un perro viejo aprendiendo trucos nuevos, ¿vale?$13",

  // FESTIVALS
  "Core.Hector.EggFestival": "¿Qué? ¿Crees que estoy aquí para causar problemas? ¿Te parezco un aficionado? No, estoy aquí para comer comida gratis.$6#$b#¡Ya me encargué de eso al final del OTOÑO pasado para MAXIMUM STINK!$9",
  "Core.Hector.FlowerDance": "Oh, odio la Danza de las Flores. Lo único que me gusta menos que me digan qué ponerme es hacer una estúpida coreografía con el estómago lleno.$16",
  "Core.Hector.Luau": "En realidad cultivé algo para mañana. Seguro que esperas que sea terrible.$0#$b#Pero, lo único que me gusta más que hacer travesuras es comer, así que estará bueno.$1",
  "Core.Hector.MoonlightJelly": "Me encanta cuando me visitan las medusas, la verdad. Ningún capricho de la naturaleza me pasa desapercibido.$8#$b#Pero definitivamente es diferente, no verlas solo...$24",
  "Core.Hector.SDVFair": "¡Oh, una competición! ¿Quieres que te ayude a hacer trampa?$9#$b#Aw, en realidad, probablemente no necesites hacer trampa. Ya he visto lo que puedes hacer. Buena suerte.$0",
  "Core.Hector.SpiritsEve": "Seguro que Mateo ya te ha hablado hasta la saciedad de las 'reglas' de la Víspera de los Espíritus, y eso está muy bien, pero...$24#$b#La verdadera regla es hacer travesuras, no daño. Las bromas no son divertidas si lastiman o molestan a alguien.$14#$b#Dicho esto, ¡tengo muchas travesuras planeadas! ¡Cuidado!$9",
  "Core.Hector.IceFestival": "Sería más ético y respetuoso con el medio ambiente simplemente COCINAR los peces en lugar de engancharlos y devolverlos.$26#$b#¡Causa estrés, daña la piel y los cansa! ¡Simplemente cómetelos en vez de pretender hacer lo 'moral' cuando no lo es en absoluto! Que festival mas estupido.$27",
  "Core.Hector.NightMarket": "¿Vas al Mercado Nocturno? Yo voy a quedarme en la línea de madera a ver los barcos.$7",
  "Core.Hector.WinterStar": "La estrella de invierno es otra especie de festival estúpido, ¿no? Bueno, le compré a Mateo algo de piel de animal para que pueda arreglar su armadura. Espero que le guste.$13#$b#Nadie puede decir que no lo intento.$14",

  // ROMANTIC (POSITIVE)
  "Core.Hector.GiveFlowersA": "Estas se ven demasiado bien para que las hayas cultivado. ¿Aideen hizo esto para ti?$9#$b#Oh, mierda, ¿son para mí? Uh, uh-$4#$b#Gracias. Yo uh, devuelvo el sentimiento. Creo. Sí.$11",
  "Core.Hector.GiveFlowersA.Filtered": "Estas se ven demasiado bien para que las hayas cultivado. ¿Aideen hizo esto para ti?$9#$b#Espera, ¿qué, son para mí? Uh, uh-$4#$b#Gracias. Yo uh, devuelvo el sentimiento. Creo. Sí.$11",
  "Core.Hector.GiveFlowersB": "Estas se ven demasiado bien para que las hayas cultivado. ¿Aideen hizo esto para ti?$9#$b#Oh, mierda, ¿son para mí? Uh, uh-$4#$b#Gracias. Yo uh, devuelvo el sentimiento. Creo. Sí.$11",
  "Core.Hector.GiveFlowersB.Filtered": "Estas se ven demasiado bien para que las hayas cultivado. ¿Aideen hizo esto para ti?$9#$b#Espera, ¿qué, son para mí? Uh, uh-$4#$b#Gracias. Yo uh, devuelvo el sentimiento. Creo. Sí.$11",
  "Core.Hector.GivePendant": "Estás realmente comprometido con tomar malas decisiones, ¿eh?$11^Estás realmente comprometida con tomar malas decisiones, ¿eh?$11#$b#Bueno, estoy comprometido a tomar malas decisiones contigo.$10",
  "Core.Hector.StardropGiftA": "¿Sabías que las Frutas estelares solo crecen en el interior de los meteoritos, ocasionalmente precipitándose hacia nosotros desde el espacio?$0#$b#Eso es una mierda, pero logré encontrarte una.$11",
  "Core.Hector.StardropGiftA.Filtered": "¿Sabías que las Frutas estelares solo crecen en el interior de los meteoritos, ocasionalmente precipitándose hacia nosotros desde el espacio?$0#$b#Esa es una mentira, pero logré encontrarte una.$11",
  "Core.Hector.StardropGiftB": "¿Sabías que las Frutas estelares solo crecen de las extrañas palmeras horizontales, que solo pueden crecer parcialmente sumergidas en agua?$0#$b#Eso es una mierda, pero logré encontrarte una.$11",
  "Core.Hector.StardropGiftB.Filtered": "¿Sabías que las Frutas estelares solo crecen de las extrañas palmeras horizontales, que solo pueden crecer parcialmente sumergidas en agua?$0#$b#Esa es una mentira, pero logré encontrarte una.$11",

  // ROMANTIC (NEGATIVE)
  "Core.Hector.DanceRejection": "No, gracias, tengo cuatro patas izquierdas.$18",
  "Core.Hector.Divorced": "Prefiero volver a estar solo que tener que mirar TU taza por más tiempo.$26",
  "Core.Hector.BreakUp": "¿@-?$20#$b#Bien, sí. Lo entiendo. Está bien. ¡Está bien!$21",
  "Core.Hector.DumpedGuys": "No se necesita ser LITERALMENTE un CANINO para tener un mínimo de lealtad.",
  "Core.Hector.SecondChanceGuys": "No creo que pueda hacer esto... No entiendo cómo llegamos aquí en primer lugar.$21#$b#Pero lo intentaré, supongo. Simplemente no lo arruines de nuevo, o... ¡te comeré!$26",
  "Core.Hector.Reject2HA": "Esas son realmente bonitas. Es genial que crezcas más que solo frutas y verduras.$0#$b#¿Qué? ¿Esas son para mí? ¡No, gracias!$4",
  "Core.Hector.Reject2HB": "Aw, ¿lo hiciste tú mismo? Es adorable.$1^Aw, ¿lo hiciste tú misma? Es adorable.$1",
  "Core.Hector.Reject4HA": "¡No, gracias! No siento eso por ti. ¡O por quienquiera, de verdad!$4",
  "Core.Hector.Reject4HB": "Estas flores son realmente bonitas, pero no estoy interesado en ti, @. Lo siento.$8",
  "Core.Hector.EngageA": "Uhhhhhhhhhhhhhhhh, no.$18",
  "Core.Hector.EngageB": "¿Puedes hacerme un favor y dejar de demostrar que la humanidad apesta, por favor?$19",
  "Core.Hector.MarriedA": "¡Te comprometiste! ¡Será mejor que lo hagas!$27",
  "Core.Hector.MarriedB": "Para. No crees que no sé lo que estás haciendo. Eres mejor que esto.$26",
  "Core.Hector.RefusalNoHeartsA": "¡Oooh, bonito collar!$1",
  "Core.Hector.RefusalNoHeartsB": "Jeje, ¿lo vas a conseguir con alguien? ¡Buena suerte!$9",
  "Core.Hector.RefusalKnownA": "Lo siento, esto realmente no encaja con mi estética.$8",
  "Core.Hector.RefusalKnownB": "¿Se supone que debo estar halagado? Uh, ¿como que no lo estoy?$4",
  "Core.Hector.RefusalBotherA": "No significa no, @.",
  "Core.Hector.RefusalBotherB": "¡Dije que no! Te amenazaría con comerte, pero siento que lo harías sonar extraño.$18",

  // RESORT
  "Core.Hector.ResortEntering": "Hace tanto calor, ¿cómo disfruta la gente esto?$2",
  "Core.Hector.ResortLeaving": "Oh gracias a Dios. He tenido suficiente 'diversión en el sol' para durar toda la vida.$9",
  "Core.Hector.ResortShore": "El océano, me encanta. ¿Por qué no puedo conseguir un océano sin playa? Una falla de diseño, seguro.$8",
  "Core.Hector.ResortUmbrella": "Creo que me esconderé aquí por el resto de este viaje, gracias.$6",
  "Core.Hector.ResortWander": "No me gusta la arena. Es gruesa, áspera e irritante y llega a todas partes.$16",
  "Core.Hector.ResortWander.2": "No me gusta la arena. Es gruesa, áspera e irritante y llega a todas partes.$16",
  "Core.Hector.ResortChair": "¿Puedo irme a casa todavía sin parecer un bicho raro?$23",
  "Core.Hector.ResortBar": "¿Por qué la gente bebe mierda que sabe a pan cuando pueden tomar cosas deliciosas hechas con frutas?$4",
  "Core.Hector.ResortBar.Filtered": "¿Por qué la gente bebe cosas que saben a pan cuando pueden tomar cosas deliciosas hechas con frutas?$4",
  "Core.Hector.ResortTowel": "Estoy tan aburriiiido, quiero ir a caaaaaaaaaaaaaaasa.$16",
  "Core.Hector.ResortTowel.2": "Cuatro mil, trescientos, noventa y seis. Cuatro mil, trescientos, noventa y si- Oh, hola @. Solo contando los granos de arena.$16",
  "Core.Hector.Resort_Towel.3": "%Hector se ha quedado dormido sin protector solar. ¡Oh, no!",
  "Core.Hector.Resort": "Bueno, ahora puedo decir oficialmente que he desafiado la isla. ¿Es hora de irse a casa?$9",

  // PLAYER DEATH
  "Core.Hector.PlayerKilled.Mines.01": "¡@!",
  "Core.Hector.PlayerKilled.Mines.02": "¿@, por qué te pondrías en peligro así?",
  "Core.Hector.PlayerKilled.Mines.03": "¡¿Qué hizo esto?! ¡Lo comeré entero!$21",

  "Core.Hector.PlayerKilled.Skull.01": "¿...@?",
  "Core.Hector.PlayerKilled.Skull.02": "Fácil, ahora... tómalo con calma.",
  "Core.Hector.PlayerKilled.Skull.03": "¡Estas despierto! Gracias a dios. ¡Hector te encontró agotado en la caverna calavera!$2^¡Estas despierta! Gracias a dios. ¡Hector te encontró agotada en la caverna calavera!$2",
  "Core.Hector.PlayerKilled.Skull.04": "Estaba tan preocupado por ti, @...$21",
  "Core.Hector.PlayerKilled.Skull.05": "Harvey, estará bien, ¿verdad? Dime que estará bien.$2",
  "Core.Hector.PlayerKilled.Skull.06": "Sí, pero debes ser un poco más cuidadoso la próxima vez.$2^Sí, pero debes ser un poco más cuidadosa la próxima vez.$2",
  "Core.Hector.PlayerKilled.Skull.07": "Los dejaré a los dos para que hablen; Hazme saber si necesitas algo.$2",
  "Core.Hector.PlayerKilled.Skull.08": "No sé qué habría hecho si algo más permanente te hubiera pasado, @.#$b#Mandíbulas primero, preguntas después. Por favor, protégete mejor, ¿vale?$17",

  "Core.Hector.GreenRain": "Lluvia druídica. Tómate un tiempo para estar en ella, si puedes. Medita. Disfrútala.$14",
  "Core.Hector.GreenRainFinished": "Todo es tan hermoso ahora, ¿verdad? La lluvia druídica es una especie de ritual antiguo, realizado por la propia tierra.$13",
  "Core.Hector.GreenRain2": "¿Has invocado esto, @? Estoy seguro de que eres lo suficientemente hábil como para hacerlo. Si no es así, no te preocupes. Con el tiempo dominarás lo druida.$12",

  // POLYAMORY 
  "Core.Hector.MarriedMonogamousNPC": "No gracias, @. Soy de una sola persona, y también lo es tu pareja actual.$24",

  // EPILOGUE 
  "Core.Hector.Epilogue.1": "Me siento bien por primera vez en mucho, mucho, mucho tiempo.$7",
  "Core.Hector.Epilogue.2": "Jacob ha sido un profesor increíblemente atento. Sin embargo, me estoy esforzando mucho por diagnosticar correctamente los problemas en lugar de limitarme a preguntar al paciente. Quiero aprender.$8",
  "Core.Hector.Epilogue.3": "He estado menos inclinado a ver series, o simplemente holgazanear... hay criaturas que necesitan mi ayuda, y estoy decidido a hacer lo correcto por ellas.$12",
  "Core.Hector.Epilogue.4": "Eloise es la luz de mi vida. No todos los días son fáciles, pero ella hace que incluso los más difíciles sean más brillantes.$13",
  "Core.Hector.Epilogue.5": "Los bichos de Jacob son muy habladores. Me estoy esforzando por conocerlos, igual que me he esforzado contigo y con el Gremio.$6",
  "Core.Hector.Epilogue.6": "Recuerdo mis anteriores interacciones contigo y me siento un poco avergonzado. Supongo que eso es crecer, ¿no?$8",
  "Core.Hector.Epilogue.7": "Creía que ser intratable era sólo mi forma de ser, pero no, resulta que estar enfermo vuelve a cualquiera un poco angustiado y difícil.$4#$b#Te pido disculpas por todo lo que te hice pasar, hace tiempo.$13",
  "Core.Hector.Epilogue.8": "Les gusto a mis pacientes, y esa es la mejor sensación del mundo. Incluso mejor que ver crecer las plantas.$1",
  "Core.Hector.Epilogue.9": "A veces dejo que Eloise escoja mi ropa. Tiene mejor gusto que yo.$4",
  "Core.Hector.Epilogue.10": "Eloise tenía razón. No soy un lobo porque están destinados a ser solitarios, soy un lobo porque son animales de manada. Y yo necesitaba una manada.$11",

