  // PENTACLE QUEST - SPRING 
  "Quests.Hector.SpecialOrders.Pentacle1.Name": "Ofrendas para la primavera",
  "Quests.Hector.SpecialOrders.Pentacle1.Text": "Entrega en el altar con velas verdes fuera de la torre en ruinas en las Montañas Profundas.",
  "Quests.Hector.SpecialOrders.Pentacle1.Objective.0.Text": "3 Chirivías recién cultivadas.",
  "Quests.Hector.SpecialOrders.Pentacle1.Objective.1.Text": "3 Narcisos, elegidos con amor.",
  "Quests.Hector.SpecialOrders.Pentacle1.Objective.2.Text": "3 Puerros, crudos.",
  "Quests.Hector.SpecialOrders.Pentacle1.Objective.3.Text": "3 Fresas, sin chocolate.",
  "Quests.Hector.SpecialOrders.Pentacle1.Objective.4.Text": "3 Cebolletas de Tizón.",

  // PENTACLE QUEST - SUMMER 
  "Quests.Hector.SpecialOrders.Pentacle2.Name": "Ofrendas para el verano",
  "Quests.Hector.SpecialOrders.Pentacle2.Text": "Entrega en el altar con velas rojas fuera de la torre en ruinas en las Montañas Profundas.",
  "Quests.Hector.SpecialOrders.Pentacle2.Objective.0.Text": "3 Arándanos recién cultivados.",
  "Quests.Hector.SpecialOrders.Pentacle2.Objective.1.Text": "3 Bayas especiadas cubiertas de suciedad.",
  "Quests.Hector.SpecialOrders.Pentacle2.Objective.2.Text": "3 De los guisantes dulces más dulces.",
  "Quests.Hector.SpecialOrders.Pentacle2.Objective.3.Text": "3 Espigas de maíz vivas.",
  "Quests.Hector.SpecialOrders.Pentacle2.Objective.4.Text": "3 Setas rojas, no las pruebes.",

  // PENTACLE QUEST - FALL
  "Quests.Hector.SpecialOrders.Pentacle3.Name": "Ofrendas para el otoño",
  "Quests.Hector.SpecialOrders.Pentacle3.Text": "Entrega en el altar con velas naranjas fuera de la torre en ruinas en las Montañas Profundas.",
  "Quests.Hector.SpecialOrders.Pentacle3.Objective.0.Text": "3 Col china, cultivada con amor.",
  "Quests.Hector.SpecialOrders.Pentacle3.Objective.1.Text": "3 Racimos de Amaranto.",
  "Quests.Hector.SpecialOrders.Pentacle3.Objective.2.Text": "3 Ciruelas salvajes. ¡No hay fechas!",
  "Quests.Hector.SpecialOrders.Pentacle3.Objective.3.Text": "3 Moras recién cogidas del arbusto.",
  "Quests.Hector.SpecialOrders.Pentacle3.Objective.4.Text": "3 Grosellas, de casa.",

  // PENTACLE QUEST - Winter
  "Quests.Hector.SpecialOrders.Pentacle4.Name": "Ofrendas para el invierno",
  "Quests.Hector.SpecialOrders.Pentacle4.Text": "Entrega en el altar con velas azules fuera de la torre en ruinas en las Montañas Profundas.",
  "Quests.Hector.SpecialOrders.Pentacle4.Objective.0.Text": "3 Raíces invernales con almidón.",
  "Quests.Hector.SpecialOrders.Pentacle4.Objective.1.Text": "3 Frutas de Cristal sin duendes de Polvo.",
  "Quests.Hector.SpecialOrders.Pentacle4.Objective.2.Text": "3 Ñames de nivales desenterrados.",
  "Quests.Hector.SpecialOrders.Pentacle4.Objective.3.Text": "3 Azafranes, no en ramo.",
  "Quests.Hector.SpecialOrders.Pentacle4.Objective.4.Text": "3 Racimos de acebo.",

  // RIVER QUESTS - Pt 1 
  "Quests.Hector.SpecialOrders.River1.Name": "Destruir la tubería con fugas",
  "Quests.Hector.SpecialOrders.River1.Text": "Entrega en el altar con velas verdes brillantes fuera de la Torre de Hector.",
  "Quests.Hector.SpecialOrders.River1.Objective.0.Text": "1 Esquirla prismática.",
  "Quests.Hector.SpecialOrders.River1.Objective.1.Text": "5 Trozos maduros de Fruta milenaria.",
  "Quests.Hector.SpecialOrders.River1.Objective.2.Text": "3 Conchas de Nautilo claramente anaranjadas.",
  "Quests.Hector.SpecialOrders.River1.Objective.3.Text": "10 De los helechos más frondosos.",
  "Quests.Hector.SpecialOrders.River1.Objective.4.Text": "3 Viales de tinta de calamar, de niños calamar.",

  // RIVER QUESTS - Pt 2 
  "Quests.Hector.SpecialOrders.River2.Name": "Recolectar esencias druídicas",
  "Quests.Hector.SpecialOrders.River2.Text": "Entrega en el altar con velas verdes brillantes fuera de la Torre de Hector. Las esencias pueden recogerse cosechando los cultivos, labrando la tierra, regando las plantas y segando la hierba.",
  "Quests.Hector.SpecialOrders.River2.Objective.0.Text": "Recopila esencias.",
  "Quests.Hector.SpecialOrders.River2.Objective.1.Text": "Devuelve las esencias al altar.",


