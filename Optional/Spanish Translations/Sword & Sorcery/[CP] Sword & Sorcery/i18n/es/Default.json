  // SUMMIT DIALOGUE 
  "CFD.Mateo.ExtraDialogue_SummitEvent_Intro_Mateo": "Hola, Cielo.$4",
  "CFD.Mateo.ExtraDialogue_SummitEvent_Intro2_Mateo": "¿Has visto alguna vez tanto esplendor?$1",
  "CFD.Mateo.ExtraDialogue_SummitEvent_Dialogue1_Mateo": "No puedo evitar pensar en los últimos %year años...$4",
  "CFD.Mateo.ExtraDialogue_SummitEvent_Dialogue2_Mateo": "Hemos pasado muchas cosas juntos, ¿no? Y no me retractaría ni un segundo, ni siquiera de las partes estresantes.$14",
  "CFD.Mateo.ExtraDialogue_SummitEvent_Dialogue3_Mateo": "...Mira todo lo que hemos aprendido y conseguido juntos; lo lejos que hemos llegado desde el principio.$27",
  "CFD.Mateo.ExtraDialogue_SummitEvent_Dialogue4_Mateo": "¿Y sabes qué? No se ha acabado. Todavía hay aventuras que vivir juntos.$4",
  "CFD.Mateo.ExtraDialogue_SummitEvent_closingmessage": "Ha sido un largo camino para ti y Mateo...",

  // MOVIE INVITATION - SPOUSE 
  "MovieInvite_Spouse_Mateo": "Siempre me alegra ver una película contigo, Cielo.$76",

