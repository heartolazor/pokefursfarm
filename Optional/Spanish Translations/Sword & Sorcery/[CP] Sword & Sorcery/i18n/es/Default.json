  // ESSEN-TIAL COLLECTION
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Name": "¡Colección Esen-cial!",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Text": "Las esencias del aire proceden de enemigos voladores. Las esencias del fuego proceden de enemigos volcánicos. Las esencias de la tierra proceden de la minería. Las esencias del agua provienen de la pesca.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.0.Text": "Deposita 50 Esencias de la Tierra en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.1.Text": "Deposita 50 Esencias del Fuego en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.2.Text": "Deposita 50 Esencias del Agua en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.3.Text": "Deposita 50 Esencias del Aire en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.4.Text": "Deposita 50 Esencias Druídicas en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.5.Text": "Deposita 50 Esencias Sombrías en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.6.Text": "Deposita 50 Esencias Solares en el cofre de la Forja subterránea.",
  "Quests.CAGQuest.UntimedSpecialOrder.RoslinEssence.Objective.7.Text": "Deposita 50 Esencias Espirituales en el cofre de la Forja subterránea.",


