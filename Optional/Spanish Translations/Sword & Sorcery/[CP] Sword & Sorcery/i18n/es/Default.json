  // STARDROP TEA 
  "Gifts.Cirrus.GiftReaction.StardropTea": "¡@! ¡Es el té con mejor sabor que he probado nunca! ¿Cómo has podido encontrar algo así? ¡El perfil de sabor es increíble!$1",

  // ANCIENT SWEET TEA
  "Gifts.Cirrus.GiftReaction.AncientSweetTea": "Ni siquiera soy una chica de té y me ENCANTA, me ENCANTA, me ENCANTA esto. ¡Sabe como una bebida de postre! ¡Gracias!$1",

  // BASIC GIFT RESPONSES 
  "Gifts.Cirrus.GiftReaction.Love": "Gracias, @! ¡Esto es jodidamente brillante!",
  "Gifts.Cirrus.GiftReaction.Like": "¡Oh, esto es genial! Gracias, @.",
  "Gifts.Cirrus.GiftReaction.Dislike": "¿Disculpa que?",
  "Gifts.Cirrus.GiftReaction.Hate": "@, ¿por qué me darías esto? No tengo espacio en mi camioneta para la basura.",
  "Gifts.Cirrus.GiftReaction.Neutral": "¡Gracias, @!",

  // ARTISANAL GOODS
  "Gifts.Cirrus.GiftReaction.CategoryArtisanalGoods": "¿Tú hiciste esto? ¿Desde cero? ¿Y lo estás compartiendo conmigo? ¡Gracias!$1",

  // TRASH
  "Gifts.Cirrus.GiftReaction.CategoryTrash": "¿Por qué harías esto?$12",

  // MINERALS & GEMS
  "Gifts.Cirrus.GiftReaction.CategoryGemsMinerals": "¡Esto es hermoso! Me encantan las piedras, sobre todo de diferentes lugares. ¡Gracias!$1",

  // LOVES - PLATONIC
  "Gifts.Cirrus.GiftReaction.PrismaticShard": "@, esto es lo más hermoso que he visto en mi vida - qué regalo tan atento, muchas gracias. Lo atesoraré.$4",
  "Gifts.Cirrus.GiftReaction.GreenTea": "¡ME ENCANTA el té! Colecciono todos los tipos diferentes de tantos lugares diferentes como puedo. ¡Gracias por esto, @!$1",
  "Gifts.Cirrus.GiftReaction.Pizza": "¡La pizza es una de mis comidas favoritas! ¡Sin embargo, la pizza aquí no es tan buena como en Zuzu!",
  "Gifts.Cirrus.GiftReaction.SalmonDinner": "He comido mucho pescado antes, ¡pero el salmón aquí es INIGUALABLE en comparación con otros lugares!$1",
  "Gifts.Cirrus.GiftReaction.FishTaco": "Este es la mejor tipo de fusión que existe. ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.CrispyBass": "Honestamente, ¡el marisco aquí es CASI tan bueno como en Puerto Drake! ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.zuzustylebagelwithlox": "@, esto es una BOMBA. Comida clásica de ciudad Zuzu. Me encanta. ¡Me alegra mucho que lo hayas hecho y hayas decidido compartirlo!$1",
  "Gifts.Cirrus.GiftReaction.ZuzuStylePizza": "¡@! ¡Esto sabe tan bien como la auténtica! ¿La enviaron por barco desde la ciudad? ¡Dios mío! ¡Gracias!$1",
  "Gifts.Cirrus.GiftReaction.ZuzuStyleCheesecake": "¡Oh Dios mío, @! Esto se siente como en casa, parece que está perfecto - ¡Gracias por compartirlo conmigo!$1",
  "Gifts.Cirrus.GiftReaction.ZuzuStyleClamChowder": "¡Oh, @! Me alegro mucho de que lo hayas hecho, espero que te resulte tan hogareño y nostálgico como a mí.$1",
  "Gifts.Cirrus.GiftReaction.PortfireDrakeSparkler": "Sinceramente, me encanta un buen cóctel sin alcohol. Me siento menos excluida porque me encanta ir a bares pero ya no bebo.$6#$b#Gracias, @. Es muy amable de tu parte haber hecho esto.$4",
  "Gifts.Cirrus.GiftReaction.GingerBeer": "Dios mío, ¿acabaste haciendo Cerveza de jengibre? ¡Estoy tan emocionada de probarlo! Gracias por participar en mis aficiones conmigo, @.$1",

  // LIKES
  "Gifts.Cirrus.GiftReaction.MapleBar": "Mateo dijo que era algo local y me hizo probar una. Y luego probé dos. Luego tres...$1",
  "Gifts.Cirrus.GiftReaction.FriedEel": "Creo que a la gente le desagrada mucho la anguila, ¡pero creo que es deliciosa!#4",
  "Gifts.Cirrus.GiftReaction.SpicyEel": "Creo que a la gente le desagrada mucho la anguila, ¡pero creo que es deliciosa!#4",
  "Gifts.Cirrus.GiftReaction.Sashimi": "Me encanta el sashimi. Comencé mi viaje con pescado crudo con salmón ahumado y ahora tengo una regla estricta de 'probar todo dos veces'.",
  "Gifts.Cirrus.GiftReaction.MakiRoll": "Me encanta el sushi. Comencé mi viaje con pescado crudo con salmón ahumado y ahora tengo una regla estricta de 'probar todo dos veces'.",
  "Gifts.Cirrus.GiftReaction.TroutSoup": "¿Es la trucha el pescado más bonito? No. ¿Es uno de los más deliciosos? Sí.$1",
  "Gifts.Cirrus.GiftReaction.JojaCola": "Sé que es un poco sacreligioso, ¡pero siempre prefiero bebidas gaseosas en vez de alcohol!$14",

  // BIRTHDAY - PLATONIC
  "Gifts.Cirrus.GiftReaction.PrismaticShard.Birthday": "@, Esto es lo más hermoso que he visto en mi vida, ¿y guardaste uno para mi cumpleaños? ¡Eres tan encantador! Gracias...$10^@, Esto es lo más hermoso que he visto en mi vida, ¿y guardaste uno para mi cumpleaños? ¡Eres tan encantadora! Gracias...$10",
  "Gifts.Cirrus.GiftReaction.GreenTea.Birthday": "¡SABES que me encanta el té! ¡Gracias @, este es un regalo de cumpleaños increíble!$1",
  "Gifts.Cirrus.GiftReaction.Pizza.Birthday": "¡Nada es mejor en tu cumpleaños que un poco de pizza! ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.SalmonDinner.Birthday": "¡Siiii, una cena de mariscos de cumpleaños! ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.FishTaco.Birthday": "¡Siiii, una cena de mariscos de cumpleaños! ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.CrispyBass.Birthday": "¡Siiii, una cena de mariscos de cumpleaños! ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.zuzustylebagelwithlox.Birthday": "¿Herviste un panecillo sólo para mí en mi cumpleaños? ¡Gracias, @!$1",
  "Gifts.Cirrus.GiftReaction.ZuzuStylePizza.Birthday": "¿Conseguistes una pizza REAL para mi cumpleaños? Gracias @, ¡esto es lo bueno!$1",

  // ITEM REJECTIONS 
