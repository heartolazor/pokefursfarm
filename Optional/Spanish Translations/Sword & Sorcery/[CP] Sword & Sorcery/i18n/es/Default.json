  // STARDROP TEA 
  "Gifts.Dandelion.GiftReaction.StardropTea": "@, esta es mi FAVORITA. COSA. SIEMPRE. Gracias, aprecio que me ofrezcan un té tan exquisito.$4",

  // ANCIENT SWEET TEA
  "Gifts.Dandelion.GiftReaction.AncientSweetTea": "Quizás sea un poco parcial, pero me encanta. El té Fruta Estelar es increíble, así como todas las demás variedades... ¿pero éste? Esto es especial.$4",

  // BASIC GIFT RESPONSES 
  "Gifts.Dandelion.GiftReaction.Love": "¡Dios mío! Gracias @, esto es muy bonito.",
  "Gifts.Dandelion.GiftReaction.Like": "¡Gracias, @! Es un regalo muy amable.",
  "Gifts.Dandelion.GiftReaction.Dislike": "¡Oh, hm! Gracias, @. ...supongo...",
  "Gifts.Dandelion.GiftReaction.Hate": "...¡Se agradece!... Gracias. ...supongo...",
  "Gifts.Dandelion.GiftReaction.Neutral": "¡Gracias, @!",
  // ARTISANAL GOODS
  "Gifts.Dandelion.GiftReaction.CategoryArtisanalGoods": "¡Esto se ve delicioso, @! ¿Lo hiciste en %farm?$1",

  // TRASH
  "Gifts.Dandelion.GiftReaction.CategoryTrash": "...Pero, ¿por qué?$2",

  // MINERALS & GEMS
  "Gifts.Dandelion.GiftReaction.CategoryGemsMinerals": "¡Esto es muy bonito! Gracias, @.$1",

  // LOVES - PLATONIC
  "Gifts.Dandelion.GiftReaction.PrismaticShard": "¡Dios mío, @! Sé lo raras que son, y para qué se usan. Aprecio un regalo tan ponderado - gracias.$1",
  "Gifts.Dandelion.GiftReaction.Dandelion": "¡Ah-ja! Sorpresa, sorpresa. Esta es una de mis flores favoritas, porque se puede hacer un té encantador con ella. Gracias, @.$1",
  "Gifts.Dandelion.GiftReaction.Starfruit": "Me encantan porque son amarillos, y el amarillo es mi color favorito. Apuesto a que también podría convertirlo en un jarabe para el té.$6",
  "Gifts.Dandelion.GiftReaction.GreenTea": "El té verde es un CLÁSICO. ¿Y estos son de hojas que tú cultivaste? ¡Encantador! Gracias, @.$1",
  "Gifts.Dandelion.GiftReaction.Potions": "¡Oh, @! Me encantan las pociones, por supuesto. Son simplemente un paso a la izquierda de preparar té, ¡pero con un poco más de dinamismo! ¡Gracias por ser tan considerado!$1^¡Oh, @! Me encantan las pociones, por supuesto. Son simplemente un paso a la izquierda de preparar té, ¡pero con un poco más de dinamismo! ¡Gracias por ser tan considerada!$1",

  // LIKES
  "Gifts.Dandelion.GiftReaction.Wine": "Me apetece un buen vino de vez en cuando. Gracias, @.$6",
  "Gifts.Dandelion.GiftReaction.Sunflower": "Me encantan porque son amarillos, y el amarillo es mi color favorito. Apuesto a que también podría convertirlo en un jarabe para el té.$6",
  "Gifts.Dandelion.GiftReaction.GoatCheese": "¡Esto combina bien con el vino! Y, ooh, té. Por supuesto que combinaría bien con el té adecuado...$1",
  "Gifts.Dandelion.GiftReaction.Truffle": "Me encantan porque Cirrus puede usarlos para decorar comidas elegantes.$6",

  // BIRTHDAY - PLATONIC
  "Gifts.Dandelion.GiftReaction.Dandelion.Birthday": "¿Me trajiste mi flor favorita, para mi té favorito, en mi cumpleaños? Eres el mejor, @.$1^¿Me trajiste mi flor favorita, para mi té favorito, en mi cumpleaños? Eres la mejor, @.$1",
  "Gifts.Dandelion.GiftReaction.Starfruit.Birthday": "¿Mi fruta favorita en mi cumpleaños? Eres tan considerado, @. Gracias, @.$1^¿Mi fruta favorita en mi cumpleaños? Eres tan considerada, @. Gracias, @.$1",
  "Gifts.Dandelion.GiftReaction.GreenTea.Birthday": "¿Té casero en mi cumpleaños? Eres tan considerado, @. Gracias, @.$1^¿Té casero en mi cumpleaños? Eres tan considerada, @. Gracias, @.$1",

  // ITEM REJECTIONS 
  "Gifts.Dandelion.GiftReject.Bouquet": "¡Uhm, no! ¡Lo siento!$1",
  "Gifts.Dandelion.GiftReject.VoidEssence": "Ah, erm - no gracias, @. Ya he tenido suficiente magia sombría para toda la vida.$2",


