  "magicitem.OwlBoyIcon.name": "Icono del Chico Búho",
  "magicitem.OwlBoyIcon.description": "¿Hoot? ¡Eres un tramposo!",
  "magicitem.destykeychain.name": "Llavero de Stiles",
  "magicitem.destykeychain.description": "Un llavero inusual para Larga Vida al Rey, en forma de X.",
  "magicitem.destykeychain.description.Trinket": "Un llavero inusual para Larga Vida al Rey, en forma de X.\n\nInvoca a Stiles' Owl\n= Recoge alimento\n= Encuentra cultivos\n= Ataca monstruos\n= ¡Ulula y habla!\n= +Buff 'Tanto polvo de estrellas'",
  "magicitem.destykeychain.dialogue.Hi": "¡El Chico Búho se ha unido a la fiesta! ¡Hoot!",
  "magicitem.destykeychain.dialogue.1": " ¿Hoot hoot?",
  "magicitem.destykeychain.dialogue.2": "¡Hoot hoot hoot!",
  "magicitem.destykeychain.dialogue.3": "¿Adónde vamos, hoot?",
  "magicitem.destykeychain.dialogue.4": "Hoot hoot hoot. ¡El chico búho te manda saludos!",
  "magicitem.destykeychain.dialogue.5": "Hoot. ¿Cómo te encuentras? ¿Estás cansado?",
  "magicitem.destykeychain.dialogue.6": "¡Hoot hoot hoot! Recuerda mantenerte hidratado.",
  "magicitem.destykeychain.dialogue.7": "¡Hoot hoot! ¡Sigue caminando, caminando, caminando!",
  "magicitem.destykeychain.dialogue.8": "¡Hoot! ¡Lo tienes!",
  "magicitem.destykeychain.dialogue.9": "¡Vamos a explorar! ¡Hoot!",
  "magicitem.destykeychain.dialogue.10": "HOOT HOOT HOOT.",
  "magicitem.destykeychain.dialogue.11": "Cuidado con los monstruos, hoot.",
  "magicitem.destykeychain.dialogue.12": "¿Quién es un buen Chico Búho? ¡Yo! ¡Hoot!",
  "magicitem.destykeychain.dialogue.13": "Se puede decir que un búho feliz... ¡se divierte!",
  "magicitem.destykeychain.dialogue.14": "¡¿Hoot?! ¡¡¡Hoot!!! ¡Préstame atención!",
  "magicitem.destykeychain.dialogue.15": "¿Podemos ir a ver a Stiles? ¿Hoot?",
  "magicitem.destykeychain.dialogue.16": "¡Manteniendo los ojos bien abiertos en busca de alimento! ¡Hoot!",
  "magicitem.destykeychain.dialogue.17": "Tus pasos son ruidosos. ¡Hoot!",
  "magicitem.destykeychain.dialogue.18": "Ratones ratones ratones... no hay ratones que cazar...",
  "magicitem.destykeychain.dialogue.19": "¡Hoy va a ser un buen día! ¡HOOT!",
  "magicitem.destykeychain.dialogue.20": "¡Eres muy amable! ¡Hoot!",
  "magicitem.destykeychain.dialogue.21": "¡El chico búho te quiere! ¡Hoot!",

  "magicitem.EmeritusKeychain.name": "Llavero de Emeritus",
  "magicitem.EmeritusKeychain.description": "¡Un llavero de Viva el Rey, con forma de Emeritus! ¡Qué mono!\n\nInvoca a Emeritus\n= Dispara bolas de fuego\n= Recoge alimento\n= Encuentra objetos en la mina\n= +Buff 'Mordisco de Pasaje'",

  "magicitem.HectorWolfKeychain.name": "Llavero {{TrueName}} Lobo",
  "magicitem.HectorWolfKeychain.description": "¡Un llavero de Larga Vida al Rey, con forma de {{TrueName}} lobo!\n\nInvoca al Lobo {{TrueName}} \n= Recoge alimento \n= Recoge cosechas \n= Recupera energía \n= +Buff 'Aqua Regia'",

