*/

  // BUILDING THE LION'S MANE 
  "Quests.CAGQuest.UntimedSpecialOrder.LionsMane.Name": "Solicitud de Cirrus",
  "Quests.CAGQuest.UntimedSpecialOrder.LionsMane.Text": "¡Ayuda a Cirrus recolectando suministros para que ella pueda construir!",
  "Quests.CAGQuest.UntimedSpecialOrder.LionsMane.Objective.0.Text": "Deposita 900 piezas de madera en el barril frente al edificio.",
  "Quests.CAGQuest.UntimedSpecialOrder.LionsMane.Objective.1.Text": "Deposita 500 piedras en el barril frente al edificio.",
  "Quests.CAGQuest.UntimedSpecialOrder.LionsMane.Objective.2.Text": "Deposita 200 piezas de madera noble en el barril frente al edificio.",
  "Quests.CAGQuest.UntimedSpecialOrder.LionsMane.Objective.3.Text": "Deposita 25 lingotes de hierro en el barril frente al edificio.",

  /*
