	"VWW.Garfish.Fish.name": "Pez Gar",
	"VWW.Garfish.Fish.description": "También conocido como aguja de mar o pez garpike.",
	"VWW.Glasseye.Snapper.Fish.name": "Pargo Ojo de Cristal",
	"VWW.Glasseye.Snapper.Fish.description": "Un género de la familia de los ojones, que se encuentra en todos los mares tropicales del mundo.",
	"VWW.Golddust.Black.Molly.Fish.name": "Molly Negro Polvo de Oro",
