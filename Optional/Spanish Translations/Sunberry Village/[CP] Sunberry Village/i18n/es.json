"SBV.SpecialOrder.SBVMuseumMinerals_Objective_Text_3": "Dona 1 Baya Lunar",
"SBV.SpecialOrder.SBVMuseumMinerals_Objective_Text_4": "Dona 1 Purpurita",
"SBV.SpecialOrder.SBVMuseumMinerals_Objective_Text_5": "Dona 1 Serpentina",

// Museo Parte 2 
"SBV.SpecialOrder.SBVMuseumArtifacts1_Name": "Museo Sunberry Pt. 2",
"SBV.SpecialOrder.SBVMuseumArtifacts1_Text": "Ahora que se han recolectado los minerales, Elias necesita que recolectes algunos artefactos. Dona los siguientes artefactos en la caja a la derecha del museo.",
"SBV.SpecialOrder.SBVMuseumArtifacts1_Objective_Text_0": "Dona 1 Estatua de Hongo",
