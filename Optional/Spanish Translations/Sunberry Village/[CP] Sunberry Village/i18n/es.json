// Pip y Pep
"MapString.sbv.pipdialogue1": "Pip: ¡Ten buenos productos! ¡Mira los productos!",
"MapString.sbv.pipdialogue2": "Pip: ¡Pip viaja por el mundo buscando productos! Pip no tiene hogar.",
"MapString.sbv.pipdialogue3": "Pip: ¡Los precios de los productos varían! ¡Pip necesita dinero para comprar más productos! :D",
"MapString.sbv.pipdialogue4": "Pip: ¡Serás el cliente favorito de Pip! ¡Compra sus productos! :3",
"MapString.sbv.pipdialogue5": "Pip: ¡Pip tiene un hermano gemelo! Pep es el hermano favorito de Pip <",
"MapString.sbv.pepdialogue1": "Pep: ...Solo compra los productos. Pip y Pep trabajan duro para conseguirlos.",
"MapString.sbv.pepdialogue2": "Pep: ¿Tienes dinero? Gástalo en productos. Pep quiere comprarle un regalo a Pip.",
"MapString.sbv.pepdialogue3": "Pep te gruñe. No suena muy amenazante.",
"MapString.sbv.pepdialogue4": "Pep: Sé amable con Pip. Si eres malo con Pip, Pep te morderá.",
"MapString.sbv.pepdialogue5": "Pep: ...¿Qué? ¿Qué? Ve a ver la mercancía, no a Pep.",
"PipPepShopNotification": "Pip y Pep han abierto una tienda en el último nivel de las Minas de Bayas de Sol.",
    // Serenity Inn
"MapString.sbv.inn.notenoughmoney": "Puedes comprar una granja en Sunberry por 150.000 $, pero no tienes suficiente dinero. Vuelve cuando lo tengas.",
"MapString.sbv.inn.farmalreadypurchased": "Ya compraste una granja en Sunberry.",

// Casas desocupadas
"MapString.sbv.unoccupieddao": "Una casa desocupada. ¿Crees que a alguien aventurero le gustaría vivir aquí? ¿Quizás un bombero?",
"MapString.sbv.unoccupiedwren": "Una casa desocupada. Pero te suena a fontanero friki y marica.",
"MapString.sbv.unoccupiedhyuk": "Una casa desocupada. Crees que este es el hogar perfecto para un hombre misterioso y atractivo.",
"MapString.sbv.unoccupiedarv": "Una casa desocupada. Crees que a este lugar le vendría bien una familia unida.",
"MapString.sbv.unoccupieddido": "Una casa desocupada. Crees que es el hogar perfecto para una profesora y su hija adolescente rebelde.",
"MapString.sbv.unoccupiedyri": "Una casa desocupada. Crees que esta casa es perfecta para un arquitecto.",
"MapString.sbv.unoccupiedlani": "Una casa desocupada. Crees que a este pueblo le vendría muy bien alguien con conocimientos tecnológicos.",
"MapString.sbv.unoccupiedripley": "Una casa desocupada. Esperas que esta casa nunca tenga un granjero rival.",
"MapString.sbv.unoccupiedripleyrsv": "Una casa desocupada. Esperas que esta casa nunca tenga un granjero rival. Ya tienes bastante trabajo con Jeric como rival.",
"MapString.sbv.unoccupiedvalli": "Una casa bien cerrada. Solo un gremlin de la basura consideraría entrar y ocupar.",
"MapString.sbv.unoccupiedthy": "¿Crees que a una polilla fugitiva le gustaría vivir aquí con sus familiares?",
"MapString.sbv.unoccupiedalchemist": "Esta casa sería perfecta para una alquimista y su amiguito.",
