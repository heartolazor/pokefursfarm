"SBV.SpecialOrder.SBVMuseumArtifacts1_Objective_Text_5": "Dona 1 moneda de oro",

// Museo Parte 3
"SBV.SpecialOrder.SBVMuseumArtifacts2_Name": "Museo Sunberry Pt. 3",
"SBV.SpecialOrder.SBVMuseumArtifacts2_Text": "¡Ya casi terminas de restaurar el Museo Sunberry! Elias necesita que recolectes los últimos artefactos necesarios para completar la colección. Dona los siguientes artefactos en la caja a la derecha del museo.",
"SBV.SpecialOrder.SBVMuseumArtifacts2_Objective_Text_0": "Donar 1 Jarra Desportillada",
