"MadDog.BearFam.Custom_BearFamDateSpot": "Lugar de cita escondido",
"MadDog.BearFam.Custom_BearFamNoKrakenMap": "Cueva del Kraken",
"MadDog.BearFam.Custom_BearLodge_Cliff": "Sótano del Lodge Bear",
"MadDog.BearFam.Custom_BearFamLoadingZone": "Zona de Carga Bear",
"MadDog.BearFam_BearEventMine": "Evento mina Bear",
"MadDog.BearFam_BearBoatMap": "Barco con Fondo de Cristal",
"MadDog.HashtagBearFam_CollegeClassroom": "Departamento de Ictiología de ZuCU",
"MadDog.BearFam.CharityShop": "Tienda Caritas",
"MadDog.HashtagBearFam_RHTerenSigHouse": "Casa de Sig y Teren junto al Río",
"MadDog.BearFam.Custom_RHTerenSigInterior": "Hogar del Sargento Barnes & Bear",
"MadDog.BearFam.BoyBathroom": "Lodge Bear - Baño",
"MadDog.BearFam.GirlBathroom": "Lodge Bear - Baño",

//Fishing Stuff
"MadDog.BearFam.Custom_KrakenLakeName": "Lago Bear Escondido",
"MadDog.BearFam.Custom_BearRiverName": "Río Scarp Escondido",
"MadDog.BearFam_RHRiverZone": "Río Bear Escondido",
"MadDog.BearFam.Krakenling": "Krakenling",
"MadDog.BearFam.KrakenlingDescription": "La descendencia de algo antiguo y cruel. Hay travesura malévola en cada movimiento de sus tentáculos.",
"MadDog.BearFam.Hafgufa": "Hafgufa",
"MadDog.BearFam.HafgufaDescription": "Inconsciente del escombro acumulado en su espalda, este pez se alimenta de algas y depósitos de metal en las profundidades.",
"MadDog.BearFam.Lyngbakr": "Lyngbakr",
"MadDog.BearFam.LyngbakrDescription": "Con un nombre que significa 'espalda de cuero', este pez tiene piel apreciada por su durabilidad y lustre.",
"MadDog.BearFam.Jojellyfish": "Jojellyfish",
"MadDog.BearFam.JojellyfishDescription": "Esta especie de medusa urticante tiene un aroma inusual a cola. A Joja realmente le gustaría que no llevara el nombre de su bebida emblemática.",
"MadDog.BearFam.Colacrab": "Cangrejo Cola",
"MadDog.BearFam.ColacrabDescription": "Estos cangrejos ermitaños han empezado a hacer sus hogares dentro de latas vacías de Joja. Parecen estar prosperando.",

