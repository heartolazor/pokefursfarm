{
  //Sig

	"Sigurd.GiftReaction.Love.1": "Vaya, esto sí que no me lo esperaba. Eh… gracias, supongo.$18",
	"Sigurd.GiftReaction.Love.2": "¿Cómo sabías que acepto sobornos? ¿Qué necesitas, esconder un cadáver? ¿O que pelee contra un oso real?$10",
	"Sigurd.GiftReaction.Love.3": "Y yo aquí, con las manos vacías, sin poder devolverte el detalle. Te lo compensaré, @.$10",

	"Sigurd.GiftReaction.Like.1": "Sí, gracias.$18",
	"Sigurd.GiftReaction.Like.2": "Vaya, qué ${generoso^generosa}$ eres, @ Gracias.",
	"Sigurd.GiftReaction.Like.3": "¿Qué he hecho para caerte tan bien? Gracias.$18",

	"Sigurd.GiftReaction.Dislike.1": "Ah. Claro, cómo no.",
	"Sigurd.GiftReaction.Dislike.2": "‘Toma, Sig, tira esto’. ¿Eh? ¿Que no era eso lo que querías decir? ¿Seguro? Bah",
	"Sigurd.GiftReaction.Dislike.3": "%Sig te mira muy mal, pero termina aceptándolo.",

	"Sigurd.GiftReaction.Hate.1": "Por amor de Yoba… ¿Tanto me odias?",
