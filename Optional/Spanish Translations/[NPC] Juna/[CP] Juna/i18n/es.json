  //NPC INFO

  "npc.display.name": "Juna",

  //MAP MESSAGES

  "forest.sign.3": "No hay nada escrito en esta señal.",
  "forest.sign.4": "` Razzamatazz^> La Bailarina",
  "forest.sign.5": "` La Tierra^> El Sol",
  "forest.sign.6": "` Tú Sabes Quién^> Tú No Sabes Nada",
  "forest.sign.7": "` El Púrpura Soso^> El Púrpura Fascinante",
  "forest.seal.1": "La Bailarina no está aquí en este momento. Por favor, deja un mensaje después del beep. *beep*",
  "Juna.cave.1": "Hay una nota encima: ROBADO A RAZ. UNO DE MIS MAYORES LOGROS.",
  "Juna.cave.2": "Parece ser una lista de compras escrita en el idioma Junimo. ¿No es un poco desperdicio de un pergamino dorado?",

  // Preferencias de Regalos

  "gift.love": "Esto es excelente y absolutamente me lo merezco. ¡Gracias, y agradeceme!",
  "gift.like": "Hm... Creo que podría hacer algo interesante con esto.",
  "gift.dislike": "¡Ni siquiera lo intentas! ¡Fuera!",
  "gift.hate": "Esto es horrible y absolutamente no me lo merezco. Eres una úlcera.",
  "gift.neutral": "Esto es, de hecho, un regalo que puedes dar a alguien.",

  // Cadenas de Animación

  "juna.scheming": "¿Qué opinas de esta risa, es lo suficientemente malvada?$3",
  "juna.spyreading": "%Juna está leyendo. ¿O no lo está?",
  "juna.sitting": "%Juna parece estar sumida en sus pensamientos.",
  "juna.recharge": "El bosque me está dando algo de su energía. Es así como mantengo mi apariencia juvenil.$6",

  "robin.introduction": "¿Ya conoces a todos en el pueblo? Suena agotador.#$b#Oh, hablando de eso: ¿alguno de los que conociste era una mujer con cabello pálido y una sonrisa aparentemente permanente en su rostro?#$b#Estoy bastante seguro de que dijo que volvería del bosque esta semana...$6",

  //***DIALOGUE FOLDER***

  // ***DIÁLOGOS DE CUMPLEAÑOS***

  "birthday.love.3": "¿Sabes mi cumpleaños? ¡Apenas sé mi cumpleaños! Bien hecho.",
  "birthday.like.3": "Oh, ¿es mi cumpleaños hoy? Los Junimos son bastante malos celebrando cumpleaños, así que esto está bien. Gracias.",
  "birthday.hate.3": "Es mi cumpleaños, que por cierto sabía perfectamente, ¿y me das esto? ¡Boo! ¡Hiss!",
  "birthday.neutral.3": "¿Para mi cumpleaños? ¿Qué es eso? Oh, cierto. Claro que lo sabía.",

  "birthday.love.8": "¿Es mi cumpleaños otra vez? Bueno, gracias a los Junimos por dar buenos regalos. ¡Brava!",
  "birthday.like.8": "Aw, definitivamente deberías haberlo hecho, ya que de hecho es mi cumpleaños. Gracias, @!",
  "birthday.hate.8": "Hoy representa el día en que el mundo me vio por primera vez, Juna, y me das... esto para celebrar? ¡Boo! ¡Hiss!",
  "birthday.neutral.8": "¿Para mi cumpleaños? Ah, sí. Ahora recuerdo.",

  "birthday.love.10": "¿Un regalo? ¿Para mí? No esperaba menos de ti, para ser honesta. Ahora somos mejores amigos.",
  "birthday.like.10": "*Juna acepta tu regalo y comienza a cantar en voz alta \"¡Feliz cumpleaños para mí!\" mientras gira alrededor de ti.*",
  "birthday.hate.10": "¡Cómo te atreves! Todo este tiempo riendo, llorando, amando y viviendo juntos, ¿y esto es lo que piensas que merezco? ¡Boo! ¡Hiss!",
  "birthday.neutral.10": "Sí, sí. Regalos, pastel, etc. etc.",

  // **ADICIONES DE DIÁLOGO**

  "wizardhouse.SVE.2.29": "¡No fue TAN hace mucho!$5",
  "winter.SVEbasement.14.5": "¡No estoy haciendo nada! No tengo idea de qué estás hablando y me resiento por la implicación de que garabatearía en cualquiera de estos valiosos libros.$3",
  
  "wizardhouse.8hearts.wizard": "¿Estás seguro de que no me extrañaste, Raz? Pasamos una semana entera juntos. Que yo simplemente me fuera así, bueno, debe haber sido desgarrador para ti.$1",
  "wizardhouse.8hearts.parents": "¿Estás seguro de que no me extrañaste, Raz? Ha pasado un tiempo desde que tuviste que pasar una semana sin mi cautivadora compañía.$3",

  "roommate.5.5": "%Juna parece estar sumida en sus pensamientos.",
  "roommate.11.20": "Debo reconocerlo - Raz es muy bueno mirando al vacío.#$b#¡Yoba, estoy aburrida!$2",
  "roommate.4.6": "Quizás si lo hiciera- no, no ... ¡y luego SALTA!$7#$b#No tengo tiempo para ti ahora, @. Esta situación de compañero de cuarto ha tenido un impacto severo en mi entrenamiento. Necesito perfeccionar esta pose antes de que intente forzarme más té.$7",
  "roommate.9.5": "¡Aparta esa vil mezcla de mí!$13",
  "roommate": "¿Cómo van las cosas por fuera, @? ¿El sol sigue saliendo y poniéndose? ¿George y Evelyn siguen con nosotros?$2",

  "juna.rain_dialogue": "$c 0.5#A veces adoro la lluvia, otras veces la aborrezco. Todos contenemos multitudes.#¡Trueno y relámpagos! Entran tres brujas. ¿No es el Bard perfecto en un día como hoy?$1",

  "juna.outside_cc": "Si hay algo que adoro de los Junimos, es su hábito de acurrucarse en edificios abandonados y convencer a la gente de que les dé cosas a cambio de arreglarlo.$1#$b#¡Por supuesto que pueden hacerlo gratis, son espíritus del bosque! Pequeños bastardos descarados.$10",
  "juna.olive.cc": "¿Recuerdas nuestro primer edificio abandonado, Olive? Yoba, éramos jóvenes.$8",

  "juna.leo.1": "Supe desde el principio que yo y el chico tendríamos una conexión, a pesar de su preocupación con los loros.",
  "juna.leo.2": "Leo nunca ha faltado a una lección, ni siquiera una vez.#$b#Estoy tan decepcionada en él.$2",
  "juna.leo.3": "Luego lo revuelves tres veces en sentido antihorario, agregas las escamas de corteza de sauce, apagas el fuego y esperas a que se vuelva verde.#$b#¡Tada! Has hecho un brebaje perfectamente funcional de muerte viviente.$4",
  "juna.leo.4": "No, no, no. Repite después de mí: \"Puedo hacer lo que quiera, cuando quiera, como quiera.\".$3",

  "fieldtrip.question.prelude": "Estoy considerando llevar a Leo en una excursión, ya que sabe tan poco sobre cualquier cosa.#$b#Nos reunimos el 2 de cada mes, ¡y todavía piensa que el ballet y la danza de salón son lo mismo!$5#$b#Uno puede soportar solo tantas preguntas tontas antes de perder la fe en la humanidad, ¿estoy en lo cierto o estoy en lo cierto?#$b#¿Qué quieres decir, que ese es el propósito de enseñar? Nunca mind, no me importa.$11",
  "fieldtrip.question.q": "¿Entonces qué opinas? ¿Debería llevar a Leo en una excursión?",
  "fieldtrip.question.yes": "¿Por qué no? El chico fue criado por loros, debería ser capaz de soportar cualquier cosa.",
  "fieldtrip.question.no": "Realmente no creo que sea una buena idea...",
  "fieldtrip.question.reply.yes": "¡¿Verdad?! Yo también lo creo.#$b#¡Espera un minuto!$11",
  "fieldtrip.question.reply.no": "¡Tú! ¡Destructor de sueños, asesino de excursiones!$5",
  "fieldtrip.question.follow_up.yes": "¡Tengo tanto que planificar!$3",
  "fieldtrip.question.follow_up.no": "Siempre es bueno saber quién tiene curiosidad por la vida y quién... no.$13",

  "spa.winter.prealex": "Durante el invierno a menudo escuchamos a alguien gruñendo y jadeando en el vestuario de los hombres.$8#$b#Olive piensa que es un jabalí, pero yo espero que sea un fantasm-ooost.$9",
  "spa.winter.postalex": "No, ¡te lo prometo, Olive! No estoy mintiendo. Hay un espíritu inquieto que atormenta el vestuario de los hombres. Lo he visto con mis propios ojos.$8",

  "juna.conversation1": "Alex y yo vimos la película más hilarante el otro día. Se trataba de una anciana en su lecho de muerte. Su familia seguía tratando de despedirse de ella con gracia, pero ella solo los antagonizaba y los empujaba a pelear.$1",
  "juna.conversation2": "Realmente te perdiste esa cena con Evelyn y George, @! ¡Deberías haber visto la cara de Alex cuando se enteró de que George y yo jugamos pétanque juntos!$1",
  "juna.conversation3": "No entiendo por qué te rendirías ante algo solo porque no pudiste ganar dinero o volverte famoso por ello. ¡Eso no tiene ningún sentido!$5#$b#¿Qué hago por dinero?#$b#Nunca lo diré.$3",

  "eastscarp.spiritseve.1": "La versión más popular del mito es así: la Madre Leeds había dado a luz una docena de veces, y en su 13ª embarazo murmuró: \"¡Que este sea el diablo!\"$1#$b#Y, efectivamente, el niño se convirtió en una criatura demoníaca que creció alas y voló hacia el bosque, donde desde entonces ha atormentado a cualquiera que se atreva a entrar.$1#$b#¿Hm, qué? No, estoy hablando del Diablo de Jersey. Puedo llevar esta máscara por fuera, pero por dentro soy alguien completamente diferente.",
  "eastscarp.spiritseve.2": "Aprecio cualquier y todas las historias de terror, sean contadas por niños, académicos obsesionados con los enanos o ancianas que buscan hacer sentir culpables a sus hijos para que las visiten más a menudo.#$b#Oh, ¿estos huevos en mi regazo? Son para cualquiera que use la palabra \"spoopy\" donde pueda oírlos.$1",
  "eastscarp.spiritseve.3": "He encontrado la máscara perfecta para hoy, @. ¡Incluso tiene mejillas rosadas, ¡justo como yo!$1#$b#¡Nos vemos en la posada!",

  //GENERIC DIALOGUE

   "winterstar.juna.recipient": "¡Ohhoho! ¡Así que eres tú, eh?$3#$b#Estoy un poco triste de que no hayas dejado crecer una enorme barba blanca, pero está bien: ¡lo aceptaré!$1",
  "movie.invite.someone_else": "Lo siento, ya tengo planes para ver una película hoy, ¡pero tal vez puedas vernos y suspirar desde lejos!",
  "movie.invite.already_seen": "Lo siento, ya he visto una película esta semana. Tengo un calendario social increíblemente ocupado.",
  "movie.invite.accept": "¿Una película? Claro. Te veré en el cine.",
  "movie.invite.accept.rude": "¿Una película? Supongo que lo permitiré. Te veré en el cine.",
  "movie.invite.reject": "Lo siento, estoy ocupado no queriendo ir al cine en este momento.",
  "dating.reject": "...$11#$b#Te haré la cortesía - ¡que, ugh, odio hacer la cortesía! - de pretender que tropezaste y te caíste sobre mí mientras llevabas un ramo destinado a otra persona.$13#$b#Porque NO quiero esto. De nadie. ¿Ok? ¿Ok?$11",
  "movie.invite.roommate": "¡Leíste mi mente! ¡Saca el regaliz negro!$1#$b#...$11#$b#No estás intentando engañarme para ver una película familiar sobre el poder del amor otra vez, ¿verdad?$2",

  //FESTIVAL DIALOGUE

  "spring.24": "¡Me encanta este baile, es tan embarazoso! Oh Yoba, ¡bendícete por traer esto a mi vida!$4#$b#Nada supera bailar y ver a la gente hacer el ridículo.$4",
  "spring.24.2": "Este es el único baile que tanto Robin COMO Olive pueden hacer mejor que yo. Robin dice que es porque \"agito mis manos en el aire de manera demasiado sarcástica\", lo que sea que eso signifique.$2#$b#Deberías ver la interpretación de Olive. ¡Realmente se lo toma en serio, el pequeño diva!$4",
  "spring.24.roommate": "He decidido que deberías pedirle a Gus que sea tu compañero de baile este año. Tiene \"baile interpretativo\" escrito por todos lados, y definitivamente estoy aquí para ello.$1",
  "summer.11": "¿Quieres saber un secreto? Nunca pude averiguar qué comen los Junimos. A veces nada, a veces todo.#$e#¿Lo que pongo yo? Oh, eso es una cosa que NO quieres saber.$3#$e#¿Crees que si hiciera un argumento convincente Lewis aceptaría cambiar el nombre del festival a algo menos playero y mover el festival a un lugar menos playero? Como, por ejemplo, el bosque?$11",
  "summer.11.2": "Du duh.$3#$b#Du duun.$3#$b#Du dun, du dun.$3#$b#Oh, ups, no te vi allí. ¿Estaba pensando en voz alta?",
  "summer.11.roommate": "¿Quieres saber otro secreto? Nunca he puesto nada en la sopa, ni siquiera una vez.$3#$b#Es el pensamiento de lo que PODRÍA añadir lo que asusta a la gente, así que ¿por qué hacer el trabajo cuando todos ya lo han hecho por mí?$1",
  "fall.27": "Si alguna vez te pierdes, solo grita RAPUNZEL y te dejaré usar mi cabello para volver a la seguridad.$1",
  "fall.27.2": "Puedo ver al menos siete cosas y media que habría hecho mejor que Raz si yo hubiera sido quien organizara este festival espeluznante. Tsk. No estoy enojada, solo decepcionada.",
  "fall.27.roommate": "Si todas esas arañas de repente se volvieran reales... ¿cuánto crees que tardaría la gente en darse cuenta?$1",
  "winter.25": "Escucha. Si eres mi secreto lo que sea, necesito que sepas que me tomo esto muy en serio. @. Mira esta cara. Esta es mi cara seria, @.$2#$e#Los Junimos son terribles para dar regalos. Todo lo que me dieron fueron hojas. ¡Una chica no puede sobrevivir solo con hojas, @!#$b#¡Y Razzamatazz! ¡Ni siquiera me hagas empezar con Razzamatazz!$11#$e#Está bien, sí, sí, me conoces demasiado bien. Ven a buscarme más tarde y te contaré todo sobre los terribles regalos que el solitario morado me ha dado a lo largo de los años.$3",
  "winter.25.2": "Por supuesto que no siempre le doy a mi amigo secreto algo que odian.$2#$b#Primero, es predecible, y segundo, la mayoría de las personas en este pueblo parecen odiar cosas que prefiero guardar para mí. ¿Por qué iba a regalar un huevo de dinosaurio?$10",
  "winter.25.roommate": "He convencido a Robin para que venga a nuestra casa más tarde y cambiemos regalos mientras picoteamos toda esta comida que he escondido en mis bolsillos. ¡Nada de trabajo o charla sobre romance permitida!$10",

  //VANILLA NPC DIALOGUE

  "robin.spring.mondays": "A veces, bueno, realmente a menudo, Juna se va en largas divagaciones sobre flores, plantas y la naturaleza.#$b#Se queja mucho sobre su crianza y su familia Junimo, pero claramente han tenido un efecto en ella.#$b#Una vez dije que me gustaban los lirios, y ella hizo un sonido como si fuera a vomitar. ¿Qué tiene de malo los lirios?$6",
  "robin.summer.mondays": "¡Sabemos cocinar otras cosas además de fideos instantáneos, sabes!$3#$b#Bueno, Demetrius sí sabe, al menos.$6",
  "robin.fall.mondays": "¡Sabes quién, ¿quién? Puedo pensar en diez personas diferentes que te hacen temblar!$4",
  "robin.winter.mondays": "Ugh, esta resaca. Baja tu voz, por favor.$2",
  "robin.spring.saturdays": "A veces me preocupa la relación entre Maru y Sebastian. Solo desearía que él le prestara un poco más de atención, eso es todo.$2",
  "robin.summer.saturdays": "¡Juna! ¡Sabes que eso solo empezará una discusión!$3",
  "robin.fall.saturdays": "No estoy tan segura de ese tipo, Harvey. Maru es una joven tan brillante y ambiciosa. ¿Quién no se enamoraría de ella si tuviera la oportunidad?$6",
  "robin.winter.saturdays": "... y luego, él dijo: \"Cariño, no creo que estos sean mis calzoncillos después de todo\"$1",
  "robin.winter.5": "Cada invierno intento asegurarme de que Juna tome un descanso y visite el Mercado Nocturno conmigo.#$b#Siempre pasa el día antes del cumpleaños del Mago ideando formas de arruinarlo para él, así que hago lo que puedo para sacarla de su cueva.#$b#Realmente me pregunto cuántos años tiene a veces...$6",
  
  "wizard.birthday.1": "Sí, soy consciente de que Juna está hojeando mis libros. Ella hace esto cada año.",
  "wizard.birthday.2": "¿Así que ahora has decidido no hablar en absoluto?",
  "wizard.birthday.3": "Salud, Ju.",
  "wizard.sunday.general": "%El Mago parece distante, como si se estuviera preparando mentalmente para algo.",
  "wizard.sunday.2.14": "A veces observo a los aldeanos locales en secreto.#$b#Espero encontrar un aprendiz. Algún día dejaré este plano mortal, pero mis búsquedas arcanas deben continuar.#$b#Ah, sí, en efecto, tuve un aprendiz hace mucho, mucho, mucho, mucho... ¿qué fue eso, Juna?#$b#Digamos que no funcionó y dejémoslo así.",
  "wizard.sunday.0.1": "Agradecería mucho si pudieras satisfacer tu adicción a la Joja Cola en otro lugar, Ju. Así es como se atraen las hormigas, ya sabes.",
  "wizard.sunday.2.3": "%El ojo del Mago está temblando incontrolablemente.",
  "wizard.sunday.4.5": "Mucho de lo que sale de la boca de Juna tiene más sentido, sospecho, dentro de su cabeza que fuera de ella. A veces sigo su lógica, a veces no.#$b#Hoy definitivamente no.",
  "wizard.sunday.6.7.before": "¡Plantaste ese libro, Juna! ¡Te vi!",
  "wizard.sunday.8.9.wizard": "Oh, no sé si \"desgarrador\" es exactamente la palabra correcta. Considerando que pusiste aproximadamente 30 calcetines sucios en mi cama mientras estabas aquí.#$b#Ella ni siquiera usa calcetines...",
  "wizard.sunday.8.9.parents": "Ah, sí. Lloré lágrimas amargas todo el tiempo, te lo aseguro.#$b#De hecho, si ves manchas sospechosas en mis notas, son definitivamente de esas lágrimas, no porque me sorprendiera tanto viendo una película de terror que accidentalmente derramé té sobre mí.",
  "wizard.sunday.10.wizardspring": "Por supuesto que Juna solo mira hacia el pasado con cariño cuando el pasado involucra verme hacer el ridículo.",
  "wizard.sunday.10.wizardsummer": "Juna y yo tenemos un acuerdo. Yo la veo bailar los viernes y ella escucha cuando intento enseñarle más sobre pociones.#$b#La poción de hoy incluía jugo de limón y, bueno... aquí estamos.",
  "wizard.sunday.10.wizardfall": "%El Mago parece haberse quedado dormido de pie.",
  "wizard.sunday.10.wizardwinter": "Entonces... bueno. Llega un momento... eh, bueno, sí. Creo. La cosa es- las personas! Con otras personas. A veces. ¿Sabes? ¡Como mi exesposa! Ella es gente. ¿Eso... *tos*... Sí? ¿Algo para ti, quizás?",
  "wizard.sunday.10.parentspring": "De hecho, tengo hermanos. Y como pediste tan amablemente, te voy a contar todo sobre ellos, Ju.",
  "wizard.sunday.10.parentsummer": "Cometí el grave error de contarle a Juna sobre ver a mi exesposa por primera vez en, oh, ¿años? Ahora cada vez que abro la boca, ella empieza a cantar esa maldita canción.",
  "wizard.sunday.10.parentfall": "¿Debes hablar de tu pasatiempo aquí, de todos los lugares, Ju? Estoy tratando de terminar un trabajo.",
  "wizard.sunday.10.parentwinter": "Sigo diciéndote, Ju, la irresponsabilidad financiera no es un asunto de risa. Deberías sentirte mal por tus padres.",
  "wizard.roommate.2.6": "Podía haber jurado que escondí dinero en este libro. Hmm.",
  "wizard.roommate.3.19": "... y luego un poco de esto, o... hmm, tal vez no...#$b#No tengo tiempo para ti en este momento. La presencia de Juna aquí ha tenido un impacto severo en mi productividad. Necesito terminar esto antes de que ella termine de bailar.",
  "wizard.roommate.11.5": "¿Estás segura de que no quieres un poco de té, Ju? Está bastante delicioso.",
  
  "alex.event_response1": "(Tienes razón. Lo siento, solo estoy nervioso.)$4",
  "alex.event_response2": "(¡Gracias!)",
  "alex.event_response3": "(Oh, eso apesta.)%fork$2",
  "alex.event_response4": "(Eh, ¿ok?)%fork$5",
  
  "wizard.conversation.sign": "Hemos estado en guerra por ese letrero durante mucho tiempo, Juna y yo. Yo lo limpio, ella lo restaura. Yo lo quito, ella lo reemplaza.#$b#Hay que admirar su tenacidad, si no es nada más.",
  "wizard.conversation.gone": "Los espíritus me dijeron que convenciste a Juna para que fuera a visitar a sus padres.#$b#...#$b#Bien. Fue Olive.#$b#... Espero que no la decepcionen de nuevo.",
  "wizard.conversation.protective": "Estoy al tanto de tu amistad con Juna, que es la única razón por la que no me importa que me preguntes sobre la mía.#$b#Lo único que diré es que hemos hecho progresos.",
  "wizard.conversation.big_foot": "... ¿Qué quieres decir con que me viste en el bosque?#$b#Ese no era yo, era otra persona. Muchos magos gustan del color púrpura, te lo aseguro. Ahora vete, tengo trabajo importante que hacer.",
  "robin.conversation.cave": "¿Así que has estado en la casa de Juna, verdad?#$b#¿Una papa? La última vez que estuve allí, me dio tres cerezas y media rebanada de pastel.$1#$b#No te preocupes, estoy segura de que pronto alcanzarás el estado de pastel.",
  "robin.conversation.wizard": "¿Has visto a Juna esta semana? Me envió un mensaje raro diciendo que tuvo que cancelar todas nuestras reuniones esta semana.#$b#¿Está pasando toda la semana con el Mago? Vaya. Mejor preparo el alcohol para la próxima semana.#$b#Espero que esté bien...$2",
  "robin.conversation.gone": "Es una locura pensar que Juna se ha ido a encontrar a sus padres, ¿verdad?#$b#Espero que no le hagan más daño del que ya le han hecho.$2#$b#Si lo hacen, ¿puedo contar contigo para ayudarme a vengarme?$3",
  "robin.conversation.robin": "Escucha esto: según la leyenda, una mujer llamada Madre Leeds había dado a luz una docena de veces, y en su 13º embarazo murmuró: \"¡Que este sea el diablo!\". Y así es como nació el Diablo de Jersey.#$b#¿No suena como algo con lo que Juna se relacionaría?$6#$b#Oh, por supuesto que no creemos que los criptidos existan realmente. ¡Esto es solo un juego que jugamos a veces cuando estamos aburridos con el póker!$4",
  "robin.conversation.picnic": "Ese picnic fue algo el otro día, ¿verdad?$1#$b#Todavía no estoy 100% segura sobre Rasmodius, pero a pesar de las pruebas en contrario, Juna es una mujer adulta y merece tomar sus propias decisiones.",
  "willy.conversation": "Ay, he visto a la chica de negro bailar. No está en la playa cada vez que llueve, pero siempre está lloviendo cuando ella está allí.#$b#La he visto por el pueblo, por supuesto, pero no me parece alguien que le gusten las olas.#$b#Siempre parece tan triste...$2",
  "jas.conversation": "A veces, la señora con el cabello pálido me mira saltar la cuerda, lo cual es un poco raro.#$b#Pero a veces veo a la señora con el cabello pálido bailar en el bosque, ¡así que supongo que está bien!$1#$b#Eso se llama E-Q-U-A-L-I-D-A-D.$4",
  "abigail.conversation": "Sé que esto va a sonar raro, pero... ¿me viste con Juna cerca del lago del bosque hace un par de noches? Porque si no lo hiciste, ¡debo haber tenido el sueño más extraño!$9",
  "leo.conversation": "Juna me ha contado mucho sobre los Junimos. Me recuerdan a mi familia de loros. Espero que encuentre lo que está buscando.",
  "krobus.conversation": "No tenía idea de que Rasmodius era de los pueblos del Pie Grande.$3#$b#Se aprende algo nuevo cada día.$1",
  "alex.conversation.theo": "...$2#$b#¿Crees que me parezco a un Theo?$4",
  "alex.conversation.winter": "Juna y yo vimos una película súper deprimente el otro día. *escalofrío* Si había otra lección en eso, no quiero saber cuál fue.$2",
  "alex.conversation.spring_stay": "Gracias por quedarte el otro día, @. No quería que mis abuelos se llevaran la impresión equivocada sobre Juna y yo.$1#$b#Somos más como hermanos, ¿sabes? Juna es como la hermana mayor entrometida que nunca tuve.#$b#(Y a Juna realmente, realmente no le gusta cuando la gente asume que está saliendo con alguien.)$7",
  "alex.conversation.summer": "Hola, @.$1#$b#Nah, solo me he estado sintiendo realmente energizado y feliz últimamente. ¡Espero que tengas un gran año!$1",
  "sebastian.conversation.hodag": "Creo que si criaturas como el Hodag existieran, más gente habría visto una para ahora.#$b#Sería bastante genial, en realidad.$1",

  //***MOVIE FOLDER***

  "movie.spring0.before": "¿ÁRBOLES? ¿Eso es lo que vamos a ver? *suspiro* Bueno, si tengo que hacerlo.$11",
  "movie.spring0.during": "Eso NO es lo que es salir de casa.$12",
  "movie.spring0.after": "@, mírame.#$b#Nunca me hagas eso de nuevo.$13",
  "movie.summer0.before": "¿El videojuego? Hm. Quizás me dé el empujón que necesito para volver a disparar con la resortera.$3",
  "movie.summer0.during": "¡Lo mereces!$10",
  "movie.summer0.after": "¡No puedo esperar para dispararle a Lewis en el trasero con una resortera esta noche!$6",
  "movie.fall0.before": "¿Raz ha visto esta película? Porque si le gustó, definitivamente a mí no me va a gustar.",
  "movie.fall0.during": "El elemento de terror casi compensa todas las aburridas tomas artísticas.$10",
  "movie.fall0.after": "Sí, está bien, me gustó bastante la amenaza al final.$3",
  "movie.winter0.before": "¡Noooooo, por favor no! ¡No me hagas hacer esto!$2",
  "movie.winter0.during": "Creo que estoy muriendo, @. Dile a Robin que la amo y a Raz que apenas lo tolero.$2",
  "movie.winter0.after": "Ugh, ¡si alguien me llama 'mamá' o 'papá', será incluido en la lista negra para siempre! No me importa cuán adorable sea.$13",
  "movie.spring1.before": "La única razón por la que le estoy dando una oportunidad es porque soy prácticamente un documental de naturaleza ambulante.",
  "movie.spring1.during": "... *suspiro* ... Te dije que iba a ser aburrido.$11",
  "movie.spring1.after": "Nunca, pero nunca le digas a Olive que esta película existe, @. Me va a obligar a verla una y otra vez.$5",
  "movie.summer1.before": "Personalmente prefiero ver películas sobre personas que creen haber sido secuestradas por extraterrestres, pero supongo que puedo prestar atención al extraterrestre solo esta vez.",
  "movie.summer1.during": "¿Cómo es que no tengo un sirviente de comida? Woe es me.$2",
  "movie.summer1.after": "'¡Pshhaw!' Lo estoy robando.",
  "movie.fall1.before": "¡Sí, por favor! Ver películas de terror es una de las pocas maneras en que puedo relajarme.$4",
  "movie.fall1.during": "Mi infancia habría sido mucho más interesante si hubiera crecido en esos bosques.$2",
  "movie.fall1.after": "Eso fue INCREÍBLE. ¡Vamos a verlo de nuevo!$4",
  "movie.winter1.before": "Ah, sí, la película que les gusta a las personas que son buenas en el adulto. ¡Hagámoslo!",
  "movie.winter1.during": "¿Perdón, qué? Oh, no tengo la menor idea de lo que está pasando, solo estoy aquí por el atractivo visual.$4",
  "movie.winter1.after": "¿No crees que el personaje principal se parecía un poco a un bailarín?$4#$b#Si me disculpas - tengo que ir a practicar ballet ahora...$7",

  //***SCHEDULE DIALOGUE FROM SCHEDULE AND STRING FOLDERS***

  "wizard.string.friday_000": "¿Qué quieres decir con que me veo orgulloso? Eso es ridículo.$1#$b#Solo quería tomar un poco de aire. El hecho de que Juna esté aquí bailando no tiene nada que ver con ello.",
  "abigail.string.sunday_001": "Aún no entiendo lo que quieres decir con eso. ¡Además, tú también tienes el cabello púrpura!$9",
  "emily.string.mon_000": "¡Juna es tan talentosa! Me siento realmente energizada viéndola.#$b#Sus preguntas son un poco inusuales, sin embargo.$u",
  "emily.string.marriage_003": "Estoy tratando de darme un buen paseo hoy. Mis piernas se sienten como canelones.#$b#Además, realmente he extrañado ver a Juna bailar. Es importante mantenerse en contacto con los viejos amigos después de haberse casado.$h",
  "robin.string.tuesday_000": "Nos reunimos todas las semanas para animarnos a mantenernos saludables.#$b#Juna está aquí solo para molestarnos, porque es grosera así.$6",
  "robin.string.summer_5": "¿Por qué nunca bailas con nosotros, Juna? ¡Es tu cumpleaños! ¡Todos deberían bailar en su cumpleaños!$h",
  "robin.string.summer_18": "¿Qué hace una persona joven y saludable como tú aquí? Una vez que llegues a nuestra edad, es importante ver al médico una vez al año.#$b#Sí, Juna, NUESTRA edad.#$b#(En realidad no tengo idea de cuántos años tiene Juna, no lo dice y es imposible de decir.)$6",
  "robin.string.fall_21": "Bueno, mientras no requiera que me mueva - este monstruo acaba de comer demasiada espagueti.$4#$b#Salud, Ju.",
  "demetrius.string.summer_5": "Déjala en paz, cariño. Estoy seguro de que una bailarina como ella no quiere moverse por el salón con nosotros.#$b#(No estoy diciendo que no disfrute bailar con mi esposa, pero no estoy NO diciendo que no entiendo de dónde viene Juna tampoco...)$3",
  "leo.lessons.1": "Estudiar con Juna no es en absoluto como estudiar con Miss Penny.#$b#Miss Penny sabe mucho, y Juna... sabe cosas diferentes.",
  "leo.lessons.2": "Según un manual de danza del siglo XV, las personas bellas eran consideradas mejores bailarinas que las personas feas \"simplemente por ser bellas\".#$b#No sé por qué necesito saber esto tampoco.",
  "leo.lessons.3": "Juna dice que Yoba hizo caca con los primeros humanos. ¿Es eso cierto?$3",
  "leo.lessons.4": "¡Me gusta cuando Juna habla sobre magia!$1#$b#Pero luego siempre empieza a murmurar sobre magos estúpidos, y, y, y luego es como si no pudiera verme ni oírme más.$2",
  "george.summer_Fri.000": "Claro, me gusta ver a Juna bailar. Cualquier idiota puede ver que tiene talento.#$b#¡Pero el verano es para pétanque!$3",
  
  "string.winter_16": "Maldita Robin y su poderosa mirada de reojo. No tengo tiempo para esto.$5#$b#No, gracias, puedo escuchar a las sirenas muy bien desde aquí.$11",
  "string.summer_18": "¿Estás escuchando esto? Me levanto temprano para apoyar a mi mejor amiga en estos tiempos difíciles de huesos frágiles, ¿y esto es lo que recibo?$2#$b#¡NO estoy viejo!$13",
  "string.fall_sun": "Solo digo, Abby. Quizás haya una razón por la que decidiste teñirte el cabello de púrpura, una razón que ni siquiera tú conoces.#$b#Como, digamos... ¿una razón con forma de Raz?$6",
  "string.fall_fri": "Disfruto viendo a Abbi jugar. ¡Mira! ¡Mírala rebotar!$4",
  "string.spring_mon.000": "Y luego barrerás el brazo así, y luego pivotarás hacia la derecha como... ¡HUPP!$7#$b#Tú y Haley no se parecen mucho, ¿verdad? ¿Qué pasa con eso? ¿Tienen, como, padres diferentes o algo así?$3",
  "string.spring_mon.001": "Eh, ¡aún no me has mostrado tu baile de loro! ¡Exijo reciprocidad!$7",
  "string.summer_Fri.000": "Para alguien que pierde tan a menudo como Georgie, ciertamente es mandón cuando se trata de pétanque.$11",
  "string.fall_21.000": "¡Feliz cumpleaños al monstruo de espaguetis, feliz cumpleaños al monstruo de espaguetis, feliz cumpleaños querido Roo-biiiin, feliz cumpleaños al monstruo de espaguetis!$1#$b#Recibirás tu regalo tan pronto como esté seguro de que no hay nadie más alrededor. Digamos que no es para consumo público.$3",
  "string.fall_21.001": "¡Feliz cumpleaños al monstruo de espaguetis, feliz cumpleaños al monstruo de espaguetis, feliz cumpleaños querido Roo-biiiin, feliz cumpleaños al monstruo de espaguetis!$1",

  //***SPECIAL ORDER***

  "so.name": "El Mash de Monstruos de Juna",
  "so.text": "Un buen amigo mío está buscando compañía, así que pensé en ayudarlo haciendo una poción especial. La mezcla es más potente si se elabora poco después de recolectar los ingredientes, ¡así que por favor entrega los artículos lo antes posible!",
  "so.objective.0": "Entregar 1 Almizcle de Monstruo a Juna",
  "so.objective.1": "Entregar 1 Tónico de Energía a Juna",
  "so.objective.2": "Entregar 20 Savia a Juna",
  "so.objective.3": "Entregar 5 Carne de Bicho a Juna",
  "so.objective.4": "Entregar 1 Aceite de Ajo a Juna",
  "so.objective.5": "Entregar 1 Pan Extraño a Juna",

  //***EVENTS FOLDER***

  //QUESTS

  "8606100.title": "Solicitud de Bebida de Juna",
  "8606100.description": "Juna necesita una Joja Cola para enjuagar el sabor de los batidos de col del Mago.",
  "8606100.summary": "Lleva una Joja Cola a Juna.",
  "8606100.reaction": "¡Oh, Yoba! ¡Gracias! Esto es lo mejor que me ha pasado.$1",
  "8606200.title": "Solicitud de Mejor Amiga de Juna",
  "8606200.description": "Juna quiere un plato de espaguetis para recordar a su mejor amiga Robin.",
  "8606200.summary": "Lleva un plato de espaguetis a Juna.",
  "8606200.reaction": "¡Por fin! No he visto a Robin en días, ha sido terrible.$2",

  //MAIL

  "mail.potion": "@!^^¡Muchas gracias por conseguirme todos esos ingredientes repugnantes, aborrecibles y rancios! La poción salió muy bien. Puede que huela terriblemente en este momento, pero valdrá la pena si ayuda a mi mejor amigo a encontrar su comunidad.^^ -Tu amiga (casi), Ju^^P.D. Oh, cierto, probablemente también quieras algún tipo de recompensa, ¿verdad? Aquí tienes un cofre que hice.^^P.D.S. Bueno, eso fue una mentira. En realidad, no hice el cofre, lo hicieron los Junimos. ¡Ups!%item id (BC)256 %%[#]Poción de Juna",
  "mail.5hearts": "Querido @,^^Cuando llegaste a Pelican Town, estaba convencida de que ibas a ser solo otro granjero aburrido haciendo trabajo agrícola aburrido todo el día (creo que es algo en la forma en que te ves, ¿sabes?). ¡Pero resulta que no estás tan mal! Aprecio especialmente tus opiniones sobre Raz, que - lo sé, lo sé, no me lo has dicho exactamente en voz alta, pero soy muy buena leyendo a las personas, @. Te entiendo. Así que, para demostrar mi alta (bueno... media a media alta) estima por ti, adjunto encontrarás algo que robé del mencionado mago. ¡Espero que te guste!^^-Tu casi-amiga, Ju %item id (O)768 1 %%[#]Bienes Robados de Juna",
  "mail.fish": "Hola, noble tonto.^Después de que tú y Abby se fueran ayer, los peces prácticamente saltaron a mis brazos de tan emocionados que estaban por ser comidos. Pero como no me gusta el pescado - EN ABSOLUTO - pensé en darle el pescado a un noble tonto en su lugar.^^¡Saludos, Ju %item id (O)137 5 (O)140 5 %%[#]¡Aquí, pececito, pececito!",
  "mail.robin": "Hola @,^^Estoy un poco preocupada por Juna. Ha estado actuando de manera extraña últimamente y no me dice por qué. ¿Puedes ver si puedes hacer que se abra contigo? Estoy segura de que has notado que Juna desvía mucho, pero a veces, si estás en el lugar adecuado en el momento adecuado - y vienes armado con una palanca - puedes despejar algunas de esas tablas sin que te salgan astillas. Bueno, esa metáfora puede haberse ido por las ramas. De todos modos, te lo agradecería mucho. Ha estado pasando mucho tiempo en el bosque detrás de la torre del Mago, así que te recomendaría que revisaras allí primero.^^-Robin^^P.D. Aquí tienes algo para tus problemas. %item id (O)709 10 %%[#]Revisa a un amigo",
  "mail.wizard.1": "Querido diario,^^Encontré esto escondido dentro de un libro mientras desempacaba mis cosas en la casa de Raz (lo llamo desempacar, él lo llama husmear). Pensé que, dado que estoy aquí ayudando con el alquiler esta semana, no lo necesita realmente, ¿verdad?^^XOXO, Ju %item money 200 1200 %%[#]Carta de la Torre 1",
  "mail.wizard.2": "Querido diario,^^¿Podrías, por favor, traerme una Joja Cola? Raz solo bebe té y batidos de col. Blergh.^^XOXO, Ju %item quest 8606100 %%[#]Carta de la Torre 2",
  "mail.wizard.3": "Querido diario,^^Encontré esto en el sótano de Raz. Sé que parece que tiene su vida bajo control, pero simplemente no creo que sea lo suficientemente maduro para cuidar de un bebé, ¿sabes? Es mejor que tú lo tengas.^^XOXO, Ju %item id (O)107 1 %%[#]Carta de la Torre 3",
  "mail.wizard.4": "Querido Diario,^^Estoy de mal humor hoy. ¿Puedes traerme un plato de espaguetis del saloon para recordarme a Robin?^^XOXO, Ju %item quest 8606200 %%[#]Carta de la Torre 4",
  "mail.wizard.5": "Querido Diario,^^¡Nunca adivinarás lo que pasó hoy! Raz me dio un regalo. ¡Un regalo decente! (Bueno, decente para él al menos.) Dijo que pensaba dármelo cuando me graduara de la Academia Mágica de Magikazam o lo que sea, pero cuando eso no sucedió se olvidó de él. Típico Raz. ¡Finalmente estamos avanzando, diario! Lo único que queda ahora es lograr que me incluya en su testamento.^^XOXO, Ju^^P.D. ¿Quieres esto, por cierto? Dije que era decente, no deseado. %item id (BC)238 1 %%[#]Carta de la Torre 5",
  "mail.wizard.6": "Querido diario,^^Ha llegado el momento de dejar a Raz a su suerte una vez más. Ha sido una semana larga, diario. Una semana muy, muy larga. Me he sentido terriblemente vieja y terriblemente cansada (aunque la Joja Cola ciertamente ayudó). Pero mientras Raz siga siendo Raz y yo siga siendo yo, si esta semana me ha enseñado algo, es que es muy difícil resistir la felicidad. Y si trabajamos un poco más en ello, tengo fe en que algún día nos convertiremos en quienes siempre debimos ser: él un hombre que le da regalos a su pupila y no la obliga a hacer magia, y yo una mujer que acepta los regalos de su maestro y no lo obliga a socializar con otras personas.^^XOXO, Ju %item conversationTopic JunaWizard7 0 %%[#]Carta de la Torre 6",
  "mail.parents.1": "Querido diario,^^Actualmente en el autobús en camino a REDACTADO, que es una ciudad en REDACTADO, es decir, mi ciudad natal. Me pregunto si nuestra antigua casa todavía estará allí. Hay un hombre roncando muy fuerte en la fila detrás de mí. Odio el autobús. Ay de mí.^^XOXO, Ju %item conversationTopic JunaGone2 0 %%[#]Carta de Juna 1",
  "mail.parents.2": "Querido diario^^Llegué. No he comido nada desde ayer, el clima aquí es pésimo, y un hombre en la frontera tuvo la osadía de interrogarme sobre el propósito de mi visita. ¡Grosero! La teletransportación a veces resulta muy útil.^Encontré nuestra antigua casa. Todavía está en pie. Todavía es fea. No puedo creer que solía vivir aquí - mi cueva es mucho más agradable. Estoy esperando el momento adecuado para acercarme y golpear la puerta. Llegará pronto, creo. Aunque estoy MUY hambrienta...^^XOXO, Ju %item conversationTopic JunaGone3 0 %%[#]Carta de Juna 2",
  "mail.parents.3": "Querido diario,^^Bueno, tengo buenas noticias, malas noticias y noticias embarazosas. La noticia embarazosa es que había olvidado cuántos años tenían mis padres. Sé que TÚ sabes que NO soy tan vieja, diario, pero eso no se puede decir de mis padres. La buena noticia es que mi madre ocupa el puesto de la persona más vieja de REDACTADO. La mala noticia es que mi padre no.^Estoy bien, no te preocupes, pero supongo que tengo que idear un plan alternativo ahora. Ugh, odio cuando esto pasa.^^XOXO, Ju %item conversationTopic JunaGone4 0 %%[#]Carta de Juna 3",
  "mail.parents.4": "Querido diario,^^¡Tengo un hermano! Lo sé, lo sé, tengo un millón de hermanos, así que ¿por qué este me sorprende? ¡Porque es joven! ¡Como yo! No estoy del todo clara sobre cómo sucedió eso, pero ¿qué me importa? Su nombre es Theo, toca cinco instrumentos diferentes y es deliciosamente sarcástico. Podría secuestrarlo, ya veremos qué pasa.^^XOXO, Ju^^P.D. Oh, resulta que ese hombre grosero en la frontera puso una especie de alerta sobre mí. Es muy molesto tener que esquivarlo a donde quiera que vaya. Theo lo encuentra hilarante, así que supongo que eso es algo. %item conversationTopic JunaGone5 0 %%[#]Carta de Juna 4",
  "mail.parents.5": "Querido diario,^^Mi madre sigue siendo la peor. Eso es todo.^^XOXO, Ju %item conversationTopic JunaGone6 0 %%[#]Carta de Juna 5",
  "mail.parents.6": "Querido diario,^^Estoy segura de que estarás encantado de escuchar que estoy de regreso en Stardew. Mi viaje puede no haber salido como esperaba, y mi madre puede haberme negado la razón por la cual me dieron en adopción (¡la peor!), pero al menos significó que conocí a Theo. Además, REDACTADO es una ciudad horrible y estoy feliz de no tener que pasar el resto de mi vida allí.^¡Nos vemos cuando regrese!^^XOXO, Ju^^P.D. Puede que me haya disfrazado de mi madre al cruzar la frontera de regreso. ¿Sabías que puedes salirte con la tuya con casi cualquier cosa cuando estás disfrazada de la persona más anciana del país? %item conversationTopic JunaGone7 0 %%[#]Carta de Juna 6",
  "mail.picnic.forest": "¡Tú allí!^^Estoy planeando un hermoso picnic para mi tercer mago favorito, y pensé que podrías querer unirte - dado que has estado presente en todos los eventos anteriores que involucran a los dos, quiero decir. ¿Sospechoso, hmmmm?^Estoy pensando en el bosque, estoy pensando en la lluvia, estoy pensando en el mediodía. Tú decides.^¡Te veo luego!^^Ju^^P.D. ¿El pastel rosa y la gelatina podrían considerarse comida de picnic, verdad?",
  "mail.picnic.beach": "¡Tú allí!^^Estoy planeando un hermoso picnic para celebrar lo lejos que he llegado en solo unos pocos meses - es realmente asombroso cuando lo piensas. Dado que has estado sospechosamente presente en la mayor parte de mi crecimiento personal, pensé que podrías querer unirte a nosotros.^Estoy pensando en la playa, estoy pensando en el sol, estoy pensando en el mediodía. Tú decides.^¡Te veo luego!^^Ju^^P.D. ¿El pastel rosa y la gelatina podrían considerarse comida de picnic, verdad?",

  //EVENTS

  //Introduction

  "event-86060001.01": "Una z más, creo.",
  "event-86060001.02": "Perfecto.",
  "event-86060001.03": "No otra vez.",
  "event-86060001.04": "Rindo.",

  //Cave introduction

  "1heart.01": "¡Eso es todo!",
  "1heart.02": "¡Eso es perfecto...$3",
  "1heart.03": "@! ¡Ni siquiera noté que entraste!$1",
  "1heart.04": "¡Bienvenido a mi cueva!$4#$b#Es la mejor cueva que el dinero no puede comprar... así que tuve que pelear con un oso para conseguirla.$6",
  "1heart.05": "Entonces, ¿qué opinas?",
  "1heart.06": "¡Tomaré ese silencio ensordecedor como una gran aprobación y envidia!$4",
  "1heart.07": "Oh, solo estaba... pensando en cosas cuando entraste. No hay nada de qué preocuparse.#$b#(Raz, en cambio...)$3",
  "1heart.08": "¡De todos modos! ¿Puedo ofrecerte algo? No soy nada si no soy una buena anfitriona.$10",
  "1heart.09": "Me temo que no tengo eso.$2",
  "1heart.10": "Oh no, ¡tampoco tengo eso!$2",
  "1heart.11": "Déjame ver qué tengo.",
  "1heart.12": "Ups.",
  "1heart.13": "Oh, claro, eso es del mes pasado.",
  "1heart.14": "Cállate.",
  "1heart.15": "¡Encontré algo!$1",
  "1heart.16": "¡Aquí tienes![192]",
  "1heart.17": "Si lo conviertes en hashbrowns, ¡recuerda guardarme algo!$1",
  "1heart.18": "¡Hashbrowns! ¡Hashbrowns! ¡Hashbrowns!$4",

  //4 hearts

  "4hearts.01": "*Aclara la garganta*",
  "4hearts.02": "¿Qué estás haciendo?",
  "4hearts.03": "Sabes que hay un hechizo para la vista deficiente, ¿verdad, Raz? Tú fuiste quien me lo enseñó, después de todo.$11",
  "4hearts.04": "... *sigh* ... ¿Debes discutir sobre todo?",
  "4hearts.05": "Sí. Sí, absolutamente debo.$3",
  "4hearts.06": "¿Ella... te recuerda a alguien? ¿Es por eso que vienes aquí?",
  "4hearts.07": "Ugh, no, dinosaurio. Solo... vete.$5",
  "4hearts.08": "Hola.",
  "4hearts.09": "(Están siendo extraños.)",
  "4hearts.10": "Me voy ahora.",
  "4hearts.11": "¡Mira lo que hiciste! ¡La asustaste!$5",
  "4hearts.12": "¡¿Yo!? Eres tú quien espía a la gente desde detrás de un libro.",
  "4hearts.13": "Oh, por favor.",
  "4hearts.14": "Espías a la gente todo el tiempo, Raz. Es literalmente la única manera en la que interactúas con las personas.$11",
  "4hearts.15": "¡Agh, está bien! ¡Me atrapaste! Estaba mirando a Jas saltar la cuerda y reflexionando sobre la naturaleza de la infancia. ¿Es un crimen experimentar por un breve momento lo que parece una infancia normal?$2",
  "4hearts.16": "¡Lo sabía!",
  "4hearts.17": "Una infancia llena de amor, risas, sol y gallinas.$4#$b#Una infancia pasada en el cálido abrazo de una tía y un tío amorosos, rodeada de animales y amigos.$4",
  "4hearts.18": "¡Una infancia sin viejos gruñones que ni siquiera se molestaron en proteger a su pupila de ser devorada por el cruel abrazo del océano!$2",
  "4hearts.19": "¡Por última vez, Ju, no puedes culparme por eso! ¡Ni siquiera sabía que habías ido tras ellos!#$b#¡Y claramente no te ahogaste en ningún abrazo dulce, considerando que estás aquí dándome problemas por ello!",
  "4hearts.20": "Claro que puedo culparte. Es lo más fácil del mundo.$3",
  "4hearts.21": "Creo que ya nos conocemos lo suficiente para que escuches algo de mi trágica historia, @.$2",
  "4hearts.22": "No quería mudarme a Stardew Valley, ¿ves? Así que cuando mis padres *me dejaron* en la casa de Raz, corrí hacia la playa e intenté volver a subir al barco con ellos.$2#$b#Sin embargo, como era bastante pequeña en ese entonces, nadie notó mi acercamiento ni me escuchó llamarles para que se detuvieran.$2#$b#Y cuando resbalé y caí del muelle al agua, nadie notó eso tampoco.$2",
  "4hearts.23": "Me salvé, por supuesto.#$b#Usé un pedazo de madera flotante para arrastrarme hasta la orilla. Oh, @, había tantos peces allí abajo, ¡rodeándome! *escalofrío*$2#$b#Pero, ¿sabes cuál fue la parte peor?$2#$b#¡Fue volver a la torre y darme cuenta de que este viejo arándano ni siquiera notó que me había escapado!",
  "4hearts.24": "Así que, seguro entiendes ahora por qué evito la playa siempre que puedo?$2#$b#¿Y por qué a veces me gusta fingir que Jas soy yo en una realidad alternativa, una en la que pude ser feliz?$2",
  "4hearts.25": "¿Por qué nunca aprendo?",
  "4hearts.26": "¡Uf, pensé que nunca se iría!$6",
  "4hearts.27": "¿Cómo va tu día hasta ahora?$1",
  "4hearts.28": "¿Acaso Juna dijo esas cosas solo para incomodar al Mago, o realmente sucedió?",
  "4hearts.29": "¿Y cuántos años tiene realmente, si todavía había ferris en Pelican Town cuando ella era joven?",
  "4hearts.30": "Estoy tan confundido...",

  //6 hearts

  "6hearts.01": "¡Aquí, pescadito, pescadito!",
  "6hearts.02": "Sé que esto no es como pescan OTRAS personas, Cat. Pero yo no soy como otras personas.#$b#Mi voluntad es fuerte y mi corazón es puro... -más o menos. Verás. Todo lo que tengo que hacer es quedarme aquí y concentrarme... y los peces vendrán a mí.$3",
  "6hearts.03": "15 minutos después.",
  "6hearts.04": "No me hables con sarcasmo, Cat.",
  "6hearts.05": "Está bien. No está funcionando hoy. ¡Pero no es mi culpa! Los peces simplemente están siendo poco cooperativos.$5",
  "6hearts.06": "¿Qué quieres decir con por qué estoy pescando en primer lugar? Sabes cuánto odio el pescado.#$b#...$11#$b#Bueno, eso no tiene sentido, Cat. Si me gustara el pescado, ciertamente no intentaría matarlos, ¿verdad? Solo iría al supermercado como una persona normal.",
  "6hearts.07": "Pensé que escuché voces.$9#$b#¿Estoy en uno de los sueños extraños de Emily?",
  "6hearts.08": "¿Por qué piensas que estás soñando? ¿Nunca has conocido a un espíritu del bosque antes?",
  "6hearts.09": "¿No?",
  "6hearts.10": "¿Pero no hablo de ellos todo el tiempo?#$b#Además, ¿soy el único que está escuchando música extraña? ¿Cat, eres tú la que está haciendo eso?$11",
  "6hearts.11": "Pensé que estabas hablando de esas extrañas muñecas que tanto te gustan.$9",
  "6hearts.12": "¡Estoy tan insultada ahora mismo!",
  "6hearts.13": "Y en serio, ¿qué es esa música?",
  "6hearts.14": "...$9#$b#Bueno... ¿no vas a presentarnos?",
  "6hearts.15": "Está bien, está bien. Este es Dog.",
  "6hearts.16": "Y este es Cat.",
  "6hearts.17": "¡Hola!",
  "6hearts.q1": "¿Por qué un Junimo se llamaría Dog?",
  "6hearts.q2": "¿Por qué un Junimo se llamaría Cat?",
  "6hearts.18": "Cat y Dog son hermanos de Olive.",
  "6hearts.19": "¿Quién es Olive, preguntas? ¡Es como si no escucharas una sola palabra de lo que digo! Olive es mi mejor amiga en el mundo y mi hermano en todo menos en sangre.$5",
  "6hearts.20": "... *clears throat* ...$11#$b#¡De todos modos! Estaba muy emocionado cuando nacieron sus hermanos, y rogó por la oportunidad de nombrarlos.#$b#... Puede que haya hecho que creyera que Cat y Dog eran nombres humanos populares en ese momento.$6",
  "6hearts.21": "¡Juna!$1",
  "6hearts.22": "Oh, por amor de... ",
  "6hearts.23": "¿Qué está pasando? ¿Qué están haciendo?",
  "6hearts.24": "Dog quiere darte un regalo, pero no sabe cómo porque aún es un bebé.",
  "6hearts.25": "Aw.",
  "6hearts.26": "¡No seas tan mala, Juna! ¡Él está haciendo su mejor esfuerzo!$1",
  "6hearts.27": "Claro. Pero solo para que sepas, vamos a estar aquí toda la noche a menos que yo o Cat lo ayudemos.",
  "6hearts.28": "*sigh*",
  "6hearts.29": "Bueno, aquí tienes, entonces. Un regalo de Dog para ti.[105]$10",
  "6hearts.30": "¿Lo entiendes? ¿Palito para masticar? ¿Porque es un perro?$1",
  "6hearts.31": "Ugh, es mi papá.",
  "6hearts.32": "Supongo que tengo que volver a casa.#$b#... Aunque esto resulta ser un sueño, fue agradable. Me gustó mucho.$4",
  "6hearts.33": "¡Ok, adiós!",
  "6hearts.34": "Oh, solo ve y llévala a casa ya, tonto noble.",
  "6hearts.35": "¡Está bien, está bien! Supongo que una buena acción merece otra. Espera aquí.",
  "6hearts.36": "Aquí tienes. Supongo que te lo has ganado.$1",
  "6hearts.37": "¡Pero aún no puedes decirle a nadie que estos juguetes son de mi parte! ¡Tengo una reputación que mantener, sabes?$4",
  "6hearts.38": "¡Aquí, pescadito, pescadito!",

  //10 hearts - if Wizard

  "event-86060008.01": "¡Bienvenido!$1",
  "event-86060008.02": "¡Llegaste tarde!",
  "event-86060008.03": "*sigh*",
  "event-86060008.04": "Juna. @.",
  "event-86060008.05": "¡Bueno, no te quedes ahí parado! ¿Qué opinas?$1",
  "event-86060008.06": "Bueno, veo muchas cosas que sé que TE gustan, Ju. Como esa Joja Cola gigante, por ejemplo.",
  "event-86060008.07": "¿Qué estás tratando de decir, Raz? ¿Que soy una mala anfitriona? ¡Mentiras y difamación! ¡Incluso le dije a Olive que no me ayudara!$5#$b#Hay una tetera justo allí, y sabes cómo me siento sobre el té. Incluso le conseguí al chico granjero un pack de hummus porque, ya sabes, chico granjero saludable bla bla.^Hay una tetera justo allí, y sabes cómo me siento sobre el té. Incluso le conseguí a la chica granjera un pack de hummus porque, ya sabes, chica granjera saludable bla bla.",
  "event-86060008.q1": "¿Es ese un huevo roto?",
  "event-86060008.q2": "¿Qué pasó con la gelatina?",
  "event-86060008.08": "El pastel y los panqueques son de Gus, y iba a traer la gelatina de mi reserva personal, lo juro, pero... lo olvidé.$2#$b#Y pensé que podría hacerlo más tipo picnic decorando con cosas típicas de la granja, pero luego rompí el primer huevo y me enojé, así que...",
  "event-86060008.09": "¡Robin!$4",
  "event-86060008.10": "... Noto que no tienes nada negativo que decir sobre la hora de llegada DE ELLA.",
  "event-86060008.11": "¡Raz, estás siendo terriblemente grosero! Le pedí a Robin que llegara seis minutos después de la hora, así que en realidad está justo a tiempo.$5",
  "event-86060008.12": "(¡Juna!)",
  "event-86060008.13": "Lo siento, Robin. No hay excusa para los malos modales, independientemente del mal ejemplo que den otras personas en la cercanía.",
  "event-86060008.14": "No hay necesidad de disculparse. Es agradable finalmente conocerte, supongo. A Juna le costó lo suyo presentarnos.$4#$b#(Llegué totalmente tarde, por cierto.)",
  "event-86060008.15": "(Lo sé.)",
  "event-86060008.16": "¡Hola!",
  "event-86060008.17": "Entonces... ¿por qué estamos haciendo esto bajo la lluvia otra vez?",
  "event-86060008.18": "¡Porque estamos lavando nuestros pecados! ¡Empezando de nuevo! ¡Brindando por nuevos comienzos!$1",
  "event-86060008.19": "*clears throat*",
  "event-86060008.20": "Bien, así que...",
  "event-86060008.21": "¿Por qué nadie está hablando? ¡Trabajé muy duro en esto! Ser el gerente de proyectos de Gus no es un picnic, sabes.$6",
  "event-86060008.22": "¡Buen trabajo!",
  "event-86060008.23": "¿Puedo ofrecerte algo de té, Robin? ¿O prefieres una taza de café?",
  "event-86060008.24": "¡El café sería encantador, gracias!$1#$b#Pero... ¿hay café? No veo ninguno.",
  "event-86060008.25": "Oh, no te preocupes por eso. Los objetos y consumibles domésticos ordinarios son bastante fáciles de conjurar. Dame un momento.",
  "event-86060008.26": "¡Estoy poniendo los ojos en blanco!",
  "event-86060008.27": "Ahí. Llené una de las tazas con café de mi torre. Espero que eso sea satisfactorio.",
  "event-86060008.28": "Estoy segura de que es genial. Gracias.$4",
  "event-86060008.29": "¡Vaya, ese es un café realmente fuerte!$1#$b#Me gusta. Gracias.",
  "event-86060008.30": "Estás siendo extrañamente poco pomposo hoy, Raz. ¿Qué pasa?",
  "event-86060008.31": "Como dije, no hay excusa para los malos modales, Ju.#$b#Además, ella es tu mejor amiga. Por supuesto que voy a querer conocerla mejor.",
  "event-86060008.32": "Quiero decir, eso no es... ¡",
  "event-86060008.33": "Ahora lo hiciste raro, tonto.$2",
  "event-86060008.34": "*giggles*",
  "event-86060008.35": "Lo que sea. ¡Vamos a comer!",
  "event-86060008.36": "Aparte de la constipation emocional, ¡se convirtió en un picnic realmente agradable!",

  //Special order event

   "event-86060011.01": "...#$b#¿Qué es ese ruido?#$b#¿Y ese OLORES? Me ha estado siguiendo todo el día.",
  "event-86060011.02": "¿Quién está ahí?",
  "event-86060011.03": "Está bien. Sé así.",
  "event-86060011.04": "¡Silba sabía que eras real!",
  "event-86060011.05": "... Juna.",
  "event-86060011.06": "¡JUNA!",
  "event-86060011.07": "Sé que estás ahí, Juna!",
  "event-86060011.08": "¿Por qué está aquí Krobus?",
  "event-86060011.09": "¿Por qué estoy aquí? ¿Por qué estás tú aquí?",
  "event-86060011.10": "¿Por qué hueles así, Rasmodius? ¿Estás burlándote de las creencias de Silba?$5",
  "event-86060011.11": "¿Qué creencias?! ¡Yo soy la víctima aquí, ella me ha estado siguiendo todo el día!",
  "event-86060011.12": "Silba es miembro de The Big Foot Coalition, un grupo dedicado a probar la existencia de críptidos.$3#$b#Según la Coalición, el críptido Big Foot tiene, además de su impresionante capacidad pulmonar, un olor muy distintivo. Se supone que facilita identificarlo, en caso de que se esconda entre nosotros.$3",
  "event-86060011.13": "Oh, por amor de...",
  "event-86060011.14": "No soy Big Foot. ¿Te parecen estos pies los de alguien llamado Big Foot?#$b#¡Todo esto es cosa de Juna, yo no tuve nada que ver!",
  "event-86060011.15": "La Coalición es una comunidad unida. Podrías hacer mucho peor que ser aceptado entre sus filas.#$b#Pero solo si te adhieres a sus principios y respetas su forma de vida.$5#$b#Si mal no recuerdo, actualmente están buscando al Hombre Polilla... ¿Tienes alguna información sobre él?$3",
  "event-86060011.16": "¡Por supuesto que no- TE VEO!",
  "event-86060011.17": "Quizás deberías ir a casa ahora, Rasmodius.",
  "event-86060011.18": "¡Está bien! Pero solo porque yo quiera, ¡no porque tú me lo digas!",
  "event-86060011.19": "¡No!",
  "event-86060011.20": "¡Estúpido Krobus!",
  "event-86060011.21": "¡Espérame, Pie Grande!",
  "event-86060011.22": "Silba nunca persigue a Krobus. :(",
  "event-86060011.23": "Así que sí, eras tú.",
  "event-86060011.24": "Todavía me queda algo de perfume.",

  //2 hearts

  "2hearts.01": "...$12",
  "2hearts.02": "... *suspiro* ...$11",
  "2hearts.03": "Tuviste que visitar la playa hoy de todos los días.$11",
  "2hearts.04": "%Juna mira con desdén las olas que lamen sus pies. Empiezas a sentirte incómodo. Quizás esta fue una mala idea.",
  "2hearts.05": "¡Estoy bien! ¡Estoy bien! Mira, ¡estoy sonriendo!$10",
  "2hearts.06": "¿Sabías que solían haber barcos de ferry entre esta playa y los pueblos del sur?#$b#Es cierto. Fue... hace un tiempo. No estoy segura de cuánto tiempo ha pasado.$11",
  "2hearts.07": "Uno de esos barcos transportaba a una niña pequeña.#$b#Ese día también estaba lloviendo. El barco olía horrible. Como perro mojado mezclado con blanqueador. La niña y sus padres tuvieron que sentarse en el suelo porque el barco estaba tan lleno.#$b#Pero a la niña no le importó nada de eso. ¡Estaba en una aventura! La primera vez que había podido ir a unas vacaciones.#$b#La primera vez en un barco, incluso. Sus padres nunca habían podido permitírselo. No hasta ese día.",
  "2hearts.08": "Resulta que no había mucho por lo que emocionarse.$11#$b#Peor. Vacaciones. De. La. Historia.$13#$b#Yo estaba...",
  "2hearts.09": "¿Qué estoy haciendo?",
  "2hearts.10": "... nada. No era nada. Ignora todo lo que acabo de decir. Estoy privada de sueño y empapada y aparentemente incapaz de controlar lo que sale de mi boca.$2#$b#Ugh, qué vergonzoso, ¿no?$6",
  "2hearts.11": "De todos modos. ¡Tengo que volver a practicar! ¡Hasta luego!$7",
  "2hearts.12": "Eso salió bien.",
  "2hearts.13": "%Juna hace una mueca que crees que intenta parecerse a una sonrisa.",

  //10 hearts - if parents

  "10hearts.01": "¡Casi olvido!",
  "10hearts.02": "¡No se pueden hacer panqueques sin crema batida!",
  "10hearts.03": "¡Bienvenido!$1",
  "10hearts.04": "Me sorprendió mucho cuando recibí tu invitación, Ju. Nunca te tomé por una amante de los picnics.",
  "10hearts.05": "Debes saber que puedo ser lo que quiera ser, oh Robin, mi Robin. ¡Así lo dicen los blogs de mamás!$4#$b#¡Y lo que quería ser hoy era una joven despreocupada que ama los picnics y la playa!",
  "10hearts.06": "Está bien.",
  "10hearts.07": "Mira, allí hay un set de té, y sabes cómo me siento con el té. Incluso le traje al chico granjero un paquete de hummus porque, ya sabes, chico granjero saludable bla bla.^Hay un set de té allí, y sabes cómo me siento con el té. Incluso le traje a la chica granjera un paquete de hummus porque, ya sabes, chica granjera saludable bla bla.",
  "10hearts.08": "El pastel y los panqueques son de Gus, y iba a traer la gelatina de mi reserva personal, lo juro, pero... lo olvidé.$2#$b#Y pensé que podría hacerlo más de picnic decorándolo con cosas típicas de granja, pero luego rompí el primer huevo y me enojé, así que...",
  "10hearts.09": "¡Pero olvídalo!",
  "10hearts.10": "¡Toma té! (Yo ciertamente no lo beberé.)$1",
  "10hearts.11": "*tos tos* ¡Vaya, ese té está realmente fuerte! ¿Estás seguro de que no es café?$1",
  "10hearts.12": "No, es solo té. Lo robé de Raz, naturalmente.",
  "10hearts.13": "Naturalmente.",
  "10hearts.14": "Pero pensé que se veía algo pálido, así que lo dejé reposar un poco más.$10",
  "10hearts.15": "¿Cuánto más?",
  "10hearts.16": "¿5 minutos? ¿Tal vez? Me distraje con una gran idea para una broma, ¡pero no puede haber sido tanto tiempo!$1",
  "10hearts.17": "¡Ese es Theo!",
  "10hearts.18": "¿Alguien ha visto mi teléfono?",
  "10hearts.19": "Colgó.$2#$b#Seguimos perdernos.$13",
  "10hearts.20": "¿Cómo está tu hermano, Ju? ¿Todavía trabaja como guardia de seguridad?",
  "10hearts.21": "No, accidentalmente vació un barril de aceite de cocina en una de sus áreas de almacenamiento, así que lo despidieron.$2",
  "10hearts.22": "Pero nunca está inactivo por mucho tiempo, no me preocupa eso.#$b#Hmm...$3#$b#¡Tú allí!",
  "10hearts.23": "¡Sí, tú!",
  "10hearts.24": "No hice nada, ¡lo juro! Solo quería ver qué estaba pasando.$7",
  "10hearts.25": "Lo sé, tonto.#$b#Ahora ven aquí y haz de mi hermano.$3",
  "10hearts.26": "(¡Juna!)",
  "10hearts.27": "¿Q... qué?",
  "10hearts.28": "No he hablado con mi hermano en días, y lo extraño. Tienes aproximadamente la misma edad que él, y definitivamente puedo verte derramando accidentalmente aceite sobre las rosas de Evelyn.#$b#Claro, en el caso de Theo probablemente no fue un accidente, pero los mendigos no pueden elegir.$11#$b#Así que por favor ven aquí y haz como si te gustara el lutfisk y los chistes oscuros durante unas horas.$6",
  "10hearts.29": "*resopla*",
  "10hearts.30": "Tenemos ca-ake.",
  "10hearts.31": "... Sí, está bien.$4",
  "10hearts.32": "Aparte del juego de roles y los chistes oscuros, ¡se convirtió en un picnic realmente agradable!",

  //8 hearts

 "8hearts.01": "...$12",
  "8hearts.02": "Tienes el peor timing, ¿lo sabes?$11",
  "8hearts.03": "Ven aquí.$11#$b#Por favor.$11",
  "8hearts.04": "Quiero... el chico dijo algo el otro día que...$11#$b#...$11#$b#¡Estoy en un estado de ánimo realmente raro, @, y lo odio!$13#$b#Ayer pasé lo que deberían haber sido 5 gloriosos minutos viendo a Raz rascarse las piernas porque le puse polvo para picazón en el forro de sus túnicas - cállate, es un clásico por una razón - y no sentí nada.$13#$b#¡Ninguna alegría, ninguna satisfacción, ni siquiera el más mínimo impulso de reírme!$11#$b#¡Y es culpa del chico loro!$13",
  "8hearts.q1": "¿Quién es el chico loro?",
  "8hearts.q2": "Dudo mucho que ese pobre chico sea el culpable de que estés de mal humor.",
  "8hearts.05": "No es... Es un chico. Creció rodeado de loros. No está muy acostumbrado a estar con personas.$11#$b#¿Recuerdas el ferry del que te hablé?$11#$b#Cuando llegué aquí por primera vez, el barco hizo una parada en una pequeña isla en medio del océano. A veces... a veces cuando estoy de un humor particular, me gusta regresar allí.$11#$b#Es lo más cercano que he estado a m-$12#$b#De todos modos. Ahí fue donde conocí al chico loro. Tal vez pueda llevarte allí alguna vez.$11",
  "8hearts.06": "¡No, espera! ¡Esto no se trata de él, se trata de mí! ¡Deja de distraerme, @!$13",
  "8hearts.didntAsk.01": "¿Et tu, @? ¿Te has unido a la pandilla de los loros?$11#$b#Bueno, olvídalo ahora. Esta historia no es sobre Leo, ¡es sobre mí! ¡Concédele atención, por favor!$13",
  "8hearts.junaCrisis.01": "¿Dónde estaba?$11#$b#Sí, familia.$12",
  "8hearts.junaCrisis.02": "Dijo algo. El chico loro. Y no entiendo por qué...$12#$b#Estábamos teniendo una charla perfectamente agradable sobre Junimos y loros y bosques profundos e islas aisladas, y-$11#$b#-y tal vez él dijo algo sobre la familia, y tal vez yo dije algo sobre la familia, y luego...$11",
  "8hearts.junaCrisis.03": "Dijo que estaba bien.$11#$b#Le pregunté qué hacía cuando se enojaba, si había alguien a quien le gritara, y dijo que no. Porque estaba bien.$11#$b#A pesar de... todo. A pesar de pasar más tiempo con loros que con personas.$12",
  "8hearts.junaCrisis.04": "¡Y simplemente no entiendo!$13#$b#¡No entiendo cómo puede estar bien cuando un día pronto, se despertará y todos, menos los loros, se habrán ido.$12#$b#¡No entiendo cómo puede estar feliz cuando todos los demás siguen DEJÁNDOLO!$13",
  "8hearts.junaCrisis.05": "¿Cómo puede estar bien cuando yo no lo estoy?",
  "8hearts.q3": "¿Qué pasó con tu familia, Juna?",
  "8hearts.q4": "(Mantente en silencio.)",
  "8hearts.junaCrisis.06": "Mis padres eran terribles con el dinero.$11#$b#Para cuando nací, apenas les quedaba algo de una herencia considerable, y lo poco que tenían lo malgastaron en cosas estúpidas e inútiles.$11#$b#Tenía muchos hermanos. Al entregarme a Raz, tenían una boca menos que alimentar.$12",
  "8hearts.junaCrisis.07": "Nadie más en mi familia mostró ningún signo de habilidad mágica. Yo era la única.$11#$b#Raz me dijo que mis padres querían lo mejor para mí, y que debería dejar de actuar como una mocosa.$11#$b#Pero no creo que eso fuera así. Creo que simplemente querían deshacerse de mí y de mis grandes y estúpidos sueños de ser bailarina.$12#$b#Además, ¿qué sabe Raz sobre crianza?$13#$b#Una vez, apenas me dejó fuera de su vista durante un mes porque no podía confiar en que no *me escabullera para girar por el bosque* en lugar de hacer mi tarea.$11#$b#Tampoco quería que estuviera cerca. Lo demostró cuando me dejó con los Junimos al año siguiente.$12",
  "8hearts.junaCrisis.08": "¿Te conté alguna vez cómo conocí a los Junimos? En realidad fue antes de que Raz nos presentara.#$b#Había un pequeño claro en el bosque, ya ves, que era perfecto para practicar ballet. Los Junimos se habían asentado en una cabaña cercana que había estado abandonada durante años.#$b#Un día simplemente miré hacia arriba y allí estaban.$10",
  "8hearts.junaCrisis.09": "Les gustaba verme bailar.",
  "8hearts.q5": "¿Alguna vez has intentado hablar con el Mago?",
  "8hearts.q6": "¿Alguna vez has intentado ponerte en contacto con tus padres?",
  "8hearts.junaCrisis.10": "¿A qué te refieres? ¿Sobre... mis sentimientos?$11",
  "8hearts.junaCrisis.11": "Está bien.#$b#¿Está bien?$11#$b#¡Está bien! ¡Está bien! ¡Lo haré!$10#$b#¡Me mudaré con Raz por una semana para obligarlo a trabajar en nuestra relación!",
  "8hearts.junaCrisis.12": "¡Tengo que cancelar todo y hacer un plan! Gracias por ayudarme, @! ¡Eres la mejor!$4",
  "8hearts.choseParents.01": "¡Yoba, no!$13#$b#...$11#$b#¿Crees que debería?$12",
  "8hearts.choseParents.02": "Está bien.#$b#¿Está bien?$11#$b#¡Está bien! ¡Está bien! ¡Lo haré!$10#$b#¡Iré a ver a mis padres y a mis millones de hermanos y los rociaré en la cara con agua hasta que me digan por qué me dejaron!",
  "8hearts.choseParents.03": "¡Tengo que cancelar todo y hacer un plan! Gracias por ayudarme, @! ¡Eres la mejor!$4",

  //Juna and the Wizard

  "event-86060026.01": "15:00",
  "event-86060026.02": "16:20",
  "event-86060026.03": "¡Plie!",
  "event-86060026.04": "¡Releve!",
  "event-86060026.05": "¡Salta!",
  "event-86060026.06": "17:46",
  "event-86060026.07": "18:11",
  "event-86060026.08": "¿¡Qué?!",
  "event-86060026.09": "...",
  "event-86060026.10": "¿¡Qué?!$11",
  "event-86060026.11": "Quiero decirte algo. Es sobre tus padres.",
  "event-86060026.12": "Ominoso.",
  "event-86060026.13": "En interés de la plena divulgación, pensé que deberías saber que... Bueno, dijiste que querías trabajar en nuestra relación...",
  "event-86060026.14": "Por el amor de Yoba, Raz, suéltalo ya.$11",
  "event-86060026.15": "Sí, sí. Está bien.#$b#La otra noche, dijiste que te dejé con los Junimos porque ya no quería lidiar contigo.",
  "event-86060026.16": "Creo que dije que no podías manejar la presión, anciano.$11",
  "event-86060026.17": "Bastante.#$b#Y aunque no voy a negar que tú y yo tuvimos una... relación desafiante en ese entonces, las cosas realmente no estaban tan mal.#$b#Si apartara a cada usuario de magia con una piedra en el zapato, el mundo se quedaría sin usuarios de magia muy rápidamente.",
  "event-86060026.18": "Entonces, ¿por qué? ¿Por qué decidiste que estaría mejor con los Junimos?$11",
  "event-86060026.19": "Tus padres me escribieron. Más de una vez. Querían saber cómo te estaba yendo.#$b#Al principio, pensé que era por preocupación por ti. Supongo que la mayoría de la gente extraña a sus hijos cuando se van.",
  "event-86060026.20": "No vi mucho sentido en mentirles. Así que les dije que, aunque eras talentoso, también eras obstinado y fácilmente distraído. Que a menudo te escapabas por la noche y rara vez parecías tomar en serio lo que decía.",
  "event-86060026.21": "No soy fácilmente distraído. Simplemente estaba aburrido y enojado.$11",
  "event-86060026.22": "Sí, bueno, nunca he dicho que sea bueno con los niños. (Aunque la gente sigue dejándolos en mi puerta...)#$b#De todos modos, como decía. Les conté esto a tus padres, y decidieron que esto significaba que tu tutoría conmigo ya no era beneficiosa y que era hora de que volvieras a casa.",
  "event-86060026.23": "¿¡Qué?!",
  "event-86060026.24": "¿Estás diciendo que querían que volviera a casa y nunca me lo dijiste?$13",
  "event-86060026.25": "¿Cómo te atreves?$13",
  "event-86060026.26": "No era beneficioso para ELLOS. Te dejaron conmigo con la esperanza de convertirte en un mago poderoso que les generaría dinero.#$b#En mis cartas a ellos, describí lo que te había estado enseñando. Cuando luego confesé la naturaleza de la situación actual, dijeron que había fallado y que lo que ya habías aprendido tendría que ser suficiente.#$b#...#$b#No querían esperar más tiempo para que su inversión diera frutos.",
  "event-86060026.27": "Oh. Ya veo.$12",
  "event-86060026.28": "Por supuesto, para cuando llegaron para recogerte, ya habías \"escapado\" al bosque para vivir con los Junimos, donde ni yo ni tus padres podíamos encontrarte.",
  "event-86060026.29": "¿Escapado, eh?$11#$b#Sin embargo, me encontraste. De hecho, me encontraste tan a menudo, que una vez te maldije con llagas solo para que dejaras de visitarme todo el tiempo.$11#$b#Estaba tan frustrado, porque no entendía por qué me dejabas con los Junimos solo para prestarme más atención de la que me habías prestado cuando vivía contigo.$11",
  "event-86060026.30": "Recuerdos entrañables, sin duda.",
  "event-86060026.31": "Entonces... ¿estás diciendo que me llevaste al bosque como una especie de - ugh - caballero andante, mentiste a mis padres sobre eso, hiciste el viaje al bosque una vez a la semana para revisar cómo estaba... todo para que no tuviera que pasar el resto de mi vida como una alcancía?$11",
  "event-86060026.32": "Qué asco. ¡Eres un cursi, Raz!$1",
  "event-86060026.33": "*suspira*",
  "event-86060026.34": "Bueno, al menos ahora lo sabes.#$b#Tengo que... hm, tengo que irme... a hacer magia ahora. Correcto. Sí.",
  "event-86060026.35": "Todavía deberías haberme dicho.$11",
  "event-86060026.36": "Lo sé.",
  "event-86060026.37": "...$11#$b#...",

  //Juna and Robin's Gossip Session

  "event-86060012.01": "¡Dímelo!",
  "event-86060012.02": "¡El buen doctor: Harvey!",
  "event-86060012.03": "¡Ahuizotl!",
  "event-86060012.04": "¡Otro!",
  "event-86060012.05": "¡La maravillosa Emily!",
  "event-86060012.06": "¡Altamaha-ha!",
  "event-86060012.07": "¡Otro!",
  "event-86060012.08": "Hola, hija.",
  "event-86060012.09": "¡El gran alcalde en persona: Lew-Lew!",
  "event-86060012.10": "¡Fácil! ¡Es un yeti!",
  "event-86060012.11": "Puedo verlo.",
  "event-86060012.12": "Uf, necesito algo para beber. Aquí está cada vez más caluroso.$1",
  "event-86060012.13": "Eso es porque sigues bailando como un loco con esta música abominable.#$b#De hecho, he cambiado de opinión. Lewis es definitivamente un monstruo del pantano de Honey Island.$6",
  "event-86060012.14": "*bufido*",
  "event-86060012.15": "¿Qué le pusiste a esto?!$1",
  "event-86060012.16": "Oh, dejé que Olive mezclara las bebidas esta vez. Ha estado en una racha de coctelero últimamente.",
  "event-86060012.17": "Por cierto, nunca dijiste qué tipo de criptido soy. Vamos, ¡confiesa!#$b#No te atrevas a decir que soy un simio zorrino o un chupacabras, no soy una succionadora de cabras.$3",
  "event-86060012.18": "Hm, eso es difícil.",
  "event-86060012.19": "Me pareces terrestre, o maaaaaybe alado. Definitivamente no acuático.$3",
  "event-86060012.20": "¡Oh, ya sé! ¡Eres claramente una Bestia de Exmoor!$1",
  "event-86060012.21": "¡Lo acepto!",
  "event-86060012.22": "*suspira*",
  "event-86060012.23": "¿Sigues siendo un wendigo, o eso ha cambiado otra vez?$1",
  "event-86060012.24": "Nah, he encontrado algo mucho mejor. ¡Este es el verdadero yo, Robin! Mi verdadero yo.$10#$b#No puedo creer que no lo haya descubierto antes...$3",
  "event-86060012.25": "Ok, ¿y? ¿Cuál es?",
  "event-86060012.26": "Eso es para que yo lo sepa y para que tú lo descubras.$6",
  "event-86060012.27": "Nooooo, vamos, Ju! ¿Por qué siempre tienes que mantenerlo en secreto?$3",
  "event-86060012.28": "¡Porque es más divertido así!$10#$b#Además, ya lo sabes. ¿Cómo, preguntas? Porque conoces a MÍ, luz de mi vida. ¡Solo mira dentro de tu corazón!$4",
  "event-86060012.29": "¡Ugh, eres tan molesta!",
  "event-86060012.30": "¡Eso es todo! ¡Voy a revocar tus privilegios musicales, Robin!$5",
  "event-86060012.31": "¡No hay nada malo con mi gusto musical!$3",
  "event-86060012.32": "Bueno...",
  "event-86060012.33": "¿Qué opinan? ¿Les gusta la música de su mamá?$3",
  "event-86060012.34": "Han estado aquí por horas. ¿No dijiste que ibas a preparar la cena?$3",
  "event-86060012.35": "¡Es culpa de Juna!",
  "event-86060012.36": "Tengo mucha hambre.$2",
  "event-86060012.37": "...",
  "event-86060012.38": "Aw, pobres patitos.$2#$b#Pero, ¿por qué estás esperando a que Robin te prepare la cena? Esa es la peor idea que he oído. ¡Vamos a bajar al saloon y a pedir comida para llevar!$1",
  "event-86060012.39": "¡Yo puedo hacerlo!",
  "event-86060012.40": "*suspira* Está bien. Volveré en un rato. ¿Todos quieren lo de siempre?$3",
  "event-86060012.41": "¡Sí, por favor!",
  "event-86060012.42": "Ahí, ahí, Robin.",
  "event-86060012.43": "Entonces... ¿alguna vez has leído algo sobre el Hodag?",
  "event-86060012.44": "Oh, mi dulce e inocente chico rana. ¡Claro que sí! Solo escucha esto...$3",
  "event-86060012.45": "¡Bueno, YO voy a hacer una ensalada!",

  //One Year with Juna and Alex

  //Fall
"event-86060016.01": "Así es, Dusty.",
  "event-86060016.02": "Eres el único hermano que necesito.$2",
  "event-86060016.03": "*suspira*",
  "event-86060016.04": "Además, los hermanos solo estorban. ¿Te imaginas intentar levantar pesas con un niño corriendo alrededor de tus pies?$2",
  "event-86060016.05": "Sí, sabes de qué hablo.$1#$b#*suspira*$2",
  "event-86060016.06": "Solo desearía que pudieras hablar.$2#$b#Apuesto a que tendrías mucho que decir sobre mi técnica. ¿Viste ese lanzamiento que hice ayer? Increíble, ¿verdad?$1",
  "event-86060016.07": "(Es deliciosamente egocéntrico, ¿no?)",
  "event-86060016.08": "(Sí, sí, sé que es una fachada. Eso es lo que lo hace delicioso. Significa que hay capas que explorar. Me encanta explorar capas, @!)$1",
  "event-86060016.09": "No sé qué hacer, Dusty. Estoy tan confundido. No soy un perdedor, y aún amo el grid ball, pero... tengo todas estas dudas últimamente.$2",
  "event-86060016.10": "(Hm...)$3",
  "event-86060016.11": "Hm...",
  "event-86060016.12": "¿En qué estás pensando?",
  "event-86060016.13": "¡Conozco esa expresión! Estás planeando algo.",
  "event-86060016.14": "Sea lo que sea que estés considerando ahora, solo... no lo hagas.",
  "event-86060016.15": "Bueno, ¡tengo que irme! ¡Hasta luego!$6",
  "event-86060016.16": "¡Gracias por el espectáculo!",
  "event-86060016.17": "Me atrapaste de nuevo.$7",
  "event-86060016.18": "¿De qué se trataba eso? ¿Qué espectáculo?",

  //Winter
  "event-86060017.01": "Creo que el hecho de que te quedes solo en este lugar espeluznante en medio del invierno es una de mis cosas favoritas sobre ti.$10",
  "event-86060017.02": "¡Juna! ¿Qué haces aquí?$6#$b#Espera, ¡este es el vestuario de hombres!$8",
  "event-86060017.03": "Olive y yo nos quedamos en el vestuario de mujeres cada vez que él nos visita, y durante el invierno seguíamos oyendo estos ruidos extraños desde aquí.#$b#Esperaba un fantasma, pero supongo que debería haber reconocido el sonido de los músculos creciendo.$2#$b#Después de todo, Raz pasó un mes saltando en una cama elástica para ponerse en forma cuando era más joven. Pensó que no me daba cuenta, pero es porque es un idiota.$11",
  "event-86060017.04": "... ¿Qué?$8",
  "event-86060017.05": "¿Qué qué?$11#$b#...#$b#Oh, ¡el tema del vestuario! Está bien, te daré 5 minutos para ponerte una camisa si te molesta tanto. ¡Rápido!$1",
  "event-86060017.06": "15 minutos y 5 segundos después.",
  "event-86060017.07": "Entonces, eh... ¿de qué querías hablar?$4",
  "event-86060017.08": "¡Sobre tu entrenamiento, por supuesto!",
  "event-86060017.09": "¿Mi qué?$7",
  "event-86060017.10": "¡Tu entrenamiento! Si vas a ser una estrella deportiva profesional, ¡tienes que trabajar duro!$5#$b#Por suerte para ti, recientemente has conocido a alguien que puede ayudarte con eso.",
  "event-86060017.11": "Oh, eso.$2",
  "event-86060017.12": "...$11",
  "event-86060017.13": "*suspira*",
  "event-86060017.14": "¿Quieres ir a ver una película?",
  "event-86060017.15": "¿Qué? No creo que estén pasando películas deportivas en este momento.$2",
  "event-86060017.16": "Bueno, gracias a Yoba por eso. ¡Aburrido!$2#$b#Yo esperaba más una película de terror o una de esas películas que es solo una larga escena de cena.",
  "event-86060017.17": "¿Pero qué pasa con el entrenamiento? Acabas de decir-$2",
  "event-86060017.18": "Eh, ¿a quién le importa lo que dije? Digo cosas todo el tiempo. ¡Vamos a ver una película!$1",
  "event-86060017.19": "¡Lección número uno! Si esa es la cara que pones al pensar en hacer el trabajo, es hora de tomar un descanso.#$b#Ahora vamos, no tengo todo el día, ¿sabes?$5",
  "event-86060017.20": "...$1",
  "event-86060017.21": "Espera, ¿estabas bromeando sobre la película de cena, verdad?$7",
  "event-86060017.22": "¿Juna?",

  //Spring
  "event-86060018.01": "¡@! ¡Hola!$1",
  "event-86060018.02": "Eh, así que... ¿estás, como, ocupada ahora?$1",
  "event-86060018.03": "Es que tengo algo esta noche con mis abuelos y Juna. Y estoy un poco preocupada de que no se lleven bien.$7#$b#Así que me preguntaba si podrías, como, acompañarnos y, eh, hacerlo menos raro?$1",
  "event-86060018.04": "¡Llegando!",
  "event-86060018.05": "(¿Por favor? Juna no... bueno, ella es genial, pero a veces dice cosas realmente raras. Y no quiero que ella y abuelo se peleen.)$7",
  "event-86060018.06": "¡Juna!#$b#¿Qué estás haciendo aquí? ¿Suspirando por Alex, verdad?$10",
  "event-86060018.07": "¡Juna!$7",
  "event-86060018.08": "Oh, lo siento, tal vez estás aquí para George? ¿Evelyn?$2#$b#Es difícil seguir la pista a todos los enamoramientos en el pueblo últimamente.$11",
  "event-86060018.09": "(¿Por favor?)$2",
  "event-86060018.10": "¿Quedarse o irse?",
  "event-86060018.11": "(Creo que estás subestimando a Juna y a tu abuelo, pero claro, me quedaré.)",
  "event-86060018.12": "(Puedo ver que me necesitan desesperadamente aquí. ¡Estoy dentro!)",
  "event-86060018.13": "(Desearía poder, pero ya tengo planes.)",
  "event-86060018.14": "(No me pagarías para quedarme en este desastre.)",
  "event-86060018.15": "¿De qué están susurrando?#$b#Si están planeando una broma, recuerden los tres p's de las bromas: preparación, diversión y placer!$6",
  "event-86060018.16": "¡Suena genial, pero solo estaba invitando a @ para que se uniera a nosotros! Como son amigos y todo.$1#$b#Eso está bien... ¿verdad?$7",
  "event-86060018.17": "¡Claro!#$b#Siempre y cuando nadie se lleve mi parte de la comida.$11",
  "event-86060018.18": "¡Vamos!$1",
  "event-86060018.19": "¿Está lista la cena? ¡Tengo hambre!",
  "event-86060018.20": "¿Olvidaste que tenemos invitados esta noche, querida? Alex está trayendo a Juna. ¡Hice pastel de carne!",
  "event-86060018.21": "Hmph. No veo por qué eso significa comer la cena a medianoche.",
  "event-86060018.22": "Oh, no seas tonto, George. Solo son las 7 en punto. Una cena tardía no te matará.",
  "event-86060018.23": "¡Oh, aquí están ahora!",
  "event-86060018.24": "Hola, abuela, hola, abuelo.$1#$b#Esta es Juna. Oh, y también invité a @, espero que esté bien.",
  "event-86060018.25": "¡Claro, querida! Cuantos más, mejor. Juna, es un placer conocerte. He oído muchas cosas realmente interesantes sobre ti.$1",
  "event-86060018.26": "Oh, qué dulce eres, ¡por supuesto que lo has hecho! Soy fácilmente una de las personas más interesantes del valle.$1#$b#Y lo mismo para ti.$6",
  "event-86060018.27": "¿Qué pasa, viejo? ¿Te has recuperado de tu última derrota humillante?",
  "event-86060018.28": "Hmph. ¡Es brujería, te lo digo! ¡Es la única razón posible por la que alguien tan antiguo como tú podría ganarme en pétanque!$3",
  "event-86060018.29": "¡Grosero!",
  "event-86060018.30": "¿Espera, qué?!$7",
  "event-86060018.31": "¿Ustedes dos se conocen?$7",
  "event-86060018.32": "Oh, querido.",
  "event-86060018.33": "*resoplido*",
  "event-86060018.34": "¿Sí? Por supuesto que sí. Jugamos pétanque siempre que este viejo saco de huesos se sienta lo suficientemente aventurero como para salir de la casa.#$b#¿Nunca te conté eso?$3",
  "event-86060018.35": "¡No! ¡No lo hiciste!$7",
  "event-86060018.36": "Ups.",
  "event-86060018.37": "Después de que Alex superó su sorpresa, y Juna y George dejaron de insultar la edad del otro, tuvimos una cena encantadora juntos. Extraña, pero encantadora.",
  "event-86060018.choseGo.01": "¿De qué están susurrando? ¿Y por qué te ves todo constipado?#$b#Si están planeando una broma, ¡anímate! Una broma adecuada requiere tres cosas: preparación, diversión y placer!$6",
  "event-86060018.choseGo.02": "¡No, es nada! ¡No te preocupes por eso! @ ya estaba saliendo de todos modos.$7",
  "event-86060018.choseGo.03": "¿Ok? Entonces adiós, supongo?$11",
  "event-86060018.choseGo.04": "Mejor entremos.",

  //Summer
  "event-86060019.01": "¡Juna!",
  "event-86060019.02": "Vaya, mareo. Nunca voy a acostumbrarme a esa cosa de teletransportación.$1",
  "event-86060019.03": "Dices eso cada vez.$10#$b#¿Qué pasa? ¿Dónde está el incendio?",
  "event-86060019.04": "¡Oh, cierto!$7",
  "event-86060019.05": "¡Estoy lista!$1",
  "event-86060019.06": "¿Para qué, tonta?!$1",
  "event-86060019.07": "¡Para volver allá afuera! Para entrenar, y ponerle esfuerzo, y hacerlo con una sonrisa en la cara y todo eso. Sabes, todas esas cosas que me has estado diciendo.$3",
  "event-86060019.08": "Bueno, en primer lugar, nunca diría algo tan cursi como 'hazlo con una sonrisa en la cara'.$2",
  "event-86060019.09": "Pero en segundo lugar: ¡por fin! Te tomó tiempo.$1",
  "event-86060019.10": "Todo parecía tan, como, difícil todo el tiempo, ¿sabes? Y tenía miedo de haber perdido mi oportunidad, ya que solo me estoy haciendo cada vez más vieja.$2",
  "event-86060019.11": "Eso es generalmente cómo funciona el envejecimiento, sí.#$b#Bueno, para la mayoría de las personas, al menos.$3",
  "event-86060019.12": "Y pronto no podré estar en ninguna de las listas de '25 menores de 25'. Eso realmente me deprimió.$2",
  "event-86060019.13": "Pero luego, cuando estaba en la cama una noche...",
  "event-86060019.14": "No estoy segura de si quiero escuchar esto.",
  "event-86060019.15": "... me pregunté: ¿y si, mañana, alguien te dijera que nunca vas a llegar a ser profesional? Como, que habían visto tu futuro y sabían que nunca sucederá. ¿Dejarías de entrenar? ¿Dejarías de ir a los juegos? ¿Dejarías de idear nuevas estrategias?",
  "event-86060019.16": "No voy a mentir, sería bastante hilarante si la respuesta a esa pregunta resultara ser 'sí'.$10",
  "event-86060019.17": "¡No, Juna! ¡Por supuesto que no es sí! ¡La respuesta es no!$1",
  "event-86060019.18": "Lo sé, tonta.",
  "event-86060019.19": "Y obviamente deberías seguir entrenando. La fama está sobrevalorada. Debo saberlo; he sido famosa por muchas cosas. ¡Al menos por tres y media!$6",
  "event-86060019.20": "Espera, ¿lo has sido?$7",
  "event-86060019.21": "Entre un cierto segmento de la... población forestal, sí.$3",
  "event-86060019.22": "¿Estás hablando de esas papas de nuevo?$1",
  "event-86060019.23": "¡No son papas!",
  "event-86060019.24": "Bueno, lo que sea. Lo importante es que voy a seguir entrenando, y seguir intentando, y si pasa, pasa.#$b#Y si no, voy a hacer mi mejor esfuerzo para ser feliz de todos modos.$1",
  "event-86060019.25": "¿Estás buscando algo? ¿Qué estás haciendo?$11",
  "event-86060019.26": "No, es solo que... Ahora que he llegado a esta decisión realmente adulta, siento que estoy viendo las cosas desde una nueva perspectiva.#$b#Y no quiero perder eso, así que estaba pensando que tal vez es hora de mudarme de la casa de mis abuelos. Tienes un lugar bastante genial aquí. ¿Conoces alguna otra cueva cercana que esté libre de, como, osos y cosas así?",
  "event-86060019.27": "%Juna comienza a reírse incontrolablemente.",
  "event-86060019.28": "¡Juna! ¡Deja de reír!$4",
  "event-86060019.29": "23 minutos y 46 segundos después.",
  "event-86060019.30": "... y esa es la razón número 6 por la cual tú específicamente nunca podrías vivir en una cueva.",
  "event-86060019.31": "No puedo creer que tengas una lista así para cada persona en Pelican Town. ¡Soy lo suficientemente genial para vivir en una cueva!$5#$b#Eres la peor hermana mayor de todas.$5",
  "event-86060019.32": "No, no lo eres.$4#$b#Ahora vamos, vamos a frotarle en la cara a tu abuelo que he resultado ser una influencia más positiva en ti de lo que él nunca fue.$10",
  "event-86060019.33": "¡Y nunca me dejas tener la última palabra!$5",

  //Farm visits

"event-86060028.01": "Pude sentir que me estabas observando anoche, así que decidí venir a decir hola. Es terriblemente grosero espiar a la gente, ¿sabes?$3#$b#...$3#$b#Bien hecho, tú.$4",
  "event-86060028.02": "Bueno, tengo que irme. Si no vuelvo rápido, Olive volverá a acabar con todos los panqueques sin mí.#$b#Esa pequeña troll.$5",
  "event-86060028.03": "¡Hasta luego, novato!",
  "event-86060028.04": "Me pregunto qué estaba haciendo con ese cartel.",
  "event-86060028.05": "Sinceramente, no puedo decir si me estaba insultando o dándome un cumplido...",

  "event-86060022.01": "¡Hola, @! Sé que probablemente me extrañaste mucho ayer, pero te aseguro que todo fue por una buena causa.$1#$b#Y como ahora he terminado de ajustar mis planes para la próxima semana, me complace anunciar que la Operación Botella de Spray está en marcha.$3",
  "event-86060022.02": "Voy a tomar el próximo autobús, así que solo pasé a decir adiós.#$b#¡No olvides alimentar a Robin y regar a Raz mientras estoy fuera!$6",

  "event-86060023.01": "¡Hola, @! Sé que probablemente me extrañaste mucho ayer, pero te aseguro que todo fue por una buena causa.$1#$b#Y como ahora he terminado de ajustar mis planes para la próxima semana, me complace anunciar que la Operación Compañero de Cuarto Involuntario está en marcha.$3",
  "event-86060023.02": "Voy a dirigirme a casa de Olive antes de decirle a Raz la buena noticia, pero quería agradecerte nuevamente por convencerme de hacer esto.#$b#¡Raz va a estar tan enojado!$4",

  "event-86060024.01": "¡Hola, diario! ¿Adivina quién ha vuelto?$6",
  "event-86060024.02": "Confío en que disfrutaste mis cartas. Trabajé muy duro en ellas, ¿sabes?$1#$b#De todos modos, he vuelto, pero estoy exhausta. Terminé sentada al lado de otra persona que ronca en el autobús de regreso a casa - ¿puedes creerlo? ¡Qué injusto! - así que voy a pretender estar en comunión con la naturaleza por el resto del día.",
  "event-86060024.03": "Oh, casi se me olvida. Te traje un souvenir. Esto solía pertenecer a mi tatarabuela.[446]",
  "event-86060024.04": "Ugh, no es divertido cuando solo me crees así. Mi tatarabuela odiaba a los conejos. Lo compré en una tienda.$2",
  "event-86060024.05": "Bueno, ¡hasta luego!$1",
  "event-86060024.06": "XOXO, Ju",

  "event-86060025.01": "¡Hola, diario! ¿Adivina quién ha escapado de su torre?$6",
  "event-86060025.02": "Confío en que disfrutaste mis cartas. Trabajé muy duro en ellas, ¿sabes?$1#$b#De todos modos, estoy de vuelta entre la sociedad educada, pero estoy exhausta. Raz y yo nos desvelamos jugando Go toda la noche - él es un muy mal perdedor, por cierto - así que voy a pretender estar en comunión con la naturaleza por el resto del día.",
  "event-86060025.03": "Oh, casi se me olvida. Te traje un último souvenir, por así decirlo. Este polvo fue creado por la tatarabuela de Raz. Aquí tienes![872]",
  "event-86060025.04": "Ugh, no es divertido cuando solo me crees así. La tatarabuela de Raz era tan tonta como una caja de piedras. En realidad, fue Raz quien creó eso.$2",
  "event-86060025.05": "Bueno, ¡hasta luego!$1",
  "event-86060025.06": "XOXO, Ju",

  //CFD patches

  "CFD.roommate.4406": "Tuve un sueño sobre impuestos que fue tan aburrido que solo siento ganas de dormir hoy.$a",
  "CFD.roommate.4462": "Me desvelé toda la noche y supervisé a la pequeña hada rara mientras regaba algunas de tus cosechas por ti. ¡Espero que estés agradecido!$10",
  "CFD.roommate.4463": "#$e#Yo personalmente llené el cuenco de agua de {0}, sin embargo.$6",
  "CFD.roommate.4465": "*Juna sonríe mientras come un bocado de panqueques.*",
  "CFD.roommate.4466": "¡Buenas noches, {0}! Oh, ¿ya es de mañana?",
  "CFD.roommate.4470": "Me levanté temprano para supervisar los aspersores y ¡ya habían terminado! Qué pena.$h",
  "CFD.roommate.4474": "Me levanté temprano e intenté hacer que los animales grandes alimentaran a los pequeños y viceversa. Fue un desastre. Pero al menos ya está hecho.$2",
  "CFD.roommate.4481": "Pasé la mañana encantando algunas de las vallas para que se repararan solas. Deberían estar como nuevas.",
  "CFD.roommate.4486": "¿Qué piensas, {0}?$3",
  "CFD.roommate.4488": "Pedí esto el otro día y finalmente llegó. ¿No es hilarante?$1",
  "CFD.roommate.4489": "Pensé que la habitación podría usar un poco más de decoración. Definitivamente intenté al máximo asegurarme de que encajara con tu temática.$3",
  "CFD.roommate.4490": "Iba a hacer una decoración experimental hoy, pero cambié de opinión.$a",
  "CFD.roommate.4496": "¿Qué piensas del nuevo papel tapiz que elegí?$3",
  "CFD.roommate.4497": "¿Qué piensas del nuevo suelo que elegí?$3",
  "CFD.roommate.4498": "*suspira*... a veces extraño mi antigua vida. Era mucho más fácil burlarme de Raz cuando solo tenía que caminar diez pasos para llegar a su puerta.$s",
  "CFD.roommate.4499": "El clima es demasiado aburrido para salir de la cama. Aburriiiiido.$s",
  "CFD.roommate.4500": "Podrías haber hecho que %pet limpiara aquí un poco mientras yo estaba fuera...$a#$e#Realmente no están haciendo su parte por aquí.$a",

  //Roommate intro - Wizard fork

  "strings.couchsurfing.mon": "¡Toda mi vida está en ruinas, Robin! ¿De verdad me culparías por querer consolarme con una rebanada de pizza celestial?$2",
  "strings.couchsurfing.sat": "Literalmente podría decirte cualquier cosa en este momento, y lo interpretarías como que quiero abrir otra botella de vino.$1",
  "strings.couchsurfing.mon.Robin": "Te perdiste una cena realmente genial esta noche, Ju. Dem hizo una deliciosa lasaña de calabaza.#$b#Lo juro por Yoba, a veces eres como una adolescente.$6",
  "strings.couchsurfing.sat.Robin": "Veo lo que dices... me estás diciendo que deberíamos abrir otra botella de vino.$1",

  "ct.couchsurfing.Juna1": "Después de mucha consideración, he decidido quedarme con Robin los lunes y sábados, con Emily los jueves y viernes, y con Alecto los martes y miércoles.$6#$b#¿Alecto? Solía estar casada con Raz, el pobre. Si él ha envejecido como queso expuesto al sol por mucho tiempo, ella ha envejecido como una botella de vino poético y peligrosamente fino.#$b#La adoro.$4",
  "ct.couchsurfing.Juna1.alecto": "Después de mucha consideración, he decidido quedarme con Robin los lunes y sábados, con Emily los jueves y viernes, y con Alecto los martes y miércoles.$6#$b#¡No puedo esperar para decirle a Raz que me estoy quedando con Alecto! Oh, cómo la adoro.$4",
  "ct.couchsurfing.Juna2": "Aparentemente, Dem no se había dado cuenta de que me había estado quedando con ellos hasta que lo visité en su laboratorio y le señalé que su nuevo experimento con hongos me recordaba al jardín de marihuana de la tía de Olive.#$b#No tenía idea de que no lo sabía, lo juro.$3",
  "ct.couchsurfing.Juna3": "He aceptado amablemente convertirme en la nueva musa de Haley. Es un trabajo duro, pero alguien tiene que hacerlo.$6",
  "ct.couchsurfing.Juna4": "Robin sigue intentando que le prepare el desayuno, como si no dijera que no cada vez que le ofrezco uno de mis cafés experimentales.$2#$b#Estos son los inconvenientes de vivir con otras personas, supongo.",
  "ct.couchsurfing.JunaCaveBack": "Ah, cómo he extrañado dormir en la corriente fresca y húmeda de mi cueva, acunada por el sonido de pequeñas patas corriendo de un lado a otro por las paredes.$1#$b#...$11#$b#¿Quieres saber un secreto, sin embargo? En realidad arreglé el problema hace semanas.$3#$b#Pero supongo que me estaba divirtiendo demasiado como para regresar a casa de inmediato. Era... agradable, ¿sabes? Agradable vivir con gente otra vez.$11",

  "ct.couchsurfing.Robin1": "He estado diciéndole a Juna que salga de esa cueva durante años. Incluso le ofrecí ayudarla a construir su propia casa, pero ella solo grita algo sobre ser aburrida y me cierra el paso.",
  "ct.couchsurfing.Robin2": "Intenté poner una cama en la habitación de Maru para que Juna durmiera, pero ella insistió en quedarse en nuestra diminuta cocina.#$b#Ahora solo si pudiera hacer que preparara el desayuno por las mañanas...$1",

  "ct.couchsurfing.Demetrius1": "¿Sabías que Juna ha estado quedándose con nosotros? Porque yo no lo sabía. No hasta que apareció detrás de mí una noche y dijo algo insultante y desconcertante sobre hongos.#$b#Me hizo dejar caer mi matraz favorito...$3",

  "ct.couchsurfing.Maru1": "Me divertí mucho mostrando mis invenciones a Juna hace unas noches. ¡Ella es realmente alentadora!$1#$b#Dijo que cree que me irá bien siempre y cuando no deje que nada \"estúpido\" me distraiga.",

  "ct.couchsurfing.Sebastian1": "No me importa tener a Juna por la casa un rato.#$b#Solo habla conmigo cuando quiere mi ayuda con su \"culto en línea\". Sus palabras, no las mías.$7",

  "ct.couchsurfing.Wizard1": "Ah, sí, el... incidente en la cueva de Juna. Algunos olores son casi imposibles de acostumbrarse.",
  "ct.couchsurfing.Wizard2": "Supongo que es agradable tener de vuelta mis domingos. Agradable, sí, no en absoluto solitario...#$b#Olvídalo.",
  "ct.couchsurfing.Wizard3": "¿Qué es eso? Oh, hm, sí, solo estoy anotando algunos pensamientos para compartir con Juna cuando regrese.#$b#Sin duda se reirá de mí, pero creo que encontrará algunas cosas bastante interesantes...",

  "ct.couchsurfing.Emily1": "Me siento mal por su cueva, pero ha sido divertido tener a Juna con nosotros.#$b#Ella viene y va a su antojo, come cosas malas para ella cuando está fuera de casa y le gusta hacer nidos en mi rincón de costura - ¡justo como un gato!$1",
  "ct.couchsurfing.Emily2": "Aparentemente Juna arregló lo que estaba mal con su cueva, así que volverá allí pronto. ¡Voy a extrañar a nuestra tercera compañera de cuarto!",

  "ct.couchsurfing.Haley1": "Pensé que iba a ser, como, super raro tener a Juna durmiendo en nuestro sofá, pero en realidad es muy divertida.$1#$b#No entiendo sus historias en absoluto, pero supongo que estoy acostumbrada a eso con Emily. Además, es muy fotogénica.",
  "ct.couchsurfing.Haley2": "¿Has notado que Juna tiene, como, dos caras? Una es toda ruidosa y dramática, pero la otra es... oculta, casi.#$b#No creo que se haya dado cuenta de que tomé esas fotos...$2",

  "robin.doll.hint": "#$1 RobinHint#Sé que puede ser difícil de creer, pero realmente extraño tener a Juna cerca. Si alguna vez quieres probar la experiencia de compañera de cuarto con Juna, intentaría pedirle con una muñeca extraña. ¡Quién sabe, podría funcionar!$h#$e#Siempre eres bienvenido a visitarnos, incluso si solo quieres charlar. Puede volverse bastante solitario aquí en las montañas.",

  "juna.reaction.doll.q": "...$11#$b#$q 860620/860621 roommate_followup#¿Quieres que me mude contigo?#$r 860620 0 roommate_yes#Sí, creo que podría ser divertido.#$r 860621 0 roommate_no#Nah, solo estaba bromeando. ¡Ups!",
  "juna.reaction.doll.yes": "Hmm, interesante.$3#$b#Creo que tú y yo necesitamos conocernos mejor primero. Dame unos días, luego ven a visitarme en mi cueva a primera hora de la mañana.#$b#Ah, y toma esto. Te permitirá echar un vistazo a tu vida.",
  "juna.reaction.doll.no": "No es exactamente tu mejor trabajo, @, pero te perdonaré ya que me conseguiste una muñeca extraña.$11#$b#Aunque... acabas de hacerme dar cuenta de que tú y yo probablemente deberíamos conocernos mejor.$3#$b#Dame unos días, luego ven a visitarme en mi cueva a primera hora de la mañana. ¡Te mostraré exactamente lo que te estás perdiendo en el departamento de compañeros de cuarto!$6",
  "juna.reaction.doll.followup": "$p 860620#Una vez que entres en mi cueva, prepárate para pasar el día entero conmigo. ¡De desayuno a copa nocturna!$1|Consideraría ese chiste de compañero de cuarto un fracaso si fuera tú, @. No todos son tan geniales como yo.#$b#¡No olvides esa invitación a mi cueva, sin embargo! Sería terriblemente grosero de tu parte insultarme dos veces.$6",

  "treasure.hunt.leah": "#$1 LeahTreasure#¿Te conté alguna vez sobre la vez que Robin, Juna y yo nos emborrachamos y sacamos las pinturas de dedos? La pintura de Juna resultó bastante hermosa, en realidad. Me pregunto qué habrá sido de ella...$h#$e#¿Te gustaría una copa de vino? ¡Invito yo!$l",
  "treasure.hunt.leah.married": "#$1 LeahTreasure#¿Te conté alguna vez sobre la vez que Robin, Juna y yo nos emborrachamos y sacamos las pinturas de dedos? La pintura de Juna resultó bastante hermosa, en realidad. Me pregunto qué habrá sido de ella...$h#$e#¡Nos vemos esta noche!$l",
  "treasure.hunt.robin": "#$1 RobinTreasure#¿Pintura de Juna? Oh, cierto, ¡lo recuerdo! Creo que Dem pudo haberla rescatado después de que Leah accidentalmente derramó vino en el sofá, pero nunca pensé en preguntarle qué hizo con ella.#$e#Debería invitar a Leah a otra noche de vino y queso pronto.$h",
  "treasure.hunt.demetrius": "#$1 DemetriusTreasure#De hecho rescaté una pintura de un encuentro cercano con vino tinto. Pero luego podría haber, bueno, distraído y dejado la pintura afuera en algún lugar. ¿Quizás junto a la orilla del lago?$2#$e#A Maru le encantaba pintar con los dedos cuando era niña. Tengo que admitir que también me divertí jugando con eso.$h",
  "treasure.hunt.dwarf1": "#$1 DwarfJunaTreasure#Puede que haya encontrado una pintura junto al lago una noche tarde. Tenía colores bonitos. Vuelve mañana y tal vez tenga más información para ti.#$e#¡Vuelve mañana! No tengo nada para ti ahora mismo.",
  "treasure.hunt.dwarf2": "Encontré la pintura con los colores bonitos junto al lago. La tomé y la puse en un marco bonito, pero te la venderé por 5,000 oro.#$b#Puedo darte una réplica que puedes regalar de inmediato, pero enviaré la pintura real a la de cabello lunar directamente.#$b#¿Qué? Es bonita. No quiero que la dañas o la dejes caer en algún lugar.",

  "reject.juna.painting": "%No debería regalar esto...",

  "juna.engaged.roommate": "¿Prometes dejarme venir y irme cuando me plazca, usar la cocina solo para experimentar - no para cocinar - comida, y dedicarte a molestar a Raz siempre que te apetezca?$3#$b#¡Entonces estoy dentro!$4#$b#Solo necesito unos días para romper con mi cueva, luego estaré allí.",
  "juna.reject.roommate": "*suspira* ¡Realmente quería decir que sí, lo juro! Pero aún no estoy segura de que no me miraras decepcionado cada vez que hiciera panqueques para el desayuno, el almuerzo Y la cena.$2",
  "juna.engagement.dialogue0": "Mi habitación va a ser una explosión de color, ya verás.$1#$b#¿Qué? Solo porque actualmente viva en una cueva oscura no significa que no aprecie las cosas brillantes.$13",
  "juna.engagement.dialogue1": "Probablemente debería advertirte antes de que hagamos esto: Olive tiene la tendencia de caminar dormida, así que si alguna vez te despiertas con algo redondo y meepy tratando de entrar en tu nevera, ¡no lo pises!$6",
  
  //Pre-event 1
  "event-86060100.01": "¡Oh, ay de mí!",
  "event-86060100.02": "¡No puedo creerlo!",
  "event-86060100.03": "¡REALMENTE no puedo creerlo!",
  "event-86060100.04": "¡Ojalá hubiera alguien noble cerca!",
  "event-86060100.05": "¿Puedo ayudarte, Juna?",
  "event-86060100.06": "¿Qué QUIERES?",
  "event-86060100.07": "Por favor, deja de llamarme noble como si fuera un insulto.",
  "event-86060100.08": "¡Espero que sí!$1#$b#Desesperadamente necesito a alguien con quien hablar, ¿ves?$2",
  "event-86060100.09": "¡Qué bueno que preguntaste!$1#$b#Porque desesperadamente necesito a alguien con quien hablar.$2",
  "event-86060100.10": "¿Por qué pensarías que es un insulto?#$b#De todos modos, me alegra que estés aquí. Desesperadamente necesito a alguien con quien hablar, ¿ves?$2",
  "event-86060100.11": "¿Sabes cómo he estado intentando convertir el agua en mi cueva en cola de Joja?",
  "event-86060100.q1": "¡Claro!",
  "event-86060100.q2": "No realmente, pero ciertamente suena como algo que harías.",
  "event-86060100.12": "Bueno.$11#$b#Ha salido mal. Ligeramente. Solo un poco.$11",
  "event-86060100.13": "¿Qué significa eso, entonces?",
  "event-86060100.14": "No creo que ser noble pueda ayudar con eso.",
  "event-86060100.15": "Significa que estaré de sofá en sofá mucho en el futuro previsible.$11#$b#Aparentemente es una... mala idea pasar más de dos noches seguidas allí.$2",
  "event-86060100.16": "¡No *necesito* ayuda!$13#$b#*suspiro*$11#$b#Lo siento. Supongo que solo quería quejarme con alguien. Aparentemente es una... mala idea pasar más de dos noches seguidas allí.$11#$b#Parece que estaré de sofá en sofá por un tiempo.$2",
  "event-86060100.17": "Probablemente debería ocuparme de eso.$11",
  "event-86060100.18": "Gracias por escuchar, supongo.",

  //Pre-event 2
 "event-86060200.01": "¡No estaba durmiendo! ¡Tú estás durmiendo!$13",
  "event-86060200.02": "Está bien. Sí, estoy un poco cansada. Y sí, sigo de sofá en sofá.$11#$b#...$11#$b#¿Quieres saber un secreto? Ya he averiguado cómo arreglar mi cueva.$3",
  "event-86060200.03": "Porque es... agradable, ¿vale? Es agradable volver a vivir con gente.$11",
  "event-86060200.04": "No me malinterpretes - el sofá de Alecto es el peor sofá en el que he estado, Robin tiene demasiadas opiniones sobre lo que como y Emily canta. En voz alta. Todo el tiempo.$2#$b#Y definitivamente extraño mi cueva, y no tengo ganas de mudarme con ninguno de ellos a tiempo completo, pero...",
  "event-86060200.05": "%Juna se encoge de hombros, luego bosteza.",
  "event-86060200.q1": "¿Qué tal mudarte con alguien que tenga un poco más de espacio?",
  "event-86060200.q2": "Solo... trata de no caerte, ¿vale? Dormir es importante.",
  "event-86060200.06": "%Juna inclina la cabeza y te mira fijamente.",
  "event-86060200.07": "¿Estás hablando de ti mismo o estás sugiriendo que me mude con Lewis?",
  "event-86060200.08": "En realidad, no es necesario que respondas.$1#$b#Porque aunque no quisieras decir nada con eso, acabas de darme una idea brillante.#$b#Esto podría ser la privación de sueño hablando, pero creo que es hora de que tú y yo nos conozcamos mejor. ¡De verdad esta vez!$3",
  "event-86060200.09": "Dame un momento.",
  "event-86060200.09.1": "¡Tachán!",
  "event-86060200.10": "Mi plan es de dos partes. Escucha con atención, @!#$b#Para que nos convirtamos en los mejores amigos, necesitamos ver cómo vive el otro.$3#$b#Usé una tontería mágica para infundir ese anillo con mi esencia, así que cuando lo equipas, obtendrás un- bueno, obtendrás algo parecido a un eco mío siguiéndote.$3#$b#¿Y sabes cuál es la mejor parte? ¡Puedo entrar y salir de ese eco tantas veces como quiera! ¡Siempre que hagas algo aburrido, puedo irme!$4",
  "event-86060200.11": "Parte 2 de mi plan maestro:$3#$b#Tienes que pasar un día conmigo. Un día entero, desde el desayuno hasta la copa de la noche.$6",
  "event-86060200.12": "Solo dame... hm, dos o tres semanas, luego ven a visitarme en mi cueva a primera hora de la mañana. Eso debería darme tiempo suficiente para preparar el día perfecto.$10#$b#Bueno, perfecto según algunos, al menos.$3", //EDIT!
  "event-86060200.13": "¡Espero con ansias!",
  "event-86060200.14": "¿Es valioso este anillo? ¿Podría venderlo?",
  "event-86060200.15": "(Temblar de miedo.)",
  "event-86060200.16": "¡No, no puedes!",
  "event-86060200.17": "Y recuerda: ¡una vez que entres en mi cueva, prepárate para pasar el día entero conmigo!$4",
  "event-86060200.goSleep.01": "Sí, sí, bla, bla.",
  "event-86060200.goSleep.02": "No hace falta que pongas esa cara. Volveré a casa pronto.",
  "event-86060200.goSleep.03": "¿Quieres ver un hechizo nuevo que Alecto me enseñó?",
  
  //Pre-event 3
  "event-86060300.01": "¿Listo para pasar todo el día con Juna?",
  "event-86060300.02": "Sí, estoy listo para pasar el rato con Juna y luego terminar el día.",
  "event-86060300.03": "No, aún no estoy listo.",
  "event-86060300.ReadyToRumble.01": "¡Bienvenido al día perfecto!$4",
  "event-86060300.ReadyToRumble.02": "Bueno, no hay tiempo para perder. ¡Tenemos mucho que hacer!$1",
  "event-86060300.ReadyToRumble.03": "¿Vienes?",
  "event-86060300.ReadyToRumble.04": "Desayuno.",
  "event-86060300.ReadyToRumble.05": "¡Bienvenido!",
  "event-86060300.ReadyToRumble.06": "Entonces, ¿qué puedo ofrecerte? Supongo que tendrás tu habitual, ¿Juna?$1",
  "event-86060300.ReadyToRumble.07": "Y eso nos lleva suavemente a la primera - ¡extremadamente importante! - pregunta del día. ¿Cuál es tu desayuno preferido?",
  "event-86060300.ReadyToRumble.08": "Desayuno completo, siempre.",
  "event-86060300.ReadyToRumble.09": "Gachas con varios toppings.",
  "event-86060300.ReadyToRumble.10": "Un tazón de cereal. Tal vez algo de tostadas.",
  "event-86060300.ReadyToRumble.11": "Solo una taza de café o té.",
  "event-86060300.ReadyToRumble.12": "¡Aceptable!",
  "event-86060300.ReadyToRumble.13": "¡Nooooo!",
  "event-86060300.ReadyToRumble.14": "Algo aburrido, pero clásico.",
  "event-86060300.ReadyToRumble.15": "Muy de académico de mediana edad.",
  "event-86060300.ReadyToRumble.16": "¡Inmediatamente!",
  "event-86060300.ReadyToRumble.17": "Oh, no te preocupes. Prometo que nada de lo que me digas hoy hará que pierdas puntos conmigo.$1#$b#Te juzgaré, seguro, pero no afectará nuestra amistad.$3#$b#Después de todo, si lo hiciera, ¡no tendría amigos!$6",
  "event-86060300.ReadyToRumble.18": "Estoy seguro de que Gus pondría algo más fuerte en tu bebida si lo pides amablemente.",
  "event-86060300.ReadyToRumble.19": "Sí, está bien. Después de todo, es mi día libre.",
  "event-86060300.ReadyToRumble.20": "¿Podrías hacer que sea una mimosa en su lugar?",
  "event-86060300.ReadyToRumble.21": "Es un poco demasiado temprano para mí, me temo.",
  "event-86060300.ReadyToRumble.22": "El alcohol no es lo mío, gracias.",
  "event-86060300.ReadyToRumble.23": "¡Ese es el espíritu!",
  "event-86060300.ReadyToRumble.24": "¡Hasta luego!",
  "event-86060300.ReadyToRumble.25": "Está bien. Me gusta el vino y la cerveza tanto como a la siguiente persona - aunque no tanto como a Robin - pero podemos saltarlo si quieres.",
  "event-86060300.ReadyToRumble.26": "¡El desayuno está servido! Hice las hashbrowns extra crujientes para la ocasión. ¡Disfruta!$1",
  "event-86060300.ReadyToRumble.27": "Bueno, esa es ciertamente una historia desconcertante y completamente loca. No sabía que lo tenías en ti.#$b#¡Me gusta!$1",
  "event-86060300.ReadyToRumble.28": "¡Oh, tenemos que irnos o lo vamos a perder!$10",
  "event-86060300.ReadyToRumble.29": "¡Adiós, Gus!",
  "event-86060300.ReadyToRumble.30": "Reunión de la ciudad.",
  "event-86060300.ReadyToRumble.31": "¡Muy bien! ¡Cálmense, todos!",
  "event-86060300.ReadyToRumble.32": "¿Puedo tener la atención de todos, por favor?",
  "event-86060300.ReadyToRumble.33": "Los he convocado hoy para discutir la última propuesta administrativa para Pelican Town. O propuestas, como fueron, aunque hacen referencia al mismo problema.#$b#Ese problema es si debemos o no realizar reuniones municipales regulares en Pelican Town.",
  "event-86060300.ReadyToRumble.34": "Se ha presentado una petición para realizar reuniones trimestrales aquí en la tienda.#$b#Dos días después, recibí una segunda petición desautorizando la primera petición en base a que las reuniones municipales son *ineficientes y estúpidas*.#$b#En mi papel como alcalde, decidí que deberíamos tener una reunión para discutir estos asuntos públicamente.",
  "event-86060300.ReadyToRumble.35": "No.",
  "event-86060300.ReadyToRumble.36": "¿Estás diciendo que nos convocaste aquí para tener una discusión pública sobre si discutir cosas públicamente?$3",
  "event-86060300.ReadyToRumble.37": "Bueno, verás ...",
  "event-86060300.ReadyToRumble.38": "Eso no es realmente ...",
  "event-86060300.ReadyToRumble.39": "Eso parece muy tonto.",
  "event-86060300.ReadyToRumble.40": "*resoplido*",
  "event-86060300.ReadyToRumble.41": "¿Quién escribió la petición?",
  "event-86060300.ReadyToRumble.42": "¡No he firmado ninguna petición!",
  "event-86060300.ReadyToRumble.43": "¿Qué petición?",
  "event-86060300.ReadyToRumble.44": "Tengo algunas ideas...",
  "event-86060300.ReadyToRumble.45": "Mami, ¿qué es una petición?",
  "event-86060300.ReadyToRumble.46": "¡Gritar palabras!",
  "event-86060300.ReadyToRumble.q1": "Solo ... ¿por qué?",
  "event-86060300.ReadyToRumble.47": "(Porque los foros públicos son locos y me encantan. ¿Por qué más?)$3",
  "event-86060300.ReadyToRumble.48": "¡Pero tú pediste esto!",
  "event-86060300.ReadyToRumble.49": "¡No, no lo hicimos!",
  "event-86060300.ReadyToRumble.50": "*suspiro*",
  "event-86060300.ReadyToRumble.51": "¿Qué pasa con los bocadillos?",
  "event-86060300.ReadyToRumble.52": "¡Quiero bocadillos!",
  "event-86060300.ReadyToRumble.53": "Y ahora: un montaje.",
  "event-86060300.ReadyToRumble.54": "Almuerzo.",
  "event-86060300.ReadyToRumble.55": "Lectura de libros.",
  "event-86060300.ReadyToRumble.56": "¡Hola, chico rebotador!",
  "event-86060300.ReadyToRumble.57": "Por favor, siéntate.",
  "event-86060300.ReadyToRumble.58": "Portero: Gracias por venir.",
  "event-86060300.ReadyToRumble.59": "Portero: Soy B. Campbell y estoy aquí para leer de mi última novela ...",
  "event-86060300.ReadyToRumble.60": "... El Mago y la Doncella.",
  "event-86060300.ReadyToRumble.61": "*se aclara la garganta*",
  "event-86060300.ReadyToRumble.62": "El gran mago de la antigua y más noble orden de protectores divinos de los gritos de éxtasis de la tierra resonaba por el castillo con corrientes de aire ...",
  "event-86060300.ReadyToRumble.63": "Té de la tarde.",
  "event-86060300.ReadyToRumble.64": "¡Camarero!",
  "event-86060300.ReadyToRumble.65": "Bien- ... *tos*",
  "event-86060300.ReadyToRumble.66": "¿Sí?",
  "event-86060300.ReadyToRumble.67": "*suspiro*",
  "event-86060300.ReadyToRumble.68": "Bienvenido a la Casa de Té Mágica de Juna. ¿Qué puedo hacer por ti?",
  "event-86060300.ReadyToRumble.69": "Déjame ver...",
  "event-86060300.ReadyToRumble.70": "¿Puedes ofrecerme algo ligero, por favor?",
  "event-86060300.ReadyToRumble.71": "Sí, algo ligero.",
  "event-86060300.ReadyToRumble.72": "¿Puedes hacerme un té con algo para acompañar?",
  "event-86060300.ReadyToRumble.73": "Voy a pedir algo ligero.",
  "event-86060300.ReadyToRumble.74": "¿Por qué no vamos con algo ligero?",
  "event-86060300.ReadyToRumble.75": "Perfecto, entonces. Te traeré el té con una pequeña pieza de pastel en un momento.",
  "event-86060300.ReadyToRumble.76": "Y sí, será genial si no te importa. Esto no está destinado a ti. ¡Asegúrate de estar atento a un agradable solitario!",
  "event-86060300.ReadyToRumble.77": "Oye, no es necesario, me refiero a ti. No te pongas tan nervioso.",
  "event-86060300.ReadyToRumble.78": "Me gustaría un poco de paz, si no es mucho pedir.",
  "event-86060300.ReadyToRumble.79": "¡Gracias!$4",
  "event-86060300.ReadyToRumble.80": "Es mejor que puedas disfrutar de la siguiente pieza de pastel en un ambiente de tranquilidad.$3",
  "event-86060300.ReadyToRumble.81": "Café.",
  "event-86060300.ReadyToRumble.82": "Vamos a buscar un lugar para comer.#$b#¿Qué te parece un pequeño café cerca de la plaza?",
  "event-86060300.ReadyToRumble.83": "Me parece bien.",
  "event-86060300.ReadyToRumble.84": "Suena perfecto. Me encantaría.",
  "event-86060300.ReadyToRumble.85": "¡Sí! ¿Vamos ahora?",
  "event-86060300.ReadyToRumble.86": "Claro, suena bien. De todas maneras, tengo hambre.",
  "event-86060300.ReadyToRumble.87": "Perfecto, vamos a eso.$4",
  "event-86060300.ReadyToRumble.88": "Me alegra que tengamos la misma idea sobre cómo debería ser el almuerzo.",
  "event-86060300.ReadyToRumble.89": "¡Esto es exactamente lo que me apetecía!",
  "event-86060300.ReadyToRumble.90": "Así es como me gusta pasar el tiempo. ¡Vamos!",
  "event-86060300.ReadyToRumble.91": "Recorrido por el pueblo.",
  "event-86060300.ReadyToRumble.92": "¡Esto es lo que te estaba diciendo antes!",
  "event-86060300.ReadyToRumble.93": "¡Vamos a dar un paseo por el pueblo para ver las vistas!$1",
  "event-86060300.ReadyToRumble.94": "¡Esa es la idea! Me encantaría ver cómo están las cosas por aquí.",
  "event-86060300.ReadyToRumble.95": "Por supuesto, esto será increíble.",
  "event-86060300.ReadyToRumble.96": "Eso suena genial.",
  "event-86060300.ReadyToRumble.97": "¡Claro! Hay mucho que hacer en el pueblo. Aunque por lo general no soy el más grande de los paseadores de perros, es bueno disfrutar de la vista de vez en cuando.$4",
  "event-86060300.ReadyToRumble.98": "Sí, eso es cierto.",
  "event-86060300.ReadyToRumble.99": "Perfecto, ¡comencemos nuestro recorrido por el pueblo!",
  "event-86060300.ReadyToRumble.100": "Luego de nuestra vuelta al pueblo.",
  "event-86060300.ReadyToRumble.101": "¡Wow! ¡Ese fue un día lleno de sorpresas!#$b#Y un montón de exploración también.",
  "event-86060300.ReadyToRumble.102": "Estoy contento de que pudiéramos pasar tiempo juntos.",
  "event-86060300.ReadyToRumble.103": "Yo también lo estoy.",
  "event-86060300.ReadyToRumble.104": "¡Gracias por todo!",
  "event-86060300.ReadyToRumble.105": "No hay problema. Estoy seguro de que podremos repetirlo.",
  "event-86060300.ReadyToRumble.106": "¿Y ahora qué?",
  "event-86060300.ReadyToRumble.107": "¿Ahora qué?",
  "event-86060300.ReadyToRumble.108": "¿Tienes alguna idea de lo que haremos después?",
  "event-86060300.ReadyToRumble.109": "Lo que sea que quieras hacer después de esto está bien para mí.",
  "event-86060300.ReadyToRumble.110": "¡Estoy emocionado! Me gusta ir a donde me lleve el viento.",
  "event-86060300.ReadyToRumble.111": "Eso suena genial. Vamos a relajarnos un poco después de este largo día.",
  "event-86060300.ReadyToRumble.112": "Para terminar el día...",
  "event-86060300.ReadyToRumble.113": "Sí, también me parece bien.",
  "event-86060300.ReadyToRumble.114": "¡Hasta la próxima!",
  "event-86060300.ReadyToRumble.115": "¡Nos vemos luego!",
  "event-86060300.ReadyToRumble.116": "¡Hasta luego!",
  "event-86060300.ReadyToRumble.117": "Hoy me divertí. Si me pidieras que me mudara contigo una segunda vez, tal vez diría que sí.#$b#Independientemente de si creo que estás bromeando o no. Recuerda eso.$3",
  "event-86060300.ReadyToRumble.118": "Naturalmente, preferiría que me lo pidieras con algo... único. Algo único para mí, quiero decir.#$b#Estoy segura de que encontrarás algo si preguntas por el pueblo. Tienes mucha creatividad para esas cosas.$10#$b#Si he aprendido algo sobre el amor romántico, es que es importante gastar dinero en rituales y tradiciones elaboradas para demostrarle a las personas que hablas en serio.$1",
  "event-86060300.ReadyToRumble.119": "¡Dedica tiempo y dinero en mí!",
  "event-86060300.ReadyToRumble.120": "Será mejor que te vayas a dormir antes de que te gane el sueño en medio de mi ilusión muy elaborada.#$b#Sería un dolor tener que llamar a Raz para llevarte de regreso a tu granja. Se pone especialmente de mal humor después de las 11pm.$2",
  "event-86060300.ReadyToRumble.121": "...",
  "event-86060300.ReadyToRumble.122": "Yo también me divertí hoy.",
  "event-86060300.ReadyToRumble.123": "Nos vemos luego, travieso.",
  "event-86060300.ReadyToRumble.124": "(No decir nada, solo darle a Juna una mirada significativa que, realmente, debería poder interpretar ahora que han pasado todo el día juntos.)",
  "event-86060300.ReadyToRumble.125": "¿Me pregunto si a Gus le quedan panqueques?",
  "event-86060300.RumbleSuggestively.01": "Y estamos de vuelta.$1#$b#¿Alguna opinión? ¿Preguntas? ¿Cumplidos o quejas?",
  "event-86060300.RumbleSuggestively.02": "¿Sientes cansancio? Sí, supuse que podría ser el caso.$2#$b#Pero me alegra que hayas aguantado hasta el final.$10",
  "event-86060300.RumbleSuggestively.03": "Hoy me divertí. Si me pidieras que me mudara contigo una segunda vez, tal vez diría que sí.#$b#Independientemente de si creo que estás bromeando o no. Recuerda eso.$3",
  "event-86060300.RumbleSuggestively.04": "Naturalmente, preferiría que me lo pidieras con algo... único. Algo único para mí, quiero decir.#$b#Estoy segura de que encontrarás algo si preguntas por el pueblo. Tienes mucha creatividad para esas cosas para esas cosas.$10#$b#Si he aprendido algo sobre el amor romántico, es que es importante gastar dinero en rituales y tradiciones elaboradas para demostrarle a las personas que hablas en serio.$1",
  "event-86060300.RumbleSuggestively.05": "¡Dedica tiempo y dinero en mí!",
  "event-86060300.RumbleSuggestively.06": "Bien, última pregunta.",
  "event-86060300.RumbleSuggestively.07": "¿Sí o no?",
  "event-86060300.RumbleSuggestively.08": "Sí, eso es exactamente lo que estoy preguntando. Y no me molestará si prefieres ir a casa. Sé que esto no es particularmente sutil, pero...",
  "event-86060300.RumbleSuggestively.09": "... hay un tiempo y un lugar para la sutileza, y no creo que este sea uno de ellos.#$b#Pero si prefieres algo diferente, como un sofá quizás, posiblemente podría convencerme para acomodarte.$3",
  "event-86060300.RumbleSuggestively.10": "Di que sí y pasa más tiempo con Juna.",
  "event-86060300.RumbleSuggestively.11": "Di que no y ve a casa.",
  "event-86060300.RumbleSuggestively.12": "Encantador.$1",
  "event-86060300.RumbleSuggestively.13": "Juna te extiende su mano.",
  "event-86060300.RumbleSuggestively.14": "¿Te unes?",
  "event-86060300.RumbleSuggestively.15": "Tiene sentido.$10",
  "event-86060300.RumbleSuggestively.16": "Será mejor que te vayas a dormir antes de que te gane el sueño en medio de mi ilusión muy elaborada, entonces.#$b#Sería un dolor tener que llamar a Raz para llevarte de regreso a tu granja. Se pone especialmente gruñón después de las 11pm.$2",
  "event-86060300.RumbleSuggestively.17": "...",
  "event-86060300.RumbleSuggestively.18": "Yo también me divertí hoy.",
  "event-86060300.RumbleSuggestively.19": "Nos vemos luego, cariño.",
  "event-86060300.RumbleSuggestively.20": "(No decir nada, solo darle a Juna una mirada significativa que, realmente, debería poder interpretar ahora que han pasado todo el día juntos.)",
  "event-86060300.RumbleSuggestively.21": "¿Me pregunto si a Gus le quedan panqueques?",

  //Roommate intro - Parent fork (content not in wizard fork)

  "ct.couchsurfing.Juna4P": "Robin sigue tratando de que le prepare el desayuno, como si no dijera que no cada vez que le ofrezco uno de mis cafés experimentales.$2#$b#Estos son los inconvenientes de vivir con otras personas, supongo. Me pregunto cómo sería vivir con Theo.",
  "ct.couchsurfing.Wizard2P": "Supongo que es agradable recuperar mis domingos, ahora que Juna está durmiendo en los sofás de otras personas.#$b#...",
  "ct.couchsurfing.Emily2P": "Parece que Juna arregló lo que estaba mal con su cueva, así que pronto regresará allí. ¡Voy a extrañar a nuestra tercera compañera de cuarto!#$b#Espero que pronto podamos conocer a su hermano, porque parece ser un espíritu muy divertido.$h",

  //Roommate dialogue

  "roommate.spring_1": "¡Redoble de tambores, por favor! *Juna despeja un poco de espacio en la sala de estar y se coloca en posición, luego procede a hacer un glissade seguido de un grand jeté. Cuando sus pies tocan el suelo de nuevo, sus zapatos han desaparecido.*$7",
  "roommate.spring_3": "Prepárate para ver la casa llena de flores silvestres cuando llegues a casa esta noche, @ - Olive está en su momento más saltarín en primavera.#$b#A menos que... ¿no crees que me vería bien en ese vestido de flores de la película de terror que vimos anoche, la de solsticio de verano?$10",
  "roommate.spring_8": "Déjame saber si necesitas que... me ocupe de esa hada de la cosecha y sus \"bendiciones\".$3",
  "roommate.spring_11": "Pasaré el día en la playa en honor al cumpleaños de Theo. Oh, no te preocupes, él lo pasará en una tienda en medio de la nada rodeado de sus colegas, así que estaremos igual de incómodos.#$b#Estar un poco miserable aumenta las apuestas y hace que todo sea más divertido, ¿no lo crees?$1",
  "roommate.spring_13": "Bueno, buena suerte en la caza hoy. Yo estaré aquí evitando hacer eso.",
  "roommate.spring_23": "Espero que hayas estado practicando tus movimientos para mañana... pero si no lo has hecho, siéntete libre de pedir prestado a Olive. En este caso muy específico, él es un excelente compañero de baile.$10",
  "roommate.spring_24": "No te preocupes, tendré una respuesta para ti antes de que empiece el baile.#$b#Oh, ¿no te dije siquiera cuál era la pregunta? Eh, lo descubrirás pronto.$6",

  "roommate.summer_1": "No te preocupes, me aseguré de abastecerme de cubos de hielo.#$b#Tuve que deshacerme de algunos de tus pescados congelados para hacer espacio, pero eso es un regalo en sí mismo, realmente.[151]$1",
  "roommate.summer_3": "Paso la mayor parte del verano con Olive en la piscina. En parte por el calor, pero principalmente porque los junimos se ven divertidísimos en el agua. Son increíblemente flotantes.$10",
  "roommate.summer_4": "Aquí tienes - hoy me siento generosa.[402 396 404]#$b#¿Qué? ¿Cómo puedes saber que esto es lo que Olive me dio para mi cumpleaños?$2#$b#Oh, está bien. Te dije que son mediocres para regalar.$6",
  "roommate.summer_5": "Brava, @. He buscado en toda la casa, pero aún no he encontrado mi regalo de cumpleaños.$4#$b#Recuerda: ¡a las 17.00 en el Saloon esta noche!",
  "roommate.summer_8": "Perdón si huelo... estuve toda la noche trabajando en una forma de apagar el sol.$2",
  "roommate.summer_11": "Asegúrate de poner algo muy bueno o muy malo en la sopa hoy, @. Quiero robar el sombrero del Gobernador y necesito una distracción.$3",
  "roommate.summer_15": "Es verano... eso significa que la casa está llena de moscas.$2#$b#No te preocupes, me aseguraré de atraparlas y llevarlas a la casa de Raz más tarde hoy.$6",
  "roommate.summer_28": "Saluda a las medusas por mí esta noche. Y si ves una con una raya purpúrea en el cuerpo, dile que Olive lo siente.",

  "roommate.fall_1": "Bueno, al menos no es temporada de zapatos todavía. Y este suéter SÍ resalta el color de mis ojos.$10",
  "roommate.fall_3": "Pásate por el spa más tarde si quieres tomar un descanso y saltar en montones de hojas conmigo y Olive.#$b#Bueno, digo en - el tamaño de Olive significa que en su mayoría salta dentro del montón sin romper nunca la superficie. Pero me asegura que no está solo durmiendo allí.$11",
  "roommate.fall_8": "El invierno está a la vuelta de la esquina. Según la Revista Boring, necesitamos revisar el sistema de calefacción, cerrar las válvulas y revisar todo el aislamiento en la casa.$11#$e#No hay que preocuparse, tampoco sé o me importa qué válvulas están hablando.",
  "roommate.fall_15": "¿Ya has decidido qué vas a usar para tu exhibición en la feria mañana? Aún creo que deberías poner mi extraña colección de muñecas.[126]$10",
  "roommate.fall_16": "Tráeme algo de comida de la feria hoy, ¿quieres?$10#$b#Y dile al tipo de la atracción Smashing Stone que realmente necesita seguir adelante. ¡No fue culpa mía!$13",
  "roommate.fall_21": "¿Qué piensas de esta forma de juguete, crees que a Robin le gustará?#$b#Aw, te estás sonrojando. Excelente.$3",
  "roommate.fall_26": "¿Crees que podrías ayudarme a ponerme mi máscara mañana? Deberías estar honrado, ¿sabes? No dejo que cualquiera se acerque tanto a mi cara.$1",
  "roommate.fall_27": "Cada año tengo un solo deseo - que Robin venga a Spirit's Eve disfrazado de tomate.$4#$e#¿Tienes algún plan de disfraz? Oh, ¡ya sé! ¿Qué tal disfrazarte de una estatua dorada de Lewis?$1",

  "roommate.winter_1": "*Juna frunce los labios hacia ti. Inmediatamente sospechoso, miras alrededor de la habitación y ves que ha estado leyendo \"Snedronningen\" de nuevo. Dando un paso atrás, la señalas acusadoramente. Su mueca de beso se convierte en un verdadero puchero.*$3",
  "roommate.winter_3": "Si estás libre más tarde, Olive y yo estaremos haciendo una obra de teatro improvisada de un acto acompañada de música de ganancias enfermas y gruñidos en el vestuario del spa. ¡Entrada libre para todos!$6",
  "roommate.winter_7": "Si la situación estuviera invertida, ¿qué crees que usarían los peces como cebo para atrapar humanos? ¿Me gusta y elogios? ¿O tal vez solo un pedazo de pan?#$e#Quiero decir, el pan es delicioso...[216]$4",
  "roommate.winter_8": "Golpea a Raz con una bola de nieve por mí hoy, ¿quieres? Se lo merece por estar afuera de su torre sin participar realmente, anhelando la oportunidad de ser un chico de verdad.$11",
  "roommate.winter_16": "¿Qué? ¿Tengo que hacerlo?$2#$b#Está bien, iré al mercado de la playa estúpido contigo.",
  "roommate.winter_17": "Bueno, me voy a celebrar el cumpleaños de Razzamatazz. Este año lo haré ver una película animada sobre un grupo de productos de limpieza encantados aprendiendo el poder del amor.$10#$e#Alerta de spoiler: va a hacer que llore.$1",
  "roommate.winter_17P": "Bueno, me voy a celebrar el cumpleaños de Razzamatazz. Este año lo haré ver un programa especial después de la escuela sobre los peligros de no protegerse, ya sabes.$3#$e#Alerta de spoiler: va a ponerse muy incómodo.$1",
  "roommate.winter_25": "¡El día de los días ha llegado! ¿Todavía estamos listos para nuestro intercambio privado de regalos esta noche?$4",
  "roommate.winter_28": "Gracias por un gran año, @. Estoy emocionada por ver qué más podemos hacer en el nuevo año.[275 417 454]$1",

  "roommate.spring_juna": "¡No más zapatos! ¡Abajo con los zapatos! ¡No zapatos en mi jardín!$6",
  "roommate.summer_juna": "Por un lado, el verano es mi mes de cumpleaños y por lo tanto el mejor mes.$10#$b#Por otro lado, hace mucho, mucho calor.$2",
  "roommate.fall_juna": "¿Has visto mi broche en alguna parte? Sospecho que Olive lo ha escondido en un montón de hojas en algún lugar, ya sea para darme una lección o para vengarse de mí por contarle a Dog sobre los juguetes chirriantes.$2",
  "roommate.winter_juna": "%Juna está respirando lentamente el aire frío del invierno y no parece escucharte.",

  "roommate.patio1": "Ten cuidado con los bailarines de swing, @. Son los más agresivos de todos los bailarines.$7",
  "roommate.patio2": "Ten cuidado con los entusiastas del vals, @. Para ser un baile tan correcto, los hombres son de los peores en ocupar espacio con sus piernas.$7",
  "roommate.patio3": "Ten cuidado con los bailarines interpretativos, @. Cuanto peor son, más te hipnotizan con sus extraños movimientos.$7",
  "roommate.patio4": "Ten cuidado con los entusiastas del tango, @. Pensarías que su intensidad se trasladaría a la cama, pero rara vez lo hace.$2",
  "roommate.patio5": "Ten cuidado con los bailarines de línea, @. Simplemente... corre.$7",
  "roommate.patio6": "Ten cuidado con los bailarines de zumba, @. Y no lo digo solo por el sueño que tuve, aunque ciertamente no ayudó.$11",

  "roommate.room1": "Tuve un sueño en el que estaba sentada en una playa, viendo cómo una fila de bailarines de zumba alegres se acercaban cada vez más. No dejaban de sonreír, @. *se estremece* Fue horrible.$2",
  "roommate.room2": "Estuviste en mi sueño anoche, oh noble de los dorks.$10#$b#¿Estás seguro de que quieres saber de qué se trataba?$3",
  "roommate.room3": "%Juna está mirando fijamente, con los ojos vidriosos, frente a ella. Cuando le preguntas qué le pasa, murmura algo sobre un sueño que involucraba pulpos y bailar hasta que sus pies sangraran.",
  "roommate.room4": "Tuve un sueño fantástico anoche, @. Fue tan bueno que incluso no me molestaría un abrazo ahora mismo.$4",
  "roommate.room5": "¡Oh! ¿Me estás diciendo que en realidad a la gente no le gusta escuchar a otros describir sus sueños? ¡Oh, no! Lo siento mucho, @.$2",
  "roommate.room6": "%Juna divaga sobre un sueño que tuvo la otra noche. Después de un rato, notas que el sueño suena mucho como una descripción de lo que tú y Juna estaban haciendo ayer. Cuando se lo haces notar, lo niega vehementemente. Tienen un duelo de miradas que dura minutos, luego Juna sonríe y te guiña un ojo. Le lanzas una papa.",

  "roommate.indoor_day.0": "Hoy estaré experimentando con comida o probando algo nuevo. Te avisaré si necesitas volver a casa y apagar algún incendio.$1",
  "roommate.indoor_day.1": "Hoy estaré experimentando con comida o probando algo nuevo. Si tienes suerte, tal vez sea una terapeuta de masajes registrada cuando regreses esta noche.$1",
  "roommate.indoor_day.2": "Hoy estaré experimentando con comida o probando algo nuevo. Los blogs de mamás dicen que es importante mejorar.$1",
  "roommate.indoor_day.3": "Hoy estaré experimentando con comida o probando algo nuevo. Si quisiera ayudar a alguien a embarcarse en un viaje espiritual, ¿quién en Pelican Town crees que estaría abierto a eso?$10",
  "roommate.indoor_day.4": "Hoy estaré experimentando con comida o probando algo nuevo. ¿Qué opinas sobre un tejón empanizado?",
  "roommate.indoor_day.5": "Hoy estaré experimentando con comida o probando algo nuevo. ¿Crees que podría lucir un sombrero piramidal?$10",

  "roommate.indoor_night.0": "En el profundo buceo de hoy en alimentos del pasado: principios del siglo XVIII en REDACTED. Lo que significa: sopa de emergencia!$10#$b#Quiero decir, sí, es exactamente tan desalentador como suena. Básicamente hacías una sopa con lo que tenías a mano. Así que aquí: toma una cucharada de nabo, hierba y pedazos de un cinturón de cuero.$2",
  "roommate.indoor_night.1": "En el profundo buceo de hoy en alimentos del pasado: finales del siglo XIX en REDACTED. Lo que significa: gachas complementadas con cerveza, histeria y montones y montones de punsch.$10#$b#Estoy bastante borracha.$1",
  "roommate.indoor_night.2": "En el profundo buceo de hoy en alimentos del pasado: siglo XVII en REDACTED. Lo que significa: una cabeza de gallo para la cena y lavar tus dientes con un palo y una taza de vinagre.$10#$b#Puedo ver cómo haces muecas por mi aliento, ¿sabes? ¡No es mi culpa, era todo lo que tenían en ese entonces!$5",
  "roommate.indoor_night.3": "He estado saltando recolectando agua de varias personas santas todo el día, para poder ver qué contienen y tener algo nuevo que ofrecer a mis seguidores.#$b#Noté una diferencia en el sabor de inmediato, pero luego me di cuenta de que la dulzura agregada probablemente provino de algo que se había echado a perder en la botella que estaba usando para recolectar el agua.$2",
  "roommate.indoor_night.4": "¡Maravillosas noticias, @! ¡Ahora soy una sanadora registrada! Acuéstate y déjame darte un impulso de salud.$10#$b#¿Qué? No, por supuesto que no voy a tocarte realmente, eso no es como funciona. Solo quédate quieto y déjame mover mis manos sobre ti.",
  "roommate.indoor_night.5": "Me gustaría mucho que simplemente... no hablemos de lo que hice hoy. Digamos que hay \"curas de salud\" por ahí que NO valen la pena, @.$13",

  "roommate.outdoor.0": "Entonces... %farm. ¿Cuál es la historia detrás de ese nombre?[395]",
  "roommate.outdoor.1": "Aunque no requiero ni espero silencio, sería bueno simplemente sentarse aquí un rato esta mañana, ¿no?[395]",
  "roommate.outdoor.2": "Acabo de ver a %pet enterrar algo debajo de ese árbol de allá.#$b#Totalmente no relacionado: ¿has visto tus llaves esta mañana?[395]$10",
  "roommate.outdoor.3": "Allí, ¿lo ves? No, ¡no eso! ¡ESO! ¿Es quien creo que es?$11#$b#Entonces... ¿has vuelto, eh? ¡Te veo! Con tus pequeños ojos de ardilla, solo merodeando alrededor de ese gran árbol.$5#$b#No bajo mi vigilancia. Aquí, sostiene esto.[395]$5",
  "roommate.outdoor.4": "¿Sientes que eres dueño de esta tierra? ¿La hierba, las flores, los árboles, las abejas?#$b#¿No? Bien. Entonces lo entiendes.[395]$10",

  "roommate.good.0": "Antes de conocerte, no sabía que me gustaba sentarme a cenar con alguien.#$b#Siempre he comido de pie, o mientras me movía, o mientras vigilaba el jardín de maleza de la tía de Olive para asegurarme de que ese tejón no volviera a entrar.#$b#Así que gracias por eso. ¡Me gustas y te aprecio!$1",
  "roommate.good.1": "Antes de conocerte, no sabía lo que era tener a alguien a quien decirle buenas noches. Es agradable, ¿no?#$b#Y recuerda: ¡Me gustas y te aprecio!$4",
  "roommate.good.2": "Antes de conocerte, no pensaba que alguna vez querría que alguien supiera dónde estaba o adónde iba durante el día.#$b#Esto es algo... difícil para mí, algo en lo que todavía tengo que trabajar.$11#$b#Pero tú lo haces más fácil.#$b#Por eso me gustas y te aprecio.$10",
  "roommate.good.3": "Antes de conocerte, no sabía lo que era tener a alguien que me apreciara desde el principio. Supongo que soy alguien a quien hay que acostumbrarse.#$b#Es un cambio agradable aunque un poco desconcertante. Y por eso sigo gustándote y apreciándote.[221]$1",
  "roommate.good.4": "Antes de conocerte, nunca había tenido a alguien que me leyera un libro.#$b#A los junimos no les interesa leer, y Raz siempre tuvo demasiado miedo de que notara su predilección por las novelas románticas como para ofrecerlo.$11#$b#Otra razón más por la que me gustas y te aprecio.$1",
  "roommate.good.5": "Antes de que me conocieras, apuesto a que no sabías lo genial que puede ser la comida cuando dejas de limitarte a lo que se considera \"comestible\" o \"socialmente apropiado\" por la sociedad.$10#$b#¿No hace que me gustes y me aprecies aún más?$4",
  "roommate.good.6": "Dame esos pensamientos malvados, @. No quiero los bonitos. No son los que hacen que me gustes y te aprecie.$3",
  "roommate.good.7": "He descubierto que en realidad es bastante raro conocer a alguien que realmente te guste. Estoy convencida de que muchas personas se dicen a sí mismas que es suficiente con solo amar a alguien.#$b#Pero cuando lo haces, muchas cosas que de otra manera serían agotadoras se vuelven estimulantes.$10#$b#El amor romántico nunca ha sido así para mí. Siempre ha sido agotador.$11#$b#Gracias por darme energía, @.$10",
  "roommate.good.8": "Sabes que puedes confiar en mí, ¿verdad? Esto no es una broma ni nada, lo juro.#$b#Si alguna vez creo que necesitas apoyo - y me refiero a realmente necesitarlo - prometo que vendré. Solo espera. Estoy en camino.",
  "roommate.good.9": "%Juna te sonríe y te ofrece el último panqueque.[211]",

  "roommate.neutral.0": "Espero que me sigas adorando cuando seas viejo y canoso y yo siga siendo joven y vivaz.$s",
  "roommate.neutral.1": "¿Crees que tu abuelo estaría orgulloso de lo que hemos hecho para hacer la vida de Raz un poco más insoportable?#$e#Estoy segura de que se conocían, y conocer a Raz es irritarlo, así que...$11",
  "roommate.neutral.2": "¿Tomando un descanso? Supongo que ser granjero es más fácil de lo que pensaba...$3",
  "roommate.neutral.3": "Si vas al pueblo, asegúrate de saludar a todos por mí. Especialmente a Lewis. ¡Díselo directamente en la cara!$1#$e#%Cuando expresas tu confusión, Juna te hace un gesto y murmura algo sobre un plan.",
  "roommate.neutral.4": "Haré la lavandería mañana por la mañana antes de que te levantes... así no tendrás tiempo de inactividad.#$b#¿Qué quieres decir con que no confías en mis hechizos de limpieza?$5#$b#Oh, porque dije que hacen que tu piel sea áspera y suave al mismo tiempo. Hmm, ¿por qué habría admitido eso contigo?$2",
  "roommate.neutral.5": "¿Estamos bien de dinero, @? ¿O necesito empezar a alquilar mi cueva otra vez?",
  "roommate.neutral.6": "Me pregunto qué estarán haciendo todos en el pueblo hoy?#$b#Solo pregunto porque no tengo idea de qué día es hoy, eso es todo. Quiero decir, si TÚ sabes el día, es prácticamente imposible no saber lo que todos están haciendo en todo momento en este pueblo.$10",
  "roommate.neutral.7": "Hoy no tengo muchas ganas de hacer nada. Lo que significa que es hora de asumirlo y hacer todas esas cosas aburridas que normalmente no hago, como meditar.",
  "roommate.neutral.8": "No importa cuántas veces piense en limpiar, la casa sigue ensuciándose más y más.#$e#Supongo que las granjas pueden ser bastante sucias.",
  "roommate.neutral.9": "Me pregunto si vivirás aquí toda tu vida.",

  "roommate.bad.0": "%Juna te ignora toda la mañana. Más tarde ese día, encuentras un pez muerto en tu cama. Al menos estaba fresco?",
  "roommate.bad.1": "No aprecio tener que recurrir al vandalismo mezquino para sacar mis frustraciones. El vandalismo debería surgir de la alegría, no del descontento.$11#$b#Hazlo bien, @. ¿Qué quieres?$12",
  "roommate.bad.2": "¿A qué entidad del Miedo crees que perteneces? Solía pensar que no había nada peor que ser observada todo el tiempo por ese gran Ojo omnisciente, pero ahora no estoy tan segura.$12#$b#Tal vez siempre he pertenecido a La Soledad, y simplemente no lo entendí hasta ahora...$12",
  "roommate.bad.3": "¿Café? *Juna te sonríe dulcemente.*#$b#%Sabes que sería mejor no beberlo.",
  "roommate.bad.4": "Sabes que puedo simplemente... regresar, ¿verdad? Que solo estoy aquí porque trabajaste para conocerme y parecías querer que estuviera aquí.$12#$b#La bondad no es una meta por alcanzar, no es estática. Podrías haber sido amable cuando nos conocimos, pero ahora?$13",
  "roommate.bad.5": "%Juna choca contra ti a mitad de giro. No intenta atraparte cuando caes.",
  "roommate.bad.6": "%Juna habla desde detrás de ti, haciéndote saltar.#$b#¿Sabes cómo te dije que resistieras, porque siempre vendría por ti?$12#$b#Bueno, ya puedes soltar.$11",
  "roommate.bad.7": "¿Infantil?! ¿Crees que estoy siendo infantil?$13#$b#\"Nos saltamos como las cosas más desalmadas del mundo, que es lo que son los niños.\" Entonces prepárate para un mundo de infantilismo viniendo hacia ti, @.$13",
  "roommate.bad.8": "Creo que has arruinado mi apetito por los dramas domésticos dolorosamente incómodos. Bravo, @. No sabía que tenías eso en ti.$13#$b#Ni que yo lo tenía, para ser honesto.$12",
  "roommate.bad.9": "%Cada vez que entras en la habitación en la que está, Juna comienza a lanzarte guisantes. Uno. Después. Otro.",

  "roommate.one.kid_0": "Le hice a %kid1 una cola que puede perseguir cuando se aburre. ¡Es adorable!$4#$b#Me preguntaron si podía hacerla permanente, pero estoy seguro de que eso es solo una fase.",
  "roommate.one.kid_1": "Mi cosa favorita de %kid1 es cómo siempre va en la dirección opuesta a la que tú vas.$1#$b#¡Por supuesto que es algo positivo! Todos los blogs de mamás dicen que debes seguir tu propio camino.",
  "roommate.one.kid_2": "¿Cuánto tiempo crees que pasará hasta que %kid1 pueda levantar cosas más pesadas que esa manta raída que tanto le gusta?#$b#Oh, no es por nada...$3",
  "roommate.one.kid_3": "¡Estoy tres de tres con estos destellos de magia, @! Les encantan al gato, al perro Y a %kid1.#$e#¿No estás contento de que me pidieras que me mudara contigo?$1",
  "roommate.two.kid_0": "¡He fallado, @! Anoche %kid1 se arrastró junto a %kid2 en el sofá y dijo, \"¡Hola %kid2, es tan agradable verte!\"$2#$b#¿Qué tipo de rareza educada es esa?$2",
  "roommate.two.kid_1": "¿Hm? Oh, dudo que %kid1 y %kid2 estén diciendo palabras reales cuando te señalan y susurran sobre ti - hasta ahora solo les he enseñado estrategias de bajo esfuerzo para molestar a la gente.$6",
  "roommate.two.kid_2": "Estaba pensando en llevar a %kid1 y %kid2 conmigo cuando vaya a visitar el bosque hoy. Olive aparentemente los extraña.#$e#Seguido, naturalmente, de una rápida parada en la torre para que puedan treparse a Raz un rato.$3",
  "roommate.two.kid_3": "Robin prometió acompañarme la próxima vez que necesites una niñera.#$b#Tenemos una apuesta sobre cuál interés les atraerá más rápido - carpintería o baile.#$e#No te preocupes, le dije que llevar una sierra es hacer trampa.$5",
  
  "roommate.rainy_day.0": "Hoy solo voy a hacer absolutamente nada más que ver películas - entre tres y diez películas de terror adolescentes deberían bastar.$10#$b#O, espera, ¿quizás zombies? ¿O zombies Y adolescentes? Ah, decisiones, decisiones.",
  "roommate.rainy_day.1": "¿Has visto el control remoto en alguna parte? Más tarde van a mostrar una selección de películas en blanco y negro con gente bonita, pero la TV está pegada al canal de deportes.$11",
  "roommate.rainy_day.2": "He estado despierta desde poco después de medianoche leyendo una biografía de una jinete femenina. Creo que puedo estar desarrollando una pequeña fijación.$10#$b#Normalmente me parecen indiferentes los caballos, pero por ella estaría dispuesta a darles una oportunidad.$1",
  "roommate.rainy_day.3": "¿Has leído el último Campbell? *Juna agita un libro con una cubierta negra brillante en el aire*#$b#Voy a quedarme dentro hoy y ver cuántas de mis sugerencias tomó en cuenta.#$b#¡Más le vale haber hecho algo con el supuesto atractivo sexual del mago y el magnetismo animal! ¡Haz tu investigación, chico saltarín! ¡Realmente! ¡¿Magnetismo animal?!$5",
  "roommate.rainy_day.4": "Hoy voy a quedarme dentro y buscar nuevas recetas para probar.#$b#Sí, sí, prometo no añadir sustancias ilegales al pastel esta vez.$6",
  "roommate.rainy_day.5": "Mira esta receta - es un ave rellena con otras aves más pequeñas. ¿No es brillante?$1#$b#Supongo que eso es lo que voy a hacer hoy.$10",
  
  "roommate.rainy_night.0": "%Juna acaricia el cojín a su lado y va a tomar un libro de la pila en su mesa de noche. Ella continúa desde donde dejaste de leer la última vez que leyeron juntos.#$b#\"Cuando despiertes en la mañana, la maldad y las pasiones de las que te acostaste habrán sido dobladas pequeñas y colocadas en el fondo de tu mente y en la parte superior, hermosamente aireadas, están extendidos tus pensamientos más bonitos, listos para que los pongas en...\"",
  "roommate.rainy_night.1": "Me gustan las noches como estas. Me gusta la lluvia, y los árboles que se mecen, y los sonidos, y la oscuridad.",
  "roommate.rainy_night.2": "%Juna acaricia el cojín a su lado y va a tomar un libro de la pila en su mesa de noche. Ella continúa desde donde dejaste de leer la última vez que leyeron juntos.#$b#\"Si pensaba en absoluto, pero no creo que alguna vez pensara, era que él y su sombra, cuando se acercaban, se unirían como gotas de agua...\"",
  "roommate.rainy_night.3": "A veces, en noches como estas, me sentaba en mi cueva y me sentía sola y no sola al mismo tiempo.$11#$b#Me gusta pensar que es porque tenía mi sombra conmigo, incluso en la oscuridad.#$b#Hm, eso fue bastante gótico. Debería escribirlo y pasárselo a Campbell.$11",
  "roommate.rainy_night.4": "%Juna acaricia el cojín a su lado y va a tomar un libro de la pila en su mesa de noche. Ella continúa desde donde dejaste de leer la última vez que leyeron juntos.#$b#\"Ella ya era adulta ahora, pero no debes sentirte mal por ella. Era de las que les gusta crecer. Al final creció de su propia voluntad un día más rápido que otras niñas.\"",
  "roommate.rainy_night.5": "¿Crees que puedes simplemente... decidir crecer? ¿Es eso algo que puedes hacer?$11",
  
  "roommate.storm_day.0": "¡Mis pies están picando, @! Si me necesitas, estaré bailando en la tormenta - ¡ja! ¿lo entiendes? - en el bosque.$7",
  "roommate.storm_day.1": "¡Mis oídos están picando, @! Es muy molesto, ya he perdido tres hisopos en el oído. Voy a ir al bosque para distraerme.$2",
  "roommate.storm_day.2": "¡Mis manos están picando, @! Es hora de ir al bosque y agitar mis manos como si no me importara.$6",
  "roommate.storm_day.3": "¡Mis ojos están picando, @! He pasado demasiado tiempo construyendo redes en línea - voy a pasar un tiempo en el bosque hoy, creo.$10",
  "roommate.storm_day.4": "¡Mis pantorrillas están picando, @! Voy a bailar y pretender hacer yoga en el bosque más tarde; para que la sangre fluya.$7",
  "roommate.storm_day.5": "¡Todo mi cuerpo está picando, @! No, por supuesto que no es sarna. ¡Boo, hiss!$5#$b#¡Simplemente significa que he pasado demasiado tiempo en interiores últimamente. Necesito estar libre, @!$2#$b#¿Bailar en el bosque, dices? ¡Qué excelente idea! ¡Es casi como si me conocieras y/o estuvieras acostumbrado a verme hacer eso cuando hay una tormenta afuera!$1",
  
  "roommate.storm_night.0": "¿Quieres un abrazo? (Aceptas. Te mojas mucho.)$1",
  "roommate.storm_night.1": "¿Quieres un abrazo? (Rechazas. Juna te persigue por las calles hasta que amenazas con correr hasta la playa.)$3",
  "roommate.storm_night.2": "¿Quieres un abrazo? (Aceptas. Ella huele a césped, barro y champú.)$10",
  "roommate.storm_night.3": "¿Quieres un abrazo? (Rechazas. Juna hace un puchero y te lanza agua.)$2",
  "roommate.storm_night.4": "¿Quieres un abrazo? (Aceptas. En lugar de abrazarte, Juna comienza a girarte alrededor y alrededor. Pronto ambos están mareados y empapados por la lluvia.)$7",
  "roommate.storm_night.5": "¿Quieres un abrazo? (Rechazas. Juna se encoge de hombros y escurre su camisa sobre tus zapatos. Tú le das un toque en la frente.)",
  
  "roommate.funleave.mon1": "Creo que esta noche me quedaré en mi cueva. Sé que no me juzgarías por comer dos cenas, pero a veces es agradable no ser observado, ¿sabes?",
  "roommate.funleave.mon2": "Creo que esta noche me quedaré en mi cueva. Aw, no te pongas triste. Sabes que te extrañaré.#$b#Prometo que volveré antes de la mañana.#$e#Ah, no sé, creo que mis consejos sobre cómo criar niños son demasiado locos para ti.#$3",
  "roommate.funleave.mon3": "Creo que esta noche me quedaré en mi cueva. Hay una ardilla malvada que ha estado acechando. Creo que me ha encontrado antes y me hace la vida difícil cada vez que estoy afuera.#$e#Quizás si me quedo aquí no me molestará mientras intento descubrir cómo hacer un sombrero de lana a prueba de ardillas.",
  "roommate.funleave.mon4": "Creo que esta noche me quedaré en mi cueva. Robin y yo acabamos de tener una charla sobre las relaciones románticas de los niños. Tal vez no sean adecuadas para nuestra audiencia.#$e#No te preocupes, me aseguré de mantener todo en términos de abrazos y besos de buenos amigos.",
  "roommate.funleave.mon5": "Creo que esta noche me quedaré en mi cueva. ¡No puedo esperar para probar el brandy raro de Demetrius! ¡Oh, no, eso suena como si estuviera hablando de algo ilegal!#~$b#Oh, está bien, solo me estaré quedando en mi cueva hasta que esté listo para la fiesta.",
  "roommate.funleave.mon6": "Creo que esta noche me quedaré en mi cueva. Dog sigue obsesionado con ese maldito juguete chirriante. ¿Quién podría molestarse en salir mientras esa cosa sigue haciendo ese ruido horrible?$3",
  
  "roommate.funleave.wed1": "Estoy corriendo una campaña de Solarion como GM esta noche. Tengo un par de encuentros de jefes que estoy preparando. Si conoces alguna idea para criaturas verdaderamente extrañas, ¡avísame!$2",
  "roommate.funleave.wed2": "Estoy observando a la gente en el pueblo para recopilar información sobre el Dr. Harvey.$6",
  "roommate.funleave.wed3": "Estoy observando a la gente en el pueblo para investigar sobre la jubilación de Evelyn. ¿Debería considerar una carrera en la administración pública?$4",
  "roommate.funleave.wed4": "Estoy observando a la gente en el pueblo para averiguar sobre la experiencia de Pam como conductora de autobús. Todo lo que puedo decir es que debe ser un viaje interesante.$7",
  "roommate.funleave.wed5": "Estoy observando a la gente en el pueblo para saber más sobre Pierre y su tienda. ¿Cómo va con el equilibrio entre la vida y el trabajo?$3",
  "roommate.funleave.wed6": "Estoy observando a la gente en el pueblo para ver cómo pasa Jodi sus días como madre ama de casa. Debe tener algunas historias buenas.#$b#¡Además, es una buena manera de buscar inspiración para nuestras propias historias!",
  
  "roommate.funreturn.wed1": "Cuando vuelvas, he incluido un nuevo ejercicio en nuestra rutina, como prometí después de ver a Alex.",
  "roommate.funreturn.wed2": "Volví con un filete para ti de una cena con Alex.#$b#¡Espero que lo disfrutes!",
  "roommate.funreturn.wed3": "Tal vez, solo tal vez, convencí a Evelyn de tomar un curso de marketing para coordinadores de redes sociales.$3#$b#¡No, booo, definitivamente no solo me estaba siguiendo la corriente! ¡Lalala, no te escucho!$2",
  "roommate.funreturn.wed4": "¡Reporte de la paloma! Se sube al autobús alrededor del mediodía todos los miércoles y viaja de Pelican Town a Zuzu City.$10#$b#(Pam sospecha que podría estar teniendo una aventura. Estoy de acuerdo.)$10",
  "roommate.funreturn.wed5": "Bueno, Pierre no fue de mucha ayuda respondiendo mis preguntas.$13#$b#Pero supongo que era de esperarse. Y todos ya saben que lo único que Caroline quiere hacer es sentarse en su invernadero a colocarse... bebiendo té.$10",
  "roommate.funreturn.wed6": "Ver a Jodi me hizo darme cuenta de algo: ¿soy la madre ama de casa de la granja %farm?$11#$b#No, tienes razón, definitivamente soy más como la ex-en-el-ático.$10",
  
  "roommate.funleave.fri1": "Voy a quedarme en mi cueva para las semifinales de pétanque. ¡No olvides eso!$2",
  "roommate.funleave.fri2": "Voy a quedarme en mi cueva mientras espero una pieza especial de la señora del vagón.$5",
  "roommate.funleave.fri3": "Voy a quedarme en mi cueva después de visitar a Sandy por unos dulces.#$b#¿Has visto a Raz últimamente? Está sospechando de las huellas de pies grandes.$6",
  "roommate.funleave.fri4": "Voy a quedarme en mi cueva mientras trabajo en una actuación de ballet para el Ratón Sombrero.$7",
  "roommate.funleave.fri5": "Voy a quedarme en mi cueva buscando a la otra mitad del malvado ardilla.$2",
  "roommate.funleave.fri6": "Voy a quedarme en mi cueva, revisando el hechizo de Raz que me estropeó la semana pasada.",
  
  "roommate.funleave.sun1": "Voy a ver al solitario púrpura para intentar convencerlo de que venga a cenar.$6",
  "roommate.funleave.sun2": "Voy a visitar al solitario púrpura para ver algunas fotos antiguas de bebé.$5",
  "roommate.funleave.sun3": "Espero que el solitario púrpura se haya recuperado de su hechizo. No quiero que se comporte como un tío torpe.$3",
  "roommate.funleave.sun4": "Voy a investigar la piedra filosofal para ver cómo destruirla.$7",
  "roommate.funleave.sun5": "Estoy buscando un caldero de plata antes de ir a la torre.$3",
  "roommate.funleave.sun6": "Estoy feliz de desmenuzar el antiguo trabajo de hechizos de Raz durante el almuerzo.$5",
  
  "roommate.funreturn.sun1": "Nah, dijo que no. Otra vez.$13#$b#Tal vez tenga que hacer una apuesta con él de nuevo...$11",
  "roommate.funreturn.sun2": "%Juna se está riendo demasiado como para responderte. En su mano derecha, sostiene lo que parece ser una fotografía en blanco y negro de un niño pequeño con sombrero de copa.",
  "roommate.funreturn.sun3": "Creo que Raz estaba a punto de intentar darme consejos otra vez, así que cada vez que abría la boca, simplemente salía corriendo de la habitación.",
  "roommate.funreturn.sun4": "Sin suerte. Todavía.#$b#De todos modos, la investigación sobre la inmortalidad me da hambre. ¿Qué cenaremos?$10",
  "roommate.funreturn.sun5": "Resulta que uno de los cuervos de Alecto había robado mi caldero. *Juna se encoge de hombros.* Kevin puede quedarse con él.#$b#Si Raz insiste en que no \"explote la torre\" porque el cobre y la plata reaccionan de manera diferente a la magia, ¡puede comprarme uno nuevo!$6",
  "roommate.funreturn.sun6": "¡Estoy maravillada, gracias! Encontré algunos de los viejos trabajos de hechizos de Raz esta mañana y me lo pasé genial desmenuzándolos durante el almuerzo.$4",

  "roommate.funleave.sun1.P": "Bueno, me voy a ver al pomposo púrpura hoy.#$b#Estoy en una misión para encontrar fotos de su familia - si es que tuvo una, y no solo nació de un pantano.$11#$b#Espera un momento... ¿cuándo se inventó la cámara otra vez?$2",
  "roommate.funleave.sun2.P": "Bueno, me voy a ver al pomposo púrpura hoy.#$b#Solo espero que se haya recuperado de su raro hechizo de la semana pasada. No creo que pueda soportar otra tarde de él intentando darme consejos financieros.$13",
  "roommate.funleave.sun3.P": "Bueno, me voy a ver al pomposo púrpura hoy.#$b#La semana pasada llené todos sus armarios con piñas. Veamos cómo le gusta ese regalo.$13",
  "roommate.funleave.sun4.P": "Hoy es el día, @. Hora de averiguar cómo crear la piedra filosofal.$1#$b#Y luego destruirla inmediatamente, por supuesto. ¿Quién en su sano juicio querría vivir para siempre?$3",
  "roommate.funleave.sun5.P": "¿Has visto mi caldero de plata por algún lado? Estoy a punto de dirigirme a la torre.#$b#Raz se pone quisquilloso cuando trato de colar un caldero de cobre con un acabado plateado.$13",
  "roommate.funleave.sun6.P": "%Juna está escribiendo frenéticamente en un gran libro encuadernado en cuero y no parece notar tu presencia.",

  "roommate.funreturn.sun1.P": "Eh, la teoría del pantano parece cada vez más probable.$11",
  "roommate.funreturn.sun2.P": "Creo que Raz estaba a punto de intentar darme consejos otra vez, así que cada vez que abría la boca, simplemente salía corriendo de la habitación gritando.",
  "roommate.funreturn.sun3.P": "Fingió no saber de qué estaba hablando cuando le pregunté sobre mi regalo, así que dejé unos cuantos más en su cama.$3",
  "roommate.funreturn.sun4.P": "Sin suerte. Todavía.#$b#De todos modos, la investigación sobre la inmortalidad me da hambre. ¿Qué cenaremos?$10",
  "roommate.funreturn.sun5.P": "Resulta que uno de los cuervos de Alecto había robado mi caldero. *Juna se encoge de hombros.* Kevin puede quedarse con él.#$b#Si Raz insiste en que no \"explote la torre\" porque el cobre y la plata reaccionan de manera diferente a la magia, ¡puede comprarme uno nuevo!$6",
  "roommate.funreturn.sun6.P": "¡Estoy maravillada, gracias! Encontré algunos de los viejos trabajos de hechizos de Raz esta mañana y me lo pasé genial desmenuzándolos durante el almuerzo.$4",

  "roommate.funleave.wed.alex1": "Tengo este nuevo ejercicio que estoy deseando que Alex pruebe hoy. Rara vez dice palabrotas, pero si lo presionas lo suficiente explota como un globo. Después de eso, solo hay puro caos.$1",
  "roommate.funleave.wed.alex2": "Aparentemente, acaban de lanzar una secuela de *La Cena*, esa película hilarante que Alex y yo vimos hace tiempo. ¡No puedo esperar para obligarlo a verla!$10",

  "roommate.funreturn.wed.alex1": "¡Mira, @! Mis pantorrillas todavía están temblando. Definitivamente incluiré ese ejercicio en mi rutina regular con Alex a partir de ahora.$10",
  "roommate.funreturn.wed.alex2": "Recuento final de esta noche: cuatro piñas coladas para mí, tres filetes para Alex. Ese hombre-niño ciertamente sabe comer.$10#$b#Aquí, traje uno de regreso para ti.[873]",

  "roommate.funleave.fri.george": "Hoy son las semifinales del campeonato de petanca.#$b#George más le vale tener cuidado, he estado en llamas toda la semana.$3#$b#Ah, y no olvides que me quedaré en mi cueva esta noche!$1",

  "roommate.spring.town": "¿Panqueques esta noche?$1",
  "roommate.summer.town": "¿Espagueti esta noche? Podemos tomar fotos y enviárselas a Robin para tentarla.$1",
  "roommate.fall.town": "¿Papas hash esta noche?$1#$b#¡Pero nada de ñame!$5",
  "roommate.winter.town": "¡Quiero chocolate caliente esta noche! Con mucha crema batida.$1",

  "roommate.spring.forest": "¿Quieres uno? Son deliciosos.[638]$1",
  "roommate.summer.forest": "¿Quieres uno? No es realmente lo mío.[91]$2",
  "roommate.fall.forest": "¿Quieres uno? Lo robé de Lewis.[613]$1",
  "roommate.winter.forest": "Recogí algo de fruta hace poco, pero se la di toda a Leah. Me gusta verla emocionarse con ellas, está obsesionada.$1",

  "roommate.spring.mountain": "Hay un pequeño pez gordo en el lago de montaña que sigue mirándome con mala cara. ¡Por eso los peces son horribles!$5",
  "roommate.summer.mountain": "Hay una pequeña ardilla en ese árbol que sigue mirándome con mala cara. Siento que la he visto antes...$11",
  "roommate.fall.mountain": "¡El pez gordo de aspecto malvado del lago de montaña ha vuelto! Mira, ¡me salpicó!$5",
  "roommate.winter.mountain": "No es realmente mi culpa que la pequeña ardilla fuera demasiado lenta para llegar a la avellana enterrada antes que yo.$11#$b#No, ¡no voy a ceder ante él! ¡Sabe lo que hizo!$13",

  "roommate.spring.beach": "Puaj, arena.$13",
  "roommate.summer.beach": "Blergh, agua.$2",
  "roommate.fall.beach": "Puaj, peces.$13",
  "roommate.winter.beach": "Blergh, barcos.$2",

  //Roommate strings

  "string.marriage_Mon.000": "Me pregunto cómo eran los bailes de hace 9,000 años.#$b#*Juna pone los ojos en blanco y sonríe.* Si yo tuviera ESA edad, te lo diría.$10#$b#Porque entonces sería increíblemente poderosa.$3",
  "string.marriage_Mon.001": "Estoy trabajando en una nueva rutina en este momento. Es una interpretación visual de cuando Raz accidentalmente se aspiró arándanos por la nariz.$7#$b#Te lo mostraré más tarde esta noche.$1",
  "string.marriage_Mon.002": "Eh, claro, ocasionalmente bailo con otras personas, pero no es una prioridad. Y definitivamente prefiero lanzar a otras personas en lugar de ser lanzada yo misma.$7#$b#Guiño guiño. *Juna dice esta última parte en voz alta mientras mantiene contacto visual y continúa su práctica.*$7",
  "string.marriage_Mon.003": "¿Por qué no? No veo el sentido en ser sutil. Siempre y cuando hayas evaluado su interés primero, realmente no veo el problema.#$b#Además, no me ha fallado aún.$6",
  "string.marriage_Mon.004": "¿Quieres jugar al Uno? Encontré una baraja en el salón el otro día.$10",
  "string.marriage_Mon.005": "Entonces, ¿cuál de mis personajes de campaña crees que debería presentar primero: la reina neutral, el depredador ápice o la sirena del bosque?#$b#Recuerda, todos son de nivel jefe y todos están destinados a traumatizar a mis jugadores de diferentes maneras.$3",
  "string.marriage_Mon.006": "Bien jugado, Robin. Si digo que me recuerdas a la madera, sería predecible, y sabes que odio ser predecible.$3#$b#¿Tal vez musgo? No me pongas esa cara - ¡no me diste otra opción!$2",
  
  "string.marriage_cave": "¡Estoy durmiendo! Zzzz Zzzz Zzzz.$13",
  
  "string.marriage_Wed.000": "¿Sabías que a Lewis le encanta la leche de cabra mezclada con leche de vaca y un poco de rábano salvaje? Me lo dijo.$1",
  "string.marriage_Wed.001": "Si quieres que a Elliott le gustes, dale pizza con tapas de magma. Realmente podrías hacerlo feliz con eso.",
  "string.marriage_Wed.002": "Si quieres hacer amigos con el Gobernador, no puedes fallar con, bueno, cualquier cosa.#$b#Oh, ¿no puedes regalarle por alguna razón? Es una pena terrible.$3",
  "string.marriage_Wed.003": "¿Alguien completamente neutral, quizás? Hmm, sí... eso sería muy molesto...$3#$b#Oh, no es nada. Solo estoy trabajando en un encuentro con un jefe.",
  "string.marriage_Wed.004": "¿Un depredador ápice, quizás? Alguien cuyo único propósito es cazar...$3#$b#Oh, no es nada. Solo estoy trabajando en un encuentro con un jefe.",
  "string.marriage_Wed.005": "¿Una ninfa del bosque? Me gustan las ninfas del bosque. Y algo con árboles...$3#$b#Oh, no es nada. Solo estoy trabajando en un encuentro con un jefe.",
  "string.marriage_Wed.006": "%Juna parece estar profunda en sus pensamientos.",
  
  "string.marriage_Fri.000": "Cada viernes vengo aquí esperando encontrar un huevo de dinosaurio, y cada viernes me voy decepcionada.$2%revealtasteJuna107",
  "string.marriage_Fri.001": "Cada viernes vengo aquí esperando encontrar un cristal de fantasma, y cada viernes me voy decepcionada.$2%revealtasteJuna561",
  "string.marriage_Fri.002": "Cada viernes vengo aquí esperando encontrar joyas élficas, y cada viernes me voy decepcionada.$2%revealtasteJuna104",
  "string.marriage_Fri.003": "Me pregunto cómo eran los bailes de hace 9,000 años.#$b#*Juna pone los ojos en blanco y sonríe.* Si yo tuviera ESA edad, te lo diría.$10#$b#Porque entonces sería increíblemente poderosa.$3",
  "string.marriage_Fri.004": "Estoy trabajando en una nueva rutina en este momento. Es una interpretación visual de cuando Raz accidentalmente se aspiró arándanos por la nariz.$7#$b#Te lo mostraré más tarde esta noche.$1",
  "string.marriage_Fri.005": "Eh, claro, ocasionalmente bailo con otras personas, pero no es una prioridad. Y definitivamente prefiero lanzar a otras personas en lugar de ser lanzada yo misma.$7#$b#Guiño guiño. *Juna dice esta última parte en voz alta mientras mantiene contacto visual y continúa su práctica.*$7",
  "string.marriage_Fri.006": "¿Te he contado CÓMO robé el libro mágico de Raz? Es una buena historia.$3#$b#Bien, todo empezó cuando Raz estaba en una cita - aunque estoy segura de que él lo habría llamado una 'asignación', el pomposo dinosaurio...$10",
  "string.marriage_Fri.007": "¿Te he contado la historia detrás de este pergamino dorado?#$b#Todo empezó cuando el tío abuelo de Olive, el mejor amigo de su primo, decidió ir a hacer rafting un día...$10",
  "string.marriage_Fri.008": "¿Te he contado los detalles sobre cómo tomé posesión de esta cueva? No fue tanto una pelea como una conversación entre yo y el oso.$10#$b#Todo empezó cuando regresé del extranjero, lista para irrumpir de nuevo en la vida de Raz y hacerlo sentir incómodo...$3",
  
  "string.marriage_Sun.000": "¿Recuerdas aquella vez que viniste a visitar el viejo bosque y accidentalmente insultaste al tercer primo de Olive porque eras tan malo en Junimonia?$10#$b#No puedo recordar exactamente lo que dijiste, solo que era algo sobre su madre. Ah, buenos tiempos.$1",
  "string.marriage_Sun.001": "No sé, Olive. Hay un pellizco, supongo, y simplemente no siento que mi pierna esté donde debería.$8#$b#Raz, prometiste que me darías notas sobre mi última actuación hoy. ¡Vamos, rápido!$8#$b#¿Raz? ¡Raz! ¡Rasmodius!$9",
  "string.marriage_Sun.002": "¿Qué está pasando ahora?$11#$b#Ayúdame, @! Finalmente se ha vuelto loco.$2",
  "string.marriage_Sun.003": "EL JUGO NO VALE LA PENA$4#$b#SI EL JUGO NO SE VE ASÍ$6",
  "string.marriage_Sun.004": "Aggie. Edna. Rubina. Flossie. Bertha. Myrtle. ¿Myrtle? ¡Tu ojo parpadeó!#$b#¿Así que el nombre de tu madre era Myrtle, Raz? Razzamatazz y Myrtle. Hmm, interesante...$3",
  "string.marriage_Sun.005": "¡No fue TAN hace mucho tiempo!$5",
  
  "string.marriage_Sun.006": "Es francamente inconcebible que mis padres hayan logrado engendrarme a mí y a Theo. El resto de mis hermanos, seguro, pero Theo? Es tan... contrario.$11#$b#Lo quiero tanto.$4#$b#Por cierto, Raz, ¿tienes algún hermano o hermana? No puedo creer que no te haya preguntado eso antes - de hecho, olvídalo, ya sé por qué no lo he hecho. Es porque realmente no me importa.$1",
  "string.marriage_Sun.007": "¿HOLA?$6#$b#¿SOY YO A QUEN ESTÁS BUSCANDO?$6",
  "string.marriage_Sun.008": "No sé, Olive. Hay un pellizco, supongo, y simplemente no siento que mi pierna esté donde debería.$8#$b#No me importa tu estúpido trabajo, Raz, estoy hablando con Olive ahora.$9#$b#¿Puedes creer este tipo, Olive?$9",
  "string.marriage_Sun.009": "Ayer Theo me contó una historia realmente divertida sobre invertir todo su fondo universitario en una empresa que fabricaba gorras de béisbol para gatos. Nuestros padres estaban FURIOSOS.$1#$b#¿Por qué debería simpatizar con ellos? Son los que pensaron que era una buena idea confiarle un título universitario a Theo.$3",
  "string.marriage_Sun.010": "Aggie. Edna. Rubina. Flossie. Bertha. Myrtle. ¿Myrtle? ¡Tu ojo parpadeó!#$b#¿Así que el nombre de tu madre era Myrtle, Raz? Razzamatazz y Myrtle. Hmm, interesante...$3",
  "string.marriage_Sun.011": "¡No fue TAN hace mucho tiempo!$5",
  
  "string.marriage_summer_5.000": "Eso nunca pasará, y lo sabes, Robin.#$b#A menos que... aceptes comprar todas las bebidas esta noche.$6",
  
  "string.marriage_winter_17.000": "¡No estoy haciendo nada! No tengo idea de lo que estás hablando y me resiento de la insinuación de que estaría garabateando en alguno de estos valiosos libros.$3",
  "string.marriage_winter_17.001": "%Juna está ignorando al Mago.",
  "string.marriage_winter_17.002": "Bueno, entonces, salud, Raz. Supongo que, en general... no eres la peor persona del mundo.$11",
  "string.marriage_winter_17.003": "¡No estoy haciendo nada! No tengo idea de lo que estás hablando y me resiento de la insinuación de que estaría garabateando en alguno de estos valiosos libros.$3",
  "string.marriage_winter_17.004": "%Juna está ignorando al Mago.",
  "string.marriage_winter_17.005": "Bueno, entonces, salud, Raz. Que tu vida esté siempre atormentada por aprendices incompetentes e indiferentes.$11",
  
  "string.marriage_winter_16.001": "No puedo creer que ahora haya dos personas arrastrándome a estos eventos en la playa. *suspiro*$2#$b#Aunque... ha pasado un tiempo desde que tuve la oportunidad de \"pasar el rato\" con una sirena.$3",
  
  "string.marriage_Wed_3.000": "Ugh, sí, sé que ELLA estaba llorando cuando llevaba el vestido de flores, Olive, pero eso no significa que yo lo haga. Estás enfocándote deliberadamente en lo incorrecto aquí.$9",
  "string.marriage_Wed_3.001": "¿Recuerdas nuestro primer edificio abandonado, Olive? Yoba, éramos jóvenes.$8",
  "string.marriage_Wed_3.002": "@! Ayúdame a convencer a Olive de que se ponga estos brazaletes antes de que entre a la piscina! Sé que no los necesitas, O, pero ¡se verá tan divertido!$8",
  "string.marriage_Wed_3.003": "Acabas de perder nuestra última sesión de saltos en montones de hojas, @. Ahora estamos revisando la colección de álbumes de recortes de Olive. Su última obsesión es prensar y conservar hojas. Yay, es tan divertido.$9",
  "string.marriage_Wed_3.004": "\"¡Argh, no, Sr. Hombre Musculoso, tus bíceps finalmente han crecido demasiado para tu cuerpo! ¡No tienen dónde ir; se fusionarán con tus mejillas!\"$9",
  
  "string.marriage_storm.000": "A veces adoro la lluvia, otras veces la aborrezco. Todos contenemos multitudes.$7",
  "string.marriage_storm.001": "¡Truenos y relámpagos! Entran tres brujas. ¿No es el Bardo perfecto para un día como hoy?$1",
  "string.marriage_storm.002": "\"Conozco mi propio corazón y entiendo a mi prójimo. Pero soy diferente a cualquier persona que haya conocido. Me atrevo a decir que no soy como nadie en el mundo entero.\"#$b#Esa es una cita dentro de una cita, @. ¡Averigua de quién estoy hablando y te daré una galleta!$1",
  "string.marriage_storm.003": "\"Anne se sentó a mi lado hasta las 2. Hablé sobre el sentimiento que ella provocó. Lamenté mi destino. Dije que nunca debería casarme. No podía gustar de los hombres. No debería gustar de las mujeres. ... y provocó la simpatía de la pobre Anne hasta las lágrimas.\"#$b#Un modelo a seguir difícil, es Lister. ¡Pero el drama! ¡Me encanta tanto el drama! No puedo evitarlo.$1",
  
  "string.marriage_summer_Fri.000": "¿Suave?! ¡Te mostraré lo suave, viejo gruñón. ¡Entregame las boules!$5",
  "string.marriage_summer_Fri_5.000": "Eso es lo más dulce que he oído en todo el día. Sin ofender, @.$4",
  
  "string.marriage_Wed_Alex.000": "Hola, noble idiota. Estamos tratando de decidir qué género de película ver.#$b#No puedo ver películas de terror con Alex, porque solo trata de consolar a alguna mujer asustada al azar para ocultar el hecho de que está demasiado aterrorizado para mirar la pantalla.$11",
  "string.marriage_Wed_Alex.001": "Esa fue una buena sesión. Apenas puedo sentir mis dedos de los pies.$1",
  "string.marriage_Wed_Alex.002": "Te veías mucho más en control hoy, Alex. Rah-rah, ojos claros, etc. etc.",
  
  "string.marriage_Wed_Alex.003": "Proteína, schmotina. ¡Vive un poco, Alex! Ser interesante es mucho más importante que ser saludable.$11",
  "string.marriage_Wed_Alex.004": "¿Theo? Hola, es tu encantadora hermana apenas mayor que tú. ¿Puedes hablar con Alex por mí? Está siendo aburrido con el azúcar y el alcohol otra vez.$2",
  
  "string.marriage_spring_11.000": "Sí, es verdad. Uhuh. ¿Qué pasa con los caracoles, aunque? ¿O tal vez los champiñones ostras?#$b#Oh, hola, @. Theo acaba de lograr escapar de observar pájaros para darme un anillo. ¡Aquí, dile feliz cumpleaños!$1#$b#¿Caracoles? Oh, no te preocupes por eso. No hay necesidad de mirar detrás de esa cortina en particular.$3",
  "string.marriage_spring_11.001": "Hmm? No, no me quedaré mucho más. Le dije a Theo que comeríamos ruidosamente al teléfono esta noche. Estamos comiendo su favorito - chile loco con pan de ajo y una botella de whisky.#$b#¿Quieres unirte a nosotros?$4",

  //Vanilla NPC dialogue

  //Wizard
  "string.Juna_SunW.000": "Por supuesto, Juna solo mira atrás con cariño cuando el pasado implica que me haga el ridículo.",
  "string.Juna_SunW.001": "%El Mago parece haberse quedado dormido de pie.",
  "string.Juna_SunW.002": "Juna y yo tenemos un acuerdo. Yo la veo bailar los viernes y ella escucha cuando intento enseñarle más sobre pociones.#$b#La poción de hoy incluía jugo de limón y, bueno... aquí estamos.",
  "string.Juna_SunW.003": "Entonces... bueno. Llega un momento... eh, sí. Creo. La cosa es: ¡la gente! Con otras personas. A veces. ¿Sabes? ¡Como mi exesposa! Ella es gente. ¿Es eso... *tos* ... Sí? ¿Algo para ti, quizás?$1",
  "string.Juna_SunW.004": "%El ojo del Mago está parpadeando incontrolablemente.",
  "string.Juna_SunW.005": "A veces observo a los aldeanos locales en secreto.#$b#Espero encontrar un aprendiz. Algún día dejaré este plano mortal, pero mis búsquedas arcanas deben continuar.#$b#Ah, sí, de hecho tuve un aprendiz hace mucho, mucho, mucho, mucho- ¿qué fue eso, Juna?#$b#Digamos que no funcionó y dejémoslo en eso.",
  "string.Juna_SunP.006": "De hecho tengo hermanos. Y dado que preguntaste tan amablemente, voy a contarte todo sobre ellos, Ju.",
  "string.Juna_SunP.007": "Cometí el grave error de contarle a Juna sobre ver a mi exesposa por primera vez en, oh, ¿años? Ahora cada vez que abro la boca, ella empieza a cantar esa maldita canción.",
  "string.Juna_SunP.008": "¿De verdad tienes que hablar de tu pasatiempo aquí, Ju? Estoy intentando hacer algo de trabajo.",
  "string.Juna_SunP.009": "Sigo diciéndote, Ju, que la irresponsabilidad financiera no es un asunto para reírse. Deberías sentirte mal por tus padres.",
  "string.Juna_SunP.010": "%El ojo del Mago está parpadeando incontrolablemente.",
  "string.Juna_SunP.011": "A veces observo a los aldeanos locales en secreto.#$b#Espero encontrar un aprendiz. Algún día dejaré este plano mortal, pero mis búsquedas arcanas deben continuar.#$b#Ah, sí, de hecho tuve un aprendiz hace mucho, mucho, mucho, mucho- ¿qué fue eso, Juna?#$b#Digamos que no funcionó y dejémoslo en eso.",

  //Robin & Demetrius
   "string.Robin.summer_5.001": "Vamos, Ju: haz el baile de las flores aquí y ahora. Te reto.$1",
  "string.Robin.Juna_Mon.003": "Juna, ¡no puedes simplemente decirle a alguien que quieres... ya sabes!$1",
  "string.Robin.Juna_Mon.004": "Eh. ¿Qué tal una partida de ajedrez en su lugar? Y no, no puedes quedarte con mi alma si ganas.#$b#Espera, ¿estás diciendo que robaste eso de la taberna?$6",
  "string.Robin.Juna_Mon.005": "Esto es para ese juego que a veces juega Sebastian, ¿verdad?#$b#¿Quién es la reina neutral otra vez? ¿Es la que puede convertirse en un árbol? Me encantaría poder convertirme en un árbol a voluntad...$2",
  "string.Robin.Juna_Mon.006": "Ok, ok, ¿qué te parece esta?: \"¿Qué aroma elegirías para describir la personalidad de tu pareja?\"#$b#Hm, tú eres... lilas mezcladas con agua de mar, creo. Pero eso es solo porque no creo que los tornados tengan un olor particular...$1",

  "string.Demetrius.summer_5.001": "Esto sí quiero verlo.$1",

  //George & Alex

  "george.summer_Fri.001": "Hmph. Seguro que no te has vuelto blanda ahora que vives en esa granja elegante con @.",
  "george.summer_Fri.002": "Eres rara, Ju, pero una buena persona de todas formas. Feliz cumpleaños, vieja bruja.$1",

  "string.Alex.Wed.000": "¡Eso no es cierto, Juna! Deja de mentir.$7",
  "string.Alex.Wed.001": "Ayúdame, @. No puedo sentir mis brazos, piernas o dedos meñiques.$2",
  "string.Alex.Wed.002": "Gracias, Juna. Me gustó ese giro que hiciste. Fue genial.$1",
  
  "string.Alex.Wed.003": "Ju-uuna. ¿Sabes cuánto azúcar hay en una piña colada? ¿Por qué no puedo simplemente tomar un batido de proteínas?$2#$b#¿Qué? ¡No! Nada es más importante que estar saludable.$7",
  "string.Alex.Wed.004": "Ju-uuna. ¡El azúcar es malo para ti! Deja de intentar que tu hermano me atraiga al lado oscuro.$5",

  //Roommate events

 "juna.action.1": "Encuentras a Juna girando por la sala de estar.",
  "juna.action.option1": "Pasa tiempo con Juna y termina el día.",
  "juna.action.option2": "Entra a la granja como de costumbre.",
  "juna.action.2": "Ella se detiene con gracia frente a ti.",
  "juna.action.3": "Encuentras a Juna sentada encima de la estantería comiendo cerezas.",
  "juna.action.4": "Ella salta y se acerca a ti.",
  "juna.action.5": "Encuentras a Juna garabateando algo en un papel mientras se ríe para sí misma.",
  "juna.action.6": "Ella levanta la vista y te señala.",
  "juna.action.7": "Encuentras a Juna estudiando su pintura.",
  "juna.action.8": "Ella se da vuelta y te mira.",
  "juna.action.9": "Encuentras a Juna leyendo un libro al revés en tu cama.",
  "juna.action.10": "Ella cierra el libro y lo lanza a un lado.",
  "juna.action.11": "Encuentras a Juna echando ingredientes que realmente no combinan en una batidora.",
  "juna.action.12": "Ella pone la tapa y levanta la vista.",
  "juna.action.13": "Encuentras a Juna discutiendo con la adivina en la televisión.",
  "juna.action.14": "Ella golpea el pie y apaga la televisión.",
  "juna.action.15": "Encuentras a Juna dormida en una silla.",
  "juna.action.16": "Ella se despierta y se estira con un bostezo.",

  "juna.day.platonic.1": "He tenido un día perfectamente maravilloso.$4#$b#¿Qué te parece si lo cerramos con películas de terror cutres y esos caramelos que te gustan tanto?$1",
  "juna.day.platonic.2": "¡Yo elijo primero!",
  "juna.day.platonic.3": "He tenido un día muy satisfactorio.$3#$b#Me gustaría terminarlo comiendo muchas tortitas. ¿Te unes?$6",
  "juna.day.platonic.4": "¡Saca el jarabe de arce!",
  "juna.day.platonic.5": "Hoy no fue... muy bueno.$12#$b#¿Podemos, no sé, romper algo?$12",
  "juna.day.platonic.6": "¡Voy a buscar el jarrón que me dio Raz!",
  "juna.day.platonic.7": "Tuve el día más extraño hoy.$11#$b#¿Sabes lo que me ayudaría a aclarar la cabeza? Tomar fotos aburridas de nuestra comida y enviárselas a Raz.$3",
  "juna.day.platonic.8": "¡Oh, también hagamos caras de pato!",

  "juna.day.nonplatonic.1": "He tenido un día perfectamente maravilloso.$4#$b#¿Te gustaría... celebrarlo conmigo?",
  "juna.day.nonplatonic.2": "Juna extiende su mano en tu dirección.",
  "juna.day.nonplatonic.3": "¿Te unes a mí?",
  "juna.day.nonplatonic.4": "He tenido un día muy satisfactorio y aún me queda mucha energía.$3#$b#¿Me dejarías gastarla contigo?$3",
  "juna.day.nonplatonic.5": "Juna te hace una señal para que te acerques.",
  "juna.day.nonplatonic.6": "Ven aquí.",
  "juna.day.nonplatonic.7": "Hoy no fue... muy bueno.$12#$b#Estaba... Hm. Me preguntaba si podrías ayudarme a despejar la mente.$12",
  "juna.day.nonplatonic.8": "Tú extiendes tu mano hacia Juna.",

  //CONVERSATION TOPICS FROM OTHER MODS

  "juna.AlectoIntroduction": "¿Finalmente conociste a Alecto? Excelente.$1#$b#Ella merece que todos la colmen de elogios, no solo yo, Kevin y Titania. Pero, por desgracia, es demasiado talentosa para mantenerse oculta.#$b#Especialmente en comparación con Raz, quien cree que agacharse detrás de unos árboles lo hace invisible durante los festivales del pueblo.$11",
  "juna.TristanReturns": "Voy a extrañar al Sr. Ginger. Los gatos son naturalmente superiores a los hombres, incluso a aquellos que en realidad son hombres transformados en gatos.$2#$b#Sin embargo, espero con ansias ver cómo reaccionan los pueblerinos al regreso de Tristan. Especialmente Shane.$3",
  "juna.DenverInjuries": "Ese Denver definitivamente es un ser humano completamente normal, ¿verdad?$3",
  "juna.JulietGremlin": "Ahí estaba yo, preguntándome si hoy sería el día en que finalmente me reuniría con mi hermana gemela perdida, Juliet, cuando de repente noté que había ganado un nuevo compañero muy lindo.$10#$b#¿Y quién soy yo para interponerme en la unión familiar entre especies? Olive nunca me lo perdonaría.$1",
  "juna.LavrilUnlocked": "Estoy pensando en Olive, estoy pensando en Void, estoy pensando en la mejor cita de juegos del mundo. ¿Sí? ¡Sí!$1",
  "juna.LucikielArrives": "En mi experiencia, los demonios son bastante obstinados.#$b#La obsesión por las cosas dulces es tolerable, pero hay un límite en cuanto al romance posesivo antes de que los abdominales dejen de valer la pena.$11",
  "juna.ReputationIncreased": "Sí, pero ¿Lucikiel sigue causando sensación por todas partes? Porque entonces todavía no estoy impresionada.$11",
  "juna.JasperGone2": "Olive se preguntaba si sabías a dónde había desaparecido ese académico desaliñado.$8#$b#Le dije que dejara de preocuparse, pero tiene la tendencia a volverse pegajoso cuando conoce a personas que dicen cosas como 'misterio de la tierra' y 'la presencia adormecida en el bosque'.$9",
  "juna.keahi_prank": "Por favor, dime que ese olor no es un intento de impresionar a Raz.$11#$b#Lo de Pie Grande fue solo una broma, lo juro. NO tenía la intención de que se usara en algún ritual extraño de cortejo.$11",
  "juna.keahi_prankNo": "El olor que llevas ahora mismo me dio una idea excelente.$3",
  "juna.event_postweddingreception": "Sí, sí, felicidades por la boda y el amor. ¿Tu recepción de boda incluyó sentarse en el suelo fingiendo que balanceaban un barco como un grupo de completos maníacos?#$b#¿No? Buu, aburrido. Entonces no estoy interesada.$2",
  "juna.PTJ03": "Me hago la misión de apoyar cualquier broma que se haga en Pelican Town.$1#$b#Además, esos dos se ven bastante lindos juntos.$10#$b#La única razón por la que te permito escucharme decir eso es porque involucra a Juliet, mi hermana gemela perdida, y si le cuentas a alguien, le diré algo a Pierre que lo hará sonrojar cada vez que te vea.$5#$b#Créeme, que Pierre se sonroje al verte es tan traumático como crees.$5",
  "juna.MeetTheCats": "Apoyo de todo corazón la lucha de Jean por los derechos de los trabajadores. ¿Qué? Solía hacer piquetes contra Raz todo el tiempo cuando era más joven.#$b#Lo volvía absolutamente loco.$3",
  "juna.ButteredJorts": "Aunque me reí durante aproximadamente 20 minutos cuando escuché lo que hizo Pam, creo que es importante que Jorts sepa que lo aprecio sin importar cuán desaliñado esté.$10#$b#¡Por eso guardo mi mejor basura para él!$1",
  "juna.AfterProposal": "Robin sigue enviándome fotos de su boda. ¡Mira! Incluso ha añadido corazones brillantes y rosas a esta. Ni siquiera sabía que sabía usar Photoshop.$13#$b#Yri es dulce y todo, pero puede que nunca la perdone por poner a Robin en un estado tan romántico.$2",
  "juna.YriWalk": "Sigo diciéndole a Robin que el Ratón de Sombrero está realmente en la onda del estilo shabby chic, pero no me cree.$2#$b#Quizás ella y Yri estarían más inclinadas a creerlo si viniera de ti. Supongo que eres, ya sabes, más 'confiable' o lo que sea.",
  "juna.SterlingTrain": "Uno pensaría que alguien a quien le gusta saltar a las vías del tren sería un poco menos quisquilloso al verte bailar en el techo de la tienda de Pierre.$2",
  "juna.SterlingBike": "Claro, las bicicletas están bien y todo, pero si realmente quieres acercarte a alguien, deberías probar la teletransportación.$3#$b#No, NO tienes permitido decirle a Sterling. Si aprende más trucos coquetos, seré yo quien acabe vomitando en una papelera.$5",
  "juna.SterlingDrugs": "Me parece que Sterling protesta demasiado sobre que las mujeres intentan 'arreglarlo'.$11#$b#Además, solo le pedí que llevara su fiesta a la torre de Raz. En parte porque molestaría a Raz, claro, pero también porque Wellwick es absolutamente encantadora, y sabía que ella estaba allí en ese momento. ¡Todos ganan!#$b#Bueno, todos menos Raz y el futuro Sterling, supongo.$11",
  "juna.SterlingTrashAlex": "Consideré brevemente hacer de Sterling mi hermano pequeño honorario, pero finalmente me decidí por Alex. Creo que es porque Sterling me recuerda demasiado a la tía de Olive.#$b#Es esa mirada nerviosa en sus ojos, ¿sabes? Bueno, eso y los vómitos.$11#$b#Ahora, Mia, ¿la has conocido? Sé que sabes que odio el coqueteo, pero por ella podría hacer una excepción.$3",
  "juna.SterlingTrashNoAlex": "Consideré brevemente hacer de Sterling mi hermano pequeño honorario, pero finalmente me decidí por otra persona. Creo que es porque Sterling me recuerda demasiado a la tía de Olive.#$b#Es esa mirada nerviosa en sus ojos, ¿sabes? Bueno, eso y los vómitos.$11#$b#Ahora, Mia, ¿la has conocido? En general, no soy fanática del coqueteo, pero por ella podría hacer una excepción.$3",

  //2.1.0

  "forest.seal.2": "¡Advertencia! ¡Cuidado con los vapores de Joja Cola!",
  
  "gift.reaction.cola.0": "*Juna te quita inmediatamente la lata de la mano y se la bebe de un trago.* ¡Gracias, @! Todo el mundo sabe que una buena sesión de conspiración requiere azúcar y aditivos.$1",
  "gift.reaction.cola.1": "¡Mira detrás de ti! ¿Es ese Pie Grande?! *En cuanto miras por encima del hombro, Juna se escapa con la cola. Estás demasiado cansado para señalar que era un regalo.*$6",
  "gift.reaction.cola.2": "Gracias, @. ¿Por qué no tomas una pajita y te unes a mí?$1#$b#...#$b#... ¿Por qué me miras con tanta sospecha?$11",
  "gift.reaction.cola.3": "Excelente. Voy a ir a echar esto al agua en mi cueva de inmediato.$1",
  "gift.reaction.ancientdoll": "¿No es la más mona? La voy a llamar Annabelle.$10",
  "gift.reaction.elvishjewelry": "Normalmente no me gustan las joyas, pero Olive me dice que esto fue diseñado por el mismo elfo que hizo mi broche.$4#$b#No me importa si lo inventó. De hecho, ¡estaría orgullosa de él si fuera el caso!$1",
  "gift.reaction.dinosauregg": "Otro más para la colección. ¡Hecho!$1",
  "gift.reaction.strangedoll": "¿No es el más mono? Lo voy a llamar Chucky.$10",
  "gift.reaction.hashbrowns": "¡Y esta vez están bien quemadas! Me gustas y te aprecio, @.$4",
  "gift.reaction.pancakes": "Consejo: si no tienes acceso a jarabe de arce, una lata de Joja Cola funciona igual de bien.$10",
  "gift.reaction.pinkcake": "Gracias, @. Esto servirá muy bien para mi trampa de hadas. Muy bien, de hecho...$3",
  "gift.reaction.ghost.crystal": "*Juna sostiene la roca frente a su ojo* A ver, veamos... ¡Ajá, ahí estás!$1#$b#...#$b#¿De verdad no sabías que hay fantasmas atrapados en estas rocas?$11",
  "gift.reaction.prehistoric": "¡Gasp! ¿Dónde encontraste esto?$4#$b#Si dices que en el Mercader Viajero, me voy a enojar mucho.$13",
  "gift.reaction.cherry": "¡Pop va la cereza! *Juna te guiña un ojo. Le lanzas uno de tus frutos restantes a la cabeza.*$6",
  "gift.reaction.poppy": "He estado desafiándome a encontrar otros ingredientes para poner en mi jarabe para la tos de antaño, ¡pero la amapola siempre funciona en un apuro!$1",
  "gift.reaction.tag.jelly": "La única mermelada que realmente no me gusta es la de tomate, ¡pero sigue siendo divertido comerla frente a Robin y Dem!$3",
  "gift.reaction.brokencd": "Estoy impresionada, @. ¿Cómo sabías que este era uno de los CDs de mezclas que Raz tiró después de su divorcio?#$b#Son todos hi-la-rantes.$1",
  "gift.reaction.pinacolada": "Lo aprecio, @, pero puedes decirle a Gus que todavía no lo he perdonado por solo servir estas en el resort.$2#$b#¿Qué dirías si solo sirvieran %favorito en la herrería?$2",
  "gift.reaction.scucumber": "*Juna emite un sonido siseante e intenta meterte el pez morado en la nariz. Huele claramente a pescado.*$5",
  "gift.reaction.purplemushroom": "¡No, no, no! ¡Los gorros de Death Caps son blancos o verde claro, no morados! ¡Buu, hiss!$13",
  "gift.reaction.solaressence": "¿Tienes idea de cuántas esencias solares me ha intentado regalar Raz en emergencias a lo largo de los años?$13#$b#Como si no supiera de su enorme colección de botín de monstruos en el sótano.$11",
  "gift.reaction.voidessence": "¿Cuántas veces tengo que decirte, @? No aprecio los ingredientes mágicos ni 'la búsqueda del conocimiento arcano'. La única excepción es el polvo de mala suerte, ¡que es increíble!$5",
  "gift.reaction.category.fish": "¡Trauma infantil! *Juna tira el pez al suelo y sale corriendo.*$2",
  "gift.reaction.potato": "¡@! Estoy absolutamente horrorizada. ¡Este claramente es el mismo patata que te di la primera vez que visitaste mi cueva!$5",
  
  "gift.reaction.RodneyAutograph": "¡Me conoces tan bien, @! Gracias, gracias, gracias.$4#$b#¿Qué? ¿Qué no hay que amar?$10#$b#Una foto autografiada de alguien que no es actor es brillante por sí sola, pero una foto autografiada de alguien tan impopular que la puedes pescar del mar? ¡Bingo!$4",

  "dumpster.dive.comment": "¡@! ¡No te atrevas a robar toda la Joja Cola de nuevo!",
  "generic.4062": "¡Hola!",
  "generic.4063": "¡Buenos días, súbditos!",
  "generic.4064": "¡Buenas tardes, súbditos!",
  "generic.4065": "¡Buenas noches, súbditos!",
  "generic.4083": "¿Finalmente has descubierto que {0}",
  "generic.4091": "Aquí tienes un secreto que no merece ser llamado secreto: a {0} le encanta '{1}'",
  "generic.4094": "Si quieres que {0} te odie, dale '{1}'.",
  "generic.4097": "Si quieres que a {0} le gustes y te aprecie - ¿y quién no querría? - dale '{1}'.",
  "generic.4100": "Si quieres ganarte el favor de {0} - presumiblemente para acercarte lo suficiente como para bajarle los pantalones - dale '{1}'.",
  "generic.4103": "Si quieres ganarte el favor de {0}, dale '{1}'. Yo le di 50 la primera semana que estuve aquí.",
  "generic.4106": "Si quieres hacerte amigo de {0} - y parece que quieres hacerte amigo de todos - no puedes equivocarte con '{1}'",
  "generic.4109": "Es su menos favorito, lo prometo. ... ¿Te mentiría yo?",
  "generic.4113": "Lo odia. ... ¿Te mentiría yo?",
  "generic.4114": "Odia esas cosas. ... ¿Te mentiría yo?",
  "generic.4116": "Ella lo adora tanto como yo la adoro a ella.",
  "generic.4118": "Se lo di un año y no dejó de quejarse. ... ¿Te mentiría yo?",
  "generic.4120": "Se lo di un año y no dejó de hablar de ello. ¡Fue lo mejor!",
  "generic.4125": "Sería un gran regalo. Si no tienes muñecos extraños a mano, claro. ¡Solo los raros no les gustan los muñecos extraños!",
  "generic.4126": "Realmente podrías ponerlo incómodo con eso. Que es lo que todos deseamos ver, ¿verdad?",
  "generic.4135": "¿A {0} le encanta '{1}'? Lo encuentra absolutamente encantador.",
  "generic.4146": "¡Alerta regional!",
  "generic.4149": "Si quieres que {0} te guste, dale '{1}'. Le encanta con una pasión ardiente. ... ¿Te mentiría yo?",
  "generic.4152": "Si quieres que {0} te guste, dale '{1}'. Le encanta con una pasión ardiente. ... ¿Te mentiría yo?",
  "generic.4154": "Si quieres que {0} te odie, dale '{1}'. Luego corre lejos, muy lejos, donde no pueda alcanzarte para castigarte por tener mal gusto en amigos.",
  "generic.4161": "Si quieres hacerle una broma hilarante a {0}, dale '{1}'. Si tienes suerte, puede que nunca te perdone.",
  "generic.4170": "Confía en mí en esta.",
  "generic.4171": "Confía en mí en esta.",
  "generic.4172": "Solo pensarlo lo hace sentirse extasiado.",
  "generic.4176": "Creo que podría tener una afinidad natural por eso.",
  
  "juna.DwarfStory": "Últimamente, cada vez que he ido a la biblioteca a espiar a peo- a leer, Rodney ha estado ahí murmurando sobre enanos.#$b#¿Está tratando de encontrar una nueva audiencia?$6#$b#Oh, ¿está escribiendo un nuevo libro? En una escala de Raz a Robin, ¿qué tan sexy crees que será?$3",
  "juna.ShadowfolkStory": "Últimamente, cada vez que he ido a la biblioteca a espiar a peo- a leer, Rodney ha estado ahí murmurando sobre los shadowfolk.#$b#¿Está tratando de encontrar una nueva audiencia?$6#$b#Oh, ¿está escribiendo un nuevo libro? En una escala de Raz a Robin, ¿qué tan sexy crees que será?$3",
  "juna.BookLaunchParty": "Las Crónicas de Stardew Valley fueron geniales, ¿verdad?$1#$b#He estado leyendo la sección sobre el mago en voz alta a Razzamatazz cada vez que tengo la oportunidad.$1",
  "juna.divorce": "¡Bienvenido de nuevo, @!$4",
  "juna.AlexTryouts": "Por supuesto que quiero que Alex le vaya bien en las pruebas. El único inconveniente es que ahora será aún más difícil convencerlo de unirse a mi grupo de apreciación del azúcar.#$b#¡Pero me encantan los desafíos!$6",
  "juna.leoValleyArrival": "*Juna hojea una carpeta llena de dibujos de figuras de palo y lo que parece ser una escritura muy densa.*#$b#¿Oh, esto? Son mis planes de lecciones para Leo. Hace tiempo que quiero enseñarle la historia del baile, pero hace demasiado calor para concentrarse en la isla.#$b#¡Penny no es la única educadora por aquí, ya sabes! La regla número uno de la enseñanza: el interés se puede cultivar siempre que los atosigues desde una edad lo suficientemente temprana.$10",
  "juna.fairyFarmVisit": "Lo sé, lo sé. Ya estoy trabajando en otra trampa. Es una cosita astuta, esa hada.$11#$b#Estaría impresionada si no encontrara su personalidad tan increíblemente molesta.",

  //1.6 UPDATE

  "juna.cave.name": "Cueva de Juna",
  "config.section.The Wizard.name": "El Mago",
  "config.section.Aromantic Juna.name": "Juna Arromántica",
  "config.section.Events.name": "Eventos",
  "juna.friends.Robin": "Robin",
  "juna.friends.Wizard": "el dinosaurio morado",
  "juna.roommate.painting.name": "Pintura de Juna",
  "juna.roommate.painting.description": "Una réplica en miniatura de la pintura de Juna. Entrégasela a Juna para pedirle que se mude contigo.",
  "slingshot.comment": "¡Oye! Sé que tengo un aura de alcalde, pero ¡mi nombre no es Lewis! Haz como el resto de nosotros y apunta a su trasero en su lugar.$5",
  "marriage.reject": "...$11#$b#Voy a hacerte el favor, que, ugh, ¡odio hacer favores!, de fingir que te tropezaste y caíste sobre mí mientras llevabas un colgante destinado a otra persona.$13#$b#Porque NO quiero esto. De nadie. ¿Vale? Vale.$11",
  "stardrop.roommate": "Entonces. Dime, @. ¿A qué te recuerda exactamente este sabor?$3",
  "winterstar.juna.give.before": "¿Sabes cuál es la mejor parte de dar regalos? Es que no puedes perder. O haces feliz a alguien con un buen regalo, o te diviertes viendo cómo una persona educada intenta, sin éxito, disimular su decepción.$1",
  "winterstar.juna.give.after": "*Juna te mira fijamente.* ¿Es eso un gesto de disgusto que veo?$3",

  //2.1.6
  "juna.recharge.GreenRain": "Estoy tan cerca de alcanzar mi forma final, @, ¡puedo prácticamente saborearlo!$4",
  "juna.GreenRain": "¿No es toda esta incertidumbre y caos simplemente hermoso?$4",
  "juna.GreenRainFinished": "¿Oh, ya se terminó?$2",
  "juna.GreenRain_2": "Si tan solo este fenómeno FUERA que nos transportaran al mundo de las hadas, como desea Abigail. ¡Esos pequeños sociópatas son divertidísimos!$10",
  "string.desert.festival": "Intenté hacer una 'apuesta' con el Chico Saltarín sobre el ganador de hoy, pero se puso muy borde conmigo.#$b#¡No es mi culpa que parezca más un arreglador de partidos que un hombre trabajando como portero para apoyar su carrera como novelista romántico!$2",
  "string.marriage_DesertFestival": "¡Me siento inspirado, @! Nunca pensé en usar camarones de esa manera...$3#$b#Cuidado: ¡nuevo experimento culinario pronto!$1",
  
  //Moved over from Dialogue files
  "location.hearts.2.saloon": "¿Sabías que una vez, en el campamento de música, Shane se comió un tarro de pepinillos para impresionar a un chico?$6",
  "location.hearts.2.wizard": "Aggie. Edna. Rubina. Flossie. Bertha. Myrtle. ¿Myrtle? ¡Tu ojo se contrajo!#$b#Así que el nombre de tu madre era Myrtle, ¿verdad, Raz? Razzamatazz y Myrtle. Hmm, interesante...$3",
  "location.hearts.4.saloon": "¿Sabías que Leah una vez robó una pintura de un museo en Ciudad Zuzu? Mmmhm.$6",
  "location.hearts.4.wizard": "¡No, TÚ pareces un arbusto morado con un sombrero!$5",
  "location.hearts.6.saloon": "¿Sabías que Sam solo finge ser malo en el billar para hacer feliz a Sebastián?#$b#¡Lo sé, es asqueroso!$6",
  "location.hearts.6.wizard": "¿Qué es esto? ¿Un libro de la biblioteca vencido? 'El mago y la doncella'. Dios mío, esto va a resultar en una multa considerable, Raz.$3",
  "location.hearts.8.saloon": "¿Sabías que Gus en realidad es uno de los osos disfrazados de 'Ricitos de Oro'?$6#$b#Aún no sé cuál, pero es por eso que sigo viniendo aquí. Estoy de incógnito.$3",
  "location.hearts.10.saloon": "¿Sabías que Marnie se merece algo mejor? Oh, no tenía a ning- a nadie en mente... solo en general, quiero decir.$11",
  "location.hearts.10.wizardW.spring": "¿Recuerdas esa vez que viniste a visitar el viejo bosque y accidentalmente insultaste al primo tercero de Olive porque eras tan malo en Junimonia?$10#$b#No puedo recordar exactamente lo que dijiste, solo que fue algo sobre su madre. Ah, buenos tiempos.$1",
  "location.hearts.10.wizardW.summer": "EL JUGO NO VALE LA PENA$4#$b#SI EL JUGO NO SE VE ASÍ$6",
  "location.hearts.10.wizardW.fall": "No lo sé, Olive. Hay como un pellizco, supongo, y simplemente no siento que mi pierna esté donde debería estar.$8#$b#Raz, me prometiste que hoy me darías notas sobre mi actuación del viernes. ¡Ándale!$8#$e#¿Raz? ¡Raz! ¡Rasmodius!$9",
  "location.hearts.10.wizardW.winter": "¿Qué está pasando ahora?$11#$b#Ayúdame, @! Finalmente ha perdido la cabeza.$2",
  "location.hearts.10.wizardP.spring": "Es francamente incomprensible que mis padres lograran engendrarme a mí y a Theo. El resto de mis hermanos, claro, pero ¿Theo? Él es tan... contrario.$11#$b#Lo amo tanto.$4#$b#Por cierto, Raz, ¿tienes hermanos? No puedo creer que no te haya preguntado eso antes... en realidad, olvídalo, sé por qué no lo hice. Es porque realmente no me importa.$1",
  "location.hearts.10.wizardP.summer": "¡HOOOLAAA?$6#$b#¿ERES TÚ QUIEN ME ESTÁ BUSCANDOOOO?$6",
  "location.hearts.10.wizardP.fall": "No lo sé, Olive. Hay como un pellizco, supongo, y simplemente no siento que mi pierna esté donde debería estar.$8#$b#No me importa tu estúpido trabajo, Raz, estoy hablando con Olive ahora mismo.$9#$e#¿Puedes creer a este tipo, Olive?$9",
  "location.hearts.10.wizardP.winter": "Ayer, Theo me contó una historia muy graciosa sobre cómo invirtió todo su fondo universitario en una empresa que fabricaba gorras de béisbol para gatos. Nuestros padres estaban FURIOSOS.$1#$e#¿Por qué debería simpatizar con ellos? ¡Ellos fueron los que pensaron que era buena idea confiarle a Theo un título universitario!$3",

  //2.2.0 NEW

  "juna.roommate.ring.name": "Juna's ring",
  "juna.roommate.ring.description": "Juna's super secret friendship gift."

}
