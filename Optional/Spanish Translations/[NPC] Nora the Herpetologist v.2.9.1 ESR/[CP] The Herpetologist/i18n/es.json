{ 
    
/// GENERIC DIALOGUE"

// NAME AND INTRO
"Core.Nora.Name": "Nora",
"Core.Nora.Introduction": "¡Oh vaya! ¿Apenas te mudaste a la granja?#$b#Estaba deseando conocerte$1#$b#Soy Nora, por cierto. Vivo en East Scarp. No dudes en visitarme, aunque...#$b#Debo advertirte que trabajo con reptiles, así que si les tienes miedo, no te gustará mi casa.",

// COMMUNITY CENTER BUNDLES
"Core.Nora.JojaBegin": "Sabes, Joja es responsable de mucha contaminación aquí en el valle. Afectando a los ecosistemas y a todos.$5#$b#Me imaginé que tú, teniendo una granja, te importaría más el bienestar del valle. Pero supongo que nunca puedes conocer tan bien a las personas...$2",
"Core.Nora.CCBegin": "¿Estás restaurando el antiguo centro comunitario? !Oh, he estado soñando con tener un lugar así para estudiar desde que llegué al valle!$1#$b#Cuando me mudé aquí ya estaba fuera de servicio. Así que me alegro que te estés encargando de ello.",
"Core.Nora.CCBus": "¡El viejo autobús fue reparado!$0#$b#¡Eso significa que mi prima Lorelai podrá volver a visitar Pueblo Pelícano algún día! Ay, la extraño tanto.#$b#Ella puede preparar todo tipo de postres deliciosos.¡Deberías probarlos alguna vez!#1",
"Core.Nora.CCComplete": "Muchas gracias por restaurar el centro comunitario. Es muy lindo ver a todos reunidos.$1#$b#¡Y bien por mi, ahora tengo un lugar diferente para estudiar!", 
"Core.Nora.MovieTheater": "¡Ya tenemos un cine!$1#$b#¿Crees que si les preguntara cortésmente estarían dispuestos a pasar un documental sobre reptiles?$3#$b#Bueno, supongo que no está de más intentarlo.$1", 

//FLOWER DANCE
"Core.Nora.FlowerDanceAccept": "¿Yo? Bueno...$3#$b#Prepárate para el baile de tu vida, @!$1",
"Core.Nora.FlowerDanceDecline": "Uhm... esto es incómodo...$2#$b#Pero creo que voy a pasar esta vez, @.",

// BIRTHDAYS

/// HEART DIALOGUE

// 0 HEARTS SPRING

"Core.Nora.Spring.Mon.0h": "¡Buenos días! Yoba, tengo mucho trabajo que hacer hoy.#$b#Oh, ¿Estoy temblando? Debe ser por el café.$3#$b#Esta es mi quinta taza de hoy. No te preocupes, estoy acostumbrada.",
"Core.Nora.Spring.Tue.0h": "Si alguna vez me hablas y no te respondo de inmediato, no te estoy ignorando, ¡Lo juro!#$b#De hecho, no escucho muy bien y debo usar audífonos auditivos, y a veces, no funcionan correctamente.#$b#Así que si asumes que no estoy escuchando lo mas seguro es que los tengo apagados.$1",
"Core.Nora.Spring.Wed.0h": "Vine al valle a trabajar en mi doctorado. Decidí quedarme después de terminarlo.#$b#Este lugar tiene tantas criaturas extrañas y fascinantes... ¡Quizá encuentre una nueva!$1#$b#¿Y si puedo nombrar a una nueva especie yo misma? ¿Qué debería elegir? Estoy pensando... ya se, ¡El Norian!$3#$b#¿Quizá es demasiado halagador?$3#$b#Ah, ya pensare en ello cuando suceda...",
"Core.Nora.Spring.Thu.0h": "%Nora se está tomando un descanso auditivo. Sonrie mientras dice 'Hola' con lenguaje de señas",
"Core.Nora.Spring.Fri.0h": "Sé que hablo mucho de serpientes, pero es solo porque son mi animal favorito.$1#$b#Lo siento si es molesto... Sé que a veces divago mucho.$2#$b#Volvera a ocurrir.#$b#Pero intentaré traerte algunos datos interesantes sobre otros reptiles.",
"Core.Nora.Spring.Sat.0h": "Cuando se tiene un horario académico, no se puede descansar los sábados.$2#$b# ¡Tengo tanto que hacer todo el tiempo!#$b#Investigar es agotador, sobre todo cuando tienes TDAH como yo...$2#$b#Me encanta mi trabajo, mi investigación, mi campo, pero a veces es difícil concentrarse a escribirlo todo.$2",
"Core.Nora.Spring.Sun.0h": "He estado pensando en tener una tortuga.$3#$b#Sí, ya sé que ya tengo a Pinkie Pie y a Stupid pero oye, qué quieres que te diga,¡Me encantan los pequeñines!#$b#No estoy segura de si a Tori le gustaría tener otra mascota en casa.#$b#Quizá debería hacerle una presentación sobre los beneficios...$3#$b#¡Vuelvo enseguida, @!", 

// 0 HEARTS SUMMER

"Core.Nora.Summer.Mon.0h": "El verano es mi estación favorita, pero tengo que tener cuidado con mis mascotas.#$b#Verás, los reptiles son ectotermos, lo que significa que su temperatura depende de la temperatura del ambiente.$4#$b#A diferencia de nosotros, los humanos, no pueden mantener constante su temperatura corporal.#$b#siempre me aseguro de que se sientan lo mejor posible.$1",
"Core.Nora.Summer.Tue.0h": "A veces pienso que Yoba me otorgó el TDAH porque si realmente pudiera concentrarme en las cosas sería imparable.$3#$b#De todos modos, ¡Que tengas un buen día!$1", 
"Core.Nora.Summer.Wed.0h": "Mi serpiente mascota, Pinkie Pie, es una Pantheropis guttatus. Comúnmente conocida como serpiente del maíz#$b#Se llaman así porque se quedan alrededor de los graneros para cazar ratones...#$b#Son inofensivas, no son venenosas en absoluto, no suponen ningún riesgo. ¡De hecho, son muy lindas!$1", 
"Core.Nora.Summer.Thu.0h": "No puedo hablar ahora, lo siento, ¡Demasiado que hacer!",
"Core.Nora.Summer.Fri.0h": "Voy a ir al Salon de Gus más tarde, quiero tomar una bebida fría. Estoy pensando en... ¡Limonada!#$b#¿Pensabas que diría cerveza? Pues te equivocas, no me gusta el alcohol.", 
"Core.Nora.Summer.Sat.0h": "¿Cómo van las cosas en las minas?#$b#Creo que si alguna vez fuera allí estaría muy perdida. Sin embargo, me pregunto si tenemos alguna especie por descubrir allí...$3#$b#¡Avísame si encuentras algún reptil genial!",
"Core.Nora.Summer.Sun.0h": "Los domingos siempre parecen alargarse durante el verano.#$b#Pero, técnicamente, sí. Los días de verano son realmente más largos, después de todo.#$b#Ya sabes, todo eso de la posición del sol. ¡Realmente interesante!$1", 

// 0 HEARTS FALL
"Core.Nora.Fall.Mon.0h": "Cada vez hace más frío...$2#$b#Apuesto a que la pastelería de Lorelai está vendiendo un montón de postres con sabor a calabaza en este momento. Debería pasarme pronto.",
"Core.Nora.Fall.Tue.0h": "Estoy intentando tallar calabazas con retratos de Pinkie Pie y Stupid.#$b#Solo diré que soy mejor investigando que esculpiendo...$1#$b#Si por casualidad te sobra una calabaza te la compro.",
"Core.Nora.Fall.Wed.0h": "¡Realmente necesitaba conseguir algunos ingredientes hoy, pero Pierre está cerrado!$2#$b#Supongo que esperaré hasta mañana. No me gusta Joja, ni un poco.",
"Core.Nora.Fall.Thu.0h": "Ja, bajaste la guardia, ahora te diré un... ¡Dato de reptiles!$1#$b#¿Sabías que las escamas de las serpientes están hechas de queratina?$4#$b#Eso es una proteína. De hecho, es la misma proteína que forma tu cabello y uñas.#$b#¿No es divertido ver las similitudes entre nosotros?",
"Core.Nora.Fall.Fri.0h": "¿Algún plan para el fin de semana?#$b#Probablemente me quede en casa para ponerme al día con la lectura pendiente.#$b#Estoy leyendo un libro genial de ciencia ficción sobre viajes espaciales.$1#$b#Supongo que es agradable leer nuevos géneros aparte de artículos científicos todo el tiempo.",
"Core.Nora.Fall.Sat.0h": "Los árboles están muy bonitos en esta época del año, ¿No lo crees @?$1#$b#Un recordatorio de que las cosas están en un cambio constante. La naturaleza es una verdadera obra de arte.",
"Core.Nora.Fall.Sun.0h": "Por mucho que me disguste el frío, hay algo en el otoño que hace que me sienta inspirada.#$b#No lo sé, las la vibra es... Única.$3", 

// 0 HEARTS WINTER

"Core.Nora.Winter.Mon.0h": "Yoba, está helando. ¡Realmente no me gusta este frío!.$2#$b#La nieve es definitivamente bonita. Sin duda tiene una estética preciosa, pero ¿A qué precio?",
"Core.Nora.Winter.Tue.0h": "Me tomo un descanso de la investigación durante las vacaciones.#$b#¿Y tú? Apuesto a que es difícil cultivar durante el invierno.#$b#Bueno,¡Siempre puedes buscar forraje!$1",
"Core.Nora.Winter.Wed.0h": "Siempre me enfermo en esta época del año.$2#$b#De momento sigo bien, sin embargo, espero que siga así mi sistema inmunológico.#$b#Debería contarle esto a Harvey, ¡Estará orgulloso al saber que todavía estoy sana!.$3",
"Core.Nora.Winter.Thu.0h": "La Fiesta de la Estrella Invernal es un festival encantador, pero los villancicos... No me gustan mucho.$2#$b#¡Están haciendo mucho ruido fuerte todo el tiempo!$5#$b#Supongo que una de las ventajas de ser sorda es que puedo apagar mis audífonos cuando estoy harta..",
"Core.Nora.Winter.Fri.0h": "¡Echo de menos el verano, soy una chica del Team Calor!#$b#Es agradable y cálido, además tenemos arándanos.$1#$b#El verano es el rey de las estaciones.#$b#El invierno es definitivamente el bufón...$3",
"Core.Nora.Winter.Sat.0h": "Estos días tengo que asegurarme de que los recintos de mis reptiles los mantienen calientes.#$b#Se vuelven tan perezosos y apenas consigo verlos.",
"Core.Nora.Winter.Sun.0h": "%Nora se está tomando un descanso auditivo. Es mejor dejarla en paz.",

// 2 HEARTS SPRING

"Core.Nora.Spring.Mon.2h": "Deberías pasarte más a menudo. ¡Stupid te extraña!$1#$b#¿Que cómo lo sé? Bueno, una madre siempre sabe.#$b# ¡No puedes negar mis instintos maternales!$1",
"Core.Nora.Spring.Tue.2h": "Me pregunto si debería unirme a la rutina de ejercicios de Robin en la tienda de Pierre...$3#$b#Debería hablarlo con Caroline. ¡Lo haré más tarde!$1",
"Core.Nora.Spring.Wed.2h": "Cada vez que me acerco al Centro Comunitario juro que veo algo...$3#$b#Lewis me dijo que son ratas, pero no estoy segura.#$b#A menos que haya una nueva variación de ratas verdes y moradas.$3",
"Core.Nora.Spring.Thu.2h": "Cada primavera, hago que Jacob eche un vistazo a mis mascotas.#$b#Ya sabes, para asegurarse de que están bien durante el duro invierno.$1#$b#Nunca he tenido problemas con ellos. ¡Supongo que soy una buena cuidadora de reptiles!#$b#Definitivamente es bueno tener un médico veterinario a la vuelta de la esquina.$1",
"Core.Nora.Spring.Fri.2h": "¿Qué te parece mi atuendo? Intento estar a la altura de la estética académica.#$b#No sé si prefiero el academicismo claro o el oscuro.$3#$b#Pero, de nuevo, ¿Realmente tengo que elegir? ¡Ponga lo que me ponga me veo fabulosa!$1",
"Core.Nora.Spring.Sat.2h": "¿Has oído hablar de la Ave Cantora de Zuzu?#$b#Ella era una famosa cantante de ópera. ¡Es genial!$1#$b#Me encanta dejar que sus canciones suenen de fondo mientras estudio. Me ayuda a concentrarme#$b#Creo que tengo todos sus discos.$3",
"Core.Nora.Spring.Sun.2h": "El océano... Es simplemente hermoso,¿No lo crees @?#$b#Cada vez que lo mires... Quiero que recuerdes...$2#$b# ¡Que las serpientes marinas son algo real allá afuera, cuidado!$1",

// 2 HEARTS SUMMER

"Core.Nora.Summer.Mon.2h": "¡Ya casi es hora de volver a alimentar a Pinkie Pie!$1#$b#Verás, las serpientes pueden expandir sus mandíbulas y tragarse a sus presas enteras...#$b#Esto significa que tardan mucho tiempo en digerir lo que comen.$4#$b#Así que por lo general hay una gran brecha de tiempo entre sus comidas.#$b#¿Te imaginas? Almorzar hoy y luego tener que esperar 2 meses, más o menos.$3#$b#¡Simplemente fascinante!$1",
"Core.Nora.Summer.Tue.2h": "%Nora hace señas de que tiene una pausa auditiva. Y te desea que tenga un buen día.",
"Core.Nora.Summer.Wed.2h": "¡Oh, hola @! Me alegro de encontrarme contigo. Ayer vi un documental que me puso la piel de gallina y quería contártelo.$1#$b#¿Conoces al cocodrilo de agua salada? ¡Es considerado el reptil viviente más grande!$4#$b#El macho puede llegar a medir hasta seis metros. Entiendo por qué la gente tiene miedo, !Pero también es magnífico!$1",
"Core.Nora.Summer.Thu.2h": "De acuerdo, SÉ que estás cultivando arándanos en tu granja.#$b#¿Me traerías algunos? ¿Por favor? ¿Porfiiiis?$1#$b#Quiero intentar hacer una tarta de arándanos.#$b#Aunque si también me traes una tarta de arándanos, tambien te lo agradecería.$3",
"Core.Nora.Summer.Fri.2h": "Los niños no paran de pedirme ver a mis mascotas reptiles.#$b#Es realmente adorable cómo se impresionan cada vez.$1#$b#Hm... Tal vez podría...$3#$b# ¡Acabo de tener una idea genial! ¡Ya vuelvo!$1",
"Core.Nora.Summer.Sat.2h": "Anoche tuve la pesadilla más ¡LOCA!$2#$b#Había un tipo calvo siguiéndome, entonces me propuso matrimonio de la nada.$2#$b#Pero cuando dije que no, ¡Aparecieron mil clones de él y me atraparon!$4#$b#Creo que también vi una cabeza gigante en alguna parte... Uf, necesito café...$2",
"Core.Nora.Summer.Sun.2h": "Todo lo que damos al valle, el valle nos lo devuelve.#$b#Por eso tenemos que tratarlo lo mejor posible. Es nuestro trabajo cuidarlo.$1#$b#Espero que estés haciendo tu parte.",

// 2 HEARTS FALL

"Core.Nora.Fall.Mon.2h": "Uf, ayer me encontré accidentalmente con el Barón Munchington cuando volvía a casa y ahora tengo alergia.$2#$b#Los gatos son criaturas adorables, pero mi nariz parece pensar lo contrario.$2#$b#No dejaré que eso me detenga.",
"Core.Nora.Fall.Tue.2h": "Antes de decidir que quería estudiar herpetología, me planteé ser bióloga marina.#$b#West Harbour tiene un centro marino encantador. Se está haciendo un verdadero trabajo de preservación.$1#$b#Siempre paso por allí cuando voy a visitar a mi prima Lorelai. Es realmente un campo asombroso.#$b#¿Debería obtener otro título?$3",
"Core.Nora.Fall.Wed.2h": "Una vez intenté aprender a tejer. Quería hacer ropa bonita y mullida para ponérmela en la estación fría.$1#$b#Pero el proceso es muy, muy complicado. Me llevó un año aprender lo básico.#$b#En realidad, no creo que sea tan dificil, tal vez sólo soy mala en eso.$3",
"Core.Nora.Fall.Thu.2h": "El otro día, ocurrió algo muy extraño.#$b#Estaba paseando por la playa y juré que veía algo en el agua. Algo extraño...$3#$b#No se parecía a ningún pez o mamífero ordinario del que haya oído hablar.$3#$b#Jum, @ si ves algo, dímelo enseguida, por favor.",
"Core.Nora.Fall.Fri.2h": "Yoba, toda esta situación con el Imperio Gotoro es horrible.$2?#$b#La guerra nunca es buena para ninguna de las partes implicadas. Sólo espero que acabe pronto.$2?#$b#Hoy vi noticias horribles al respecto...$2",
"Core.Nora.Fall.Sat.2h": "¿Te he contado alguna vez que una vez escribí un libro?#$b#Después de licenciarme, me pasé un año entero viajando por la República Ferngill, aprendiendo más sobre su fauna de reptiles y anfibios.$1#$b#Se titula ¡La herpetología de la República de Ferngill! y estoy muy orgullosa de él.$1#$b#Si alguna vez lo encuentras por ahí, dale una oportunidad, ¿Quieres?",
"Core.Nora.Fall.Sun.2h": "Creo que he comido fideos instantáneos demasiadas veces este mes como para considerarlo saludable...$2#$b#Bueno, en mi defensa, no soy una gran cocinera. Y no tengo mucho tiempo para cocinar.#$b#Pero supongo que debería ordenar algo de comida de vez en cuando.$1",

// 2 HEARTS WINTER

"Core.Nora.Winter.Mon.2h": "No creo que vaya a ver ningún camaleón de cola púrpura esta temporada.#$b#Hace demasiado frío y clima seco para ellos. Apuesto a que probablemente estén acurrucados en algún lugar acogedor.$1#$b#Bueno, al menos espero que lo estén. De lo contrario, estarían en una mala posición con este horrible frío.$3",
"Core.Nora.Winter.Tue.2h": "Otro día, otro pañuelo. Y si, por pañuelo quiero decir que tengo gripe de nuevo.$2#$b#Como cada maldito año... ¡Achis!$2",
"Core.Nora.Winter.Wed.2h": "Sé que normalmente soy una chica de café, pero MATARÍA por un chocolate caliente ahora mismo.#$b#¿Sabes si Gus vende?$3#$b#Bueno, apuesto a que Rosa si lo hace así que mas tarde le preguntaré.$1",
"Core.Nora.Winter.Thu.2h": "Hace demasiado frío para caminar hasta el museo.#$b#Por eso prefiero ir a la posada durante el invierno.$1#$b#Es cálido, acogedor y tengo buena compañía. Me agrada mucho Rosa.",
"Core.Nora.Winter.Fri.2h": "Tengo una relación de amor y odio con las vacaciones...$2#$b#Está bien tomarse un descanso, pero tengo TDAH. Me resulta físicamente imposible sentarme y no hacer nada.$2#$b#Suelo utilizar este tiempo para organizar otros proyectos, leer artículos y escribir, porque... ¿Por qué no?$1",
"Core.Nora.Winter.Sat.2h": "¡HEY TU! ¿Quieres oír algo genial?$1#$b#Una cría de víbora se llama vivorezno. ¿No son las cositas más adorables que existen?#$b#Quizás deba conseguir un viborezno de pitón, son una lindura.$1#$b#Y una vez que crezca, le podría hacer compañía a Stupid y Pinkie Pie, ¿No crees?$3",
"Core.Nora.Winter.Sun.2h": "Realmente espero estar haciendo esto bien.$2#$b#Ya sabes, todo el asunto de la investigación. Estaré devastada si no soy capaz de ayudar a esta especie a sobrevivir.$2#$b#Sólo espero hacer una diferencia...$2#$b#Lo siento. El frío me pone de mal humor a veces.$2",

// 4 HEARTS SPRING

"Core.Nora.Spring.Mon.4h": "¿Crees que el TDAH sabe que intento controlarlo?#$b#Porque sigo olvidando ir a buscar mi medicina para eso, será mejor que la tome cuanto antes. Nos vemos @.$3",
"Core.Nora.Spring.Tue.4h": "La primavera es mi estación favorita para disfrutar del bosque mientras investigo.#$b#El bosque el mejor lugar para estar de todo el valle. Tan lleno de flores, sonidos relajantes y tan hermoso.$1#$b#¿Y sabes qué es lo mejor? Que no se te mete arena en sitios donde no debería, como en la playa.$5",
"Core.Nora.Spring.Wed.4h": "Por favor @, ¿Podrías cantarme una canción?. Cualquier canción pegajosa está bien.$2#$b#Hoy en la mañana me ha salido un anuncio de JojaCola mientras veía la programación matutina y no puedo quitarme ee maldito ritmo de la cabeza.$2#$b#¡Y No quiero nada con esta horrible corporación!$5",
"Core.Nora.Spring.Thu.4h": "Clyde me dio cinco tipos diferentes de dolores de cabeza hoy por teléfono.$2#$b#Oh, ¿Que quién es Clyde? ¡Es mi hermano!#$b#Espera, ¿Nunca te dije que tenía un hermano?$3#$b#Bueno cuanto más sepas de mí, mejor.$1",
"Core.Nora.Spring.Fri.4h": "Me encantaría charlar pero tengo trabajos extra y debo terminarlos antes del lunes. ¡No puedo detenerme a charlar!$2",
"Core.Nora.Spring.Sat.4h": "He oído cosas maravillosas sobre tu granja, @.#$b#Es bueno tener agricultores cerca para poder comprar productos frescos. Sigue trabajando duro.$1",
"Core.Nora.Spring.Sun.4h": "A veces me gustaría ser una serpiente hocico de cerdo para hacerme la muerta y evitar mis problemas.$2#$b#¿Qué? ¿Que a qué problemas me refiero? Yo, eh... no es nada, de verdad. No te preocupes.$1#$b#Pero deberías verlas haciéndose las muertas. ¡Realmente son tan adorables!",

// 4 HEARTS SUMMER

"Core.Nora.Summer.Mon.4h": "Ah, estoy tan cansada hoy...$2#$b#Stupid está pasando por su muda. Es un proceso delicado, así que a veces prefiero quedarme despierta con él.#$b#Los reptiles necesitan mudar de piel de vez en cuando porque, si su cuerpo crece, la piel no lo hace. Así que fabrican una nueva capa de piel y se desprenden de la vieja.#$b#También de esa forma se deshacen de los parásitos. ¿No es genial?$1#$b#¡Voy a comprarle algunos bocadillos!",
"Core.Nora.Summer.Tue.4h": "Ahora los niños quieren que mis conferencias sean semanales.#$b#Yo estaría dispuesta a hacerlo. Son realmente adorables y con ganas de aprender.$1#$b#Necesitamos inspirar a las nuevas generaciones.#$b#Además, parece que le agrado mucho a Eloise... No estoy muy segura de por qué, ya que no somos tan cercanas.$3#$b#Ella sigue invitándome a su casa. ¡Quizás debería pasarme por allí!",
"Core.Nora.Summer.Wed.4h": "Últimamente me siento bastante fatigada.$2#$b#Puede que tenga algo que ver con el hecho de que he sobrevivido esta semana gracias a las galletas de chocolate negro, una cantidad muy poco saludable de café expreso y aproximadamente media bolsa de papas fritas.$3#$b#Pero eso es sólo una teoría.$1",
"Core.Nora.Summer.Thu.4h": "El ámbito académico es increíble, pero podría pagar más, ¿sabes?$2#$b#Mi prima me habló de este precioso collar de esmeraldas que encontró. Tiene forma de serpiente. Siento que fue hecho para mí.#$b#Excepto por el hecho de que probablemente cuesta el doble de mis ingresos anuales.$3#$b#Ah, de todas formas yo soy una chica más de bufandas.$1#$b#Dicho esto, ¿sabías que mi cumpleaños es el mes que viene?",
"Core.Nora.Summer.Fri.4h": "¿Cómo puede ser tan bueno todo lo relacionado con el verano?#$b#Los cultivos, la brisa, las lluvias de verano, el ambiente...$1#$b#No hay nada mejor, en verdad.",
"Core.Nora.Summer.Sat.4h": "Oh eres tú @, ¡ Eres justo la persona que estaba buscando!$1#$b#¿Crees que podrías dejarme estudiar tu granja? Me gustaría ver si las condiciones son ideales para las especies nativas de la zona.#$b#Me estoy quedando un poco sin ideas para mi proyecto...$2",
"Core.Nora.Summer.Sun.4h": "Hoy vi la polilla más linda en mi casa.#$b#¿Sabías que estuve a punto de dedicarme a la entomología?$1#$b#Pero quiero decir... serpientes. Realmente no hay competencia.",

// 4 HEARTS FALL

"Core.Nora.Fall.Mon.4h": "¡TIENES QUE VER ESTO!$1#$b#Mira, ¡Una Tetracheilostoma carlae, comúnmente llamada serpiente de hilo!$4#$b#Es la serpiente más pequeña del mundo. ¿No es la cosita mas linda que has visto?$1#$b#Sólo necesitaba enseñarle esto a alguien.",
"Core.Nora.Fall.Tue.4h": "Cada vez que llega el otoño, pienso en que necesito más bufandas.$3#$b#Pero Tori dijo que si consigo más tendré que mudarme porque no habrá sitio en mi habitación.$1#$b#Yo, particularmente, no creo que se puedan tener demasiadas bufandas.",
"Core.Nora.Fall.Wed.4h": "Tuve... Una conversación con Sebastian el otro día, creo?$3#$b#Sí, estoy tan sorprendida como tú.$1#$b#No estaba muy interesado en hablar conmigo. Pero resulta que a los dos nos gustan mucho las ranas.#$b# ¡Y resulta que justamente es temporada de ranas!$1#$b#Así que porfa, @. ¡Ten cuidado con los pequeñines!",
"Core.Nora.Fall.Thu.4h": "¿Con qué frecuencia va a las montañas?$3#$b#Sigo escuchando rumores de que alguien se desmaya constantemente en las minas.#$b#No eres tú... ¿Verdad?$2",
"Core.Nora.Fall.Fri.4h": "Necesito al menos cuatro cafés expresos más antes de poder tener cualquier tipo de interacción social hoy, @.$2#$b#¿Nos vemos luego en el salón?",
"Core.Nora.Fall.Sat.4h": "Sabes, hay algo especial en este valle.$1#$b#Cuando vivía en la ciudad de Zuzu no me había dado cuenta de lo mucho que me gustaba la naturaleza.#$b#Yoba, realmente odiaba el ruido y la contaminación. Definitivamente la vida en la ciudad no es para mí.$1",
"Core.Nora.Fall.Sun.4h": "Hoy me siento bien. ¡Motivada, decidida, lista para conquistar el mundo!#$b#Otro día, otra cacería, ¿Verdad?$1#$b#Mejor disfrutar de esta concentración mientras dure. ¡Nos vemos!",

// 4 HEARTS WINTER
"Core.Nora.Winter.Mon.4h": "Llega de nuevo la temporada de frío...$2#$b#Como un presagio de enfermedad. Un monstruo blanco que pretende atraparnos a todos.$5#$b#¿Cómo se escapa de él...?$2",
"Core.Nora.Winter.Tue.4h": "Espero que Tori esté bien. En esta temporada de frío hay personas que la pasan realmente mal.$2#$b#Resulta que Tori está cuidando de su familia en el extranjero. Estoy cuidando de sus Slimes mientras ella no está.#$b#Para eso estamos las amigas.$1",
"Core.Nora.Winter.Wed.4h": "Rosa es un encanto. Siempre me habla cuando me quedo en la posada estudiando.$1#$b#Es como un santuario. Tan cálido, tan acogedor.#$b#Y tiene excelentes historias que contar.$1",
"Core.Nora.Winter.Thu.4h": "A veces pienso que debería hablar menos. Ya sabes, estar más callada, más... tranquila.$2#$b#Pero, ¿qué gracia tiene eso? El infodumping es mas cool.$1#$b#Bueno, al menos para mí. ¿Para todos los demás? La verdad es que no lo sé.",
"Core.Nora.Winter.Fri.4h": "%Nora parece disgustada. No quiere hablar ahora.",
"Core.Nora.Winter.Sat.4h": "Siento que no pudiéramos hablar ayer... Tengo muchas cosas en la cabeza, eso es todo.$2#$b#Gracias por comprender, @.",
"Core.Nora.Winter.Sun.4h": "Jacob ha sido un ángel últimamente.#$b#Cada invierno, me ayuda con los reptiles. Ya sabes, suministros, bienestar... Lo tiene todo cubierto.$1#$b#No tengo palabras para agradecérselo.",

// 6 HEARTS SPRING
"Core.Nora.Spring.Mon.6h": "Hoy, literalmente, no he conseguido hacer nada.$2#$b#El TDAH estaba actuando más de lo normal. No podía concentrarme en nada.$2#$b#Ugh, ¡Es tan frustrante!$5",
"Core.Nora.Spring.Tue.6h": "¡Hoy Stupid me ha dado un susto de muerte!$2#$b#Estaba limpiando su recinto y lo saqué un momento.#$b#Lo siguiente que sé es que el mi niño está escalando mi estantería más alta. ¿Cómo lo hace?$5#$b#No te preocupes, ha sido recuperado sano y salvo. Ningún gecko resultó herido durante esta limpieza.",
"Core.Nora.Spring.Wed.6h": "Sabes @, realmente te admiro...#$b#Dejar atrás la gran ciudad y venir al valle, empezar de cero en algo completamente distinto a lo que estabas acostumbrado... No debió de ser nada fácil.$2#$b#Pero me alegro de que lo hicieras, me gusta mucho ser tu amiga.#$b#Además es un plus, ¡Tus arándanos son los mejores de este lugar!$1#$b#Hm... porfa no le digas a Pierre que dije eso.$3",
"Core.Nora.Spring.Thu.6h": "Hay muy pocas veces que echo de menos vivir con mis padres. Muy, muy pocas.#$b#Porque, ya sabes, independencia y... Esas cosas.$2#$b#Pero hoy... Oh, que daría por una de las famosas limonadas rosas de mi madre...$2#$b#Ella siempre ha sido una gran cocinera. Me pregunto por qué no conseguí nada de esa habilidad.$3",
"Core.Nora.Spring.Fri.6h": "¡Ja! ¿Pensabas que te daría un dato curioso sobre serpientes? Pues te equivocas...#$b#¡Te daré un dato curioso sobre cocodrilos!$1#$b#¿Sabías que, al igual que los gatos, las madres cocodrilo cargan a sus crías con su hocico?#$b#¿No es adorable? A la mayoría de la gente no le gustan sus colmillos, pero es bonito ver sus instintos maternales.$1",
"Core.Nora.Spring.Sat.6h": "Nunca pensé que se pudiera tomar demasiado café, pero... Creo que hoy he llegado a mi límite.$2#$b#Quizás las cosas estén peor de lo que pensaba.$2",
"Core.Nora.Spring.Sun.6h": "Tengo mis sospechas de que estoy desarrollando algún tipo de intolerancia a la lactosa...$3#$b#¿Pero sabes qué? Creo que prefiero vivir en la ignorancia.$1#$b#Nadie me privará del pastel de chocolate, ¿Me oyes? ¡Nadie!",

// 6 HEARTS SUMMER
"Core.Nora.Summer.Mon.6h": "Eloise no para de pedirme que vayamos a la playa. La verdad es que se me están acabando las excusas para no ir.$2#$b#No me gusta, pero no le puedo decir que no a esa niña. ¡Es tan adorable!#$b#Además, Vincent me contó unas historias muy interesantes sobre un monstruo... Puede que deba investigar eso.$3",
"Core.Nora.Summer.Tue.6h": "¿Quieres saber algo gracioso?$1#$b#Cuando discuto con Clyde, a veces me harto y apago mis audífonos.#$b#Lo malo es que él conoce lenguaje de señas. Por lo que si insiste en discutir, mejor cierro los ojos.#$b#¿Qué puedo hacer entonces? Ah, esa es la verdadera experiencia de hermanos.$1",
"Core.Nora.Summer.Wed.6h": "Ojalá el puesto de helados estuviera todo el año.#$b#¿Por qué sólo podemos comprar helados en verano? ¿Los antojos de helado son exclusivos del tiempo caluroso?$3#$b#Yo, por mi parte, nunca rechazaría un helado de arándanos.$1",
"Core.Nora.Summer.Thu.6h": "Ayer fui a visitar a Maru. Hablaba de su último invento.#$b#No suelo entender mucho porque no sé absolutamente nada de mecánica. Y también se me dan muy mal las matemáticas.$1#$b#Pero no le digas que he dicho eso. Será nuestro secreto, ¿Vale?#$b#Sólo te lo cuento porque somos amigos.$1",
"Core.Nora.Summer.Fri.6h": "A veces empiezo frases y ni siquiera sé adónde quiero llegar con ellas.#$b#Sólo espero descubrirlo por el camino.$1#$b#El viaje siempre es divertido, ¿No te parece?",
"Core.Nora.Summer.Sat.6h": "¿Crees que te interesaría aprender el lenguaje de signos, @? Quiero decir, si no lo sabes ya.$1#$b#Sería una buena forma de comunicarnos mientras me tomo uno de mis descansos auditivos.#$b#También podríamos utilizarlo para jugar al ahorcado en completo silencio mientras estamos en la biblioteca.$1",
"Core.Nora.Summer.Sun.6h": "@, ayer hice el descubrimiento más fascinante.#$b#Me acabo de dar cuenta de que me gustan mucho las telenovelas.$1#$b#El drama que hay detrás de todo... Las absurdas revelaciones... Todo encaja a la perfección.#$b# Por favor, por favor, veamos una juntos algún día.$1#$b#¡Yo invito las palomitas!",

// 6 HEARTS FALL
"Core.Nora.Fall.Mon.6h": "Oh @, ¿Leah es tu amiga?#$b#Desde que he empezado a pasear más por el bosque, he ido conociéndola más. Podría decir que somos... ¿Amigas?$3#$b#Me ha enseñado mucho sobre la búsqueda de alimentos. ¿Quién iba a decir que se podía encontrar tanta comida en la naturaleza?$1",
"Core.Nora.Fall.Tue.6h": "Hablé con Tori anoche. Realmente la extraño.$2#$b#Su viaje está siendo más largo de lo que esperábamos. Pero lo que importa es que ella y su familia están bien, ¿No?#$b#Bueno, @. Ya te avisaré cuando vuelva.",
"Core.Nora.Fall.Wed.6h": "Últimamente he estado pensando...$3#$b#Bromeo mucho sobre lo de hablar demasiado, pero en realidad temo en secreto ser muy pesada.$2#$b#Si alguna vez empiezo a molestarte @, por favor, dímelo ¿vale?$2#$b#Me ha pasado antes con otras personas. Pero oye... está bien, lo entiendo.",
"Core.Nora.Fall.Thu.6h": "Hoy, una vez más, he utilizado mi dinero de adulto, que gano con mi trabajo de adulto, para tomar sabias decisiones financieras.#$b#En otras palabras, tengo tres nuevos calcetines de serpiente y una lámpara de luna.$1#$b#Y, eh, algunas bufandas nuevas...$3#$b#Las compras online matarán a mi billetera. Pero quiero decir, ¡Serotonina del día garantizada!",
"Core.Nora.Fall.Fri.6h": "Esta temporada me trae recuerdos de mi mamá...#$b#Le encanta el otoño. Es su estación favorita.#$b#Siempre me preparaba una taza de chocolate caliente para entrar en calor. ¡Con malvaviscos y todo!$1#$b#Y luego ella me decía... Ah, sabes no importa.$2#$b#Realmente la extraño. Tal vez debería llamarla alguna vez.",
"Core.Nora.Fall.Sat.6h": "Acabo de darme cuenta de que no te he contado ni un dato curioso esta semana. ¿Cómo pude olvidarlo?$3#$b#¿Sabías que las ranas fueron los primeros animales terrestres en tener cuerdas vocales?#$b#Lo utilizan por varias razones, ya sea para encontrar pareja o para ahuyentar a los depredadores.$1#$b#Quiero decir, Sebastian tiene toda la razón al gustarle tanto las ranas.",
"Core.Nora.Fall.Sun.6h": "He decidido que, esta temporada, por fin me pondría a ver alguna película de miedo.#$b#Y estoy, de hecho, fracasando de miserablemente.$1#$b#Definitivamente, los documentales me gustan más.",

// 6 HEARTS WINTER
"Core.Nora.Winter.Mon.6h": "Apuesto a que el invierno es una época dura para tu granja, ya que no tienes cultivos que plantar. Debes encontrar otras fuentes de ingresos.$2#$b#Pero, para ser justos, el invierno es una época difícil para cualquiera.#$b#Yoba, odio el frio. ¿Alguna vez te lo he dicho?$2",
"Core.Nora.Winter.Tue.6h": "@, ¿qué crees que es mejor para cenar esta noche? ¿Sopa de patata con puerro o sopa de cebolla con queso?$3#$b#La sopa se está convirtiendo rápidamente en mi especialidad ahora que estoy intentando aprender a cocinar.#$b#No dudes en pedirme un poco si quieres. Siempre termino haciendo comida demás.$1",
"Core.Nora.Winter.Wed.6h": "%Nora se está tomando un descanso auditivo. Te saluda alegremente.",
"Core.Nora.Winter.Thu.6h": "Oh @, que cuentas?#$b#Yo, actualmente estoy releyendo uno de mis libros favoritos para esta época del año: Un cuento de Estrella invernal.#$b#Mi parte favorita es cuando el espíritu de La estrella invernal pasado visita al protagonista. Es realmente reconfortante ver cómo se convierte en un hombre mejor.$1",
"Core.Nora.Winter.Fri.6h": "Nunca creí que fuera verdad, pero hoy ese canal de la tele ha dicho que iba a tener un día de mala suerte.#$b#Y entonces Clyde llamó. Eso tiene que ser una señal, ¿Verdad?$3#$b#Tal vez los espíritus de la fortuna me persiguen...$3#$b#¿Oh? Oh no, sólo estoy bromeando. En realidad aunque a veces peleamos, nos llevamos muy bien.$1",
"Core.Nora.Winter.Sat.6h": "Sabes @, Ni siquiera recuerdo cómo era este valle antes de que llegaras.#$b#El lugar ya era increíble, ¡Pero es como si lo hubieras hecho mucho más increíble!$1#$b#Realmente agradezco poder ser tu amiga.",
"Core.Nora.Winter.Sun.6h": "Estoy intentando pensar en qué propósitos quiero comprometerme para el año que viene...$3#$b#Siempre es difícil... Sé que hay muchas cosas en las que podría mejorar, pero la cuestión es cómo conseguirlo.$2#$b#Oye, tal vez podría comprometerme a ser más molesta.$1#$b#Jaja, solo estoy jugando. No te preocupes.",

// 8 HEARTS SPRING
"Core.Nora.Spring.Mon.8h": "Los niños parecen realmente contentos de que pase más tiempo en casa. He intentado enseñarles pequeños trucos.#$b#El favorito de Stupid es hacerse el muerto. Que sin duda voy a usar la próxima vez que alguien vaya a mi casa.$1#$b#Claro que no les diré que es un truco, eso le quitaría la gracia, ¿No lo crees?$3",
"Core.Nora.Spring.Tue.8h": "Oh @, adivina qué?#$b#Clyde dice que podría venir a visitarme pronto. ¡Quizás puedas conocer por fin a mi hermano!$1#$b#Sólo... ponte algo elegante, ¿De acuerdo?#$b#Lo digo por tu propio bien.$2",
"Core.Nora.Spring.Wed.8h": "Me siento un poco deprimida hoy... Realmente todavía quiero encontrar el camaleón de cola púrpura por ahí.#$b#Pero, ¿Cuándo es el momento de dejar de buscar? ¿Cómo lo sabré?$2#$b#Es triste pensar que podemos perder especies enteras así...$2",
"Core.Nora.Spring.Thu.8h": "Realmente no estoy acostumbrada a la levantarme muy temprano. ¿Eh? ¿Qué quieres decir con que no tengo que madrugar?$3#$b#A veces simplemente no lo puedo evitar. En mi tiempo libre leo o veces simplemente me paso toda la mañana mirando al techo...#$b#¿Quién hubiera pensado que estar desempleada me llenaría de éstos eventos, ¿Verdad?$1",
"Core.Nora.Spring.Fri.8h": " @, ¿Seguirías siendo mi amigo si fuera una serpiente?$3#$b#Anoche tuve un sueño raro en el que me convertían en serpiente. Y entonces todo el mundo me ignoró para siempre.#$b#Así que, ya sabes, te lo pregunto por si llega a pasar.$1",
"Core.Nora.Spring.Sat.8h": "¿Sabías que sólo el 2 porciento de las serpientes son peligrosas para el ser humano?#$b#Es decir, a pesar de su mala fama, dos tercios de las serpientes del mundo no son ni siquiera venenosas.$1#$b#En total, solo hay entre 30 y 40 especies de serpientes que representan un peligro real para el ser humano.",
"Core.Nora.Spring.Sun.8h": "Hay un nuevo programa de televisión sobre dinosaurios que se estrenó anoche.#$b#Los dinosaurios son completamente inexactos, los efectos especiales son los peores que he visto, la trama es cada vez más absurda en cada capítulo.#$b#¡Creo que encontré mi nueva serie favorita!$1",

// 8 HEARTS SUMMER
"Core.Nora.Summer.Mon.8h": "Creo que tener demasiado tiempo en las manos y poco dinero en la cuenta bancaria es una combinación peligrosa.$2#$b#Dicho esto, ¡Estoy deseando que llegue mi nuevo marco de mariposas!$1#$b# ¡Y mi lámpara serpiente!#$b#¡Y... mi pijama de cocodrilo!$2#$b#Y... Quizás tengo un problema$3",
"Core.Nora.Summer.Tue.8h": "@, ¿De qué sabor crees que soy?$3#$b#Hoy me he despertado con esta pregunta en la cabeza. No sé de dónde ha salido.#$b#Harvey dijo que probablemente soy limón. No sé si le gustan las cosas con limón o si es una forma sutil de decirme que soy agria... Lo que sea que eso signifique.$3",
"Core.Nora.Summer.Wed.8h": "Creo que iré a observar aves con Eloise esta semana.#$b#Ella está muy emocionada por contarme todo sobre sus amigos de la pajarera. ¡Es tan adorable!$1#$b#Somos como mejores amigas de infodumping si lo piensas.",
"Core.Nora.Summer.Thu.8h": "Mi estúpido audífono ha decidido dejar de funcionar por completo en mitad de la noche.$2#$b#Por suerte tenía uno de repuesto. Puede que consiga uno nuevo hasta el fin de semana.#$b#",
"Core.Nora.Summer.Fri.8h": "Debo decir, @...$2#$b#La vida me parece mucho más ligera ahora que no tengo sobre mis hombros el peso de mis propias expectativas.#$b#Incluso este aire de verano se siente más fresco. Yo sólo...#$b# ¡Me siento muy bien! Aún no me he acostumbrado.$1",
"Core.Nora.Summer.Sat.8h": "¿Sabías que cuando un lagarto o una serpiente saca la lengua, en realidad están captando partículas de olor del aire para percibir el aroma de las cosas?#$b#Así que cuando les veas sacar la lengua, no te está haciendo una grosería, te están analizando.$1#$b#Bueno, a decir verdad creo que es un poco gracioso.",
"Core.Nora.Summer.Sun.8h": "Oye, ¿Crees que todavía necesito ir a terapia ahora?$3#$b#No sé, parece que he resuelto todos mis problemas pero Clyde dice que todavía los tengo.$2#$b#Y que no debería 'fingir que no están ahí' o 'actuar como si me hubiera curado'. Lo que sea que eso signifique.#$b#A decir verdad creo que nada mas me está molestando. ¡Me siento completamente bien!",

// 8 HEARTS FALL
"Core.Nora.Fall.Mon.8h": "Oh, hola @. ¡Tengo noticias emocionantes! ZuCU se ha puesto en contacto conmigo y me ha preguntado si quería dar una conferencia para los estudiantes de biología.$1#$b#Creo que voy a aceptar. ¿Crees que sería una buena profesora?#$b#Es decir, básicamente es una excusa para hablar durante horas sobre herpetología con gente al azar, cosa que ya hago a diario.#$b#¡Pero me pregunto si les agradaré! Y si lo entenderán todo...$3#$b#Supongo que sólo hay una forma de averiguarlo.",
"Core.Nora.Fall.Tue.8h": "¡Es temporada de ranas otra vez! Ya he visto tres esta misma mañana.$1#$b#Es maravilloso que podamos ver a los pequeñines paseando por el pueblo. ¿Cómo puede alguien ver una rana y no alegrarse inmediatamente?#$b#Son criaturas tan divertidas. Como yo, no lo crees @?.$1",
"Core.Nora.Fall.Wed.8h": "Uf, he estado teniendo dolores de cabeza cada dos días porque no estoy tomando tanta cafeína como antes.$2#$b#A veces me mareo.$2#$b#Pero no se lo digas a Harvey, me hará hacerme análisis de sangre y esas cosas. Todos sabemos cómo terminaría eso.#$b#¿Quién me iba a decir que beber 4 tazas de café en lugar de 10 me haría pasar un mal rato?$3",
"Core.Nora.Fall.Thu.8h": "¿De qué me disfrazaré este año en la Vispera de los Espíritus?$3#$b#Quería ir de algo diferente este año, pero el traje de Medusa me está llamando...#$b#¡Y lo mejor es que Pinkie Pie puede participar en él!$1#$b#A quien quiero engañar, no hay lugar para dudas. ¡Será de medusa!.",
"Core.Nora.Fall.Fri.8h": "Lo siento @... Me siento un poco deprimida hoy.#$b#No sé por qué, supongo que a veces sigo agobiándome.$2#$b#Es como si mi mente no se callara, incluso cuando no pasa nada.$2#$b#Hablaremos en otro momento, ¿Vale?",
"Core.Nora.Fall.Sat.8h": "Esta época del año siempre me hace pensar...$3#$b#Crees en fantasmas, @?#$b#Oh, por ninguna razón en particular. Simplemente aveces pienso en eso.$1#$b#Si existen los fantasmas, no me extrañaría que rondaran por el valle.#$b#Este lugar está lleno de secretos...$2",
"Core.Nora.Fall.Sun.8h": "Lo juro por Yoba, ¿Cómo me las arreglo para coger la gripe todos los años cuando empiezan las estaciones frías?$2#$b#¿Para qué sirve tener un sistema inmunológico? ¡Osea, tienes un solo trabajo!$5#$b#Ugh, Tengo que comprar más pañuelos. Puedo sentirlo venir.$2",

// 8 HEARTS WINTER
"Core.Nora.Winter.Mon.8h": "No me hables. Anoche tuve el calambre más doloroso, desgarrador y traumatizante. Siento que me dejó una cicatriz de por vida.$2#$b#Todavía me estoy recuperando.$2",
"Core.Nora.Winter.Tue.8h": "¿Crees que puedo convencer a alguien para que vea una película conmigo hoy?$3#$b#Aún es martes, pero me apetece hacer un fuerte de mantas y comer palomitas. Hace demasiado frío para estar afuera.#$b#¿Te interesaría por casualidad?$1",
"Core.Nora.Winter.Wed.8h": "Hoy he intentado construir un muñeco de nieve. Bueno, técnicamente, ¿Una serpiente de nieve?$3#$b#De todos modos, terminó siendo una simple pila de nieve porque mis manos comenzaron a congelarse después de cinco minutos. Y me moqueaba la nariz.#$b#Yo realmente odio el invierno.$2",
"Core.Nora.Winter.Thu.8h": "Mi misión hasta final de mes es probar todos los tipos de chocolate caliente que se me ocurran.#$b#Ayer probé uno con naranja, clavo y anís estrellado. Fue una de las cosas más deliciosas que he hecho nunca.#$b#Por favor, pásate por mi casa algún día y te lo prepararé. ¡Y podemos ponernos al día!$1#$b#Mis reptiles también te extrañan.",
"Core.Nora.Winter.Fri.8h": "Hoy he leído un artículo muy interesante sobre los cocodrilos. Son tan geniales, ¡Parecen dinosaurios caminando por el planeta!#$b#¿Sabías que puedes distinguir entre caimanes y cocodrilos mirándo su hocico cerrado?#$b#Si sólo puedes ver los dientes superiores, tienes un caimán. Si también puedes ver los dientes inferiores, ¡Es un cocodrilo!$1#$b#Será mejor que Tori rece a Yoba para que no me hiperfije en estos tipos a continuación. No creo que a ella le agrade tener uno como mascota.$3",
"Core.Nora.Winter.Sat.8h": "A veces me gustaría que pudiéramos cambiar de color de pelo como hacen los animales.#$b#¿Sabías que, cuando llega el invierno algunos animales cambian su pelaje por una versión blanca para camuflarse mejor con el entorno?$3#$b#Qué genial sería que nosotros también lo hiciéramos.$1#$b#Lo siento, es que tengo demasiado tiempo libre y no paro de pensar en cosas así.#$b#Yoba, realmente necesito un trabajo.$2",
"Core.Nora.Winter.Sun.8h": "¿Sabes lo que creo que sería divertido? Si tuviéramos un gran árbol comunitario de estrellas de invierno en el centro de la ciudad al que todos pudiéramos añadir pequeñas baratijas.#$b#Si podemos hacerlo con la sopa, ¿Por qué no también con la decoración?$3#$b#Aunque no creo que a Lewis le guste. Es un aguafiestas.$2",

// 10 HEARTS SPRING
"Core.Nora.Spring.Mon.10h": "---",
"Core.Nora.Spring.Tue.10h": "¿Me extrañaste ayer?#$b#Extraño muchísimo el valle cada vez que paso el día en la ciudad de Zuzu. ¡Es mucho mejor aquí!#$b#¡Pero REALMENTE estoy amando el trabajo! No tengo quejas en ese departamento.$1#$b#El departamento de herpetología, quiero decir. Porque soy simplemente buena en lo que hago.",
"Core.Nora.Spring.Wed.10h": "Creo que Gunther me pedirá que reorganice la sección de astronomía hoy.#$b#¿Crees que debería hacerlo alfabéticamente o por autor? Creo que el autor es mejor, pero algunas personas piensan lo contrario.$3#$b#Un día lo haré por color sólo para ver la expresión de su cara.$1",
"Core.Nora.Spring.Thu.10h": "Me dejo llevar mucho cuando compro en Pierre's. Es un peligro, sinceramente.#$b#No me puedo permitir llegar tarde a mi trabajo. Pero hay tantas cosas interesantes.$1#$b#Y cuando veo todas esos ingredientes empiezo a pensar en todas las recetas que podría hacer con ellos.#$b#Luego tengo que hacer un mapa mental para planificar las comidas de la semana.$3#$b#¿Ves por qué es peligroso?",
"Core.Nora.Spring.Fri.10h": "Ahora entiendo mucho más el atractivo de los fines de semana.#$b#Quiero decir, cuando estaba haciendo investigaciones, no me importaba si era sábado o domingo, porque lo haría de todas formas.$3#$b#Entiendo, tenía una fecha límite. Pero ahora tengo días libres... ¿Y sabes lo que eso significa?#$b#Puedo investigar más. ¡Pero esta vez, únicamente porque quiero!$1",
"Core.Nora.Spring.Sat.10h": "Realmente estoy considerando usar este tiempo libre para escribir un nuevo libro.$3#$b#Anteriormente ya había escrito uno y estoy bastante orgullosa de ello.$1#$b#Aunque, si lo hago sería como conseguir un tercer trabajo a estas alturas... Lo pensaré.$3",
"Core.Nora.Spring.Sun.10h": "Me siento rara andando sin la constante ansiedad y presión que puse sobre mis hombros durante todos esos años.#$b#Por supuesto, todavía tengo ansiedad, sólo que por otras razones.$3#$b#...Lo siento, eso surgió de la nada. A veces es algo raro.$2",

// 10 HEARTS SUMMER
"Core.Nora.Summer.Mon.10h": "---",
"Core.Nora.Summer.Tue.10h": "Oh hola @. Sabes, ayer tuve que dar una conferencia sobre mi tesis doctoral, ¡Fue muy emocionante!.$1#$b#Recuerdo cuando solía ser una estudiante en conferencias como esas... Parece como si hubiera ayer.$3#$b#¿Crees que inspiraré a alguien a dedicarse a la vida académica? Ese es mi sueño.$1",
"Core.Nora.Summer.Wed.10h": "Trabajando en el museo estoy empezando a ser amiga de más personas.#$b#Lo cual es irónico, porque son las mismas personas que solía ignorar por completo mientras estudiaba.$3#$b#No a propósito, por supuesto. ¡Pero ahora tengo conversaciones con ellos!#$b#Pero no te preocupes @, tú sigues siendo mi mejor amig.$1",
"Core.Nora.Summer.Thu.10h": "Pinkie Pie hizo literalmente la cosa más divertida e increíble que una serpiente podría hacer esta mañana.#$b#¡Ni siquiera te lo he contado aún! Aunque creo que no me vas a creer de todos modos.#$b#Ni yo misma lo creería si no lo hubiera visto con mis propios ojos.$3#$b#Lo siento, tendrás que quedarte con la duda, jaja.",
"Core.Nora.Summer.Fri.10h": "Esta ha sido una semana difícil en el trabajo. Hay mucho que hacer.$2#$b#Lo único que quiero es la hamburguesa más grande jamás hecha en la historia de la humanidad y una taza gigantesca de limonada.$2#$b#Y tal vez una barra de chocolate. Y... un poco de café.#$b#D¿Crees que Gus tendrá todo eso?$3",
"Core.Nora.Summer.Sat.10h": "Por mucho que amo el verano, los mosquitos me están MATANDO.$2#$b#Creo que me queda como 1 litro de sangre. El resto se lo han chupado.$3#$b#Y llevo repelente como si lo necesitara para sobrevivir. Lo cual creo que hago.$3#$b#SLo siento, ¿Demasiada información? ¡Simplemente estoy enojada con esos bichos!$2",
"Core.Nora.Summer.Sun.10h": "Mañana llevaré a Stupid a mi lección. Él será nuestro modelo.$1#$b#La universidad tiene muchos reptiles pero creo que este es su momento de brillar.#$b#¡El ama toda la atención que recibe!$1#$b#Y puede ver otros geckos, lo que es muy bueno para sus habilidades sociales.",

// 10 HEARTS FALL
"Core.Nora.Fall.Mon.10h": "---",
"Core.Nora.Fall.Tue.10h": "Lo siento, hoy me levanté tarde y no tuve tiempo de preparar café. Espero encontrar alguno en el camino.#$b#Podemos hablar más tarde, ¿Si? Todavía no soy una persona despejada.",
"Core.Nora.Fall.Wed.10h": "En teoría, ahora que tengo un trabajo adecuado, podría tener otra mascota, ¿Verdad?#$b#Y teóricamente, como no tengo uno, sino DOS trabajos, podría tener DOS nuevas mascotas...$3#$b#Y si consigo otro gecko, no cuenta, porque podrían compartir las cosas de Stupid... Entonces podría tener TRES nuevos chiquitines...$3#$b#Ya sabes lo que dicen, ¡El corazón de una mamá siempre es lo suficientemente grande para uno más! ¡O tres mas!?$1",
"Core.Nora.Fall.Thu.10h": "Debería dar otra clase para los niños, ha pasado un tiempo desde la última.#$b#Jas pide sin parar saber más sobre los animales, tiene un alma muy curiosa.$1#$b#Ahora es una cuestión de acomodar mi horario, de verdad. ¡El momento no es el mejor, pero haré que funcione!",
"Core.Nora.Fall.Fri.10h": "Ya sabes, las serpientes tienen un cráneo diferente al nuestro.#$b#El cráneo humano es principalmente un gran trozo de hueso. Diseño clásico.#$b#Los cráneos de las serpientes tienen múltiples huesos, por lo que les resulta más fácil tragarse a sus presas enteras.#$b#¿Qué tan genial sería si pudiéramos hacer eso?$1#$b#Por supuesto que no me tragaría a nadie, simplemente me gusta su estética.$3#$b#¡Muy útil para comer en el festival de los espíritus!$1",
"Cora.Nora.Fall.Sat.10h": "Esta mañana hacía un poco más de frío... Lo puedo sentir...$2#$b#El invierno se acerca.$2#$b#Será mejor que me abastezca de medicinas a partir de ahora. A partir de aquí las cosas sólo empeoran.$2#$b#Si no me ves por ahí, asume que estoy muriendo en casa como un enfermizo huérfano victoriano.$2",
"Core.Nora.Fall.Sun.10h": "Estoy preparando la conferencia más sorprendente y entretenida para mañana.#$b#¿Quieres verla? ¡Tal vez podrías venir más tarde y te mostraría las diapositivas!$1#$b#Extraño salir contigo. Eres básicamente mi persona favorita, ¿Lo sabías?",

// 10 HEARTS WINTER
"Core.Nora.Winter.Mon.10h": "---",
"Core.Nora.Winter.Tue.10h": "Tener clases durante el invierno debería ser ilegal.$2#$b#Los estudiantes no quieren estar allí, YO no quiero estar allí.$2#$b#Todo lo que queremos hacer es acurrucarnos bajo las mantas y tomar una buena bebida caliente en nuestras casas.$2#$b#Apuesto a que tu hogar es bastante acogedor en esta época del año. ¡Quizás te visite uno de estos días!",
"Core.Nora.Winter.Wed.10h": "Encontré un libro nuevo en la biblioteca que realmente me gusta. Definitivamente me lo llevaré a casa hoy.$1#$b#¿De que se trata? Oh, ya te diré-#$b#Bueno, en realidad... Hm...$3#$b#Escucha. Tiene dos dragones peleando en la portada. No necesitaba mucho más que eso para convencerme.",
"Core.Nora.Winter.Thu.10h": "Mi ansiedad está aumentando hoy.$2#$b#Supongo que todavía me siento un poco... Incompleta.$2#$b#No sé si un sentimiento como este desaparece alguna vez.$2#$b#Pero creo que es posible aprender a vivir con ello. Por muy molesto que sea.",
"Core.Nora.Winter.Fri.10h": "Pronto deberé comprarme un nuevo audífono.$3#$b#El que tengo ahora está muriendo lentamente, me temo.#$b#Ayer, Tori me pidió que le comprara huevos. Ahora tengo un montón de cebos y no sé qué hacer con ellos.$2#$b#Quizás se los regale a Willy. A él le gustan estas cosas.$3",
"Core.Nora.Winter.Sat.10h": "¡Oh, pero si es mi persona favorita en todo el mundo!$1#$b#Para que lo sepas, creo que luces muy bien hoy.#$b#No olvides tomarte un desanso de vez en cuando, ¿Vale?#$b#Sigo escuchando rumores de que te desmayaste en medio de la noche. Eso es preocupante, ¿Sabes?$2",
"Core.Nora.Winter.Sun.10h": "¿Puedes creer que tomé una siesta hoy? !UNA SIESTA!#$b#En este momento de mi vida pensé que era una leyenda urbana. ¿Dormir a medio día?$1#$b#¿Duermes suficientes siestas? Si no, ¡Deberías hacerlo! Sinceramente, cambia completamente la vida.#$b# Podríamos tener una cita para tomar una siesta si quieres...$1#$b#Uh, quiero decir... como... ¡C-Como amigos, por supuesto! ¿Como... una tarde de siestas?$3#$b#¿Sabes que? Tengo que irme. ¡Adiós!$2",

// 10 HEARTS SPRING - DATING
"Core.NoraD.Spring.Mon.10h": "---",
"Core.NoraD.Spring.Tue.10h": "¡Hola cariño! Me alegro de verte por aquí.$1#$b#Estaba pensando en pasar por tu casa más tarde. Le pedí a Tori que cuidara a mis niños.#$b#¿Qué te gustaría, pizza o ramen?",
"Core.NoraD.Spring.Wed.10h": "¡Guau, la investigación realmente está a toda velocidad esta semana!#$b#Estamos más cerca que nunca de secuenciar el genoma del camaleón de cola morada.$1#$b#¡Eso sería enorme y ayudaría con el proceso de desextinción!#$b#Incluso podríamos obtener un premio por eso algún día. ¡Imagínate eso!$1",
"Core.NoraD.Spring.Thu.10h": "Cariño, he estado pensando en comprarle un nuevo terrario a Stupid. Se ha estado portando mal últimamente.#$b#Tal vez esté celoso de ti. ¿Crees que es algo que una noche de cine podría solucionar?$3#$b#Le gusta la de Cretaceous Park. La primera, por supuesto.$3#$b#¡Nos vemos más tarde, calabacita!",
"Core.NoraD.Spring.Fri.10h": "¡Oye, tú! Oh, me muero por contarte más sobre la investigación en la escuela.#$b#¡Siento que estamos cerca de algo grande!$1#$b#Están pensando en enviar más miembros de ZuCU a la isla y estudiar más del ecosistema.$1#$b#En tiempos como estos, todos tenemos que enfrentarnos a grandes corporaciones como Joja.#$b#¡Cuanta más información para hacerlo, mejor!",
"Core.NoraD.Spring.Sat.10h": "Hola cariño. Oye, Penny me ha pedido una conferencia para los niños esta semana.#$b#¿Puedo practicarla contigo?#$b#Quiero decir, realmente no necesito más práctica, pero me encantaría pasar tiempo contigo.$1",
"Core.NoraD.Spring.Sun.10h": "Se me acaba de ocurrir algo loco: ¿Te he dicho alguna vez que la lengua de los camaleones tiene huesos?#$b#¡El esqueleto hiogloso está modificado en una extensión llamada proceso entogloso, es hermoso!$1#$b#¿Te imaginas si tuviéramos eso? Porque yo lo hago. Todo el tiempo.",

// 10 HEARTS SUMMER - DATING
"Core.NoraD.Summer.Mon.10h": "...",
"Core.NoraD.Summer.Tue.10h": "¡Yoba, este verano se siente como el más caluroso hasta ahora!$2#$b#Hm... ¿crees que es porque estamos saliendo?$3#$b#Quiero decir, ERES muy caliente. Debe ser eso.#$b#Lo siento, no pude resistirme..$1",
"Core.NoraD.Summer.Wed.10h": "Esta época del año siempre me da ganas de ir a la playa.#$b#Es como si olvidara por qué no me gusta en primer lugar.$3#$b#Luego planeo todo, voy y lo recuerdo: arena. siempre es la arena.$3",
"Core.NoraD.Summer.Thu.10h": "¿Alguna vez piensas en el hecho de que la luna que vemos hoy es la misma que vieron los dinosaurios hace un millón de años?#$b#Porque lo hago... todo el tiempo...$2#$b#Eso es todo. Voy a ver la peli de Dinosaurio otra vez.$1#$b#¿Quieres unirte a mí?",
"Core.NoraD.Summer.Fri.10h": "Ahora que estoy contigo, descubrí algo. El verano odia el romance.$3#$b#Piénsalo. Cualquier otra estación es mejor si nos abrazamos.$3#$b#Pero durante el verano, es como si ambos estuviéramos en un horno.$2#$b#En la casa de una bruja muy, muy malvada que odia el amor.#$b#Yoba, ¡No puedo esperar al otoño!",
"Core.NoraD.Summer.Sat.10h": "'Popular... You're gonna be popular...'#$b#'I'll teach you the proper poise when you talk to boy-...' Oh, hola amor.#$b#Lo siento, tengo la nueva canción de Twisted metida en la cabeza otra vez.$1#$b#Esta va a ser tu vida a partir de ahora. Acostúmbrate.",
"Core.NoraD.Summer.Sun.10h": "Sabes, cuando empiezas la universidad, y escribes tu primer trabajo... #$b# Piensas wow. Esto es difícil. Muy difícil. Pero mejorará.#$b#Bueno, ¿adivina qué? No mejora.$1#$b#Si tengo que formatear sólo una cita más me voy a volver loca. LOCA, ¿me oyes?",

// 10 HEARTS FALL - DATING
"Core.NoraD.Fall.Mon.10h": "...",
"Core.NoraD.Fall.Tue.10h": "@, ¡La clase de ayer fue TAN DIVERTIDA!$1#$b#Me siento tan poderosa... formando mentes jóvenes así...#$b#Y esta clase es simplemente... ¡increíble! ¡Están tan ansiosos por aprender!$1#$b#¿Crees que algún día estaré enseñando a Jas, Eloise o Vincent en ZuCU?$1#$b#Yoba, sólo de pensarlo me emociona.",
"Core.NoraD.Fall.Wed.10h": "¡Olvidé decírtelo!#$b#El lunes, mientras estaba en la ciudad, encontré EL esmalte de uñas verde perfecto.$1#$b#Ahora sólo necesito, ya sabes. Aprender a pintarme las uñas. ¿Crees que Haley podría enseñarme?$3",
"Core.NoraD.Fall.Thu.10h": "Oye, ¿con quien crees que nos emparejamos para la Víspera de los espíritus de este año?$1#$b#¡Tu y yo podríamos ser dinosaurios! ¡Sólo, ya sabes, grandes trajes de dinosaurio!$1#$b#¡Te daré algo de tiempo para que lo pienses! Pero, ten algo en cuenta: Ya los compré.",
"Core.NoraD.Fall.Fri.10h": "Maldita sea, puedo sentirlo...$2#$b#Esa sensación repentina... como una mano fría... con dedos helados y fuertes...$2#$b#Va a pasar. Me está dando gripe otra vez.$1#$b#¿Puedo ir a tu casa más tarde? ¿Y me preparas chocolate caliente? ¿Por favor? ¿Por favor?$1",
"Core.NoraD.Fall.Sat.10h": "¡Mira esto! Lo encontré escondido en el museo.$4#$b#¡Es sobre el Ferngill prehistórico!#$b#¿Has oído hablar alguna vez del Terror Ferngill? Sí, era una serpiente ENORME que solía vagar por el valle. Hablo de 10 metros. Habla de muchas otras especies también. ¡Yoba, sé que voy a tener que leer todo esto hoy!$1",
"Core.NoraD.Fall.Sun.10h": "Estoy pensando en iniciarme al yoga. ¿Qué dices?#$b#Realmente parece relajante y me vendría bien.#$b#Una vez, intenté meditar para ayudarme con mi ansiedad. Pero me puse ansiosa porque estaba tardando demasiado.$3#$b#Bueno, ¡tal vez lo vuelva a intentar!",

// 10 HEARTS WINTER - DATING
"Core.NoraD.Winter.Mon.10h": "...",
"Core.NoraD.Winter.Tue.10h": "¡Uf, lo siento amor, estoy tan apurada hoy!$2#$b#Estamos tratando de hacer todo lo que podamos antes de las vacaciones en ZuCU.$3#$b#¡Es mucho, pero te prometo que al final valdrá la pena!$1#$b#Te veo luego, ¿de acuerdo?",
"Core.NoraD.Winter.Wed.10h": "Jeje... Tengo un secreto.#$b#¿Sabes qué? No debería decir nada.$3#$b#Está bien, está bien. Ya te tengo un regalo para La Estrella Invernal.$1#$b#¡No, no te voy a decir qué es!#$b#...¿Quieres una pista?$3",
"Core.NoraD.Winter.Thu.10h": "¿Qué crees que hacen los peces cuando el lugar donde viven está congelado?$3#$b#Ya sabes, y todos siguen nadando dentro. Quiero decir, TIENEN que darnos un buenos chismes.$3#$b#¡La última vez que escuché, que una prueba de paternidad fue peor de lo que debería!",
"Core.NoraD.Winter.Fri.10h": "¡Hola bebé! ¿Quieres que nos encontremos en el salón para tomar algo esta noche? #$b#¡Estoy pensando en un capuchino!#$b#Ese realmente fue uno de nuestros mejores inventos. Y por nuestro, me refiero a la raza humana.$1#$b#El juntar café, leche, chocolate y canela... Simplemente brillante. Realmente genial.$1$b#Es como el pan de ajo. ¿Hay algo mejor?$1",
"Core.NoraD.Winter.Sat.10h": "Pinkie Pie y Stupid se vuelven muy flojos en esta época del año.#$b#Pero quiero decir, lo entiendo. Si yo fuera una serpiente e hiciera tanto frío afuera, también pasaría todo el día durmiendo.$1#$b#No es que tengan responsabilidades ni esas cosas.#$b#Realmente están viviendo el sueño, ¿eh?$3",
"Core.NoraD.Winter.Sun.10h": "Oye... Sólo quiero decir...$2#$b#Hiciste que este año fuera mucho mejor. Gracias por todo.#$b#¡Tengo muchas ganas de que llegue el próximo año para poder pasarlo contigo!$1",


/// FESTIVALS (DAY BEFORE)
"Core.Nora.EggFestival": "Oh, hola @! ¿Vas a ir mañana al Festival del Huevo?#$b#Es un gran problema por aquí. ¡La gente se vuelve realmente competitiva!$1#$b#Así es esto, viva la competencia.",
"Core.Nora.FlowerDance": "En realidad, nunca he sido bueno bailando. O cualquier cosa que realmente implique ritmo.#$b#Pero me gusta la parte de usar un lindo vestido. Lleva algo elegante, ¿Quieres @?$1",
"Core.Nora.Luau": "¿Qué llevarás el día de mañana?$1#$b#Oh, solo tengo curiosidad. Nunca me verás comiendo de esa sopa..",
"Core.Nora.MoonlightJellies": "Los Lunaloos son criaturas absolutamente fascinantes.#$b#Me gusta pedir deseos para que se los lleven al mar por mí. A veces incluso les tiro algo como regalo.$1#$b#¡Nunca algo que pueda contaminar el mar, por supuesto! Debemos preservar nuestros ecosistemas.",
"Core.Nora.SDVFair": "La feria realmente estimula el turismo en el valle.$1#$b#El primer año aquí hice un puesto de reptiles, ya sabes, fósiles y esas cosas.#$b#¡Pinkie Pie incluso hizo una aparición en vivo!$1#$b#Pero este año no tuve tiempo, así que disfrutaré de la feria.",
"Core.Nora.SpiritsEve": "Oh, tengo una sorpresa para el festival de mañana...#$b#No te diré que es, ¡Ve al laberinto y lo descubrirás!$1",
"Core.Nora.IceFestival": "De alguna manera, en el Festival del Hielo parece hacer incluso más frío que en el resto del invierno.$2#$b#¡Definitivamente me abrigaré!$2#$b#¿Crees que la gente me juzgaría si llevara una manta conmigo?$3",
"Core.Nora.NightMarket": "Creo que esta podría ser mi fiesta favorita.#$b#El misterio, las curiosidades, las cosas que venden...#$b#¡Incluso puedes subir al submarino! He visto algunas cosas fascinantes ahí abajo.#$b#¡Estoy muy emocionada por el evento de este año!",
"Core.Nora.WinterStar": "¡Mañana es la estrella de invierno! Espero que hayas tenido un año maravilloso en el valle.$1#$b#No puedo esperar a ver los regalos. Espero conseguir algo realmente genial este año. Ya sabes, ¿Relacionado con los reptiles quizás?#$b#Las posibilidades son infinitas... pantuflas de dinosaurio... chaleco de cocodrilo... collar de serpiente...$3#$b#¡No puedo esperar!$1",

/// FESTIVALS DIALOGUE - VANILLA

// EGG FESTIVAL
"Festivals.Nora.EggFestival.1": "Creo que para hacer las cosas más interesantes deberíamos utilizar huevos de codorniz.#$b#Son mucho más pequeños y dificiles de encontrar.#$b#¡Sería divertido ver a Abigail intentar encontrarlos!$1",
"Festivals.Nora.EggFestival.2": "Si Lewis me dejara participar en esto, te aseguro que ganaría.#$b#No enserio, quiero decir, ¡Te derrotaría, destruiría y quemaría hasta los malditos hueso-$1#$b#... Ejem. Si, creo que soy un poco competitiva. Ahora sé porqué Lewis no me deja participar.$3",

// FLOWER DANCE
"Festivals.Nora.FlowerDance.1": "Sé que a mi prima, Lorelai, le encantaría un festival como este.#$b#E.0lla es del tipo romántico. Yo en cambio...#$b#¿Ya has encontrado pareja? Eres tan encantador, estoy seguro de que te será fácil.$1",
"Festivals.Nora.FlowerDance.2": "Soy consciente de que esto es una tradición, pero ¿No sería bonito si cambiáramos un poco el baile cada año?$3#$b#¡Podríamos tener una competencia de baile. Con diferentes estilos!$1#$b#Oh, definitivamente yo podría hacer break dance, estoy segura de ello.",

// LUAU
"Festivals.Nora.Luau.1": "¿Cómo hemos permitido nosotros, como sociedad, que la gente coma de una olla con Yoba sabe qué?$5#$b#Podrían verter veneno allí y nadie lo sabría hasta que alguien cayera muerto.$3#$b#No es que yo lo haya pensado. Yo nunca cometería un asesinato...#$b#No sin ninguna razón, quiero decir.$1",
"Festivals.Nora.Luau.2": "¿Sabes que? He decidido probar la sopa este año.#$b#La vida es demasiado corta para tener miedo cualquier tipo de comida extraña.$1#$b#Si muero, diles a todos que Pinkie Pie y Stupid son mis herederos legales.",

// MOONLIGHT JELLIES
"Festivals.Nora.MoonlightJellies.1": "Aunque no son mi campo de especialización, como son Cnidarios, siempre me han gustado mucho los Lunaloos. Son tan pequeños, brillantes y esféricos.#$b#A esos pequeños les encanta brillar. ¿No es algo con lo que se puede identificar uno?$1#$b#A mi también me gustan las cosas brillantes, aunque para serte sincera prefiero las cosas con escamas",
"Festivals.Nora.MoonlightJellies.2": "Los Lunaloos son un animal común en esta zona, y esta migración es natural para su comportamiento. Todo se trata de ciencia.$1#$b#Pero, cuando estoy aquí, mirando todo esto... Esperando a que pasen...#$b#¿No te parece la cosa más mágica? Tenemos tanta suerte de ver esto.$1",

// SDV FAIR
"Festivals.Nora.SDVFair.1": "Tengo una colección especial de pelucas solo para este día.#$b#Acudo a la adivina como diferentes alter egos para ver si su respuesta cambia.$1#$b#Deberías oír el destino de mi buen amigo, McJebediah Ahoy.#$b# ¡Sí, es marinero! ¿Qué lo delató?$3",
"Festivals.Nora.SDVFair.2": "¡Hey @! ¿Disfrutando de la feria?$1#$b#Mi personaje para el adivino de este año se inspiró en un programa que vi. Es el Dr. Mattathias Medicalschool.#$b#Como te podrás imaginar, es un doctor.$1#$b#Y aparentemente tiene MUCHAS cosas que hacer este año.$3",

// SPIRIT'S EVE
"Festivals.Nora.SpiritsEve.1": "¡Ja! ¿Te gusta mi disfraz?#$b#Amo a Medusa. ¡Ella no recibe el trato que se merece!#$b#Ah, también, Pinkie Pie está aquí. ¡Di hola Pinkie Pie!#$b#Oh, a ella le agradas mucho",
"Festivals.Nora.SpiritsEve.2": "Psst, no se lo digas a nadie, pero agregué una serpiente al laberinto.#$b#No te preocupes, ella es una actriz profesional. Ella misma me pidió que lo hiciera.$1#$b#¿Que cómo lo sé? Tengo mis métodos.",

// ICE FESTIVAL
"Festivals.Nora.IceFestival": "Definitivamente NO estoy hecha para el clima frío.$2#$b#BPero todavía vengo todos los años. Me gusta ver a todos los vecinos.#$b#Y hay un fuego acogedor aquí así que... no está del todo mal.$1",
"Festivales.Nora.IceFestival.2": "Así que, este año he decidido no estar cerca del fuego y venir a construir un muñeco de nieve en su lugar.$1#$b#Y ahora me arrepiento de todas y cada una de las decisiones vitales que he tomado y que me han llevado a este momento.#$b#Puede que no lo parezca, pero estoy a punto de congelarme.$2",

// WINTER START
"Festivals.Nora.WinterStar": "¡Feliz estrella del invierno!$1#$b#Recibí algunos sombreros graciosos para Pinkie Pie y Stupid como regalos. ¡Deberías ver qué lindos se ven!#$b#¡Espero que tú también recibas un regalo muy a la moda!$1#$b#Quizás podríamos conseguir suéteres a juego...$3",
"Festivales.Nora.WinterStar.2": "¡Feliz Estrella de Invierno! Este año tengo un regalo extra para ti. Una historia.#$b#¿Recuerdas que te dije que no me gusta mucho el alcohol? Sí, verás...#$b#Esto se debe a que, durante mi primer Winter Star en el valle, me pasé un poco y... bueno...$3#$b#Digamos que Lewis pide a la gente que no baile sobre las mesas todos los años por mi culpa.$2#$b#No es mi momento de mayor orgullo.$2",

// NIGHT MARKET
"NightMarket.Nora.1A": "Estoy pensando si debería entrar o no en el submarino.#$b#En este momento, es la curiosidad, el sentido de aventura y de investigadora que hay en mí versus el miedo devastador de morir aplastada o ahogada.$3#$b#...Si, quizás el próximo año.$1",
"NightMarket.Nora.1B": "¡Este festival es el mejor de todos! ¡Este es uno de los mejores cafés que he probado en mi vida!$1#$b#Definitivamente pediré receta de esto. ¿Crees que me la darán?$3",
"NightMarket.Nora.2A": "La playa es mucho más tolerable en invierno que cualquier otro día.#$b#Irónico, ¿No? Odio la playa, excepto cuando hace frío. Pero odio el frío, excepto cuando estoy en la playa.$1#$b#¿Qué puedo decir? Soy una chica de muchos misterios.#$b#De todos modos, ¿Viste las pinturas? ¡Son muy lindas este año!",
"NightMarket.Nora.2B": "El vendedor no quiso darme su receta. Lo cual entiendo totalmente, no me malinterpretes.#$b#Ahora estoy intentando adivinarla probando tantas tazas como pueda.#$b#Siento un toque de canela... Y podría ser...$3#$b#...¿Nuez moscada?$3#$b# Oh que rayos, ¡Dame otra taza!",
"NightMarket.Nora.3A": "He estado pensando en el espectáculo de sirenas que montan todos los años.#$b#¿Crees que las sirenas serían consideradas mamíferos o peces?$3#$b#¿Tendrían los mismos derechos que nosotros? ¿Tendrían que luchar por ellos?$3#$b#Son tantas implicaciones...$3",
"NightMarket.Nora.3B": "Quizás beber tanto café durante tres noches seguidas no fue mi mejor idea.$2#$b#Definitivamente mi horario de sueño está desordenado. Estoy teniendo pesadillas dignas de un Oscar.#$b#¡Y lo haría de nuevo!$1",

/// FESTIVALS DIALOGUE - CUSTOM FESTIVALS

"Festivals.Nora.LoveFestival": "Realmente no estoy buscando el amor en este momento. Tengo otras prioridades y estoy feliz como estoy.#$b#Pero me gusta asistir a este festival. Es lindo ver a todas las parejas siendo tan románticas.$1#$b#¿Simplemente no amas el amor?",
"Festivals.Nora.SurfingFestivals": "Quizás debería intentar participar al menos una vez...$3#$b#Ya sabes, sólo para ver a qué se debe todo este alboroto. ¡Pero parece un poco peligroso!#$b#Quiero decir, estas olas son realmente impredecibles. ¡La gente podría resultar gravemente herida!$2#$b#Dicho esto, te deseo mucha suerte.$1",
"Festivals.Nora.FireworksFestival": "@, realmente TIENES que probar la comida aquí.#$b#El takoyaki es increíble. Y creo que el yakisoba podría ser uno de mis platos favoritos de todos los tiempos.$1#$b#Por supuesto, los fuegos artificiales también son geniales. Los colores chispeantes y brillantes siempre son un éxito para mí, sabes.",
"Festivals.Nora.RidgesideGathering": "No tengo ni idea de qué está haciendo Maru aquí.$2#$b#Pero ella ha estado planeando esto todo el día. Apuesto que será genial.#$b#Sólo soy la amiga que da apoyo emocional. ¡Vamos chicas!$1",
"Festivals.Nora.EmberOfResolutions": "Esta hoguera es tan acogedora cada año... Y tan brillante...#$b#Definitivamente compensa subir hasta aquí con este frío.$1#$b#¿Ya pusiste tu tronco ahí, @? Es algo muy importante, ya sabes.",
"Festivals.Nora.FerngillFashionFestival": "",
"Festivals.Nora.Marketpalooza": "Este es realmente el único día en el que puedo beber 6 tazas de café en 30 minutos y nadie puede juzgarme.$1#$b#Bueno, quiero decir, nadie puede juzgarme DEMASIADO.$3#$b#Ya sabes, ¡Porque el dinero se destina a obras de caridad. Estoy haciendo esto por la causa, lo juro!#$b#Además, Nikolai vende los fantásticos tarros de miel que elabora. ¿Qué es lo que no me encanta de este festival?$1",

/// GIFTS

// BASIC GIFT RESPONSE
"Gift.Nora.GiftReaction.Love": "¡Esto es asombroso! ¡Muchas gracias, esto me hace tan feliz!$1",
"Gift.Nora.GiftReaction.Like": "¡Oh vaya, esto es genial! ¡Lo pondré en un lugar seguro!",
"Gift.Nora.GiftReaction.Neutral": "Gracias, esta bonito.",
"Gift.Nora.GiftReaction.Dislike": "Este... Gracias, supongo.$2",
"Gift.Nora.GiftReaction.Hate": "Lo siento, pero ¿Por qué me diste esto? Esto es asqueroso.$5",

// BIRTHDAY GIFT RESPONSE
"Gift.Nora.GiftReaction.Birthday.Love": "¿Esto es un regalo de cumpleaños? ¿Te acordaste?#$b#Eres la persona mas dulce del mundo, ¡Gracias! ¡Gracias! ¡Gracias!$1",
"Gift.Nora.GiftReaction.Birthday.Like": "¡Te acordaste de mi cumpleaños! ¡Gracias!$1",
"Gift.Nora.GiftReaction.Birthday.Neutral": "¡Aw, Lindo regalo! gracias",
"Gift.Nora.GiftReaction.Birthday.Dislike": "Oh, no debiste molestarte. Enserio... No debiste.$2",
"Gift.Nora.GiftReaction.Birthday.Hate": "Esto es simplemente cruel de tu parte, que te pasa?!$5",

// DUMPSTER DIVING
"CT.Nora.DumpsterDiving": "Oh, esto... sa-$7#$b#¿Sabes qué? No quiero saber. Ten un buen día.$7",

// DATING
"CT.Nora.Reject": "Oh, uh... oye.$2#$b#Lo siento, solo... todavía estoy lidiando con todo esto, ¿sabes?$2#$b#¿Podrías darme algo de tiempo para simplemente... procesarlo?$2",
"CT.Nora.BreakUp": "...¿Qué?$2#$b#Yo... Realmente pensé que estábamos bien...$2#$b#No... Lo entiendo. Solo...$2#$b#Espero que encuentres lo que estás buscando.$2",
"Gift.Nora.GiftReaction.RejectPendant": "...Oh, @.$2#$b#Lo siento. No puedo hacer eso.$2#$b#Realmente me importas, pero nunca me vi... casándome o teniendo hijos.$2#$b#Espero que lo entiendas.$2",

// STRINGS

"Strings.Nora.ClinicAppointment.1": "Cada vez que vengo a mi cita en la clínica me gusta ponerme al día con Maru.#$b#Somos CientificAmigas.$1",
"Strings.Nora.ClinicAppointment.2": "¡Achis!, la gripe. Me atrapa todos los años.$2#$b#¿Ya te pusiste las vacunas?",
"Strings.Nora.ClinicAppointment.3": "Por favor que no me pidan un análisis de sangre. Por favor, odio las agujas.$2",
"Strings.Nora.Research.1": "La cosa con la búsqueda de camaleones es que son muy buenos camuflándose.$2#$b#¡Hey, avísame si encuentras uno!",
"Strings.Nora.Research.2": "A los camaleones les gusta la humedad, entonces, ¿Qué mejor lugar para investigar que cerca del río?$1#$b#Además, hay que comprobar las propiedades de esta agua.$3",
"Strings.Nora.Research.3": "También es bueno variar mis ubicaciones al investigar.#$b#Quizás me estoy perdiendo algo aquí.",
"Strings.Nora.Research.4": "Está empezando a hacer más frío...#$b#Los camaleones deberían estar en sus nidos o escondidos ahora mismo.$1",
"Strings.Nora.Saloon": "Trato de ir al salón de vez en cuando, incluso cuando estoy ocupada.#$b#Es bueno relajarse un poco. Y además puedo hacer amigos.$1#$b#Apuesto a que notaste que me gusta hablar, eh?",
"Strings.Nora.Studying": "%Nora parece no escucharte. Ella está concentrada.",
"Strings.Nora.Gunther.1": "Gunther acaba de hablarme de sus estudios.#$b#Tiene algunas historias realmente interesantes que contar.$1",
"Strings.Nora.StudyRain": "Por mucho que me gustaría quedarme en casa todo el día, el deber me llama.#$b#Pero puedo ver a algunos amigos, así que es agradable.$1",
"Strings.Nora.Pets.1": "Oh, Pinkie Pie es tan divertida. Mírala.$1#$b#Al principio no le gustan los extraños, pero pronto se acostumbrará a ti, estoy segura.",
"Strings.Nora.Pets.2": "Creo que le agradas a Stupid. Saca la lengua cuando alguien le cae bien.", 
"Strings.Nora.Pets.3": "Mis niños son muy flojos durante el invierno.#$b#Mira, Stupid está tomando una siesta. ¡Que adorable!$1#$b#Apuesto a que es bastante cálido y acogedor allí.",
"Strings.Nora.TownBridge.1": "Realmente me gusta relajarme aquí.#$b#Veo a los peces y hago pequeñas historias sobre ellos.$1#$b#¿Ves a ese rojo de ahí? Si, se acaba de divorciar#$b#Y déjame decirte que la batalla legal por la custodia de 30 pecesitos es desagradable...$3",
"Strings.Nora.TownBridge.2": "@! ¡Genial, justo a tiempo para los últimos chismes sobre peces!$1#$b#Ese pececito rosado de ahí... Acaba de descubrir que su novio la estaba engañando.#$b#Es un bastardo, ¿Verdad? Es ese rojo de ahí. ¿Y adivina quién era la amante?#$b#¡Su hermana! ¡Así es! Esa morada que finge que todo está bien allí.$5#$b#Yoba, realmente amo este show.",
"Strings.Nora.Inn.1": "Es agradable tener un lugar tan acogedor justo al lado de mi casa.#$b#Puedo estudiar y comer pasteles deliciosos. Es lo mejor de ambos mundos.$1",
"Strings.Nora.Inn.2": "Me estoy poniendo al día con Rosa.#$b#Me está dando una de sus recetas para que intente cocinarla.$1#$b#Aunque probablemente fracasaré al hacerlo. ¡Pero vale la pena intentarlo!",
"Strings.Nora.Inn.3": "El invierno es la estación perfecta para el chocolate caliente, no crees?$1#$b#Definitivamente deberías probar el de Rosa. ¡Ella realmente sabe como prepararlo!",
"Strings.Nora.Reading.1": "No hay nada como una lectura ligera después de una larga semana.#$b#Has oído hablar alguna vez de este libro, @? ¡Es uno de mis favoritos!$1",
"Strings.Nora.Reading.2": "Los días lluviosos son perfectos para quedarse en casa y leer.$1#$b#El sonido de la lluvia es tan relajante... Y me da una excusa para vestir mi mantita por la casa.",
"Strings.Nora.Coffee.1": "El café por la mañana es imprescindible. No puedo vivir sin él.$1#$b#Todos los días pruebo una nueva bebida de café. Luego lo califico del 1 al 10 en mi cuaderno.#$b#Quizás algún día publique algo al respecto...$3",
"Strings.Nora.Coffee.2": "Esta va a ser una semana intensa...#$b#Tengo que tomar mis seis tragos diarios de espresso para poder superarla.$1#$b#No intentes hacer esto en casa.",
"Strings.Nora.Busy.1": "%Nora está ocupada ahora mismo. Ella está muy concentrada.",
"Strings.Nora.Busy.2": "%Nora está trabajando en algo. No se le debe molestar.",
"Strings.Nora.Coffee.3": "Estoy intentando beber un poco menos de café. Ya sabes, desde ahora puedo irme a la cama a una hora razonable.#$b#Así que ahora en lugar de 6 tazas, me bebo 3.$1",
"Strings.Nora.CoffeeInn": "Este es definitivamente el mejor lugar para tomar una bebida caliente.#$b#Por favor, no le digas a Gus que dije eso...$1",
"Strings.Nora.Library.1": "Ahora que terminé mis estudios, estoy tratando de leer más sobre diferentes temas.#$b#Estoy pensando en... ¡Algo de entomología hoy!$1#$b#¿O debería optar por las prácticas funerarias del mundo?$3#$b# Oh, lo siento! No quise ser sonar siniestra, sólo tengo curiosidad.$1",
"Strings.Nora.Library.2": "Hoy voy a leer este libro sobre folklore.#$b#No estoy segura de si realmente creo en la magia, pero me gustan las historias de cualquier manera.$1#$b#Quién sabe, tal vez sean ciertas.",
"Strings.Nora.Gunther.2": "No estoy segura de que a Gunther le guste que yo tenga más tiempo libre. Sigo bombardeándolo con preguntas.$3#$b#Bueno, ¡No se puede silenciar a un alma curiosa!$1",
"Strings.Nora.PinkiePie": "¡Oh, definitivamente parece le agradas a Pinkie Pie!$1#$b#Solo no te tomes como algo personal que se esconda bajo las hojas, simplemente le gusta estar allí.",
"Strings.Nora.Stupid": "¿Quieres intentar alimentar a Stupid alguna vez? A él realmente le gustan los grillos.#$b#¡Te pometo que no te morderá!$1",
"Strings.Nora.Beach": "He estado tratando de ampliar mis horizontes... Ya sabes, todo esto de salir de tu zona de confort.#$b#Dicho esto, todavía odio pisar la arena. Pero puedo admirar la playa desde aquí mismo.$1",
"Strings.Nora.Reading.3": "Descubrí que me gustan mucho los libros de terror.#$b#La Casa Maldita de Junimo es mi libro mi favorito. ¡Puedo prestartelo si quieres!$1",
"Strings.Nora.Research": "Oh, todavía no voy a renunciar a mi plan original. Si es posible, me gustaría encontrar el camaleón de cola morada.#$b#Me lo voy a tomar con calma, ¿Sabes?$1#$b#Serás la primera persona en saber si encuentro uno, te lo prometo.",
"Strings.Nora.Jacob": "Oh @, ¿Estás aquí para un control de tus mascotas?$1#$b#Vengo muy a menudo para hablar sobre el cuidado de los reptiles con Jacob. Y para ponerme al día también, por supuesto.#$b#Es un hombre muy agradable. Y Eloise también es encantadora. Ella dice que soy una adulta genial.$1",
"Strings.Nora.Pierre.1": "Arándanos, arándanos... Yoba, ¿Por qué es tan difícil encontrar cosas con sabor a arándanos aquí?$2#$b#Bien, simplemente llevaré chocolate.$2",
"Strings.Nora.Pierre.2": "No. Ya no compraré más fideos instantáneos.$2#$b#Seré una verdadera chef. Cocinaré una pasta a la Bolognesa.#$b#No estoy segura de haber dicho eso bien.$3",
"Strings.Nora.Saloon.2": "Gus es un salvavidas. Cocina tan bien que comería aquí todos los días si pudiera.$2#$b#Desafortunadamente, sólo soy una académica, realmente no puedo gastar tanto dinero, ¿Verdad?",
"Strings.Nora.Saloon.3": "He estado tratando de entender cómo funciona este juego. Incluso estoy tomando notas.$1#$b#Hasta ahora no tengo nada.",
"Strings.Nora.Inn.4": "Siento que la gente se pierde este ambiente al no venir a la posada. Éste es un lugar tan encantador.#$b#Y Rosa es un amor. Incluso soporta mi charla incontrolable.",
"Strings.Nora.ESLake": "El sueño de mi vida es que una rana se mude a este pequeño estanque.#$b#Imagínate tener una rana como vecina. Ese debería ser el sueño de todos.",

// strings for after she gets a job cause I'm losing count of how many are here already

"Strings.Nora.Coffee.4": "Ayer llegué a casa tan tarde desde la ciudad de Zuzu... Quizás necesite una dosis extra de café hoy.#$b#Me distraje con la biblioteca de allí. Es tan grande que la he extrañado mucho.$1",
"Strings.Nora.Working.1": "Bueno, parece que tengo mucho que hacer hoy. Organizarme para la investigación de mañana, revisar los archivos antiguos...$3#$b#¿Quizás podamos ponernos al día en otro momento?",
"Strings.Nora.Bridge.3": "Oh, ¿estás aquí para la última actualización?#$b#Entonces, aparentemente, ese pez rojo de allí tiene un hermano gemelo que NO conocía.#$b#Y ahora se pelean por ese pez rosado. Y no puede decidir cuál de los hermanos quiere.$1#$b#Oh sí, todos son gay.",
"Strings.Nora.Researching": "Ah, también sigo al día con mi trabajo de investigación.$1#$b#Quién sabe, es probable que el Norian todavía esté ahí fuera, ¿Verdad?",
"Strings.Nora.FinishWork": "¡Ya casi terminamos el día! ¿Quieres pasar el rato después de esto?#$b#Vamos, te invitaré a cenar. Soy básicamente millonaria ahora que tengo un trabajo real.$3#$b#Ah, solo estoy bromeando, por supuesto. Pero sí, ¡Hagamos planes algún día!$1",
"Strings.Nora.Bridge.4": "Este episodio de Fish Gossip ha sido genial hasta ahora. No esperaba tanto drama.$3#$b#Ese salmón de allí acaba de decirle a su marido que los bebés no son suyos.#$b#Sospecho que la trucha de ahí atrás... ciertamente parece sospechoso.$3",
"Strings.Nora.Friday": "Bueno, supongo que se acabó la semana$1#$b#¿Vas a descansar este fin o seguirás trabajando en la granja?#$b#¿También es importante que descanses, sabes?$1",
"Strings.Nora.Saloon.4": "Me encanta lo animado que se pone este lugar cada viernes.#$b#Espera, tengo que presentarle mi idea de bebida a Gus. Sin alcohol, con sabor a manzana verde y temática de serpiente.#$b#Se llamará Apple Rattle.$1",
"Strings.Nora.Jacob.2": "Oh, hola @! Espero que tus mascotas se encuentren bien.#$b#Sólo estoy aquí para charlar un poco. Una de mis especialidades.",
"Strings.Nora.Book": "Este libro está empezando a no tener sentido.$3#$b#Probablemente sea señal de que es hora de dormir.",
"Strings.Nora.QuietReading": "%Nora está leyendo y no te nota. El libro tiene pájaros en la portada.",

"Strings.Nora.CommunityDay.1": "He estado escondiendo pequeñas serpientes en el cristal del Centro Comunitario hasta que alguien se de cuenta.#$b#Llevo 37. ¡No se lo digas a nadie!$1",
"Strings.Nora.CommunityDay.2": "¿Sabes qué sería genial durante el Día de la Comunidad? ¡Una fiesta de misterio y asesinato!$1#$b#Definitivamente podría organizarlo. ¿Crees que la gente participaría?$3",
"Strings.Nora.CommunityDay.3": "Voy a ayudar a los niños con sus trajes de Víspera de los espíritus este año.$1#$b#¡Tengo que encontrar algo de inspiración aquí!",
"Strings.Nora.CommunityDay.4": "Oh, @!$1#$b#Sólo quería agradecerte nuevamente por restaurar este lugar.#$b#He podido conocer a todos un poco mejor.#$b#Además, mira este fantástico libro de recetas que encontré.$4",

"Strings.Nora.GreenRainPinkiePie": "Puede sentir que algo no está bien.$3#$b#¡Espero que no esté demasiado asustada!$2",
"Strings.Nora.GreenRainStupid": "Sí, no tiene absolutamente ninguna idea de lo que está pasando.#$b#Oh, la ignorancia es felicidad.$1",

"Strings.Nora.PrideInTheValley": "Nunca pensé que tendríamos un festival del orgullo en el valle, ¡Pero estoy muy feliz de que lo hagamos!$1#$b#¿Has probado el Muffin de Bi-Arándano y Chocolate? Se siente realmente cómo mezclan ambos sabores, es la mejor comida aquí.",

"Strings.Nora.SpiritsEveInn.1": "¡Me alegro de que estés aquí!$1#$b#La fiesta del pueblo es genial, pero la Víspera de los Espíritus en la posada tiene algo especial.#$b#¡Diviértete, @! Y ten cuidado con los monstruos ocultos, por supuesto",
"Strings.Nora.SpiritsEveInn.2": "No me gusta mucho la leche, sobre todo cuando hay café, pero me encanta el café con leche con especias de calabaza. Sabe exactamente a otoño y a horrores más allá de la comprensión humana al mismo tiempo. Exactamente como se pretendía.$1",
"Strings.Nora.SpiritsEveInn.3": "Uf, creo que ya he comido demasiados dulces. Probablemente me quede despierta toda la noche.$2#$b#Bueno, ahora que estoy aquí, no hay razón para contenerse más ¿verdad?$1#$b#¿Puedes pasarme esos granos de caramelo de ahí por favor? Ah, y un poco de chocolate ya que estás",

// MINI MAP
"MiniMap.House.Name": "Casa de Tori y Nora",

// RECIPES
"Bagi.Nora.PickleCornDog": "Corn dog de pepinillo",
"Bagi.Nora.PickleCornDog.Description": "Un pepinillo cubierto con una masa cremosa y luego frito en aceite bien caliente.",
"Bagi.Nora.SpicyPizza": "Pizza picante",
"Bagi.Nora.SpicyPizza.Description": "La misma base que una pizza común, pero con chile habanero como cobertura. ¡Muy picante!",

/// GIFT REACTIONS - VANILLA ITEMS

"Gifts.Nora.Coffee": "¡Oh vaya, muchas gracias!$1#$b#Ahora estoy a sólo una taza de mi dosis diaria. ¡Eres un salvavidas!",
"Gifts.Nora.BlueberryTart": "Estoy literalmente muy muy feliz. ¡Este es mi postre favorito!$1#$b#No era necesario que me dieras esto, pero ciertamente me alegro de que lo hayas hecho.",
"Gifts.Nora.TripleShotEspresso": "Esto es exactamente lo que necesitaba antes de sumergirme en mi investigación de hoy.#$b#¡Ah, @. Siempre sabes cómo animarme!$1",
"Gifts.Nora.SnakeSkull": "¿Esto es... lo que creo que es?$2#$b#¡Qué descubrimiento tan increíble! ¿Y me lo estás dando? ¿De verdad?$1#$b#Debo agradarte mucho mucho. Pondré esto en un lugar especial.",
"Gifts.Nora.ChocolateCake": "¡Gracias! ¿Cómo supiste que se me antojaba un pastel de chocolate?$1#$b#No hay nada lo suficientemente malo que un buen trozo de pastel de chocolate no pueda solucionar.",
"Gifts.Nora.PumpkinPie": "Esto... sabe exactamente a otoño.$1#$b#Los postres con sabor a calabaza son mis cosas favoritas del otoño, ¿Sabes?#$b#Bueno, eso, las vibraciones espeluznantes y el hecho de que es temporada de ranas.$1#$b#Eh, tal vez simplemente me gusta el otoño...$3",
"Gifts.Nora.Emerald": " ¡¡MIRA ESO!! ¡Es tan hermosa!$1#$b#El verde es mi color favorito. Créeme cuando te digo que atesoraré esta gema, gracias.",
"Gifts.Nora.Strawberry": "Cualquier cosa hecha con fresas sabe increíblemente bien.#$b#Lástima que no sé cocinar.$2",
"Gifts.Nora.Blueberry": "Aww. Si tuviera gente que me regalara arándanos todos los días, creo que sería un 250% más feliz.#$b#No es que no sea feliz. Pero entiendes mi punto.$1",
"Gifts.Nora.Tulip": "¡Los tulipanes son flores tan bonitas! Gracias, @.#$b#¡Lo pondré en un florero de inmediato!",
"Gifts.Nora.Wine": "Parece muy buen vino, @. No deberías desperdiciarlo conmigo.#$b#No me gusta beber alcohol. Lo siento.$2#$b#¡Seguramente a Harley le encantaría!",
"Gifts.Nora.EnergyTonic": "Oh, uh, gracias.$2#$b#En mi casa solo usamos café para mantenernos despiertos. Consejo para la próxima vez.",
"Gifts.Nora.Pickles": "Oh, cómo te digo esto...?$3#$b#Soy la clase de chica que siempre pide su sandwich sin pepinillos.$2",
"Gifts.Nora.Pearl": "Por muy bonitas que sean creo que el proceso para obtener una perla no merece la pena.$2",
"Gifts.Nora.Slime": "Mi compañera de cuarto es literalmente una ranchera de slimes. Estoy segura al decirte que esto no es lo mío.$5",
"Gifts.Nora.GreenTea": "Sabes, todo el té caliente me sabe a agua hirviendo.$2#$b#¡El té helado es mucho mejor!",
"Gifts.Nora.Spaghetti": "Ah, carbohidratos... el mayor nutriente de todos.$1#$b#Bueno, al menos para mí. Soy una chica amante de los carbohidratos.",
"Gifts.Nora.Beer": "@, no me gusta mucho la bebida. Llego a brindar en eventos.#$b#Pero cuando lo hago, tiene un sabor horrible.$2",
"Gifts.Nora.JojaCola": "... Es enserio?$2#$b#¿Me estás regalando una Joja Cola? ¡¡¿A MI?!!$2#$b#Ok, para futuras referencias, yo realmente ODIO los productos JoJa",
"Gifts.Nora.SoggyNewspaper": "Mmm... quiero decir...$2#$b#¿La basura de un hombre es el tesoro de otro?$2#$b#Y solo para que conste, yo no soy el basurero. Simplemente esto no me gusta.$2",
"Gift.Nora.Driftwood": "¿Me estás dando... madera?$2#$b#¿Qué esperas exactamente que haga con esto? Tengo genuina curiosidad.$2#$b#Nuevo juguete para Stupid, supongo.",
"Gift.Nora.AnAutographedPhoto": "¡Oh, Rodney O'Brien! el es un amor.$1#$b#Usaré esto como separador para mis libros.",
"Gift.Nora.Jasper": "Creo que el jaspe es una piedra preciosa bastante subestimada.$1#$b#Es muy bonita, pero cuando lo pones al lado de un diamante, se eclipsa fácilmente.$2#$b#Gracias por ver la belleza de esto, @.",
"Gift.Nora.AmphibianFossil": "Vaya, @, ¿Dónde encontraste esto?$1#$b#Tienes un verdadero tesoro en tus manos. ¡No dejes que Gunther te descubra con él en tus manos!",
"Gift.Nora.DinosaurEgg": "Vaya, este huevo se ve raro. ¿Estás seguro de que es bueno?$2#$b#¿Qué? ¿Un huevo de dinosaurio?$7#$b#¿Y me lo estás regalando?#$b#Ni siquiera sé qué decir. La comunidad científica nunca me creerá.$3#$b#¡Pero me encanta! ¡Gracias!$1",
"Gift.Nora.Fish": "Oh, uh... wow.$2#$b#Un pescado entero. Sólo para mí.$2#$b#Y ni siquiera envuelto en papel de periódico... Bueno, uh, ¿gracias?$2",
"Gift.Nora.Gems": "¡@! ¿Dónde has encontrado esto?$1#$b#¡Es tan bonito! Las gemas son tan especiales, ¡no deberías tenerlas!$1#$b#¡Muchas gracias!$1",
"Gift.Nora.Flowers": "¿Flores? ¿Para mí? ¡No me lo esperaba! Me acabas de alegrar el día, @!$1#$b#Si sigues haciendo esto puede que empiece a sentirme especial",
"Gift.Nora.StardropTea": "...¿Qué es esto?$3#$b#Huele tan bien...#$b#¿Cómo está caliente Y frío al mismo tiempo?#$b#¡Me... Encanta!$1#$b#¡Gracias por esto!$1",

/// GIFT REACTIONS - CUSTOM ITEMS

// RODNEY'S BOOKS
"Gift.Nora.ArcanaPrunus": "¡Oh, Arcana Prunus! Soy un gran fan de este libro. Tengo todas las ediciones especiales y todo. Tienen su propia sección en la estantería de mi casa.#$b#¡Gracias por ampliar mi colección!$1",
"Gift.Nora.ArtifactOrCutlery": "Te voy a ser sincera, no suelo profundizar mucho en este tema.$2#$b#Pero es el libro de Gunther, así que por supuesto que me lo llevo.#$b#Tenemos que apoyar a nuestros amigos, ¿verdad?$1",
"Gift.Nora.CrabsAndWhyIHateThem": "Científicamente hablando, no deberíamos odiar a ninguna especie local.$3#$b#Cada especie tiene su propio papel que desempeñar en el equilibrio ecológico.#$b#Pero no puedo evitar reírme con este libro. Mateo es tan divertido.$1#$b#Gracias @, esto definitivamente mejorará mi día",
"Gift.Nora.DeferenceArlington": "Sabes, compré el primer par de volúmenes de esta serie cuando salió por primera vez.#$b#Pero luego... Siguieron llegando.$2#$b#Pronto fueron 14 volúmenes y no tengo la capacidad de atención para eso.$3#$b#Como, para el volumen 4 ni siquiera podía recordar el nombre del protagonista.",
"Gift.Nora.FishingForDumbDumbs": "Oh. No me va mucho la pesca, @, lo siento.$2#$b#Además, ¿Me estás llamando tonta?$5",
"Gift.Nora.GettingChicksToLoveYou": "¿QUÉ? ¿Libro de cómo hacer que las ´pollitas´ te amen? Me entra mucho pánico cuando intento hablar con mujeres hermosas.$1#$b#Oh, ¿se trata de gallinas reales?$3#$b# Bueno, las gallinas son geniales y normalmente tampoco me quieren, así que esto podría ayudar.",
"Gift.Nora.Goblins": "¡Vaya, muchas gracias! ¡Me encanta el trabajo del profesor Jasper Thomas!$1#$b#Su investigación es realmente interesante y siempre estoy emocionado de escuchar sobre un nuevo libro suyo",
"Gift.Nora.GuideToSculptingWithGold": "Sí, no, no es esto.$2#$b#No puedo creer que Lewis haya tenido el descaro de publicar algo como esto. A veces es increíble.$5",
"Gift.Nora.HerpetologyOfFerngill": "Oh, bueno... ¿Gracias? Supongo.$3#$b#Quiero decir, este es mi propio libro. Escribí esto. Todavía tengo copias en mi casa.#$b# ¿No revisaste la portada?$2",
"Gift.Nora.LunarkinTrollTales": "¡Lunarkin Troll Tales! Es un gran libro.$1#$b#Recuerdo que solía leerlo en la universidad siempre que tenía tiempo. Me ayudó a relajarme después de una intensa semana de exámenes. #$b#Y perdí mi copia en algún lugar en ese entonces. Creo que alguien me la tomó prestada y nunca la devolvió.$3#$b#¡Muchas gracias!.",
"Gift.Nora.MysteriesOfTheDwarves": "¡Otro gran libro del profesor Jasper! Su genio sigue sorprendiéndome cada vez.$1#$b#Debería pasar por su casa en algún momento para que podamos hablar sobre esto. Me encantaría saber más sobre sus teorías.",
"Gift.Nora.PepperRexes": "¿Estás seguro de que no quieres conservar esto?$3#$b#Este es un libro crucial si alguna vez planeas tener Pepper Rexes en tu granja.#$b#Oh, ¿Puedo tenerlo? Bueno, entonces no tienes que decírmelo dos veces. ¡Me encantan los Pepper Rexes!$1",
"Gift.Nora.TheBookOfYoba": "Oh, gracias. No soy realmente una persona religiosa, pero aprecio que pienses en mí con esto.",
"Gift.Nora.TheGreatBookOfSlimes": "¡Oh, esto es interesante! He estado tratando de aprender más sobre los slimes para poder sorprender a Tori.$1#$b#¡Esto será útil, gracias!",
"Gift.Nora.TheGreatTomeOfMayo": "No puedo imaginar el propósito de este libro. Y no digo eso mucho.$2#$b#Pero gracias, supongo.$3",
"Gift.Nora.TheJojaConspiracy": "¡Este es un libro necesario! ¡Esos idiotas de Joja nos han estado ocultando tantas cosas desde que llegaron a este valle!$5#$b#No suelo ser de conspiraciones, pero Joja sí haciendo algunas cosas feas.$2#$b#¡Gracias por esto! ¡Debemos hacérselo saber a la gente!",
"Gift.Nora.TheTarotRevealed": "No sabía que te gustaban las artes místicas, @, pero no me sorprende.#$b#No sé si creo en esto pero he visto cosas más raras cosas que suceden en este valle así que...$3#$b#¡No estaría de más intentarlo! ¡Cuanto más conocimiento, mejor!$1",
"Gift.Nora.WhyPepperRexesAreTheBest": "NO podría estar más de acuerdo con este libro.#$b#Pepper Rexes SON los mejores. Y si alguien te dice lo contrario, ¡MIENTE!$5#$b#Nadie debería siquiera necesitar convincentes, pero si lo hacen, este es el libro adecuado.$1",

// PRIDE IN THE VALLEY
"Gift.Nora.BiBerryMuffin": "No podría estar más feliz con la elección de comida para las personas bisexuales en el festival.#$b#Además, sabes que los arándanos son mis favoritos. ¡Gracias!$1 ",

// BEARFAM
"Gift.Nora.SigurdPerfectRamen": "Debo decir que la primera vez que comí esto casi me desmayo. Sig lo hizo demasiado picante para mí.#$b#Así que, por supuesto, lo tomé como algo personal. Y decidí aumentar mi tolerancia a las especias desde ese día.#$b#Ahora, esta es una de mis recetas favoritas. ¡Será mi cena esta noche!$1",
"Gift.Nora.HoneyCakes": "¡Guau, tienen un sabor increíble! Sondra es una gran cocinera.$1#$b#¡Gracias, granjero! ¡Espero que también tengas uno para ti!",
"Gift.Nora.TTBrownies": "¿Qué? ¿BROWNIES?$7#$b#¡Los brownies son una de mis cosas favoritas! ¿Cómo lo sabes?$1#$b#Tan dulces y ricos... Estoy viviendo el sueño ahora mismo. ¡Gracias!",
"Gift.Nora.PeachJoja": "¿Joja? Uh, no, gracias.$2#$b#¿Dónde encontraste esto, en algún lugar del fondo del río?$3",
"Gift.Nora.PumpkinJoja": "¿En serio? Pensé que ya sabías lo que siento por Joja.$2#$b#Lo siento pero yo paso, gracias.$2",

// CLOWN'S MODS
"Gift.Nora.SunshineHoney": "Este es uno de los tarros de miel de Nikolai, ¿verdad?#$b#Este es mi sabor favorito. ¡Sabe un poco a caramelo!$1#$b#Y siempre me calienta. ¡Tengo que guardar esto para el invierno!$3",
"Gift.Nora.HotChoco": "¿Chocolate caliente? ¡Ah, siempre sabes como calentar mi corazón!$1#$b#Esto es justo lo que necesitaba ahora mismo. ¡Muchas gracias!",
"Gift.Nora.MilkCoffee": "Normalmente no pongo leche en mi café porque lo siento como dos mundos en conflicto.$3#$b#Quiero decir, el café te pone alerta y la leche te da sueño... así que para mí, uno anula al otro...$3#$b#Dicho esto, sabe delicioso. ¡Gracias por esto!",
"Gift.Nora.TastyPastry": "¡Yoba, me encantan los pasteles!$1#$b#Se trata de la textura. Esponjosos y crujientes al mismo tiempo. ¡Gracias!",

// DATING

// MAP STRINGS
"NoraToriBookshelf1": "Es una copia de 'El Gran Libro de los Slimes'. Parece apropiado para la casa de un ranchero de Slimes.",
"NoraToriBookshelf2": "Una bola de nieve decora la estantería. Al mirar más de cerca, ves una serpiente y un Slime en su interior.",
"NoraToriBookshelf3": "'Cuando el Pepper Rex hace Zoom Zoom hace que mi corazón haga Boom Boom: Un ensayo sobre por qué los Pepper Rexes son los mejores', por el Dr. Mateo Luis",
"NoraToriBookshelf4": "Una pila de libros sobre la anatomía de los Slimes.",
"NoraToriBookshelf5": "'Los misterios de los enanos', de M. Jasper. Parece desgastado.",
"NoraToriBookshelf6": "Un cuenco decorado con pequeñas serpientes pintadas. Parece que fue hecho por niños.", 
"NoraToriReadingCornerBooks": "Entre los demás libros se destaca una copia de 'La herpetología de la República Ferngill'.",
"NoraToriOpenBook": "Hay muchas anotaciones y aspectos destacados de investigación. Nora debe haber estado estudiando.",
"NoraToriHandbag": "Una bolsa de mano. En el interior, un surtido de bolígrafos, un lápiz labial de tono claro, protector solar y una libreta.",
"NoraToriClock": "Es un reloj. El sonido es muy relajante.",
"NoraToriPhone": "Un teléfono con una libretita al lado. La última entrada dice 'Pierre CIERRA los miércoles NO VAYAS' y muchos signos de exclamación.",
"NoraToriCoffeeMachine": "Una máquina de café. Parece elegante.",
"NoraToriFridge": "La nevera está cubierta de fotografías de Nora y Tori en sus viajes. Se ven felices.",
"NoraToriTrash": "La basura. Un par de cáscaras de plátano y una bolsa de plástico con lo que parece piel de serpiente en su interior.",
"NoraToriTV": "Aquí hay un documental sobre la vida silvestre.",
"NoraTrash": "Hay muchos borradores y una nota adhesiva con ¿QUÉ SON SLIMES? escrito en él.",
"NoraBookshelf1": "Los tesoros universitarios de Nora: un montón de cuadernos viejos usados con diferentes fechas.",
"NoraBookshelf2": "'Reptile Keeper: Cómo cuidar a tus reptiles'. De ellas salen varias notas adhesivas de diferentes colores.",
"NoraBookshelf3": "Un álbum de fotos titulado 'TOUR DE FERNGILL: AÑO SABÁTICO'.",
"NoraBookshelf4": "Es un dibujo de Nora y Penny con Jas, Vincent y Eloise.",
"NoraBookshelf5": "Una copia de 'Arcana Catcher: Prunus', de Rodney O'Brien.",
"NoraBookPile2": "Una pila de libros con varios artículos académicos.",
"NoraBookPile1": "Una variedad de libros sobre extinción y especies en peligro de extinción.",
"NoraDesk": "Una mesa de estudio con todos los elementos esenciales para el mismo.",
"NoraDresser": "El ropero de Nora. Tiene un cajón entero dedicado a bufandas.",
"NoraToriStupid": "Stupid te mira directamente. No hay un solo pensamiento detrás de esos ojos.",
"NoraToriPinkiePie": "Pinkie Pie te ve venir y se esconde debajo de las hojas. Ella no es muy sociable.",   

/// CONVERSATIONS TOPICS
"CT.Nora.SterlingDrugs": "Oh, Sterling es muy educado. Siempre ha sido amable conmigo.#$b#Pero sus hábitos hacen que me preocupe por él...$#$b#¿Podrías controlarlo de vez en cuando? Parece que agradas mucho.",
"CT.Nora.SterlingFight": "He oído que las cosas se pusieron tensas en casa de Pierre con Sterling.$2#$b#Es un buen hombre. La adicción no es una broma, de verdad.$2#$b#Espero que se recupere de verdad ahora. Todo el mundo merece una segunda oportunidad.",
"CT.Nora.SterlingRecovery": "Estoy muy feliz de ver que Sterling está mejorando.$1#$b#Es un proceso difícil, pero creo que puede hacerlo. Me alegra que estuvieras presente para ayudarlo.",
"CT.Nora.DylanIntro": "Oh, ¿Conociste a Dylan? Me cae bien, es un buen amigo.$1#$b#Cuando nos conocimos, pasamos horas hablando de nuestros intereses comunes.#$b#Bueno, en realidad fui yo quien habló la mayor parte, pero él tuvo la amabilidad de escuchar.$3#$b#¿Sabías que existen serpientes marinas? Sí, lo aprendimos en un documental.#$b#Nos gusta ver documentales juntos de vez en cuando. ¡Únete a nosotros algún día!$1",
"CT.Nora.Jean&Jorts": "Me quedé absolutamente en shock la primera vez que escuché hablar a esos gatos.#$b#Incluso pasé días investigando para ver si había otros registros de animales que hablaran...$1#$b#Ni una sola serpiente o gecko que hable ha sido documentado.$2#$b#Personalmente creo que es un crimen de odio contra mí.",
"CT.Nora.ButteredJorts": "¡Oh, pobre Jorts! ¿Por qué tendría suficiente mantequilla para eso...$2#$b#¡Espero que el gato esté bien!$2",
"CT.Nora.Mia": "¡Mia es la chica mas dulce del mundo!$1#$b#Estoy tratando de hacer arreglos para que Lorelai venga aquí y hornee con ella.#$b#¡Realmente siento que serían buenas amigas!$1",
"CT.Nora.RodneyIntro": "¿Has conocido a ese autor que vive en el silo? Sí... ese tipo es realmente extraordinario.#$b#Tengo la sensación de que no le agrado. Quizás es porque hablo demasiado$3#$b#Es cierto, él tiene estilo. Debo admitirlo. Y me gustan sus libros.$1",
"CT.Nora.CambriaIntro": "Cambria es muy dulce, pero ese pollo suyo...$2#$b#¡Él intenta comerse a Stupid cada vez que la ve. Simplemente diabólico!$5#$b#Entiendo eso de la cadena alimenticia y todo eso, pero él es mi bebé.$2#$b#Solo cometí el error de llevarlo a su casa una vez... nunca más.$2",
"CT.Nora.EliIntro": "Eli es en realidad una de mis personas favoritas.$1#$b#Él iguala mi nivel de entusiasmo por las cosas. Y encuentro fascinante su campo de trabajo.!#$b#Le tome prestada una de sus bufandas hace algún tiempo y aún no se la he devuelto. ¡No le digas!$1",
"CT.Nora.EliSaloon": "¡Eli me dijo que pasaron el rato en el salón! Suena como una noche divertida.$1#$b#Es muy considerado. Siempre le da a la gente los pequeños obsequios que encuentra durante sus expediciones.#$b#Me gustaría que la gente viera ese lado de él más a menudo. Siguen diciendo que es simplemente raro.$2",
"CT.Nora.EliGuild": "Me alegro de que Eli finalmente haya completado esa expedición. Me estaba preocupando mucho.$2#$b#Sé que él puede cuidarse solo, pero tú has estado allí, sabes lo peligroso que es.#$b#Yo también me preocupo por ti, @$5",
"CT.Nora.EliGuestRoom": "¡@, te ves pálido! ¿Algo te ha estado preocupando?$7#$b#Ah... ¿Viste la habitación de invitados en casa de los hermanos?$3#$b#Sí, eso explica He aprendido a no hacer muchas preguntas al respecto.#$b#Me ayuda a dormir mejor por las noches.$2",
"CT.Nora.DylanTown": "Oh, pobre Dylan. Es absolutamente brillante, pero sus habilidades sociales son... discutibles.$2#$b#Y supongo que Eli no hace nada más fácil. Son completamente opuestos.$3#$b#Pero ellos se aman y pase lo que pase, se tienen el uno al otro.#$b#¡Y también esos dos nunca se van a deshacer de mí!#$b#Tal vez no lo logre, pero no se los dejaré fácil...$3",
"CT.Nora.DylanSaloon": "No entiendes cuánto habría pagado por ver a Dylan emborrachándose ayer en la cantina.#$b#Eso suena como un evento único en la vida. Y Eli tuvo que llevarlo a casa?$1#$b#Sé que se está muriendo de vergüenza. Voy a burlarme de él por mucho tiempo.",
"CT.Nora.DylanLibrary": "He estado tratando de convencer a Dylan de que debería dar la conferencia a los niños.#$b#Sólo sé que tiene talento natural. ¡Tiene que creer más en sí mismo!$1",
"CT.Nora.DylanLesson": "La conferencia de Dylan fue genial, ¿no? Oh, sé que a los niños les encantó.$1#$b#¡Incluso podríamos formar equipo algún día y dar una conferencia doble! ¿Crees que podría hacerlo? ¿Convencerlo?$3#$b#Ah, es demasiado pronto para pensar en ello. ¡Déjalo disfrutar este momento, se lo ganó!#$b#¡Incluso estoy en camino de enmarcarlas ahora mismo!",
"CT.Nora.DylanCCAquarium": "¡Dylan hizo un gran trabajo con el acuario! Está mucho mejor ahora, ¿no crees?$1#$b#Ya se me están ocurriendo chismes de peces para eso... Bueno , los corales también deben tener chismes, ¿verdad? $3#$b#¡Tengo que felicitarlo por eso otra vez! ¡Se ve absolutamente increíble!$1",
"CT.Nora.SootIntro": "¿Conociste a Soot? ¡Oh, es completamente adorable!$1#$b#En realidad, es buen amigo tanto de Pinkie Pie como de Stupid. Pero sobre todo de Stupid.#$b#Siento que ellos todos coinciden de alguna manera.#$b#Soot es Eli, Stupid soy yo y Pinkie Pie es Dylan. Ella siempre parece tan harta de ellos dos.",
"CT.Nora.WillyBoatRepaired": "¿Entonces todos podremos visitar la Isla Genjibre ahora?#$b#Me pregunto qué especies hay allí esperando a ser descubiertas.$3#$b#El Norian está a la vuelta de la esquina, ¡Recuerda mis palabras.!",
"CT.Nora.ResortOpen": "Estaba pensando en irme de vacaciones a ese nuevo resort.$3#$b#BPero creo que me volvería loca sin nada que hacer. ¡De por si ya me vuelvo loca aún cuando tengo cosas que hacer!$2#$b#Además, no me gusta mucho la playa... Debo pensarlo un poco mejor.$3",
"CT.Nora.Wedding": "¡Wow, te casaste! ¡Realmente lo hiciste! ¡Con anillo y todo!$1#$b#Estoy realmente orgullosa de ti @. Oh, creces tan rápido.",
"CT.Nora.BabyBoy": "¿Un bebé? ¿TU PEQUEÑO? ¿Ya tiene madrina? ¡Porque estoy disponible!$1",
"CT.Nora.BabyGirl": "¿Una bebé? ¿TU PEQUEÑA? ¿Ya tiene madrina? ¡Porque estoy disponible!$1",
"CT.Nora.RailroadEartquake": "¿Oíste ese ruido anoche?#$b#De hecho realmente te lo estoy preguntando. Todo el mundo habla de este ruido pero yo estaba profundamente dormida.#$b#No escuché nada.",
"CT.Nora.Mateo": "¿MATEO? ¡Absolutamente los amo!$1#$b#La primera vez que nos vimos, irrumpí en su casa y los sorprendí usando ropa interior de dinosaurio y comiendo una paleta.$1#$b#Sólo quería ver a su dinosaurio. Ya sabes, el vivo, no el de la ropa interior.#$b#¡Pero su amistad fue un buen bonus!$1",
"CT.Nora.JasperMissing": "No he visto a Jasper por la biblioteca últimamente durante mis sesiones de estudio, ¿Has oído algo sobre él?$2#$b#Estoy empezando a preocuparme un poco.$2",
"CT.Nora.JasperBack": "¡Jasper finalmente ha regresado! Aunque ha cambiado bastante.$2#$b#Intentaré contarle datos interesantes sobre los reptiles para animarlo. Siempre le gusta aprender.",
"CT.Nora.LeoArrival": "Escuché que trajiste a un niño de la Isla Genjibre, ¿Es verdad?#$b#Es fácil sentir que no encajas cuando te mudas a un lugar nuevo...$2#$b#Espero que se adapte bien. ¡Le contaré datos interesantes sobre reptiles!$1",
"CT.Nora.BookLaunchParty": "¡El lanzamiento del libro de Rodney fue muy emocionante!$1#$b#¡Ya recibí mi copia. No puedo esperar a leerlo esta noche!",
"CT.Nora.RodneyPoetryReading": "Tori dijo que Rodney estaba leyendo poesía en medio de la noche...$3#$b#De hecho, estaba bastante molesta. Yo no escuché nada.$3#$b#Es la ventaja de tener problemas auditivos, supongo.$3",
"CT.Nora.MateoConfrontation": "Gunther ha estado bastante agitado últimamente.$3#$b#Cada vez que intento hablar con él, simplemente parece... Fuera de sí.$3#$b#Espero que todo esté bien. Se ve muy estresado.$2",
"CT.Nora.MateoPain": "Siento mucha pena por Mateo. Espero que no sea nada grave y que regresen pronto.$2#$b#¿Crees que les agradaría si les llevo un poco de sopa cuando vuelvan?$3",
"CT.Nora.GuildComplete": "Oh, ¿Viste el nuevo edificio en la playa? Es maravilloso, ¿Verdad?$1#$b#No puedo creer que tengamos nuestra propia sucursal de la Gremio de Aventureros. ¡Estoy tan emocionada!$1#$b#Espera, ¿Eso significa que también tendremos monstruos en el Acantilado?$3#$b#Bueno, me alegro de que ahora tengamos a alguien que se encargue de eso.",
"CT.Nora.GuildFinale": "Cuando te digo que NO PODÍA creer que Mateo SIMPLEMENTE tiene un dinosaurio ahora.$7#$b#No sé cómo pasó eso, pero tuve que irrumpir en el gremio para verlo con mis propios ojos.$b#Los pillé usando ropa interior con dinosaurios y comiendo un helado de paleta. Lo cual fue, eh... toda una vista.$3#$b#¡Solo quería ver al dinosaurio! Al vivo, no al de la ropa interior.",
"CT.Nora.DylanBeach": "¡He oído que tú y Dylan limpiaron la playa! ¡Bien hecho, @!$1#$b#Es nuestro deber cuidar de este lugar. Al fin y al cabo, es nuestro hogar.",
"CT.Nora.NoraChameleon": "Todavía no puedo creer lo que está pasando. ¿Tú también lo puedes creer?$1#$b#Tengo mucho trabajo en este momento, pero valdrá totalmente la pena.$b# ¡Lo encontramos, @! ¡Encontramos el camaleón de cola morada!",
"CT.Nora.DitR_CT_ShadowPlay": "Anoche me enredé en un libro de terror y terminé leyendo hasta muy tarde.$2#$b#¡Y luego ese ruido! ¿Qué era eso, un oso? ¡Fue tan aterrador!$7#$b#No estoy precisamente orgullosa de que mi grito asustara aún más a Tori, pero fue una escena graciosa, no voy a mentir.$1",
"CT.Nora.DitR_CT_SensFlowers": "Que una extraña flor, nunca antes vista, esté floreciendo por todo el valle de la noche a la mañana es... Raro.$3#$b#Pero según mi experiencia, este no es un lugar ordinario. ¡Así que espero que no sea nada malo!$1#$b# Y es bastante bonita, no crees?",
"CT.Nora.JulietGremlin": "¡El cachorro que encontró Juliet es adorable!$1#$b#Espero que termine cuidándolo. Ella no cree que sea capaz, pero lo es.$b#¡Y una mascota siempre lo mejora todo!",
"CT.Nora.GreenRain.1": "¿Wow, te atreviste a salir con esta lluvia?$7#$b#No tengo idea de qué causó esto, y no pretendo averiguarlo. Dejaré eso a Demetrius.$3#$b#En su lugar, me voy a quedar en casa y leer un libro de terror. Parece apropiado.",
"CT.Nora.GreenRain.2": "Me preguntaba si esto volvería a pasar desde el año pasado.$3#$b#Al parecer, es inofensivo. Pero igualmente me tomaré el tiempo para quedarme en casa y no hacer nada.",
"CT.Nora.LucickielArrives": "Escuché que hubo una conmoción en la ciudad. ¿Algo sobre un recién llegado?$3#$b#La gente parecía muy asustada por este tipo. ¿Tuviste la oportunidad de verlo por ti mismo?$2#$b#La gente lo llamaba demonio, pero no puede ser tan malo, ¿verdad?$3",
"CT.Nora.ReputationIncreased": "Entonces, Lucickiel trabajará con Clint de ahora en adelante, ¿eh?#$b#Esta ciudad... nunca deja de sorprenderme. Pero debería haberlo visto venir, ¿verdad?$3# $b#El valle da la bienvenida a todos aquellos con buenas intenciones. Es un refugio para almas raras con buen corazón.$1#$b#Me alegro de que haya encontrado su lugar.",
"CT.Nora.JohnsArrival": "¿Viste que se mudó un chico nuevo? ¡El vecindario sigue creciendo!$1#$b#¿Crees que le gustan las serpientes? Qué genial sería si así fuera...$3#$ b#Siempre es agradable ver gente nueva viniendo al valle. Este lugar es bueno, más gente debería conocerlo.",
"CT.Nora.FaintingIncident": "Ese chico nuevo, John, ¿escuché que se desmayó hoy en casa de Pierre?$3#$b#Eso suena horrible, acababa de salir de la tienda cuando sucedió. Espero que esté bien.$3#$ b#¿Quizás podrían ver cómo está? Parece que están hablando últimamente. Parece un buen tipo.",
"CT.Nora.BusFire": "¡Gracias Yoba por estar ahí hoy para ayudar a Barron con el fuego!$7#$b#Te vi corriendo para ayudarla. ¡Fuiste tan rápido! Ni siquiera me di cuenta de lo que estaba pasando hasta más tarde.$2#$b#Fue muy valiente de tu parte. ¡Y me alegro que ella también esté bien!",
"CT.Nora.SigLowBattery": "Oh, sí, entiendo perfectamente a Sig. A veces se nos acaba la batería cuando menos lo esperamos.#$b#Por favor, no te lo tomes como algo personal, no te estamos ignorando, sólo somos sordos.$1#$b#Sigo diciéndole a la gente que aprenda el lenguaje de signos para que sea más fácil para todos, pero no todo el mundo está dispuesto a hacerlo.$2",
"CT.Nora.SigAndCigarettes": "Ah, sí, Sig tiene la costumbre de fumar...$3#$b#Es un buen amigo mío, y por eso trato de convencerlo de que lo deje.#$b#No solo es malo para él, sino también para el medio ambiente, ¿sabes?$3#$b#¡Intenta también hacerle entrar en razón!",
"CT.Nora.SigHatesCrowds": "Aw, me he enterado de lo que pasó en el Saloon... Pobre Sig...$2#$b#Iré a verlo más tarde. Tal vez pueda hornear algunos brownies...$3#$b#...Pensándolo mejor, eso solo empeoraría las cosas. Soy una pésima repostera.#$b#¡Pero podría comprar un pastel en el Salón!$1",
"CT.Nora.SigTheSoldier": "Creo que Sig está pasando por cosas que realmente no podemos entender en este momento...$2#$b#Quiero decir, fue a la guerra. No tenemos idea de lo que eso es.$2#$b#Me alegro de que tenga a Teren. Alguien que realmente entiende, ¿sabes?",
"CT.Nora.SigTheHero": "Honestamente, ni siquiera puedo EMPEZAR a describir lo enojada que estoy con Sig.$5#$b#¿Qué estaba pensando? ¿Ir solo a las minas así?$5#$b#Ugh... Perdón por explotar, @. Solo estoy... muy preocupada.$2",
"CT.Nora.SigRecovery": "Sig finalmente ha sido dado de alta por Harvey. Estoy tan aliviada.$1#$b#Le dije que si vuelve a meterse en problemas como este, voy a matarlo de verdad.#$b#¿Acaso este tipo tiene un deseo de morir?$5#$b#Espera un momento...$3",
"CT.Nora.SoItBegins": "Me alegro de que Sig finalmente haya comenzado terapia. Realmente la necesita.#$b#Y Teren ha sido muy bueno con él.$1#$b#Le compré una tarjeta de felicitaciones por 'Felicidades por el diagnóstico de enfermedad mental', ¿quieres firmarla?$1",
"CT.Nora.SigFuture": "¡SIG SE ESTÁ CONVIRTIENDO EN MAESTRO!$1#$b#No podría estar más feliz. ¡Incluso podríamos enseñar juntos algún día!$1#$b#Además, es realmente bueno en eso. Hemos estado practicando sus conferencias, así que lo sé.",
"CT.Nora.SigandHonors": "¡Wow, Sig ha llegado tan lejos! Estoy super orgullosa de él.$1#$b#Los dos juntos casi hacemos una persona normal entera. ¿Te lo puedes creer?$1#$b#Me alegro de que todo el mundo aquí llegue a verlo como yo lo veo ahora... La increíble persona que es.",
"CT.Nora.ASongForSondra": "...Si soy honesta, puede que haya apagado mi audífono durante una de esas bandas en el concurso de Sondra...$3#$b#Sssh, ¡ni se te ocurra decírselo a nadie! ¡Lo negaré hasta que me muera!$5#$b#Además... ¡Tú harías lo mismo si pudieras!#$b#Pero Sam, Sebastian y Abigail fueron realmente geniales. Estoy emocionada por su álbum completo.",
"CT.Nora.GudrunQinstagram": "¿Hmm? ¿El Qinstagram de Gudrun? ¡Sí, la sigo! Es muy dulce.#$b#¿Qué, qué hay de malo en usar las redes sociales para publicar fotos de animales?$3#$b#Mi red social existe con el único propósito de publicar fotos de mis reptiles... y de otros reptiles que realmente no son míos.#$b#Así que sí, la entiendo completamente. ¡Y tiene razón!$1",
"CT.Nora.GudrunEcoFriendly": "Yoba, a veces no puedo creer lo que dice Pierre.$5#$b#¿A alguien de esta ciudad le importa el medio ambiente?$2#$b#¿Sabes qué? Tal vez debería hacer una presentación de diapositivas realmente aterradora al respecto.$3#$b#¡Algo como 'Si sigues actuando así, todos moriremos más temprano que tarde'!$5",
"CT.Nora.GudrunWeird": "Algo no anda bien con Gudrun últimamente...$3#$b#O tiene mucho miedo de la perspectiva de la vida adulta y su futuro... o está muy estreñida.$3#$b#De cualquier manera, debería ir a ver cómo está. Mi mamá tiene esta GRAN receta casera que...$3#$b#Oh, ¿no crees que sea eso? Sí, probablemente tengas razón.$3#$b#Por suerte, también tengo mucha ansiedad general y experiencia de agotamiento, ¡así que tal vez le pueda dar algún consejo!$1#$b#Vaya, eso sonó triste. Supongamos que no lo dije.$3",
"CT.Nora.GudrunRanAway": "¿Has visto a Gudrun? ¡Toda su familia está muy preocupada! ¡Y yo también!$2#$b#Solo espero que esté bien. No pudo haber llegado tan lejos, ¿verdad? Tal vez lo estemos pensando demasiado...$2#$b#¡ESPERA! ¡ME OLVIDÉ DEL AUTOBÚS! ¡NO LO ESTAMOS PENSANDO LO SUFICIENTE!$5",
"CT.Nora.GudrunComesHome": "¡Oh, hola! ¡Voy a darle a Gudrun una bandeja llena de brownies como bienvenida!#$b#¿Si yo los preparé? ¡Ja, claro que no!$1#$b#Ella necesita sentirse querida ahora mismo. Si le cocinara mis propios brownies, tendría el efecto contrario.",
"CT.Nora.GudrunOnCampus": "¡El otro día me encontré con Gudrun en ZuCU!#$b#Estoy tan orgullosa de ella, ya es mayor y está persiguiendo su sueño académico!$1#$b#Ya casi no la recuerdo cuando era bebé...#$b#Principalmente porque no estuve presente en ese momento, ¡pero aún así! ¡Crecen tan rápido!$1",

// DATING CT
"CT.Harvey.GirlfriendNora": "Hola @, me enteré de lo tuyo con Nora.$1#$b#Les deseo lo mejor a ambos. Ella es una buena amiga mía, igual que tú.",
"CT.Leah.GirlfriendNora": "Entonces, tú y Nora finalmente son pareja, ¿eh?#$b#Me preguntaba cuánto tiempo les tomaría a ambos darse cuenta de que se gustaban.$1",
"CT.Penny.GirlfriendNora": "¡Oh, tú y Nora son novios! ¡Eso es maravilloso!$1#$b#Ella me lo dijo hoy temprano. Es como si no pudiera contenerlo.",
"CT.Haley.GirlfriendNora": "Entonces, ¿tú y la chica lagartija, eh?#$b#Supongo que hay cierto encanto en ser una nerd.",
"CT.Emily.GirlfriendNora": "¡Ajá! ¡Lo sabía! ¡Sabía que ustedes dos tendrían una relación!$1#$b# Podía sentir la energía de ambos. ¡Estaba perfectamente claro!",
"CT.Lewis.GirlfriendNora": "Entonces, ¿tú y la Sra. Chambers? Veo que realmente estás construyendo tu propio hogar aquí en el valle.$1#$b#Oh si, las noticias vuelan.",
"CT.Maru.GirlfriendNora": "Awww, ¡estoy tan feliz por ti y Nora! ¡Ustedes son una pareja adorable!$4#$b#No te atrevas a lastimarla entendido... no lo hagas.$3",

/// MAIL
"NoraPHD.1": "Mi querido @,^^Prefiero discutir las cosas cara a cara, como ya sabes. Sin embargo, después de nuestra conversación de anoche en mi casa, tuve una epifanía sobre mi próximo curso de acción.^^También me gustaría disculparme por mi colapso. Últimamente las cosas se han sentido abrumadoras, pero estoy segura de que podré darle la vuelta.^^Me voy hoy a la Universidad de la Ciudad de Zuzu para terminar el trabajo que he comenzado. Volveré en aproximadamente una semana. Para entonces, asegúrate de venir al salón en algún momento. ¡Tengo la sensación de que estaremos celebrando!^^Besos de mí y de los niños,^^Nora.",
"SavingTheSpecies.1": "Hola @,^^ ¡El descubrimiento que hicimos ayer es lo más increíble que podría haber soñado! Ocuparse de una especie en peligro de extinción requiere mucha atención, así que he estado trazando el mejor curso de acción posible para tratar de salvar a esos pequeños.^^Me he reunido con el Profesor Caracol, un intelectual que reside en la Isla Jengibre. Él me está ayudando con muchas cosas.^^ Por favor, si tienes tiempo, ¡Ven a su oficina la próxima semana! Creo que deberías ver en lo que estamos trabajando.^^Tu mejor amiga,^^Nora.",
"NoraDating": "Querido @,^^Tuve que reunir todo el coraje para escribirte esta carta. Cada vez que pensaba que podía hacerlo, me acobardaba. Pero temo que ya no puedo contenerme más.^^Me has estado dando vueltas en la cabeza estas últimas semanas más de lo que me gustaría admitir. Si hay alguna posibilidad de que sientas lo mismo...^^¿Nos vemos en el bar para tomar algo? ¿Mañana? ¿A las 7 de la tarde?^^Si no apareces, lo entiendo. Bueno, tal vez te vea allí.^^Te quiere, Nora.",

///VILLAGERS CTS FOR NORA

"CT.Harvey.NoraIntro": "¿Nora? Oh, es una mujer encantadora.#$b#Aunque puede ser un poco intimidante para los recién llegados.#$b#Dále una oportunidad, ¿De acuerdo?$1",
"CT.Maru.NoraIntro": "¿Conociste a Nora? Es realmente inteligente.#$b#Es bueno tener más mujeres científicas por aquí.",
"CT.Emily.NoraIntro": "Me gusta Nora. Siempre pasa por el salón los viernes y podemos charlar.#$b#Al menos, ella puede charlar mientras yo atiendo a los clientes. Pero de todos modos es divertido.$1",
"CT.Haley.NoraIntro": "¿La chica de la serpiente? Honestamente, no la soporto.$3#$b#Una vez que empieza a hablar, es como si nunca se detuviera.$2#$b#Y la forma en que se viste... Sin comentarios.$3",
"CT.Jodi.NoraIntro": "Nora es una buena influencia para los niños. Los motiva a estudiar para ser como ella.#$b#A Vincent siempre le encanta cuando Penny la invita a casa para una lección.",
"CT.Leah.NoraIntro": "Nora es agradable, le gusta pasar por mi cabaña cuando va al bosque.#$b#Incluso me trae algunas cosas que recolecta. Es muy atento de su parte.",
"CT.Gunther.NoraIntro": "Nora es una de las científicas más dedicadas que conozco.#$b#Casi estoy seguro de que pasa más tiempo en la biblioteca que en su propia casa.$1",
"CT.Sebastian.NoraIntro": "¿Esa herpetóloga? Supongo que está bien...$2#$b#Solo trato de evitar su camino cuando no tengo ganas de hablar. Lo cual es frecuente.",
"CT.Vincent.NoraIntro": "¿Nora...?$3#$b# Oh, te refieres a la Sra. Chambers?#$b#¡Es tan inteligente. Además tiene una serpiente y un gecko!#$b#¡Son realmente lindos!",
"CT.Jas.NoraIntro": "Oh... La Sra. Chambers es realmente inteligente.$3#$b#Tal vez algún día yo también pueda ser tan inteligente como ella.$3",
"CT.Penny.NoraClass": "Me alegro de que Nora pudiera unirse a nuestra clase.#$b#Traer a personas para que discutan sus temas favoritos con los niños puede ser realmente enriquecedor para ellos.",
"CT.Jas.NoraClass": "La clase de hoy estuvo realmente genial.#$b#¡La Sra. Chambers me dejó tomar prestado su libro!",
"CT.Gunther.NoraClass": "Que la clase se lleve a cabo en la biblioteca es un placer.#$b#Esos niños están tan ansiosos por aprender. ¡Afortunadamente, tienen a muchas personas dispuestas a enseñarles!$1",
"CT.Vincent.NoraClass": "¿Viste lo genial que fue la clase de la Sra. Chambers?#$b#¡Cuando crezca, también quiero estudiar animales!#$b#¡Tal vez estudie perros. Me gustan los perros!",
"CT.Harvey.NoraFear": "Estoy tratando de ayudar a Nora a trabajar en su miedo a las agujas.#$b#Era mucho, mucho peor cuando recién llegó al valle.#$b#Llegué a pensar que tendría que sedarla en algún momento.$2#$b#¡Me alegro de que hayamos superado eso!$1",
"CT.Maru.NoraFear": "Pobre Nora... Siempre es un poco difícil para ella.$2#$b# Me alegro de que hayas estado ahí para ayudar, @!",
"CT.Harvey.NoraSad": "Oye, @, ¿Has hablado últimamente con Nora?#$b#Parece un poco diferente... No es su yo usual y hablador, me temo.$3",
"CT.Maru.NoraSad": "¿Nora te parece un poco rara?#$b#Está tan ocupada que temo que pueda sufrir un agotamiento.$2#$b#¿Podrías ir a verla si puedes, @?",
"CT.Leah.NoraSad": "Nora está tan ocupada últimamente que ni siquiera pasa a traerme plantas silvestres.$2#$b#Honestamente, estoy preocupada por ella.$3",
"CT.Gunther.NoraSad": "¿Sabes si le está pasando algo a nuestra querida amiga herpetóloga?#$b#Me temo que podría estar estudiando demasiado. Incluso las mentes más brillantes merecen descansar.",
"CT.Harvey.NoraBusy": "No tengo idea de lo que Nora está haciendo para mantenerse tan ocupada, pero espero que esté bien.#$b# Una vez que termine su doctorado, debemos celebrar!$1",
"CT.Maru.NoraBusy": "¿Nora simplemente desapareció, eh? Me pregunto en qué estará trabajando...#$b#Nada en la vida académica es fácil, ¿Verdad?",
"CT.Gunther.NoraBusy": "Bueno, Nora vino, recogió una pila enorme de libros y regresó a su casa.#$b#No estoy seguro de qué está tramando, pero sé que será excelente.",
"CT.Penny.NoraBusy": "Iba a preguntarle a Nora si estaría dispuesta a dar otra charla, pero no ha estado por el pueblo últimamente.#$b#Espero que vuelva pronto.$1",
"CT.Harvey.NoraProud": "¡Honestamente, estoy tan orgulloso de Nora!$1#$b#Espero que ahora reduzca el café y las comidas congeladas. ¡Le he estado diciendo eso durante siglos!#$b#Eso definitivamente no es saludable en grandes cantidades.",
"CT.Maru.NoraProud": "¿Crees que ahora que Nora tiene más tiempo libre no le importaría unirse a mí para construir un robot de dragón de Komodo?#$b#Me encantaría que me ayudara con la anatomía.$3",
"CT.Leah.NoraProud": "Es un alivio que Nora tenga más tiempo libre ahora.#$b#El valle tiene mucho que ofrecer y sería una pena que no pudiera disfrutarlo todo.$1#$b#La llevaré a recolectar plantas silvestres en algún momento.",
"CT.Gunther.NoraProud": "Nora tiene un futuro brillante por delante.#$b#Me alegro mucho de haber podido ayudarla en su camino.",
"CT.Harvey.NoraMuseum": "Me alegro mucho de que Nora haya conseguido este trabajo. Es una forma de ocupar la mente.$1#$b#Espero que no se exceda con eso.#$b#Ese ha sido un patrón, me temo.$2#$b#Si alguna vez tengo que extraerle sangre de nuevo, desearme suerte.",
"CT.Maru.NoraMuseum": "¡Nora me dijo que ahora tiene un trabajo!#$b#Por un momento pensé que tendría que volver a la ciudad de Zuzu para siempre.#$b#Definitivamente la extrañaría. !Me alegro de que se quede!$1",
"CT.Leah.NoraMuseum": "Espera, entonces ¿Nora tiene ahora dos trabajos?#$b#¿Uno aquí y otro en la ciudad de Zuzu?#$b#Me alegro por ella, ahora si me disculpas seguiré trabajando en mi arte.$1",
"CT.Gunther.NoraMuseum": "Tener a Nora en el Museo está haciendo que las cosas sean mucho más fáciles para mí.#$b#Es bastante útil. Y el financiamiento adicional también es bienvenido.",
"CT.Elliot.NoraMuseum": "He visto que la herpetóloga local consiguió un trabajo en el Museo.#$b#Supongo que cuantas más personas estén dispuestas a contribuir a la preservación del valle, mejor.",
"CT.GuntherSilvian.NoraIntro": "Nora es una de las científicas más dedicadas que conozco.#$b#Casi estoy seguro de que pasa más tiempo en la biblioteca que en su propia casa.$1",
"CT.GuntherSilvian.NoraClass": "Que la clase se lleve a cabo en la biblioteca es un placer.#$b#Esos niños están tan ansiosos por aprender. ¡Afortunadamente, tienen a muchas personas dispuestas a enseñarles!$1",
"CT.GuntherSilvian.NoraSad": "¿Sabes si le está pasando algo a nuestra querida amiga herpetóloga?#$b#Me temo que podría estar estudiando demasiado. Incluso las mentes más brillantes merecen descansar.",
"CT.GuntherSilvian.NoraBusy": "Bueno, Nora vino, recogió una pila enorme de libros y regresó a su casa.#$b#No estoy seguro de qué está tramando, pero sé que será excelente.",
"CT.GuntherSilvian.NoraProud": "Nora tiene un futuro brillante por delante.#$b#Me alegro mucho de haber podido ayudarla en su camino.",
"CT.GuntherSilvian.NoraMuseum": "Tener a Nora en el Museo está haciendo que las cosas sean mucho más fáciles para mí.#$b#Es bastante útil. Y el financiamiento adicional también es bienvenido.",
"CT.GuntherSilvian.NoraChameleon": "Nora me contó que ustedes dos encontraron el camaleón en la Isla Jengibre.#$b#¿Quién hubiera pensado que estaría allí todo este tiempo.$1#$b#No puede dejar de hablar de eso. Y de ti también.#$b#Dijo que fuiste fundamental para su descubrimiento.$1",
"CT.Harvey.NoraChameleon": "Oye, @. ¿Sabes si Nora está bien?#$b#Me la encontré ayer. O mejor dicho, ella me encontró a mí.#$b#Y me refiero a eso literalmente. Iba corriendo a toda velocidad y no me dijo a dónde iba.$2#$b#Cuando me percaté, ya estaba demasiado lejos.$2",
"CT.Leah.NoraChameleon": "Me desperté hoy con alrededor de 20 mensajes de Nora.$2#$b#Uno de ellos era puro grito. Está realmente emocionada por esto, ¿eh?",
"CT.Maru.NoraChameleon": "Entiendo completamente la emoción de Nora con todo esto.#$b#Para ella, esto es lo que la robótica es para mí.$1#$b#Las CientificAmigas simplemente nos entendemos.",
"CT.Penny.NoraChameleon": "Nora dijo que está trabajando en una charla de 4 horas sobre sus últimos descubrimientos para los niños.#$b#No estoy segura de cómo va a funcionar eso, pero no tuve el corazón para decírselo.$2",

// VILLAGERS CT - DATING NORA

/// MOVIES!
"Nora.MovieInvitation": "¿Una película? ¡Claro, tengo algo de tiempo extra hoy!$1#$b#¿Está bien si lloro? Suelo ponerme muy emocional.$3",
"spring.movie.0.1": "¿El pequeño y valiente árbol? ¡Tenía ganas de ver esta!$1#$b# El Árbol se ve tan lindo! ¡Míralo! ¡Pequeñín!",
"spring.movie.0.2": "Dejar el hogar así para crecer... Realmente toma mucho valor.$2#$b#Esto me toca realmente el corazón...$3",
"spring.movie.0.3": "Fue una experiencia increíble. Qué historia tan asombrosa.#$b#Realmente inspira a no rendirse. ¡Me encantó!$1#$b#Gracias por invitarme, @!",
"spring.movie.1.1": "Realmente me encantan los documentales.#$b#¡Nuestro mundo tiene tantas cosas hermosas por ver!$1",
"spring.movie.1.2": "Esto me hace querer viajar de nuevo. Lo extraño...$1#$b#¿Quién sabe qué más hay ahí afuera por descubrir?#$b# Gracias por esto, me lo pasé genial!$1",
"summer.movie.0.1": "He leído sobre el Rey de la Pradera antes.#$b#¡No sabía que estaban haciendo una película! ¡Suena genial!$1",
"summer.movie.0.2": "Nora se está mordiendo las uñas...",
"summer.movie.0.3": "¡¿QUÉ?! MALDITO HIJO DE P-$5",
"summer.movie.0.4": "¡Vaya, me alegro de que tuviera tan buena puntería!$1#$b#¡Definitivamente investigaré más sobre su historia! Fue divertido.",
"summer.movie.1.1": "¿Wumbus? No tengo idea de qué se trata. ¡Pero me encanta la ciencia ficción!$1#$b#Hace bastante que no veo una película de ciencia ficción. ¡Vamos a hacerlo!",
"summer.movie.1.2": "La verdad, esperaba un poco más de ella.$3#$b#¿Cómo puede alguien estar tan desinteresado en todo como Rossel?$2#$b#Wumbus es un buen tipo. Él realmente lo está intentando.$2",
"fall.movie.0.1": "¿Mysterium, eh? Nunca he oído de esta película...$3#$b#¿Crees que será demasiado aterradora?$3",
"fall.movie.0.2": "Nora parece increíblemente confundida.",
"fall.movie.0.3": "No entendí ni una sola cosa de lo que pasó ahí.$3#$b#Ni siquiera me asustó. No sabía qué estaba pasando.#$b#No tengo la atención suficiente para películas como esta.$3",
"fall.movie.1.1": "Oh, esta se ve tan aterradora.$2#$b#¡Las películas de terror siempre me han gustado!$2",
"fall.movie.1.2": "Ahora esta sí es una buena película de terror.$1#$b#¡Estaba aterrorizada. Me encantó!",
"winter.movie.0.1": "Por lo general, no soy una gran fan de las películas del Día de la estrella invernal.#$b#¡Pero igual estoy emocionada de pasar tiempo contigo!$1",
"winter.movie.0.2": "¡Fue mucho mejor de lo que esperaba!#$b#La forma en que seguían esperando que todo estaría bien... ¡Son tan fuertes!$2#$b#¡Y ahora el espíritu de la Estrella de Invierno vive!$6#$b#Perdón, necesito un pañuelo.$2",
"winter.movie.1.1": "¡Tren Expreso de Zuzu City! ¡Esta es una de mis favoritas!$1#$b#¡Nunca se vuelve vieja.  Me encantaría verla contigo!",
"winter.movie.1.2": "Los ojos de Nora se están llenando de lágrimas. Está moviendo los labios.",
"winter.movie.1.3": "Ah, esta película... ¿Qué puedo decir?$1#$b#Verla contigo la hizo aún más especial.",

/// MAIN EVENTS DIALOGUE

// INTRODUCTION

"Events.NORA.Introduction.Nora.1": "Oh, tengo que conseguir más comida para los niños hoy...$3",
"Events.NORA.Introduction.Nora.2": "Todavía no he comprado fruta esta semana.$3#$b#Oh, y ese ensayo es hoy... ¿O era mañana?$3",
"Events.NORA.Introduction.Nora.3": "De todas formas debería ponerme con eso pronto.$3#$b#No querría...",
"Events.NORA.Introduction.Nora.4": "¡Oh, hola!$1#$b#!Lo siento, no te había visto!#$b#Estaba divagando sola sobre las cosas que tengo que hacer.#$b#Es, mm... más común de lo que crees.$3",
"Events.NORA.Introduction.Nora.5": "Soy Nora, por cierto.$1#$b#Espera, ¿Ya te lo había dicho?$3#$b#A veces olvido las cosas que he dicho antes.$3#$b#Pero bueno, no hace daño decirlo dos veces supongo.$1#$b#Te has mudado recientemente aquí, ¿Verdad?",
"Events.NORA.Introduction.Nora.6": "Siempre es bueno ver caras nuevas en el valle.#$b#Y es muy fácil enamorarse del lugar, así que ni siquiera tengo que decirte que te gustará.$1",
"Events.NORA.Introduction.Nora.7": "Recuerda ser siempre amable con Stardew Valley. Y él será amable contigo.",
"Events.NORA.Introduction.Nora.8": "Bueno, voy tarde. ¡Todavía tengo muchas cosas que hacer!$1#$b#Pasa un buen día, @. Oh, y cuidado con el gecko al salir.#$b#¡No te preocupes, no muerde! Y bueno, si lo hace, no dolerá mucho.$1",

// 2 HEARTS
"Events.NORA.2H.Nora.1": "Oh, @! Que gusto verte aquí en el Bosque Cindersap.$1#$b#¿Te apetece acompañarme en esta tarde soleada?",
"Events.NORA.2H.Nora.2": "En realidad estoy aquí por mi investigación. Ya sabes, para mi doctorado.",
"Events.NORA.2H.Nora.3": "¿Has oído hablar del camaleón de cola púrpura?#$b#No me sorprendería que no. Es una especie muy rara... y hay una razón triste para eso.$2",
"Events.NORA.2H.Nora.4": "Esta especie está en peligro de extinción. Es muy sensible a los cambios ambientales, y con el calentamiento global y la contaminación, está desapareciendo lentamente.$2#$b#En realidad se originaron en una isla llamada Arkánia y eventualmente llegaron aquí.#$b#El valle solía estar lleno de ellos hace veinte años. Era el hábitat perfecto para que se reprodujeran y encontraran suficiente comida.#$b#Sin embargo, desde que llegó Joja, las cosas han cambiado mucho. Supongo que sabes por qué.$5",
"Events.NORA.2H.Nora.5": "Mi principal objetivo aquí es ver si quedan algunos de ellos en este lugar.$2#$b#Si es así, tengo que evaluar cuántos quedan, qué los está afectando más y si todavía hay una forma de revertir la situación.$3",
"Events.NORA.2H.Nora.6": "Cada vez que una especie se extingue, es como... que muere una parte del planeta. Se pierde una parte de la historia.$2#$b#Y es realmente triste ver que los humanos están dispuestos a hacer cosas que saben que dañarán el planeta, solo... Por dinero.$2",
"Events.NORA.2H.Nora.7": "Es nuestro trabajo como científicos hacer algo al respecto.",
"Events.NORA.2H.Nora.8": "De todas formas, debería volver a ello. ¡Uno de ellos podría aparecer en cualquier momento!$1#$b#Gracias por la compañía, @.",

// 3 HEARTS
"Events.NORA.3H.Vincent.1": "Entonces... ¿Es como una armadura?$3",
"Events.NORA.3H.Nora.1": "Bueno, no realmente, ¡Pero cerca!$1#$b#Las escamas pueden proteger a los reptiles contra otros animales, es cierto. Pero no es lo único que hacen.#$b#También les ayudan a moverse a veces, ¡Incluso les permiten almacenar agua dentro de sus cuerpos!$4",
"Events.NORA.3H.Eloise.1": "¡Eso suena genial!",
"Events.NORA.3H.Vincent.2": "¿Entonces por qué nosotros no tenemos escamas?",
"Events.NORA.3H.Nora.2": "¡Eso es porque tenemos muchas otras cosas que los reptiles no tienen!$1#$b#Así que no necesitamos escamas.",
"Events.NORA.3H.Jas.1": "Entonces, ¿Qué somos nosotros?",
"Events.NORA.3H.Penny.1": "Oh, @. Qué bueno verte.#$b#Estábamos en medio de una clase con nuestra invitada especial.",
"Events.NORA.3H.Vincent.3": "¿Puede @ quedarse también?",
"Events.NORA.3H.Eloise.3": "Sí, @, ¡Por favor quédate. Estamos aprendiendo sobre reptiles con la Sra. Chambers!",
"Events.NORA.3H.Penny.2": "Eres bienvenido a quedarte si lo deseas, @.",
"Events.NORA.3H.Nora.3": "Bien, ¿En dónde nos quedamos...",
"Events.NORA.3h.Nora.4": "Bueno, ya que lo preguntas, Jas, ¡Nosotros somos clasificados como mamíferos!",
"Events.NORA.3H.Eloise.4": "Y eso es diferente de las aves también, ¿Verdad?",
"Events.NORA.3H.Nora.5": "¡Tienes razón, Eloise!$1#$b# Las aves, los reptiles y los mamíferos son todos grupos diferentes de animales.$4#$b#¡Y hay muchos otros también, como los anfibios y los peces!",
"Events.NORA.3H.Vincent.4": "¿Y qué es lo que los hace tan diferentes entre sí?$3",
"Events.NORA.3H.Penny.3": "Niños,  no creo que la Sra. Chambers tenga tiempo para contarles todo eso hoy$1",
"Events.NORA.3H.Nora.6": "¡Oh, no te preocupes Penny, está bien. Estoy totalmente dispuesta a pasar más tiempo aquí si lo desean!$1#$b#No soy experta en todos los grupos de animales, pero recuerdo bien mis conceptos básicos de mi carrera de biología.",
"Events.NORA.3H.Nora.7": "Muy bien niños, abróchense el cinturón, porque estamos a punto de entrar en el fascinante mundo de la zoología...$4",

// 4 HEARTS
"Events.NORA.4H.Nora.1": "¿Cómo que no lo tienen?$2",
"Events.NORA.4H.Gunther.1": "Eso es exactamente lo que es, Sra. Chambers.#$b#Me temo que ninguno de los libros que está buscando se encuentra actualmente en nuestro inventario.#$b#De hecho, creo que el único libro sobre el tema que tenemos aquí ahora es su propio libro, gracias a su generosa donación.",
"Events.NORA.4H.Nora.2": "Aw, eso es realmente lamentable.$2#$b#Pero lo entiendo. Sé que el museo se está reconstruyendo lentamente después de lo que le pasó a la colección.$2#$b#Además, te lo he dicho, Gunther. ¡Nora está bien! Ms. Chambers es tan formal!#$b#Me recuerda a mis días en la universidad.",
"Events.NORA.4H.Gunther.2": "Sí, es muy lamentable.#$b#Pero eres bienvenida a traer tus propios libros aquí para estudiar. Disfruto de tu compañía.",
"Events.NORA.4H.Nora.3": "Eres demasiado amable, Gunther. Aprecio que prestes oído a todo lo que tengo que decir.",
"Events.NORA.4H.Nora.4": "Ah, @! ¡Justo a tiempo!$1#$b#Ven conmigo, me gustaría mostrarte algo.",
"Events.NORA.4H.Gunther.3": "Tomaré la indirecta y volveré al trabajo ahora.",
"Events.NORA.4H.Nora.5": "¡Sígueme!",
"Events.NORA.4H.Nora.6": "Está justo en ese estante de allí.#$b#Es algo de lo que estoy muy orgullosa.$1#",
"Events.NORA.4H.Nora.7": "¿Ves esto? Es una copia de 'La Herpetología de la República de Ferngill'.#$b#Y es muy especial para mí, ¡Porque yo lo escribí!$1",
"Events.NORA.4H.Nora.8": "Verás, en realidad salté un año en la escuela secundaria y pasé directamente de segundo a cuarto...$2#$b#Así que era más joven que la mayoría cuando ingresé a la Universidad de Zuzu.#$b#La universidad fue una experiencia maravillosa para mí. El campo académico es realmente para lo que fui hecha.$1#$b#Por eso me lancé directamente a mi maestría después de graduarme.",
"Events.NORA.4H.Nora.9": "Ah, siempre fue el plan obtener un doctorado.#$b#Pero, por mucho que lo amara, se vuelve... Abrumador, a veces.$2#$b#Me di cuenta de que necesitaba un descanso antes de lanzarme a la investigación más extensa e inmersiva de mi vida.",
"Events.NORA.4H.Nora.10": "Así que tomé un año sabático.$1#$b#Pero aún así, aunque se suponía que debía despejar mi mente del tema, simplemente... me sumergí en ello.#$b#Durante un año, viajé por Ferngill aprendiendo más sobre las especies locales de reptiles y anfibios, y recopilando tanta información como pude.$1#$b#Y escribí este libro al respecto.$4",
"Events.NORA.4H.Nora.11": "Pero hay... más en ello.$2#$b#Mientras viajaba, era difícil no sentir... que no pertenecía.$2#$b#Toda mi vida, he estado tratando de encajar. De sentir que soy parte de algo más grande. Un grupo, una comunidad...$2#$b#Y aunque la academia puede sentirse así, a veces se siente todo lo contrario.$2",
"Events.NORA.4H.Nora.12": "Stardew Valley fue en realidad mi última parada antes de volver a Zuzu City.#$b#Me alojé en la posada mientras realizaba la investigación, pero... En el poco tiempo que estuve aquí, pude sentirlo.#$b#Sentí que este era el lugar donde se suponía que debía estar. Que había un propósito más grande aquí.$1#$b#Así que, cuando me enteré de que Tori estaba buscando un compañero de piso, me postulé de inmediato.",
"Events.NORA.4H.Nora.13": "Fue aquí donde terminé el libro y lo publiqué.#$b#Esta copia que ves aquí es en realidad la primera que recibí. Así que...#$b#!Léelo si tienes tiempo! Te lo prometo, es divertido.$1",
"Events.NORA.4H.Nora.14": "Y, una vez más, estoy divagando. Perdona por eso.$1#$b#Ahora te dejaré ir, @.",

// 6 HEARTS
"Events.NORA.6H.Nora.1": "Ah, Nora. Esta vez realmente la has cagado, ¿Eh?$2",
"Events.NORA.6H.Nora.2": "Oh, @. ¡Eres tú!$1#$b#No sabía que disfrutaras de los paseos nocturnos.#$b#Es una noche preciosa, ¿No?",
"Events.NORA.6H.Nora.Question.1": "Lo siento, granjero, pero creo que realmente no estoy de humor para tener una conversación normal.",
"Events.NORA.6H.Q1.Answer.1": "¿Ha pasado algo?",
"Events.NORA.6H.Q1.Answer.2": "Eso no suena realmente a ti.",
"Events.NORA.6H.Q1.Response.1": "Ah. Realmente no se me da bien esto, ¿Verdad?",
"Events.NORA.6H.Q1.Response.2": "...¿Creo que no, verdad?$2",
"Events.NORA.6H.Nora.4": "Estoy muy cerca de terminar mi doctorado.$2#$b#Bueno, en realidad, solo... Tengo que entregarlo pronto. Pero aún me queda mucho por hacer.$2",
"Events.NORA.6H.Nora.5": "Cuando le dije a mis padres que quería ser herpetóloga, no estaban exactamente... Entusiasmados.$2#$b#Mi familia está llena de abogados, incluido mi hermano, así que les sorprendió que eligiera esto.$2#$b#No se opusieron. De hecho, me apoyaron. Me dijeron que sería una gran científica y haría descubrimientos increíbles. Solo que les sorprendió.",
"Events.NORA.6H.Nora.6": "Pero las cosas no resultaron exactamente así.$2#$b#Mi madre siempre presumía de que yo era la mejor de mi clase, persiguiendo el campo académico y siendo inteligente.#$b#Pero eventualmente... Creo que se quedó sin cosas de las que presumir.$2",
"Events.NORA.6H.Nora.7": "Ser académica es difícil. Ser mujer en este campo es aún más complicado.$2#$b#Tienes que probar constantemente que vales.$2#$b#Las cosas que antes eran fáciles se vuelven un desafío. Y el TDAH a veces hace que sea imposible concentrarme.$2#$b#Es como... Si tuviera las ruedas más brillantes y ahora se estuvieran oxidando.$2",
"Events.NORA.6H.Nora.8": "Esta investigación que estoy haciendo, tratando de salvar a esta especie...$2",
"Events.NORA.6H.Nora.9": "Necesito que sepas que me importan.#$b#Los reptiles han sido una pasión mía durante toda mi vida. Y haría cualquier cosa por salvarlos.#$b#Pero...$2",
"Events.NORA.6H.Nora.10": "Me avergüenza admitir que una parte de mí realmente quiere lograr esto porque quiero volver a sentirme extraordinaria.$2#$b#No solo... Yo. Sino alguien que hizo una diferencia.$2",
"Events.NORA.6H.Nora.11": "La luna se ve preciosa hoy, ¿Verdad?",
"Events.NORA.6H.Nora.12": "Lo que más me gusta de la luna es que... siempre está ahí.$2#$b#No importa cuánto caos traiga tu vida, la luna sigue siendo la misma.$2#$b#Supongo... que me trae consuelo. Saber que ella siempre está ahí para mí.$2",
"Events.NORA.6H.Nora.13": "Ya es tarde, @. No te retengo más.",

// 8 HEARTS PART 1
"Events.NORA.8H1.Nora.1.1": "¿Quién es?$5",
"Events.NORA.8H1.Nora.1.2": "Oh, @, eres tú.$2#$b#Lo siento, pero ¿Podrías dejarme sola? Yo-Yo estoy muy ocupada en este momento y yo-$2#$b#...Creo que ya no puedo hacer esto.$6",
"Events.NORA.8H1.Nora.2": "Ya no están aquí, @. Se fueron, se fueron todos.$6#$b#O tal vez soy muy mala en mi trabajo.$2",
"Events.NORA.8H1.Nora.Question.1": "Fracasé, @. Ahora todo ha terminado.",
"Events.NORA.8H1.Nora.Q1.Answer.1": "¿De qué estás hablando?",
"Events.NORA.8H1.Nora.Q1.Answer.2": "Deja de ser dramática y dime qué pasó.",
"Events.NORA.8H1.Nora.Q1.Answer.3": "¿Por qué no respiramos profundo? Déjame ayudarte.",
"Events.NORA.8H1.Nora.Q1.Response.1": "¡Los camaleones, @. Se han ido!$6",
"Events.NORA.8H1.Nora.Q1.Response.2": "Lo siento, es que estoy realmente abrumada en este momento...$2#$b#Por eso quería que me dejaran sola.$5",
"Events.NORA.8H1.Nora.Q1.Response.3": "...Está bien. Lo intentaré. Solo dame un segundo.$2",
"Events.NORA.8H1.Nora.4": "Como sabes, he estado buscando los camaleones de cola púrpura durante bastante tiempo.$2#$b#Ha sido más de un año. Un año de mi vida dedicado a esto, y no he encontrado ninguno.$2#$b#No me queda más tiempo. Tengo que entregarlo pronto.$2#$b#Y ahora toda mi tesis es inválida.$2",
"Events.NORA.8H1.Nora.5": "Le prometí a mis padres... Les prometí que los volvería a hacer sentir orgullosos.$2#$b#Pensé que podía hacerlo. Estaba tan segura de ello, que ni siquiera consideré una hipótesis diferente.$6#$b#Realmente... He perdido mi chispa.$6",
"Events.NORA.8H1.Nora.6": "Ni siquiera sé qué soy aparte de esto.$2#$b#No sé qué hacer. Estoy muy decepcionada y solo quiero rendirme.$6",
"Events.NORA.8H1.Nora.Question.2": "¿Y si esto no es para lo que estoy hecha?",
"Events.NORA.8H1.Nora.Q2.Answer.1": "Lo eres. ¡Eres Nora, la herpetóloga!",
"Events.NORA.8H1.Nora.Q2.Answer.2": "Un contratiempo le puede pasar a cualquiera.",
"Events.NORA.8H1.Nora.Q2.Answer.3": "Tal vez deberías rendirte.",
"Events.NORA.8H1.Nora.Q2.Answer.4": "Tal vez estés mirando esto desde la perspectiva equivocada.",
"Events.NORA.8H1.Nora.Q2.Response.1": "...Ah, @. Me gusta mucho ese título, en realidad.",
"Events.NORA.8H1.Nora.Q2.Response.2": "Sí... Supongo que podría pasar.",
"Events.NORA.8H1.Nora.Q2.Response.3": "¿Tú crees?#$b#Bueno, yo... tal vez... *sollozo*$2",
"Events.NORA.8H1.Nora.Q2.Response.4": "¿De verdad? ¿Crees que hay algo bueno aquí?$2",
"Events.NORA.8H1.Nora.8": "¿Sabes qué? Yo... no puedo rendirme ahora.$2#$b#Esta ciencia, este proyecto, es toda mi vida. No puedo tirarlo todo por la borda.$2#$b#Tienes razón, @... Tal vez si lo miro desde otra perspectiva...$3#$b#Tal vez aún pueda funcionar.",
"Events.NORA.8H1.Nora.9": "Tienes que irte ahora. Nada personal, es solo que... Necesito trabajar en esto.",
"Events.NORA.8H1.Nora.10": "Oh, y...$2#$b#Gracias, @.#$b#Lo que acaba de pasar... Significa mucho para mí.",

// 8 HEARTS PART 2
"Events.NORA.8H2.Leah.1": "¡Mira, Nora! ¡Te lo dije!$1#$b#Estoy muy orgullosa de ti. Aunque voy a extrañar que revolotees por el bosque cerca de mi casa.#$b#Nuestras conversaciones siempre fueron divertidas.$1",
"Events.NORA.8H2.Nora.1": "Eres demasiado amable, Leah.#$b#¡Y no te preocupes. Seguro que seguiré merodeando! ¡No voy a renunciar a eso por completo!$1",
"Events.NORA.8H2.Maru.1": "¿Cómo te sientes al haber terminado oficialmente la universidad después de tanto tiempo?",
"Events.NORA.8H2.Nora.2": "Sé que se supone que debo decir que me siento aliviada, pero sé que voy a terminar echándolo de menos.$1#$b#Bueno, supongo que ahora tendré más tiempo para compartir información con la gente, así que eso está bien...$3",
"Events.NORA.8H2.Nora.3": "Y en última instancia, creo... Que me siento orgullosa.#$b#Las cosas no salieron exactamente como esperaba, pero... Está bien. Ahora puedo verlo.",
"Events.NORA.8H2.Harvey.1": "¡Deberías estarlo! Lo has hecho genial.$1",
"Events.NORA.8H2.Nora.4": " ¡Oh, @, estás aquí! ¡Maravilloso!$1",
"Events.NORA.8H2.Nora.5": "Esperen un momento, chicos, quiero hablar con @ un segundo. ¡Ahora vuelvo!",
"Events.NORA.8H2.Nora.6": "¡Me alegro mucho de que hayas venido! La fiesta no sería tan buena sin ti.$1",
"Events.NORA.8H2.Nora.7": "Primero que nada, quiero disculparme por irme tan de repente esta semana pasada.$2#$b#Pero necesitaba concentrarme para poder darle la vuelta a esto. ¡Y lo he conseguido!",
"Events.NORA.8H2.Nora.8": "Después de nuestra conversación, me di cuenta de que incluso si las cosas van de manera diferente a lo que tenía planeado, no era demasiado tarde para marcar la diferencia.",
"Events.NORA.8H2.Nora.9": "Tal vez no pude salvar al camaleón de cola púrpura... lo cual realmente me entristece.$2#$b#Así que decidí escribir mi ensayo final sobre la extinción en sí y las formas de prevenirla.#$b#Lo expliqué todo, qué la causa, cómo intentar salvar una especie, e incluso cité a algunas otras en peligro.$4#$b#¡Y también me he puesto en contacto con otros académicos sobre esas especies! ¡Incluso algunos científicos me han contactado a mí!$1#$b#¿Esto es lo que se siente ser famoso?$3",
"Events.NORA.8H2.Nora.10": "Me estoy desviando de nuevo. El punto es...#$b#Ser considerada una niña superdotada cuando era joven me hizo pensar que tenía que mantener ese estándar también como adulta.$2#$b#Y cuando me di cuenta de que no era tan buena entonces... Era cada vez más difícil seguir intentándolo.$2#$b#Me castigaba mucho por fracasar, y eso me ponía en una mala espiral.$2#$b#Y yo simplemente...$2",
"Events.NORA.8H2.Nora.11": "Gracias por hacerme ver que no necesito ser perfecta para ser lo suficientemente buena.",
"Events.NORA.8H2.Nora.12": "¡Oh, volvamos a la fiesta! ¡Gus está sacando la comida pronto!$1",

// 9 HEARTS
"Events.NORA.9H.Nora.1": "Oh. Hola, @.#$b#No tendrás por casualidad un paraguas contigo, ¿Verdad?$3",
"Events.NORA.9H.Nora.2": "Está bien. Estoy disfrutando de la lluvia.",
"Events.NORA.9H.Nora.3": "Este es el lugar donde empecé mi investigación. Hace tanto tiempo.#$b#Tenía tantos planes.$2",
"Events.NORA.9H.Nora.4": "¿Recuerdas lo que te dije cuando nos conocimos por primera vez aquí, en este bosque?$2",
"Events.NORA.9H.Nora.5": "Cada vez que una especie se extingue, una parte del planeta muere con ella.$2",
"Events.NORA.9H.Nora.6": "No me había dado cuenta de esto.$2#$b#Estaba tan concentrada en terminar el doctorado...$2#$b#Y con toda la ansiedad... No lo entendí.$2#$b#Tal vez hayamos perdido a esta especie para siempre.$2",
"Events.NORA.9H.Nora.7": "Lo siento, no quiero ponerme tan melancólica. Es solo que...$2#$b#La naturaleza es tan hermosa. Es tan perfecta. Cada detalle está ahí por una razón.#$b#Y nosotros... Los humanos, quiero decir... Siempre lo estropeamos.$2",
"Events.NORA.9H.Nora.8": "Pero tal vez solo soy una pesimista.#$b#Tal vez, en algún lugar, otro científico también está buscando a esos pequeños.#$b# ¡Y tal vez tengan éxito! ¿Quién sabe?$1",
"Events.NORA.9H.Nora.9": "Bueno, salgamos de esta lluvia entonces.#$b#Me estoy congelando. ¡Me debes un café!$1",

// 10 HEARTS PART 1
"Events.NORA.10H1.Nora.1": "Espero que haya algo interesante...",
"Events.NORA.10H1.Nora.2": " @! ¡Hola!$1#$b#Oh, la verdad es que estoy en un pequeño dilema ahora mismo. ¿Podrías darme algún consejo?",
"Events.NORA.10H1.Nora.3": "Así que, después de terminar el doctorado, dejé de recibir la beca de investigación de ZuCU. Lo cual era de esperar, por supuesto.#$b#Pero eso también significa que tengo que conseguir un nuevo trabajo ahora.$3#$b#Quiero decir, los suministros para reptiles no se compran solos, ¿Verdad?",
"Events.NORA.10H1.Nora.4": "Estaba mirando el tablón de anuncios a ver si hay ofertas de trabajo por aquí.$1#$b#De hecho... ZuCU me ha ofrecido un puesto de docente. Es una buena oferta, trabajar en lo que me gusta. Pero...#$b#Eso también significaría volver a Zuzu City. Y no quiero dejar el valle atrás.$2#$b#Me he acostumbrado a amar este lugar muchísimo. Y a la gente también.",
"Events.NORA.10H1.Gunther.1": "Bueno, un saludo, ustedes dos.",
"Events.NORA.10H1.Nora.5": "¡Gunther! ¡Qué bueno verte!$1#$b#Siento que nunca te veo salir de ese museo. Te vendría bien ir más a menudo al exterior.$3",
"Events.NORA.10H1.Gunther.2": "Acabo de terminar de hacer unas compras. Yo también tengo que comer, por si no lo sabías.$1",
"Events.NORA.10H1.Nora.6": "No te culpo. Si yo trabajara en el museo, también pasaría todo el tiempo allí.$1#$b#De hecho, básicamente ya lo hago si lo piensas.#$b#Oh, espera un momento... Hablando de eso...$3#$b#¿No tendrás por ahí alguna oferta de trabajo para una herpetóloga, verdad?",
"Events.NORA.10H1.Gunther.3": "Por mucho que me gustaría, no es tan sencillo.$2#$b#Tendría que conseguir recursos para eso, lo cual no puedo prometerte.$2#$b#Para ser completamente honesto, conseguir más fondos para el museo ha sido un problema durante mucho tiempo.$2#$b#Estamos bien como estamos ahora, pero me temo que no podemos contratar a nadie nuevo. Lo siento, Nora.$2",
"Events.NORA.10H1.Nora.7": "Lo entiendo completamente. También siento oír eso.$2#$b#Me encantaría trabajar contigo algún día, Gunther.",
"Events.NORA.10H1.Gunther.4": "Siento que serías una excelente adición a nuestro personal. Es una verdadera lástima.$2",
"Events.NORA.10H1.Nora.8": "En realidad, Gunther... Esta conversación me ha dado una idea.#$b#Si puedo conseguir esto...$3#$b#¿Puedes darme un poco de tiempo para volver a comunicarme contigo?",
"Events.NORA.10H1.Gunther.5": "No tengo ni idea de lo que estás hablando, así que supongo que sí.",
"Events.NORA.10H1.Nora.9": "¡Genial! ¡Los veré a ustedes en un par de días!$1",
"Events.NORA.10H1.Gunther.Question.1": "¿Deberíamos preocuparnos?",
"Events.NORA.10H1.Gunther.Q1.Answer.1": "Probablemente esté bien, ella sabe lo que hace.",
"Events.NORA.10H1.Gunther.Q1.Answer.2": "Me prepararía para las palabras si fuera tú.",
"Events.NORA.10H1.Gunther.Q1.Answer.3": "He aprendido a no hacer demasiadas preguntas.",
"Events.NORA.10H1.Gunther.Q1.Response.1": "Tienes razón. Bueno, debo irme. Tengo que volver al museo.$1",
"Events.NORA.10H1.Gunther.Q1.Response.2": "Oh Yoba, ¿Qué he hecho...$2#$b#Supongo que ahora debo volver al museo.",
"Events.NORA.10H1.Gunther.Q1.Response.3": "Es una gran persona. Seguramente esté bien.#$b#Supongo.$1#$b#Bueno, debo volver ahora. Hasta la próxima vez, @.",

// 10 HEARTS PART 2
"Events.NORA.10H2.Gunther.0": "Muy bien, deberíamos poder empezar pronto. ¿Cómo te sientes?$1",
"Events.NORA.10H2.Nora.0": "¿Hablas en serio? ¡Me siento genial!$1#$b#Ahora solo tenemos que esperar a que @ llegue...",
"Events.NORA.10H2.Nora.1": "@, ¡Me alegro mucho de que hayas podido venir! ¡Gunther y yo tenemos una noticia emocionante!$1#$b#Ja, dicho así parece que estuviéramos anunciando nuestro compromiso o algo.$1",
"Events.NORA.10H2.Gunther.1": "Eso sería extremadamente inapropiado, ya que ahora soy oficialmente tu jefe.$1",
"Events.NORA.10H2.Nora.2": "¡¿Como así?! ¡Tendrías suerte de casarte conmigo, viejo!$1",
"Events.NORA.10H2.Gunther.2": "¿Sabes que no soy tan viejo, verdad?$6#$b#Además, podría despedirte.",
"Events.NORA.10H2.Nora.3": "Bah, me echarías de menos.#$b#Así que, @, como supongo que ya habrás adivinado, ¡Soy la nueva investigadora postdoctoral del Museo!$1",
"Events.NORA.10H2.Gunther.3": "Nora se unirá a nuestro personal y será responsable de realizar investigacions sobre la ecología y la vida salvaje del Valle de Pelican.$1",
"Events.NORA.10H2.Nora.4": "Después de nuestra última conversación, visité ZuCU para discutir el trabajo que me ofrecieron. Y se me ocurrió hacer una... ¿Contraoferta?#$b#Ni siquiera estoy segura de que se pueda hacer eso con los trabajos...$3#$b#De todos modos, les pregunté si estarían interesados en financiar una rama de investigación aquí, en Pueblo Pelícano.$1#$b#No quería irme de aquí, pero tampoco quería cortar lazos con la Universidad.#$b#Así que ahora trabajo para el museo con fondos de ZuCU. Cualquier nuevo descubrimiento o artículo publicado será bajo el nombre de la Universidad.#$b#¡Y nosotros obtenemos los fondos!$1",
"Events.NORA.10H2.Gunther.4": "Esto no solo nos dará más financiación, sino también más visibilidad.",
"Events.NORA.10H2.Nora.5": "¡Sí! Y también daré clases semanales en ZuCU como parte del trabajo.$1#$b#Hablando sobre biología en general, herpetología, nuevos hallazgos, métodos de investigación...#$b#¡Realmente no podría estar más feliz!$1",
"Events.NORA.10H2.Gunther.5": "Bien, voy a empezar a trabajar ahora. Deberías hacer lo mismo, ¿Sabes?$1",
"Events.NORA.10H2.Nora.6": "¡Sí, sí,  estaré lista en un minuto!",
"Events.NORA.10H2.Nora.7": "Realmente no puedo creer que haya llegado tan lejos, @. Todo parece un sueño para mí. Y, además...$1#$b#Me alegro mucho de no tener que irme. Yo... #$b#Te echaría mucho de menos.",
"Events.NORA.10H2.Nora.8": "Debería irme ahora, tengo mucho que hacer. ¿Primer día, verdad?$1#$b#¡Pero hablemos pronto!", 

/// EXTRA EVENTS

// CLINIC EVENT - 4 HEARTS
"Events.NORA.Clinic.Maru.1": "Nora, no tienes por qué estar tan nerviosa. Todo va a salir bien, ¡Te lo prometo!",
"Events.NORA.Clinic.Nora.1": "Como científica y académica que soy, sé muy bien que esto es necesario y un procedimiento súper sencillo.$2#$b# Pero como mero ser humano, mortal, ¡Tengo permitido entrar en pánico!$5",
"Events.NORA.Clinic.Maru.2": "Realmente necesito que te mantengas calmada ahora. ¡No podemos hacerlo si te desmayas! Eso solo empeoraría las cosas.$2",
"Events.NORA.Clinic.Nora.2": "¡Bueno, mi plan está funcionando!$5",
"Events.NORA.Clinic.Nora.3": "Ugh, lo siento, Maru. Ahora mismo no estoy en mi mejor momento.$2",
"Events.NORA.Clinic.Maru.3": "Está bien, lo entiendo. Solo respira hondo, ¿De acuerdo?",
"Events.NORA.Clinic.Maru.4": " @! ¡Excelente! ¿Tal vez puedas ayudar a Nora a calmarse un poco?",
"Events.NORA.Clinic.Nora.4": "Lamento que tengas que verme en este estado. De verdad, yo... me pongo muy nerviosa con estos procedimientos.$2",
"Events.NORA.Clinic.Nora.5": "¿Por qué estoy nerviosa? Ah, eh, no es nada grave, en realidad...$2#$b#Verás, todo comenzó el día que bebí accidentalmente seis tazas de café expreso...",
"Events.NORA.Clinic.Nora.6": "¡Pensé que podría manejarlo! Normalmente lo hago.$5#$b#Pero hacía mucho calor... Y terminé sintiéndome muy fatigada. ¡Eso le puede pasar a cualquiera!#$b#Gunther me encontró desmayada en una de las mesas de la biblioteca. Me ayudó a llegar a casa, pero me hizo prometer que vería a Harvey.$2#$b#Y después de hablar con Harvey, dijo que necesitaba hacerme una prueba de sangre para asegurarse de que todo lo demás esté bien.$2",
"Events.NORA.Clinic.Nora.7": "El problema es... que yo, eh...$2#$b#Le tengo miedo a las agujas. ¿De acuerdo? Ya lo dije.$2#$b#Yoba, ¿Por qué YO? ¡Solo quería estudiar!$5#$b#Creo que he finjido la apariencia de una mujer empoderada...$2",
"Events.NORA.Clinic.Harvey.1": "Nora, ya todo está listo. Ven, por favor.",
"Events.NORA.Clinic.Nora.8": "Pues yo NO estoy lista.$5#$b#Verás, solo estaba tomando una siesta. ¡Gunther es un paranoico! Realmente no necesito esto...",
"Events.NORA.Clinic.Harvey.2": "Nora, entiendo que tengas miedo. Pero es importante cuidar de tu salud. Y esto es necesario.#$b#Creo que podrías tener una deficiencia de hierro y esa sea la razón por la que te has sentido tan fatigada últimamente. Pero necesito asegurarme.$2",
"Events.NORA.Clinic.Harvey.3": "Te prometo que será muy rápido. Ni siquiera lo vas a sentir, es como un piquete de mosquito.#$b#¿Por qué no mencionas todas las especies de lagarto que puedas recordar mientras hago te pongo la inyección? ¡Veamos cuántas puedes nombrar y convirtámoslo en un juego!$1",
"Events.NORA.Clinic.Nora.9": "Yo...$2#$b#Creo que... Creo que puedo hacer eso.",
"Events.NORA.Clinic.Harvey.4": "¡Excelente! Sígueme entonces.$1",
"Events.NORA.Clinic.Nora.10": "Gracias por tenerme paciencia, @. Nos veremos por ahí.",

// ISLAND EVENT - PART 1
"Events.NORA.IslandA.Nora.1": "¡Gracias por la ayuda, Willy!$1#$b#No me di cuenta de que traía tantas cosas aquí.$3#$b#¡La habitación del resort está llena, pero lo conseguimos todo!",
"Events.NORA.IslandA.Willy.1": "No hay problema, señorita. Me alegro de poder ayudar.$1#$b#Seguro que necesitará sus suministros si va a pasar un par de noches aquí.",
"Events.NORA.IslandA.Nora.2": "¡Oh no, solo voy a pasar el día!$1",
"Events.NORA.IslandA.Willy.2": "¿Solo el día?#$b#...Supongo que nunca se es demasiado cuidadoso.$2",
"Events.NORA.IslandA.Nora.3": "Lo sé, lo sé, es mucho.#$b#La playa simplemente... no es mi lugar favorito.$2#$b#Además, necesitaba mis materiales de investigación.$1#$b#Quiero ver qué tipo de biodiversidad tiene este lugar que mostrarnos.",
"Events.NORA.IslandA.Willy.3": "Entonces te deseo suerte.$1#$b#Que pases un buen día, señora. Yo me voy a pescar un rato.",
"Events.NORA.IslandA.Nora.4": "¡Tú también, Willy! ¡Gracias de nuevo!$1",
"Events.NORA.IslandA.Nora.5": " @! ¡No esperaba encontrarte aquí hoy!$1#$b#¿Disfrutando de las maravillas tropicales?",
"Events.NORA.IslandA.Nora.6": "Justamente iba a explorar la isla. Ven, vamos a caminar juntos.",
"Events.NORA.IslandA.Nora.7": "Todo el mundo ha estado hablando mucho de este lugar últimamente, así que pensé: '¿Por qué no?'$1#$b#También he oído que hay un científico por aquí en alguna parte...$3",
"Events.NORA.IslandA.Nora.8": "Si me disculpas, tengo que ponerme a trabajar ahora.#$b#Gunther ha sido insistente en que explore este lugar.#$b#Nos veremos más tarde, ¿De acuerdo?",
"Events.NORA.IslandA.Nora.Question.1": "¿Qué? ¿Qué pasa?",
"Events.NORA.IslandA.Nora.Q1.Answer.1": "¡El camaleón! ¡Estaba justo ahí!",
"Events.NORA.IslandA.Nora.Q1.Answer.2": "Yo... Debo estar viendo cosas.",
"Events.NORA.IslandA.Nora.Q1.Response.1": "¿Camaleón? No veo nada.$3",
"Events.NORA.IslandA.Nora.Q1.Response.2": "¡Oh no, no me digas eso @!$1#$b#Quiero explorar el lugar de noche, ¡Me vas a asustar!",
"Events.NORA.IslandA.Nora.Question.2": "Ok, estás actuando raro...",
"Events.NORA.IslandA.Nora.Q2.Answer.1": "¡TE LO JURO! ¡Estaba ahí!",
"Events.NORA.IslandA.Nora.Q2.Answer.2": "¿Será otro efecto del té del Mago...?",
"Events.NORA.IslandA.Nora.Q2.Response.1": "...Bueno, me aseguraré de buscarlo, supongo.$3",
"Events.NORA.IslandA.Nora.Q2.Response.2": "Realmente no tienes mucho sentido, @.$2",
"Events.NORA.IslandA.Nora.9": "Creo que deberías descansar un poco.$2#$b#Te veo más tarde, ¿De acuerdo?#$b#Que tengas un buen dí-$1",
"Events.NORA.IslandA.Nora.10": "...?$7",
"Events.NORA.IslandA.Nora.11": "...!$7",
"Events.NORA.IslandA.Nora.12": "¿POR LOS PANTALONES MÁS ROSADOS DE YOBA, ESTO ES REAL?$7#$b#¿ESTÁS VIENDO ESO?$7#$b#¿POR QUÉ NO ME DIJISTE NADA?$5#$b#Lo siento, lo siento, es solo que-$7#$b#¡TENGO QUE IR AHORA MISMO!$1",

// ISLAND EVENT - PART 2
"Events.NORA.IslandB.Nora.1": "¡Gracias por toda la ayuda, Profesor Caracol.#$b#No voy a mentir, ¡Estoy extasiada! ¡Esto es una gran noticia para la comunidad científica!$1#$b#¡Pronto estaremos fuera de la oficina!",
"Events.NORA.IslandB.Snail.1": "Es un honor participar en un evento así.$1#$b#Espero que me mencionen en el artículo que publiques.",
"Events.NORA.IslandB.Nora.2": "¡Absolutamente!$1",
"Events.NORA.IslandB.Nora.22": "Jacob, ¿Cómo va todo por allá?",
"Events.NORA.IslandB.Jacob.1": "Este pequeño parece estar bien.$4#$b#Encontré un parásito, pero nada de qué preocuparse. Ya se lo quité.#$b#Ahora estoy trabajando en ponerle un chip.",
"Events.NORA.IslandB.Nora.3": "¿Qué hay de las muestras de sangre?$3",
"Events.NORA.IslandB.Jacob.2": "Ya están en la caja refrigerada.#$b#No podemos arriesgarnos con este clima.",
"Events.NORA.IslandB.Nora.4": "Eres el mejor, Jacob. Gracias por venir con tan poco aviso.",
"Events.NORA.IslandB.Nora.5": " @! ¡Recibiste mi carta!$1#$b#Pensé que querrías ver esto, ya que estuviste presente durante toda mi investigación.#$b#Así que, quiero que conozcas a...#$b#¡Echo!$1",
"Events.NORA.IslandB.Nora.6": "Ahora mismo, estamos haciendo los procedimientos estándar.#$b#Tomamos algunas muestras de sangre, asegurándonos de que esté sano...$3#$b#Por ahora, este es el único ejemplar que encontramos. Así que, podría ser el último con vida.$2#$b#Sin embargo, lo estamos chipando y monitoreando antes de soltarlo.#$b#¡Podría llevarnos a otros, quizás hasta encontremos una hembra!$1",
"Events.NORA.IslandB.Gunther.1": "Pero recuerda, debe mantenerse en un lugar seguro antes de permitirle regresar allí.#$b#No sabemos si esta especie tiene depredadores alrededor, por lo que debe ser vigilado y protegido en todo momento.",
"Events.NORA.IslandB.Jacob.3": "También tenemos que asegurarnos de que no se lastime. Podría ser la única oportunidad de revivir a la especie.",
"Events.NORA.IslandB.Nora.7": "Sí. Es por eso que lo mantendremos aquí por un tiempo antes de intentar encontrar a los demás.#$b#Le he enviado una carta al departamento de herpetología de ZuCU solicitando ayuda sobre cómo proceder.#$b#Están armando un equipo para explorar la isla y encontrar más de ellos.#$b#Otro equipo trabajará en mantener a Echo seguro y cómodo aquí hasta que decidamos el siguiente curso de acción.",
"Events.NORA.IslandB.Gunther.2": "Parece que tienes todo planeado, Srta. Chambers.$1#$b#Si me disculpan, debo regresar al museo ahora. Es mejor documentar todo esto mientras está fresco.$3",
"Events.NORA.IslandB.Snail.2": "Yo también debo volver a mi trabajo. Pero Echo es bienvenido aquí el tiempo que lo necesiten.#$b#¡Brindemos por la esperanza de que encuentren pronto un espécimen hembra!$1",
"Events.NORA.IslandB.Nora.8": "¡Muy bien! ¡Les debo a todos una bebida!$1#$b#Mantén un ojo en Echo, Profesor. Jacob y yo vamos a llevar estas muestras al laboratorio.#$b#¡Vamos, todos, tenemos trabajo que hacer!$1",

// EXTRA EVENT
"Events.NORA.Extra.Nora.1": "¡POR YOBA! ¡Me asustaste!$7#$b#¡No deberías estar acechando a la gente así!$5",
"Events.NORA.Extra.Nora.Question.1": "¿Por qué hiciste eso?",
"Events.NORA.Extra.Nora.Q1.Answer.1": "Te dije hola, pero no respondiste.",
"Events.NORA.Extra.Nora.Q1.Answer.2": "Lo siento, no quise asustarte...",
"Events.NORA.Extra.Nora.Q1.Response.1": "¿Eso hiciste?$3#$b#¡Ah, es cierto! ¡Tenía apagado mi audífono!$7",
"Events.NORA.Extra.Nora.Q1.Response.2": "Oh, no, espera...$3#$b#Esto es culpa mía, tenía apagado mi audífono. No es tu culpa.",
"Events.NORA.Extra.Nora.2": "Creo que te lo mencioné, soy sorda.#$b#Bueno, no totalmente, pero tengo problemas de audición.$3#$b#Cuando mi audífono está apagado, normalmente puedo leer los labios.#$b#Pero como estabas detrás de mí, no tenía idea.",
"Events.NORA.Extra.Nora.3": "Sí, sí, no te preocupes por eso.$1#$b#En realidad no nací sorda. Fue por una infección grave que tuve cuando era niña. Una cosa horrible.#$b#He pasado mucho tiempo con un fonoaudiólogo desde entonces.$3#$b#Pero no hay necesidad de sentirte mal por eso. Mi vida es perfectamente buena.$1",
"Events.NORA.Extra.Nora.4": "De todos modos, la próxima vez que no responda, no te lo tomes personal, ¿De acuerdo?#$b#Y por favor, no me asustes así de nuevo.$1",

/// CROSSOVER EVENTS

// FROG FRIENDS
"Events.NORA.FrogFriends.Marnie.1": "Muchas gracias por aceptar ayudarnos, Sra. Chambers.$1",
"Events.NORA.FrogFriends.Nora.1": "¡Oh, por favor, Nora está bien!$1#$b#Y, por supuesto, estoy más que feliz de ayudar.#$b#Estos pequeños amigos merecen el mejor hogar posible.",
"Events.NORA.FrogFriends.Robin.1": "Muy bien, entonces deberíamos empezar.$1#$b#Cuanto antes termine con estos planos, más rápido podremos traer las ranas aquí.",
"Events.NORA.FrogFriends.Nora.2": "¿Crees que el nuevo granjero estará dispuesto a criar ranas?$3#$b#Sería MUY GENIAL lo si estuviera...",
"Events.NORA.FrogFriends.Marnie.2": "Bueno, hablando del diablo...#$b#Hola, @. Nora estaba hablando de ti.",
"Events.NORA.FrogFriends.Nora.3": "No te preocupes, ¡solo cosas buenas!$1#$b#Ya que estás aquí, puedo preguntarte directamente.$3#$b#Entonces, ¿qué opinas sobre las ranas? ¿Algún comentario sobre ellas?",
"Events.NORA.FrogFriends.Robin.2": "¿Quizás sería mejor si proporcionáramos un poco de contexto aquí?$1",
"Events.NORA.FrogFriends.Nora.4": "Quiero decir, esa es una pregunta perfectamente aceptable por sí sola, pero probablemente tengas razón.$3",
"Events.NORA.FrogFriends.Marnie.3": "No te preocupes, yo me encargaré de esto.$1#$b#@, planeo vender ranas aquí en la tienda, además de los animales de granja habituales.#$b#Nora y Robin están aquí para ayudarme a planificar recintos adecuados para ellas, para que puedan criarse aquí en el valle.#$b#Pensé que los tres juntos podríamos encontrar algo lo más cómodo posible para las pequeñas.",
"Events.NORA.FrogFriends.Robin.3": "Si decides que quieres tenerlos en tu granja, simplemente pasa por mi tienda.#$b#Incluiré la opción de construir un terrario y también mejorarlo para que pueda albergar más animales en el futuro.$1#$b#Hm, me pregunto si Sebastian querrá que construya uno en nuestro patio trasero...$2",
"Events.NORA.FrogFriends.Nora.5": "Yo apoyaría totalmente su decisión. Todo el mundo debería tener una rana en algún momento.",
"Events.NORA.FrogFriends.Nora.Question.1": "¿Qué opinas? ¿Criarás ranas en tu granja?",
"Events.NORA.FrogFriends.Nora.Q1.Answer.1": "Creo que me gustaría intentarlo.",
"Events.NORA.FrogFriends.Nora.Q1.Answer.2": "No lo sé, tendré que pensarlo.",
"Events.NORA.FrogFriends.Nora.Q1.Answer.3": "...Creo que paso.",
"Events.NORA.FrogFriends.Nora.Q1.Response.1": "¡Genial! Visitaré tu granja con más frecuencia.$1#$b#¿Sabes? Podrías ponerle mi nombre a una de ellas, ¿eh?$3",
"Events.NORA.FrogFriends.Nora.Q1.Response.2": "Bueno, ¡por favor consideralo!#$b#Sé que la mayoría de la gente piensa que son asquerosos, pero son tan lindaas como otros animales.#$b#¡Tenemos que amar a los no amados!$1",
"Events.NORA.FrogFriends.Nora.Q1.Response.3": "Oh... realmente pensé que no discriminarías a las ranas.$2#$b#Ningún animal vale menos que otro.$2#$b#Bueno, tal vez las cucarachas... Pero no voy a entrar en ese tema.$3",
"Events.NORA.FrogFriends.Robin.4": "Bueno, si decides criarlas, acércate a mi tienda y te construiré el terrario.$1#$b#Ahora, si me disculpas, tengo que irme. Que tengan un buen día.",

// RODNEY
"Events.NORA.Rodnora.Gunther.1": "¿En qué puedo ayudarte hoy, Rodney?",
"Events.NORA.Rodnora.Rodney.1": "Bueno, mi querido Gunther, dado que tu sección de ficción tiene una grave carencia en el departamento de ciencia ficción, me preguntaba si tenías algún libro sobre formas de vida extraterrestre.#$b#¡Para fines de investigación!$1",
"Events.NORA.Rodnora.Gunther.2": "*suspira* Bueno, supongo que podrías darle Misterios del Ena-",
"Events.NORA.Rodnora.Nora.1": "¡GUNTHER! Tienes que leer este libro, lo conseguí de un amigo de ZuCU.$1#$b# Nos da un nuevo enfoque a las teorías anteriores sobre esa especie que mencioné el otro día.-$4",
"Events.NORA.Rodnora.Rodney.2": "Disculpe señorita, ¡Es de muy mala educación interrumpir la conversación de otra persona!$5",
"Events.NORA.Rodnora.Nora.2": "Oh, yo lo... Lo siento mucho! No era mi intención...$2#$b#Espera un minuto...$3#$b#¿No eres tú... EL AUTOR DOS VECES GANADOR DE PREMIOS RODNEY O'BRIEN?$7#$b#¡Señor!¡Soy una gran, gran admiradora! Es un placer conocerlo, ¡mi nombre es Nora!$1",
"Events.NORA.Rodnora.Gunther.3": "¿Quieres decirme que no se habían conocido hasta este mismo día? Pensé que eran vecinos.",
"Events.NORA.Rodnora.Nora.3": "¡Lo somos! Pero, quiero decir, ¡es el Rodney O'Brien!#$b#¿Qué se suponía que debía hacer, solo saludarlo? ¡No podría hacerlo! ¡Es una leyenda, Gunther!$5",
"Events.NORA.Rodnora.Rodney.3": "Bueno... yo... eh... quiero decir... $8#$b#No sé qué decir. Ahora me siento como un idiota por hablarte así y por ignorarte desde que me mudé aquí.$2",
"Events.NORA.Rodnora.Gunther.4": "¿La has estado ignorando?",
"Events.NORA.Rodnora.Rodney.4": "Es vergonzoso, y por favor no lo tomes como algo personal Nora, pero...$2#$b# Eres un poco ruidosa y yo soy muy terco, disfruto de la tranquilidad...",
"Events.NORA.Rodnora.Nora.4": "Ah, ya lo sé. Soy un poco habladora, lo admito.#$b#Pero ya que lo mencionaste, hay algo que puedes hacer para compensarme.$3",
"Events.NORA.Rodnora.Gunther.5": "No mencionó nada de compensa-",
"Events.NORA.Rodnora.Nora.5": "¿Me dejarías invitarte a una bebida? ¡Me muero de ganas de tener una conversación real contigo! $1",
"Events.NORA.Rodnora.Rodney.5": "Oh, hey hola @! ¡Me alegro mucho de que estés aquí!$1#$b#Nora y yo estábamos a punto de pasar por el salón a tomar algo, ¿Nos acompañas?#$b#(Susurra)Por favor, no me dejes solo con ella.$2",
"Events.NORA.Rodnora.Message": "Los tres se dirigen al Salón Fruta Estelar para tomar algo y charlar.",
"Events.NORA.Rodnora.Nora.6": "¡Estuvo muy rico! ¡Gracias a ambos por este delicioso almuerzo!$1#$b#Me tengo que ir ahora, todavía tengo mucha investigación por hacer hoy.#$b#Pero si tienes más preguntas sobre las serpientes, ¡ya sabes dónde encontrarme!$1",
"Events.NORA.Rodnora.Rodney.6": "No es tan mala como me la imaginaba. En realidad, es bastante genial. Para ser una nerd.$1",

// NORA SET DATING
"Events.NORA.SetDating.Nora.1": "Hola @! Yoba, hace un día precioso hoy, ¿no?$1",
"Events.NORA.SetDating.Nora.2": "Entonces, eh... pensé en enviarte una carta con esta información, pero...$2#$b#¡Pensé que sería mejor si te lo decía en persona!",
"Events.NORA.SetDating.Nora.3": "Lamentablemente, tengo prisa.$2#$b#Tengo que tomar el autobús a Ciudad Zuzu si planeo llegar a tiempo para clases.#$b#Entonces...¿Podríamos hablar en otro momento?#$b#¿Más tarde, en el salón, a las 7 p. m.?",
"Events.NORA.SetDating.Nora.4": "Genial, entonces nos vemos más tarde!$1",

// NORA DATING INVITE
"Events.NORA.DatingInvite.Nora.1": "Está bien... está bien, lo peor que pueden decir es no, ¿verdad?$2#$b#*suspiro* Gus, ¿puedes traerme otro café?$2",
"Events.NORA.DatingInvite.Gus.1": "Nora, ya te has tomado cinco tazas desde que llegaste aquí.",
"Events.NORA.DatingInvite.Nora.2": "¡Eso fue hace mucho tiempo! Han pasado como, ¿cuánto? ¿3 horas ya?$5",
"Events.NORA.DatingInvite.Gus.2": "Más bien 30 minutos.$2#$b#Y, para ser justos con @, llegaste temprano.",
"Events.NORA.DatingInvite.Nora.3": "Lo sé, lo sé... Estoy nerviosa.$2#$b#Quiero decir, todo lo que hice estos últimos años fue estudiar y escribir artículos y mi doctorado.#$b#Mis habilidades para las citas están peligrosamente oxidadas. Si alguna vez las tuve, claro.!",
"Events.NORA.DatingInvite.Gus.3": "Parece que estás a punto de descubrirlo. Recuerda, sé tú misma. Todo saldrá bien.",
"Events.NORA.DatingInvite.Nora.4": "¡Gus, espera! ¡Se supone que eres mi compinche!$5#$b#¡Danos algunos temas para romper el hielo!¡No me dejes sola!¡$2#$b#Heeeeeeeeeeeeeeeeeey tú! ¡No te esperaba aquí esta noche!$1",
"Events.NORA.DatingInvite.Nora.5": "Hm, sí, quiero decir, te invité aquí. Excelente, excelente punto.#$b#Entonces... ¿cómo está la granja? ¿Cómo va todo?$2",
"Events.NORA.DatingInvite.Nora.6": "Eso suena genial!$1#$b#...",
"Events.NORA.DatingInvite.Nora.7": "Uh, así que...$3",
"Events.NORA.DatingInvite.Nora.8": "De hecho, ¿podríamos ir a otro lugar? Hay demasiada gente aquí...#$b#Y hay algo importante que quiero decirte.",
"Events.NORA.DatingInvite.Nora.9": "¿Recuerdas cuando me encontraste en el puente?#$b#Hablábamos de los chismes que inventé para los peces en el río.#$b#Bueno, yo era la que hablaba, en realidad.#$b#Pero tú... escuchabas.",
"Events.NORA.DatingInvite.Nora.10": "Me hiciste sentir que me veías. Como...$2#$b#No me encontrabas rara ni incómoda. Podía simplemente... ser yo misma a tu lado.#$b#Me sentí segura. Estaba agradecida de tener a alguien tan increíble como tú.$1",
"Events.NORA.DatingInvite.Nora.11": "Y entonces me di cuenta... No quiero que seamos amigos... quiero decir... $2#$b#Me gustaría ser más... que solo una amiga... para ti.",
"Events.NORA.DatingInvite.Nora.12": "Por supuesto, si no quieres, aún podríamos ser amigos... Pero tenía que preguntar primero.",
"Events.NORA.DatingInvite.Nora.QuestionFork.1": "Entonces... ¿qué dices?",
"Events.NORA.DatingInvite.Nora.Question.Fork.1": "¡A mí me pasa lo mismo! ¡Pensé que nunca me lo preguntarías!",
"Events.NORA.DatingInvite.Nora.Question.Fork.2": "Yo... Lo siento, pero no creo que se una buena idea.",
"Events.NORA.DatingInvite.Nora.Yes.1": "¡SANTO YOBA! ¡Wow, eso fue un realmente vergonzoso!$1#$b#¡Estaba tan nerviosa pensando que podrías decir que no!#$b#¡Así que ahora soy tu novia!$1#$b#Quiero decir, no sé si estamos haciendo títulos o algo así pero si te gustaría llamarme tu novia...$3#$b#Quiero decir, que me encantaría pero no sientas que te estoy presionando a hacer alg-",
"Events.NORA.DatingInvite.Nora.Yes.2": "Oh, sí. Sí, eso también suena bien.$1#$b#Creo que esta es la primera vez que alguien realmente me hizo callar.",
"Events.NORA.DatingInvite.Nora.Yes.3": "Entonces... ¿quieres acompañarme a casa? ¿Quizás... quedarte un rato?",
"Events.NORA.DatingInvite.Nora.No.1": "Oh...$2#$b#Sí, uhm, probablemente tengas razón...$2",
"Events.NORA.DatingInvite.Nora.No.2": "No, no, está bien...$2#$b#Esto fue, um... Esto fue una mala idea. Deberíamos... seguir siendo solo amigos...$2",
"Events.NORA.DatingInvite.Nora.No.3": "Entonces... es mejor si me voy ahora, ¿eh?$2#$b#Te veré por ahí.$2#$b#¡No creas que te estás deshaciendo de mis datos nerds sobre lagartijas!#$b#Entonces, eh... nos vemos...$2",

// NORA DATE
"Events.NORA.Date.Nora.1": "¡Hola, calabacita! ¡Estaba a punto de pasar por la granja para verte! $1#$b#¡Qué bueno que te encontré aquí!#$b#Entonces, ¿te apetece tener una cita conmigo?",
"Events.NORA.Date.Nora.2": "¡Sí! ¡Vamos! Tengo algo especial planeado para ti.$1",
"Events.NORA.Date.Nora.3": "¿Qué? ¡De ninguna manera voy a decirte que es!#$b#No, no, ¡tendrás que venir conmigo y averiguarlo!#$b#No te hagas muchas ilusiones, es simple, de verdad.$3#$b#¡Pero realmente espero que te guste!",
"Events.NORA.Date.Nora.4": "Está bien, mantén los ojos cerrados, ¿de acuerdo?#$b#¡No mires!$1#$b#Está bien, solo un poco más lejos...#$b#¡Abre los ojos!",
"Events.NORA.Date.Nora.5": "¡Ta-da!$1#$b#¡Te horneé un pastel!#$b#¡Y lo hice desde cero! Ya sabes, ¡la masa, el relleno, el glaseado!$1#$b#¡Es un pastel de chocolate! ¡Espero que te guste!",
"Events.NORA.Date.Nora.6": "Bueno, porque no vienes y lo pruebas!",
"Events.NORA.Date.Nora.Question.1": "Entonceeees... que opinas?",
"Events.NORA.Date.Nora.Q1.Answer.1": "Eees... realmente bueno! Eres una gran chef por naturaleza!",
"Events.NORA.Date.Nora.Q1.Answer.2": "Verás, yo... creo que lo importante es que lo hiciste con cariño.",
"Events.NORA.Date.Nora.Q1.Response.1": "*suspiro* No tienes que mentir @. Sabe horrible, verdad?",
"Events.NORA.Date.Nora.Q1.Response.2": "*suspiro* Eso significa que... Sabe horrible, no es así?",
"Events.NORA.Date.Nora.11": "Bueno, la verdad es que eso es culpa tuya.#$b#Siempre he sido una mal cocinera. ¡Lo sabías desde el principio!$1",
"Events.NORA.Date.Nora.12": "Está bien, entonces tengo otra propuesta para ti.#$b#¿Qué tal si hacemos unas palomitas y ves un musical conmigo?#$b#¡Tengo una copia en DVD nueva de Twisted! ¡Estaba esperando verla contigo!$1",

/// ELI AND DYLAN

// crossover 1
"Events.NORA.END.Nora.1": "...Solo digo, es justo que quien elija la película no sea quien elija los bocadillos. ¡Uno no puede tenerlo todo!$3",
"Events.NORA.END.Eli.1": "Eso suena justo.#$b#No me importa qué tipo de comida súper específica quieras, mientras yo tenga mi café para acompañarlo.$1",
"Events.NORA.END.Dylan.1": "¿No te importa? ¿Seguro de eso?$6#$b#Recuerda que estamos hablando de Nora.$5",
"Events.NORA.END.Nora.2": "Oye, no veo cómo los Corn dog de pepinillo son súper específicos, ¡es un bocadillo perfectamente aceptable!$5#$b#Además, yo también quiero un poco de ese café Eli, así que no te lo quedes todo para ti.",
"Events.NORA.END.Dylan.2": "Eso es exactamente de lo que hablaba.$7#$b#Eso suena diabólico, ¿planeas tener dolor de estómago?$5",
"Events.NORA.END.Nora.3": "¡Son solo las consecuencias de una deliciosa experiencia gourmet!$1",
"Events.NORA.END.DylanText": "Yoba, sálvame...",
"Events.NORA.END.Eli.2": "Estoy de acuerdo con cualquier bocadillo que decidan, pero yo debería elegir qué vemos y a qué hora lo vemos.$12#$b#Ya sabes, para una mejor experiencia.$1",
"Events.NORA.END.Dylan.3": "NO puedo quedarme despierta después de las 10pm otra vez esta semana.$2",
"Events.NORA.END.Nora.4": "¡Él no podrá funcionar, Eli! ¡Ten algo de empatía!$5",
"Events.NORA.END.Eli.3": "¡Pero es el mejor momento posible para ver cualquier cosa! ¡Lo hará más espeluznante!$1",
"Events.NORA.END.Dylan.4": "¿Por qué asumes que eres tú quien elige la película?$4",
"Events.NORA.END.Eli.4": "Porque pareces muy preocupado por los bocadillos, así que pensé que la película podría ser mi elección.$1#$b#Además, tengo muchas ganas de algo espeluznante y no, ya sabes... un documental sobre la vida marina.$12",
"Events.NORA.END.Nora.5": "Un documental sobre la vida marina puede ser totalmente espeluznante. ¿HAS VISTO el océano? ¿Alguna vez?$3",
"Events.NORA.END.Dylan.5": "El único que debería tener miedo esta noche es el inodoro después de que comas esa monstruosidad.$9#$b#NO vas a usar nuestro baño.$5",
"Events.NORA.END.RobinText": "Oh Yoba...",
"Events.NORA.END.EmilyText": "¿Saben que podemos escucharlos?",
"Events.NORA.END.Eli.5": "Oh pobre, pobre Tori.$2",
"Events.NORA.END.Nora.6": "Bien, ¿qué sugieres entonces? No podemos estar aquí toda la noche-$3#$b#¡Oh, @! ¡TODOS, DEJEN de hablar de nuestros hábitos gastrointestinales!$5",
"Events.NORA.END.DemetriusText": "Gracias Yoba, por fin.",
"Events.NORA.END.Nora.Question.1": "¿Qué tal, @? ¿Algún plan para mañana en la noche?",
"Events.NORA.END.Nora.Q1.Answer.1": "Solo las cosas habituales de la granja.",
"Events.NORA.END.Nora.Q1.Answer.2": "Lo siento, ¿pero de quiénes hábitos gastrointestinales estamos hablando?",
"Events.NORA.END.Nora.Q1.Response.1": "¡Oh, entonces estás libre!#$b#Bien, tenemos una pregunta para ti.",
"Events.NORA.END.Nora.Q1.Response.2": "¡AHAHA no sé de qué estás hablando!$1#$b#¡De todos modos, una pregunta para ti!",
"Events.NORA.END.Nora.7": "Mañana tendremos una noche de películas. Va a ser una película de miedo que Eli eligió.#$b#¿Quieres acompañarnos?",
"Events.NORA.END.Eli.6": "¡Sí, nos encantaría tenerte con nosotros!$1",
"Events.NORA.END.Dylan.6": "Oye, ya que @ viene, tal vez pueda ayudar a elegir los bocadillos.$1#$b#Ya sabes, algo no tan amenazante para nuestros estómagos.#$b#Como, digamos... ¡una pizza picante!$3",
"Events.NORA.END.Nora.8": "¿Cómo es que la comida picante es mucho mejor para nuestros estómagos que la frita?$5",
"Events.NORA.END.Dylan.7": "¿Quién en la Tierra querría comer un pepinillo frito?$4",
"Events.NORA.END.Eli.7": "¡Bueno, tengo una idea!$1#$b#Ya que @ viene, ¿por qué no tenemos ambos bocadillos?#$b#De todas formas vamos a necesitar más comida.$6#$b#Además, me gustaría probar ese corn dog de pepinillo...$11",
"Events.NORA.END.Dylan.8": "Oh, vas a compartir el baño en casa de Nora.$2",
"Events.NORA.END.Eli.8": "Entonces está decidido.$1#$b#@, ven a nuestra casa mañana en la noche. Empezamos a las 7.#$b#Oh, y trae una pizza picante y un corn dog de pepinillo. Aquí, toma estos.",
"Events.NORA.END.Message": "¡Has aprendido dos recetas nuevas: Corn Dog de Pepinillo y Pizza Picante!",
"Events.NORA.END.Nora.9": "¡Nos vemos entonces, @!$1",

}

