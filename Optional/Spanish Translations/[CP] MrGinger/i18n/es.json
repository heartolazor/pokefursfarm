  "NPCD.Name.MrGinger": "Sr. Jengibre",
  "gift.love.false": "¡Mirrup!",
  "gift.like.false": "¡Mirp!",
  "gift.dislike.false": "¿Mirrrrp?",
  "gift.hate.false": "Mirruck.",
  "gift.neutral.false": "¿Mirrrr?",
  "gift.love.true": "Oooh, ¡una ofrenda de tributo! Me encanta. *Purrs*",
  "gift.like.true": "Oooh, ¿un regalo para mí? ¡Esto es genial!",
  "gift.dislike.true": "¿Esto es para mí? ¿Se supone que debo... comerlo?",
  "gift.hate.true": "No me gusta que se burlen de mí, @.",
  "gift.neutral.true": "Oh, me has traído un regalo. Lo que sea.",
  "rainyday.false": "Murrrr...$2",
  "rainyday.true": "Gah, odio la lluvia. Aun así, es una buena excusa para quedarse dentro y dormir, ¿no?",
  //Festivals
  "spring13.false": "¡Murr!",
  "spring24.false": "¡Mirrup!",
  "spring24.false.y2": "¡Mirrup!",
  "summer11.false": "¿Mirrp?",
  "summer28.false": "¡Mirrup!",
  "fall16.false": "¡Mirrup!",
  "fall27.false": "¿Mi-au?",
  "fall27.false.y2": "¿Mi-au?",
  "winter8.false": "¡Mirp!",
  "winter25.false": "Murrr...$2",
  "spring13.true": "¿Un festival para celebrar esos dinosaurios en miniatura? ¿Por qué?$2#$b#Y los pequeñitos, no son ni un bocado. No vale la pena el esfuerzo.",
  "spring24.true": "Te lo he dicho antes y te lo vuelvo a decir. Los Gatos. No. Bailan.$2",
  "spring24.M6.true": "Hm... ¿Crees que Marlon la sacará a bailar alguna vez?$1#$b#Lo he visto enfrentarse a monstruos aterradores, ¿qué tiene que perder? ¿Su otro ojo?$3",
  "spring24.true.y2": "¿Lewis y Marnie bailando juntos? Lo creeré cuando lo vea, @. Pobre Marnie...$2",
  "summer11.true": "Yo no me comería la sopa si fuera tú. Va a saber a entrañas de ratón y a calcetines viejos.#$b#¿Por qué? Porque eso es lo que he añadido.$3",
  "summer28.true": "No están hechas de gelatina, y no son peces.#$b#¿Por qué los humanos dan nombres estúpidos a las cosas?",
  "fall16.true": "¿Vas a que te lean la suerte, @? Ras cree que es la verdadera, pero no sé...#$b#Probablemente sólo te dirá que hay un alto y apuesto desconocido en tu futuro.",
  "fall27.true": "¿Y si soy esa 'calabaza' de oro que todos buscan?$2",
  "fall27.true.y2": "¿Qué? ¡No estoy acosando a Shane y Jas! Sucede que yo también quería ir por aquí.$2",
  "winter8.true": "*cantando* 'Pescado, pescado, mi plato favorito'. Oh, hola @.$3#$b#¿Crees que si lo pido amablemente, me dejarán llevarme algunos de estos a casa?$4#$b#¿Los van a devolver? Qué desperdicio.$2",
  "winter25.false.y2": "¡Mirp!",
  "winter25.true": "¿Qué? ¡No estoy enfadado porque nadie me haya traído un regalo!$5#$b#Sólo necesitaba un tiempo a solas, ¿vale?$2",
  "winter25.true.y2": "Si se lo pido amablemente a Shane, ¿crees que me dará unos arenques? Hah, tal vez voy a ayudarme a mí mismo.",
  "fall20.false": "¿Mirrr?",
  "fall20.true": "Me parece que gatos VS perros es una competición más atractiva.#$b#Por supuesto, la superioridad felina reina en todo excepto en la obediencia sin sentido.$1",
  "winter28.false": "¡Mrpp!$1",
  "winter28.true": "Oye @... Estoy aquí para mantener a Shane fuera de problemas. ¿Quieres ayudar? Podrías empezar por traerme algo de esa sabrosa comida.$1",
  //birthday strings
  "birthday.love1.false": "¡Mirrupppp!$h",
  "birthday.like1.false": "¡Mirp!$h/¡Mirp!$h",
  "birthday.like2.false": "¡Mirp!$h",
  "birthday.dislike1.false": "Murr...$s/Murrrr...$s",
  "birthday.dislike3.false": "Murr...$s/Murrrr...$s",
  "birthday.neutral1.false": "¿Mirp?",
  "birthday.love1.true": "¡Oh! ¡Esto es genial! ¡Me gustan estas costumbres humanas de hacer regalos!$h",
  "birthday.like1.true": "Oooh, ¡un regalo para mí! ¿Porque soy un año mayor? ¡Qué logro! ¡Gracias!$h/Oooh, ¿un regalo para mí? ¿Porque soy un año mayor? ¡Qué logro! ¡Gracias!$h",
  "birthday.like2.true": "Oooh, ¡un regalo para mí! ¿Porque soy un año mayor? ¡Qué logro! ¡Gracias!$h",
  "birthday.dislike1.true": "¿Es mi cumpleaños? ¿Así que me estás regalando basura? Interesante costumbre humana.$s/¿Es mi cumpleaños? ¿Así que me estás regalando basura? Interesante costumbre humana.$s",
  "birthday.dislike2.true": "¿Es mi cumpleaños? ¿Y esta es la habitual ofrenda inútil?$s",
  "birthday.neutral1.true": "¡Oh! ¿Un regalo para mí? ¿Hoy es mi cumpleaños? Ah, los humanos tienen unas costumbres tan pintorescas.",
  //Custom Fixed Dialogue
  "DumpsterDive.false": "%El Sr. Jengibre te mira con desaprobación. Estos son sus cubos de basura.",
  "DumpsterDive.true": "¡Oye! ¿Qué estás haciendo? ¡Soy el mejor gato, soy el primero en hacerlo!$5",
