  //before 6-heart
  "movies.0.false.1": "¡Mirrup!",
  "movies.0.false.2": "/message \"El Sr. Jengibre mira fijamente la pantalla.\"",
  "movies.0.false.3": "¡Mirp!$3#$b#%El Sr. Jengibre parece satisfecho con su elección de película.",
  "movies.1.false.1": "¡Mirrup!",
  "movies.1.false.2": "pause 500/message \"El Sr. Jengibre parece triste.\"",
  "movies.1.false.3": "Murr.$2",
  "movies.1.false.4": "¿Mrip?$1",
  "movies.2.false.1": "¡Mirrup!",
  "movies.2.false.2": "/message \"El enfoque del Sr. Jengibre es la intención.\"",
  "movies.2.false.3": "¡Mirp!#$b#%El Sr. Jengibre parece impresionado.",
  "movies.3.false.1": "Mirrup...",
  "movies.3.false.2": "/message \"El Sr. Jengibre parece aburrido.\"",
  "movies.3.false.3": "Muurrr. ¿Mirrup?",
  "movies.4.false.1": "¡Mirrup!$1",
  "movies.4.false.2": "%El Sr. Jengibre está ronroneando.",
  "movies.4.false.3": "%El Sr. Jengibre parece haber disfrutado.",
  "movies.5.false.1": "¡Mirp!",
  "movies.5.false.2": "/shake MisterGinger 3000/pause 500/",
  "movies.5.false.3": "Miiirrrow...$2",
  "movies.5.false.4": "%El pelaje del Sr. Jengibre todavía está un poco esponjado.",
  "movies.6.false.1": "%El Sr. Jengibre parece disgustado por tu elección.",
  "movies.6.false.2": "/message \"¿Esas son lágrimas en los ojos del Sr. Jengibre?",
  "movies.6.false.3": "¿Mirrow?$2",
  "movies.7.false.1": "¡Mirrup!",
  "movies.7.false.2": "/message \"El Sr. Jengibre está agachado en su silla.",
  "movies.7.false.3": "Muuur.$5",
  "movies.7.false.4": "%El Sr. Jengibre parece agotado.",
  "movies.8.false.1": "¡Mirrup!",
  "movies.8.false.3": "Mrp.$5",
  "movies.9.false.1": "¡Mirrup!",
  "movies.10.false.1": "Mirrup.",
  "movies.11.false.1": "¡Mrrrow!$5",
  //After 6-heart event
  "movies.0.true.1": "¿Una historia contada en una pantalla? Bueno, supongo que podría ser divertido.",
  "movies.0.true.2": "/message \"El Sr. Jengibre mira fijamente la pantalla.\"",
  "movies.0.true.3": "Muy entretenido. Lo disfruté.",
  "movies.1.true.1": "A Jas le encantó esta, y tiene muy buen gusto.#$b#Para empezar, le gusto.$1",
  "movies.1.true.2": "pause 500/message \"El Sr. Jengibre parece triste.\"",
  "movies.1.true.3": "Puedo ver el atractivo.$2",
  "movies.1.true.4": "Lindo, pero ñoño.#$b#¿Ñoño? ¿Lo entiendes?$1",
  "movies.2.true.1": "He estado en lugares, no estoy seguro de necesitar verlos en la pantalla.",
  "movies.2.true.2": "/message \"El enfoque del Sr. Jengibre es la intención.\"",
  "movies.2.true.3": "De acuerdo, lo admito, fue hermoso.",
  "movies.3.true.1": "Suena a corazón y a náuseas.",
  "movies.3.true.2": "/message \"El Sr. Jengibre parece aburrido.\"",
  "movies.3.true.3": "No, no es mi especialidad. Mmmm pescado... ¿Podemos almorzar?",
  "movies.4.true.1": "Parece entretenido.",
  "movies.4.true.2": "Esto es ridículo.$1",
  "movies.4.true.3": "¡Qué película más tonta! Muy divertida.",
  "movies.5.true.1": "¿Asustado? Hah, soy el más valiente del pueblo. ¡Me río de tu miedo!^¿Asustada? Hah, soy el más valiente del pueblo. ¡Me río de tu miedo!",
  "movies.5.true.2": "/shake MisterGinger 3000/pause 500/",
  "movies.5.true.3": "No... No lo hagas... ¡Eek!",
  "movies.5.true.4": "¿Qué? ¿Estaba asustado? No, estás imaginando cosas.$2",
  "movies.6.true.1": "¿Pah, romance? Los gatos no hacen esas cosas ñoñas y sentimentales.",
  "movies.6.true.2": "/message \"¿Esas son lágrimas en los ojos del Sr. Jengibre?",
  "movies.6.true.3": "No estoy llorando. Estás llorando. Probablemente fueron las luces.",
  "movies.7.true.1": "Abigail estaba hablando de este. !Debería ser uno de los buenos!",
  "movies.7.true.2": "/message \"El Sr. Jengibre está agachado en su silla.",
  "movies.7.true.3": "Demasiado fuerte...",
  "movies.7.true.4": "¡La trama no tenía sentido y los ruidos eran demasiado fuertes!$1",
  "movies.8.true.1": "Hmmm, a Ras le gustó esta. Confío en su juicio.",
  "movies.8.true.2": "...",
  "movies.8.true.3": "Nunca confiar en Ras, no, nunca más.",
  "movies.9.true.1": "Estaría encantado de volver a verlo, si insistes.$1",
  "movies.10.true.1": "Sí, claro, ¿por qué no? Estaba bien.",
  "movies.11.true.1": "Todavía tengo pesadillas.",
  //C S   S T R I N G S   A N D   M O R E
  //Note: these will only be activated under very specific situations, so are unlikely to be seen by many, if any, players
  "5367": "Bueno, esto es inusual, pero muy bien, si insistes. *Se aclara la garganta*#$b#Es un gran honor para mí, en este día {0} de {1}, apoyar a @ y, erm, al Sr. Jengibre en el compromiso de su dedicación mutua.",
  "5369": "Bueno, esto es inusual, pero muy bien, si insistes. *Se aclara la garganta*#$b#Es un gran honor para mí en este día {0} de {1}, apoyar a @ y, erm, al Sr. Jengibre en el compromiso de su dedicación mutua.",
  "5371": "@... Jengibre... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, os declaro compañeros de por vida!$h",
  "5377": "@... Jengibre... #$b# Como alcalde de Pueblo Pelícano, y portador regional del sello matrimonial, ¡os declaro compañeros de por vida!$h",
  "5379": "Pueden... ¿abrazarse o algo así?",
  "2782": "Oooh, eso fue divertido, ¿no?$3#$e#¡Y ahora aquí estoy, viviendo en una granja! ¿Tienes ratas o ratones? Bueno, ¡no por mucho tiempo!$4",
  "4439": "¿Un humano en miniatura dando tumbos? ¡Más vale que no me pise la cola!#$b#Aún así, lo que te haga feliz. Yo trato.$3",
  "4440": "A ver si lo entiendo: rellenas unos papeles, y te entregan un bebé en la puerta...#$b#Eso es mucho menos sucio que la forma en que los gatos hacen las cosas.",
  "4441": "¿Mirp? {0}, he mordido accidentalmente los papeles de la adopción.#$b#¿Qué? Estaban revoloteando en el viento, pensé que era una polilla.",
  "4444": "Bebés... son gatitos humanos, ¿verdad? ¡Esto va a ser genial! Le voy a enseñar a cazar, y a trepar a los árboles y... ¿qué?$1",
  "4447": "¿Qué tipo de cosas les gustan a los bebés? ¿Dormir, gritar?#$b#¿Esos grandes y mullidos animales de mentira con ojos de cristal? ¡Puedes mantenerlos lejos de mí! Cosas raras.",
  "4448": "A ver si lo entiendo: ¿rellenas unos papeles y te entregan un bebé en la puerta?#$b#Eso es mucho menos sucio que la forma en que los gatos hacen las cosas.",
  "4449": "Necesito un minuto para mí...  Hey, no son MIS hijos.$5",
  "4462": "Me levanté temprano y regué algunos cultivos para ti. ¡Y ya sabes lo que pienso del agua!",
  "4463": "#$e#Oh, y llené el cuenco de agua de {0}. Pobrecitos, simples mascotas de la casa, no saben lo suficiente como para encontrar su propia agua.",
  "4465": "¿Mirrrp? ¿Me has traído algo delicioso {0}?",
  "4466": "*bosteza* Ah, buenos días, {0}. Estaba recuperando mi sueño reparador.",
  "4470": "¡Me levanté temprano para regar tus cultivos, y casi me mojan los aspersores!$2#$b#¡Son malvados, te digo, malvados!$5",
  "4474": "Me levanté temprano y alimenté a todos tus tontos animales de granja. Ahora tienes más tiempo para pescarme.$1",
  "4481": "No podía dormir, así que me levanté y reparé algunas de las vallas. No podemos dejar que los animales se escapen, ¿verdad?",
  "4500": "Los humanos... no pueden limpiar lo que ensucian. ¿A qué clase de desorden llamas tú? Al menos lo único que dejo es mi pelaje.",
  "baby.adopt.1": "¡Su nuevo bebé {0} ha llegado! Espero que estés preparado para ser padre o madre.",
  "baby.adopt.q": "¿Estoy preparado para adoptar un bebé?",
  "baby.adopt.m": "¿Qué nombre le ponemos? Jengibre es un buen nombre.",
  "baby.adopt.f": "¿Qué nombre le ponemos? ¿Qué tal 'Fluffy'?",
  "engagement.0": "¿Te das cuenta de que soy un gato, no?#$b#Bien, sólo lo comprobaba.#$b#Estoy bastante seguro de que esto es poco ortodoxo incluso para tus extraños estándares humanos, pero ¿pescado y queso para el resto de mi vida?$3",
  "engagement.1": "¿Dudas de mí, @? Todo está bajo control. Tengo contactos, ya sabes.$1#$b#Bueno, _un_ contacto, y eso es Ras. Pero es muy bueno para arreglar las cosas.$4",
  "roommate.0": "¡Sólo estoy poniendo mis asuntos en orden! ¿Qué? ¿Crees que el Rancho se maneja solo?",
  "roommate.1": "¡Eh, podrías avisar a los ratones de que estoy a punto de mudarme!",
  "strings.engagedRoommate": "¿Pescado y queso para el resto de mi vida? ¡Claro, cuenta conmigo!#$b¡Sólo tengo que poner en orden algunos asuntos primero! Dame unos días.$1",
  // M A I L
  "mail.wizard.hearts6": "Saludos joven,^ Nuestro mutuo conocido ha solicitado tu presencia en mi torre, después de las horas de oscuridad. Por favor, trae un fragmento del Vacío. ^    -M. Rasmodius, Mago.",
  "mail.hearts6.title": "Una invitación",
  "mail.harvest.hearts6": "¡Hola!^ Nuestro mutuo conocido ha solicitado tu presencia en nuestra torre, después de las horas de oscuridad. Por favor, trae una astilla del sol. ^    -H. Diosa.",
  // Q U E S T
  "quest.mrginger.1": "Petición del Sr. Jengibre",
  "quest.mrginger.2": "Entrega una Esencia sombría a la Torre del Mago.",
  "quest.mrginger.3": "Visita la torre del Mago con una esencia sombría después de las 18 hrs.",
  // E V E N T S
  //2 hearts (spoken dialogue from Emily)
  "2hearts.0": "¡Hola Osiris!$1",
  "2hearts.1": "¿Mirrrp?$2",
  "2hearts.2": "Vale, vale... ¡No se lo digas a Gus!$3",
  "2hearts.3": "Oh, tienes hambre, ¿verdad, Osiris?$2",
  "2hearts.4": "¡Oh, hola @! Me has sorprendido.$1",
  "2hearts.5": "No se lo vas a decir a Gus, ¿verdad?$2",
  "2hearts.6": "Uf. Sé que Osiris vive en el rancho, y probablemente esté bien alimentado - pero siempre parece tan hambriento.$3",
  "2hearts.7": "Es una criatura muy especial, Osiris. A veces tengo la sensación de que es más que un gato.$4",
  "2hearts.8": "¡Aunque tal vez no exista tal cosa como 'sólo un gato'!$1",
  "2hearts.9": "¿Qué te parece?#¡Hay algo único en él!#Todos los gatos tienen una mente propia.",
  "2hearts.10": "¡Demasiado correcto!",
  "2hearts.11": "¿Te gustó eso, Osiris?$3",
  "2hearts.12": "¡Mirp!$1",
  "2hearts.13": "¡Me alegro!",
  "2hearts.14": "Apareció en el pueblo poco después de que Jas llegara aquí. Era sólo una niña pequeña, recientemente huérfana. ¡Era tan triste!$2#$b#Nadie sabía de dónde venía, ni a quién pertenecía, pero ¿sabes qué?$3#$b#...Creo que es su ángel de la guarda.$4",
  "2hearts.15": "Uy, mejor me voy. Gus se estará preguntando en qué me he metido. Adiós @, y adiós Osiris. ¡Nos vemos!",
  "2hearts.16": "¿Murrrrr?$2",
  //4 hearts (multiple speakers)
  "4hearts.1": "¿Miau?",
  "4hearts.2": "¡Shoo!",
  "4hearts.3": "¡Hola Sr. Jengibre! Pasó por aquí para hacer un poco de ejercicio, ¿verdad?$1",
  "4hearts.4": "¡Mirp!",
  "4hearts.5": "¡Hola gatito! ¿No eres un tipo guapo?$1",
  "4hearts.6": "¿Sr. Jengibre? ¿Así que ese es su nombre?$1",
  "4hearts.7": "Bueno, es el nombre que Jas le puso.$1#$b#Sin embargo, ella dice que no es su nombre *real*.$3",
  "4hearts.8": "¡Y aquí le he estado llamando Tigre!$4",
  "4hearts.9": "Sam le llama Ganso. No estoy seguro de por qué.",
  "4hearts.10": "Ah, hola @. Has conocido al Sr. Jengibre, ¿verdad?$1",
  "4hearts.11": "Vale señoras, estamos aquí para hacer ejercicio, no para adular a un gato tonto.$3",
  "4hearts.12": "Murrrrrr...$5",
  "4hearts.13": "¡Oh no, ahora lo has hecho enojar!$2",
  "4hearts.14": "¡Hey!",
  "4hearts.15": "¿Qué hace ese gato aquí?$3#$b#¡¡¡Sabes que soy A-A-A-aaa-CHUU!!!$2",
  //5 hearts (dialogue is Willy)
  "5hearts.1": "*ahogado* ¡Mrrrrp! $6",
  "5hearts.2": "*Puffs* Ahoy ahí @. ¿Has visto a Bosun? ¿Gato grande y naranja?#$b#El mendigo de la peste me ha robado el almuerzo.",
  "5hearts.3": "#(señala al norte) Se fue por ahí.#Está detrás de este arbusto.",
  "5hearts.4": "Gracias muchacho, me hacía mucha ilusión.^Gracias muchacha, me hacía mucha ilusión.",
  "5hearts.5": "¡Mreep mirrp!$4[698]",
  "5hearts.6": "¡Sí, puedo ver tu cola, Bosun!",
  "5hearts.7": "¡Devuélvelo, ladrón!",
  "5hearts.8": "¡Lo tengo!",
  "5hearts.9": "Gracias. Aprecio tu honestidad, muchacho.^Gracias. Aprecio tu honestidad, muchacha.",
  "5hearts.10": "Mroooow.$2",
  "5hearts.11": "Bueno, está un poco masticado, así que podrías tenerlo, Bosun.#$b#¡No vayas a pensar que estás siendo recompensado por tus crímenes!$a",
  "5hearts.12": "Dime muchacho, ¿qué tal si tú y yo almorzamos en el salón?$1^Dime muchacha, ¿qué tal si tú y yo almorzamos en el salón?$1",
  //6-heart event (This is the important one!)   
  "6hearts.wizard.1": "Siento no poder ayudarte con tu problema más acuciante, Trix. Pero quizás... bueno, ninguno de nosotros puede saber lo que nos depara el futuro.",
  "6hearts.wizard.2": "Oh sí, correcto, excepto Madame Welwick, pero ella no dice nada de este tema en particular.",
  "6hearts.wizard.3": "Lo sé, lo sé. Pero la paciencia, dicen, es una virtud, y tal vez... bueno, tal vez esta noche ponga los engranajes en movimiento... la rueda girando...",
  "6hearts.wizard.4": "Vale, sí, estoy dudando de nuevo. He estado demasiado tiempo solo, amigo mío.",
  "6hearts.wizard.5": "Y justo a tiempo. Nuestro invitado ha llegado.^Y justo a tiempo. Nuestra invitada ha llegado.",
  "6hearts.wizard.6": "Hola @, me alegro de que te hayas unido a nosotros.",
  "6hearts.wizard.7": "Sí, sí, lo sé. Por favor, ¡paciencia!",
  "6hearts.wizard.8": "¿Has traído el artículo solicitado, @?",
  "6hearts.wizard.9": "Excelente, esto es precisamente lo que necesitamos. ¡Comencemos!#$b#¿Qué estamos preparando? Oh, eso es una sorpresa.$h",
  "6hearts.wizard.10": "Bien, aquí vamos: una onza de polvo de estrellas. Un poco de sangre de paloma. Los pétalos de una rosa hada.#$b#Y, gracias a ti, @, el ingrediente final, el golpe de gracia: un fragmento de oscuridad, una astilla del corazón del vacío...",
  "6hearts.wizard.11": "¡Ya te haces una idea!$h",
  "6hearts.wizard.12": "Toma. Bebe. Sé que la última vez no fue muy agradable, pero el beneficio supera el coste, ¿no?$h",
  "6hearts.13": "¿@? ¡@!$2",
  "6hearts.14": "¿Hola? ¿@? ¿Funcionó?$2",
  "6hearts.15": "¿@? ¿Estás bien?",
  "6hearts.wizard.16": "#No siento los pies.#¡Mira, un gato que habla!#Necesitaba una rodaja de limón.#¡Es la última vez que tomo algo que me ofrezcas!",
  "6hearts.wizard.17": "Debo decir que es un efecto secundario bastante inesperado, pero estoy seguro de que se me pasará en poco tiempo.#$b#No hay tiempo.",
  "6hearts.wizard.18": "¡Ha funcionado! Ha funcionado de verdad. Siento haber dudado de ti, Ras.$4",
  "6hearts.wizard.19": "¡Hey Ras, parece que alguien aprecia tus talentos culinarios!",
  "6hearts.wizard.20": "Ahora dices eso, @, pero no puedes negar que mis brebajes son bastante beneficiosos.",
  "6hearts.21": "Oye, @. Es estupendo tener a alguien más con quien hablar.#$b#Quiero decir, Ras está bien - pero es un poco cola en el aire, ¿no crees?...$1",
  "6hearts.wizard.22": "Puedo escucharte, sabes. Gatito.",
  "6hearts.wizard.23": "Gatito... Sabes que odio ese nombre. Es tan denigrante. Como si fuera una especie de mascota común de la casa.$5#$b#Por favor, no me llames nunca Gatito, @.$1",
  "6hearts.24": "Cualquiera puede hablar con los animales, pero se necesita un tipo especial de persona para _escucharles_.#$b#Sí, es un cumplido. No te acostumbres a ellos. Tengo una reputación que mantener, ya sabes.",
  //If Harvest Goddess is installed:
  "6hearts.harvest.1": "Siento no poder ayudarte con tu problema más acuciante, Trix. Pero quizás... bueno, ¿quién puede saber lo que depara el futuro?",
  "6hearts.harvest.2": "Oh sí, correcto, Madame Welwick, pero no dice nada de este tema en particular.",
  "6hearts.harvest.3": "Lo sé, lo sé. Pero la paciencia, es una virtud, y quizás... bueno, quizás esta noche se pongan las cosas en marcha.",
  "6hearts.harvest.4": "Sí, lo sé, estoy tan ansioso por verlo cumplido como tú, amigo mío.",
  "6hearts.harvest.5": "Y justo a tiempo. Nuestro invitado ha llegado.^Y justo a tiempo. Nuestra invitada ha llegado.",
  "6hearts.harvest.6": "Hola @, me alegro de que te hayas unido a nosotros.",
  "6hearts.harvest.7": "Sí, sí, lo sé. Por favor, ¡paciencia!",
  "6hearts.harvest.8": "¿Has traído el artículo solicitado, @?",
  "6hearts.harvest.9": "Excelente, esto es precisamente lo que necesitamos. ¡Comencemos!#$b#¿Qué estamos preparando? Oh, es una sorpresa, pero una que creo que te encantará, querido.$h^¿Qué estamos preparando? Oh, es una sorpresa, pero una que creo que te encantará, querida.$h",
  "6hearts.harvest.10": "Bien, aquí vamos: una onza de polvo de estrellas. Una pluma regalada por un visitante lejano. Los pétalos de una rosa hada.#$b#Y, gracias a ti, @, el ingrediente final, el golpe de gracia: una brizna de sol...",
  "6hearts.harvest.11": "Sí, lo sé, Trix. Por favor, ten paciencia.$h",
  "6hearts.harvest.12": "Aquí, respira profundo. Inhala la magia. Siente cómo se impregna en tus sentidos.$h",
  "6hearts.harvest.13": "¿@? Por favor, no tengas miedo. Te tenemos. Estamos aquí para ti.",
  "6hearts.harvest.16": "#No siento mis pies.#¡Oh, mira, un gato que habla!#¿Qué pasó? ¿Me he desmayado?",
  "6hearts.harvest.17": "¡Oh no, querido! Es un efecto secundario inesperado. Debería desaparecer en breve.^¡Oh no, querida! Es un efecto secundario inesperado. Debería desaparecer en breve.#$b#¡Lo siento!$2",
  "6hearts.harvest.18": "¡Funcionó! Realmente funcionó. Lamento haber dudado de ti, Diosa.$4",
  "6hearts.harvest.20": "Mis disculpas, @. La potencia, de vez en cuando, hace que uno se maree.",
  "6hearts.harvest.21": "Hola, @. Es estupendo tener a alguien más con quien hablar.#$b#Quiero decir, la Diosa es maravillosa - pero ella está bien... ¡es una diosa!$1",
  "6hearts.harvest.22": "Puede que lo sea, Trix, pero también soy tu amiga.",
  "6hearts.harvest.23": "Lo sé, y me siento honrado, Diosa. Pero a veces, bueno... ya sabes.$1",
  "6hearts.harvest.24": "Eso hago, mi amigo felino. Por favor, trátalo bien, @. Porque este gato es más de lo que parece.",
  //8 hearts (dialogue mixed between Mr. Ginger, Jas and Shane)
  "8hearts.1": "¡@! ¡Estoy tan contento de que estés aquí!#$b#¡Necesito tu ayuda!$2",
  "8hearts.2": "¡Es Jas! Está dentro y está asustada y sola, ¡y no puedo llegar a ella!$2",
  "8hearts.3.drunk": "¡Tiene terribles miedos nocturnos! Marnie está fuera, ¡y Shane está durmiendo como el gran inútil que es!$2",
  "8hearts.3.sober": "¡Tiene terribles miedos nocturnos! Marnie está fuera, ¡y Shane está durmiendo como el gran inútil cabeza de chorlito que es!$2",
  "8hearts.3.spouse": "¡Tiene terribles miedos nocturnos! ¡Marnie está fuera, y Shane está en tu granja!$2",
  "8hearts.4": "Hay una llave debajo de esa roca falsa junto a la puerta.",
  "8hearts.5": "Por favor, ¿me ayudas?#¡Claro que sí!#¿Por qué? No soy una niñera.",
  "8hearts.6": "...Y la princesa bajó sus labios para dar un cuidadoso beso en la cabeza babosa de la rana...",
  "8hearts.7": "¡Ewww!$3",
  "8hearts.8": "...Se produjo una chispa de luz, lo suficientemente brillante como para deslumbrar a la princesa.#$b#Cuando su visión se aclaró, allí, ante ella, se agachaba un hombre.",
  "8hearts.9": "¡No un hombre, un príncipe! Un apuesto príncipe.",
  "8hearts.10": "No, un príncipe no. Un simple campesino, que la amaba con todo su corazón.#$b#Y si tenía los ojos un poco saltones, y la piel pegajosa, ¿qué importa?$1",
  "8hearts.11": "¡Ick!$3#$b#Tío Shane, eres muy gracioso.$1",
  "8hearts.12": "Gracias. Pero en serio, niña, no necesitas un príncipe para ser feliz.$3",
  "8hearts.13": "¡Lo sé! Sólo necesitas saber que hay alguien a quien le importas.$4#$b#¿Verdad?$1",
  "8hearts.14.drunk": "Sí, así es, cariño.$l#$b#Ahora, ¿ya estás lista para volver a dormir? ¿Pesadilla olvidada?#$b#...(El tío Shane necesita descansar su dolorida cabeza)...",
  "8hearts.14.sober": "Sí, así es, cariño.$l#$b#Ahora, ¿ya estás lista para volver a dormir? ¿Pesadilla olvidada?#$b#Recuerda, he prometido estar aquí para ti. Desde ahora y siempre.",
  "8hearts.14.spouse": "Sí, así es, cariño.$l#$b#Ahora, ¿ya estás lista para volver a dormir? ¿Pesadilla olvidada?#$b#Recuerda, he prometido estar aquí para ti. Desde ahora y siempre, incluso ahora que estoy viviendo con @.",
  "8hearts.15": "No está olvidado. Pero sí mejor. Sí, mejor.$3#$b#Creo que ya puedo dormir.",
  "8hearts.16": "Buena chica, vamos a meterte en la cama.",
  "8hearts.17": "Buenas noches tío Shane. Gracias. Eso me hizo sentir mucho mejor.$1",
  "8hearts.18": "Ella no me necesitaba después de todo. Ahora lo tiene a él.$2",
  "8hearts.19": "#Ella siempre te necesitará. Él es su tío - ¡pero tú eres su GATO!#Los niños se aburren de sus mascotas, es cierto.#Tú sólo eres un gato, Shane es su tío.#Siempre me tendrás a mí, Sr. Jengibre.",
  "8hearts.20": "Gracias. Eso me hace sentir mucho mejor.$1",
  "8hearts.21": "¿Sólo soy una mascota...? ¡No! Soy su amigo...$2#$b#¡Y no dejaré que me digas lo contrario!$5",
  "8hearts.22": "La familia es más importante que las mascotas. Lo entiendo.$2#$b#No me gusta, pero lo entiendo.$2",
  "8hearts.23": "¿En serio? Gracias, @. Eso significa mucho.$4",
  "8hearts.24": "*somnolienta* ¿Sr. Jengibre? ¿Sr. Jengibre? ¿Eres tú?",
  "8hearts.25": "¡Adiós @! ¡Me tengo que ir!$3",
  "8hearts.26": "Ella realmente ama a ese gato.",
  "8hearts.27": "¿No me ayudas a consolar a una niña asustada?$5#$b#Eres una persona terrible, @. No puedo creer que te haya considerado mi amigo.$2",
  "8hearts.28": "¡No te preocupes Jas! ¡Estoy aquí!",
  //10-hearts part 1
  "10hearts.1.1": "No es un mal botín, Mermelada.#$b#¡Comeremos bien esta noche!",
  "10hearts.1.2": "Aunque estoy seguro de que Marnie te alimenta bien.",
  "10hearts.1.3": "¿Marnie me alimenta? Soy más que capaz de alimentarme por mí mismo, muchas gracias.$1#$b#¡Campeón reinante del Rancho ocho años seguidos!$4#$b#Aunque sí, agradezco el queso y el pescado.$1",
  "10hearts.1.4": "Gracias por hacerme compañía esta noche.",
  "10hearts.1.5": "Algo se siente un poco... raro... esta noche, ¿no crees?",
  "10hearts.1.6": "Huele a nubes al borde de una tormenta.$2",
  "10hearts.1.7": "El vacío está inquieto.#$b#Deberíamos darnos prisa.",
  "10hearts.1.8": "¡Eh, tú! ¡Respiración del vacío!$5#$b#¡Deja a mi amigo en paz!$5",
  "10hearts.1.9": "¿Gat-ito?",
  "10hearts.1.10": "¡No me llames Gatito!$5",
  "10hearts.1.11": "¿Mermelada? ¿Estás bien?",
  "10hearts.1.12": "¡Me has salvado la vida! ¡Eres un héroe!",
  "10hearts.1.13": "¡Oh, estás herido! Será mejor que te curen.",
  "10hearts.1.14": "Oh, no te preocupes, @, es sólo un rasguño y Linus me ha remendado bien.$2#$b#En realidad, por favor, sí preocúpate. ¡Me duele! Un poco de queso podría ayudarme a curar.$2",
  //10-hearts part 2
  "10hearts.2.core.1": "¡Ah, @! Venía a visitar el pueblo.",
  "10hearts.2.core.2": "Esta mañana me he encontrado con mi buen amigo Linus y me preguntaba si, por casualidad, has visto a 'Mermelada' por ahí.",
  "10hearts.2.core.3": "Creo que también se hace llamar: Osiris, Trix y Sr. Jengibre, ¿entre otros?",
  "10hearts.2.4": "¿Alguien ha dicho mi nombre? No es que tenga la costumbre de venir cuando me llaman pero, bueno...#$b#... Ah, ¡hola Marlon!",
  "10hearts.2.5": "¡Ha pasado mucho tiempo! ¿Todavía vives con el viejo en esa casa de la montaña?$1#$b#¿Soñando con una vida que podría haber sido - si hubieras seguido tu corazón, en lugar de tu terca conciencia?$1",
  "10hearts.2.core.6": "Hablador, ¿verdad?",
  "10hearts.2.7": "Marlon nunca aprendió a 'escuchar'.$4",
  "10hearts.2.8": "Así que, barba gris, ¿qué te trae desde las montañas?#$b#Sabes, deberías bajar y decir 'hola' a Marnie mientras estás aquí.#$b#Ella está deprimida y lee libros de bolsillo nauseabundos; está esperando que un pirata la saque de sus casillas.$3",
  "10hearts.2.9": "Ves, no puedes entender una palabra de lo que digo. Humanos tontos. Necesitan limpiarse los oídos.",
  "10hearts.2.core.10": "Bueno, esto es algo inusual, pero he venido aquí con una propuesta.",
  "10hearts.2.11": "¿Una propuesta? ¿Cuál es tu propuesta?$1",
  "10hearts.2.core.12": "He oído que tu gato ha sido todo un héroe, @.",
  "10hearts.2.13": "¡Estoy aquí, barba gris, puedes hablar conmigo, ya sabes!",
  "10hearts.2.core.14": "¿Y nos preguntábamos si podrías estar interesado en unirte al Gremio de Aventureros?",
  "10hearts.2.15": "¡El Gremio de Aventureros! ¿Yo? ¡Un defensor del pueblo!$4",
  "10hearts.2.core.16": "Es un trabajo peligroso, ¿cómo crees que perdí el ojo?#$b#¿Pero qué dices?",
  "10hearts.2.17": "La oportunidad de proteger a Jas y a todos los demás, ¡sería un honor! Pero, ¿qué opinas, @?",
  "10hearts.2.18": "#¡Eres valiente y fuerte, y te necesitan!#Tienes que seguir lo que es correcto para ti.#No quiero que te hagan daño.#Tú, ¿un defensor? ¡Eres un gato!",
  "10hearts.2.19": "Lo soy, ¿verdad? ¡Me alegro de que lo reconozcas!",
  "10hearts.2.20": "Eres muy sabio... pero sí, ¡creo que es esto!",
  "10hearts.2.21": "Yo tampoco quiero salir herido, @. Pero soy rápido, y astuto, y astuto. ¡Puedo hacerlo!",
  "10hearts.2.22": "¿Y tu punto es? ¿Ser un gato me hace débil?#$b#Mis dientes y mis garras son mis armas, @.#$b#¿Quieres desafiarme?$5",
  "10hearts.2.core.23": "¿Es eso un 'sí'?",
  "10hearts.2.core.24": "¿Estás dispuesto a prestar el juramento de lealtad?",
  "10hearts.2.core.25": "Muy bien. ¿Juras, el conocido como Mermelada y también, el Sr. Jengibre, solemnemente poner la vida de los demás por encima de la tuya?",
  "10hearts.2.core.26": "¿Prometes actuar como guardian y protector?#$b#Para proteger de la plaga de la oscuridad y la pestilencia del vacío. Lo que reside dentro y fuera.",
  "10hearts.2.core.27": "Puedes levantarte, noble felino.",
  "10hearts.2.28": "Gracias por este honor, Marlon. Te haré sentir orgulloso, lo prometo.",
  //Marlon is real
  "10hearts.2.real.1": "¡Hola @! Venía a visitar el pueblo.",
  "10hearts.2.real.2": "Estaba hablando con Linus esta mañana, y no puedo creer que vaya a preguntar esto... pero, urm, ¿has visto, err, a 'Mermelada' por aquí?",
  "10hearts.2.real.3": "Gato pelirrojo. Se le conoce con los nombres de: Osiris, Trix y Sr. Jengibre, entre otros.",
  "10hearts.2.real.6": "Un mendigo ruidoso, ¿verdad?",
  "10hearts.2.real.10": "Esto es ridículo... pero he venido con una propuesta.",
  "10hearts.2.real.12": "Ese gato ha sido todo un héroe.",
  "10hearts.2.real.14": "Y, urm, queríamos invitarlo a unirse al Gremio de Aventureros.",
  "10hearts.2.real.16": "Es un trabajo peligroso, quiero decir, ¿cómo crees que perdí mi ojo?#$b#Podría ser comido por un monstruo o algo así. Pero, ¿quieres unirte?",
  "10hearts.2.real.23": "¿Es eso un 'sí'?",
  "10hearts.2.real.24": "Ahora tenemos que hacer el Juramento de Lealtad. Es una tontería, lo sé. No es que un gato pueda hacer un juramento. Pero, hay formalidades que tenemos que mantener.",
  "10hearts.2.real.25": "Muy bien. ¿Juras solemnemente tú, el llamado Mermelada y el Sr. Jengibre, y Yoba sabe qué más, anteponer la vida de los demás a la tuya?",
  "10hearts.2.real.26": "¿Prometes actuar como guardian y protector?#$b#Para proteger de la plaga de la oscuridad y de la pestilencia del vacío.#$b#Lo que reside dentro y fuera. Y todas las demás tonterías pretenciosas.",
  "10hearts.2.real.27": "Felicidades gato, ahora eres un defensor del pueblo. Intenta que no te maten.",
  //Shane and Mr Ginger (dialogue all Shane)
  "5295020.1": "¿Te ha enviado Marnie a ver cómo estoy, Jengibre?$2",
  "5295020.2": "Oh, no te pongas nervioso, sólo es Joja cola.$2",
  "5295020.3": "Ojalá no lo fuera...$2#$b#Las cosas se pusieron pesadas hoy, Jengibre. Realmente pesadas. Quiero enterrarlas... para adormecer el dolor...$5",
  "5295020.4": "Yoba... Debo estar loco. Hablando con un gato.#$b#No es que entiendas, no es que te importe.$2",
  "5295020.5": "Vale, sí, eres un buen gato, Jengibre. Y un buen amigo para Jas.$1",
  "5295020.6": "Bueno, será mejor que me vaya... pero gracias gato... es raro, pero eso realmente ayudó.",
}