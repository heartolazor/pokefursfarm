				// Mod info
				"mod.name": "Love of Cooking",

				// Config options
				"config.page.info": "Informacion",
				"config.page.options": "Opciones",

				"config.option.cookingmenu_name": "Menú de cocina",
				"config.option.cookingmenu_description": "Sustituye la interfaz de artesanía por un nuevo menú de cocina.\nLas recetas se guardan en tu recetario para buscarlas, ordenarlas, filtrarlas y marcarlas como favoritas.\nLos ingredientes se añaden manualmente al cocinar.",
				"config.option.cookingskill_name": "Habilidades culinarias y recetas",
				"config.option.cookingskill_description": "¡Añade una nueva habilidad de cocina al nivel!\nLos niveles de habilidad desbloquean nuevas recetas de cocina y profesiones.\nGana experiencia cocinando, con bonificaciones para recetas nuevas y avanzadas.",
				"config.option.cookingtool_name": "Herramienta de cocina y mejoras",
				"config.option.cookingtool_description": "¡Añade un nuevo utensilio de cocina que se puede mejorar!\nReduce a 1 el número de ingredientes utilizables al cocinar, aumentando con el nivel de la herramienta.\nPuedes comprar mejoras del Herrero para cocinar recetas avanzadas.\n\nRequiere el nuevo menú de cocina.",
				"config.option.seasonings_name": "Más condimentos",
				"config.option.seasonings_description": "¡Añade nuevos sabores para mejorar tu cocina!\nIntroduce elementos de menor valor que elevan la calidad de los alimentos cocinados.nSe consume automáticamente al cocinar.",
				"config.option.foodbuffsstarthidden_name": "Los aficionados a la comida empiezan escondidos",
				"config.option.foodbuffsstarthidden_description": "Las ventajas de cada alimento no se muestran en los alimentos hasta que no te los has comido.\nSi se desactiva, los alimentos y recetas mostrarán siempre sus ventajas",
				"config.option.foodhealingtakestime_name": "Los alimentos se curan con el tiempo",
				"config.option.foodhealingtakestime_description": "Los alimentos restablecen la salud gradualmente con el paso del tiempo.\nPodrás aprovechar mejor los alimentos con ventajas cuando estés a tope de energía,\nPero no podrás recuperar salud instantáneamente cuando estés en peligro.",
				"config.option.foodcanburn_name": "Los alimentos pueden quemarse",
				"config.option.foodcanburn_description": "¡Tienes la oportunidad de arruinar tu comida al cocinar!\nNo recomendado a menos que te guste fracasar.",
				"config.option.townkitchens_name": "Cocinas de pueblo",
				"config.option.townkitchens_description": "Te permite interactuar con cualquier cocina de el pueblo.\nNecesitas ser amigo de alguien que viva allí.",
				"config.option.menuanimation_name": "Animaciones de menú",
				"config.option.menuanimation_description": "Si desea reproducir una transición rápida al abrir el menú de cocina.\n\nRequiere el nuevo menú de cocción.",
				"config.option.cookinganimation_name": "Animaciones de cocina",
				"config.option.cookinganimation_description": "Ya sea para jugar un poco de animación al cocinar en la cocina.\n\nRequiere el nuevo menú de cocción.",
				"config.option.foodregenbar_name": "Mostrar barra de regeneración de curación de alimentos",
				"config.option.foodregenbar_description": "Con la curación de alimentos con el tiempo activada, puedes ocultar la barra de regeneración de alimentos.\nLa barra aparece junto a las barras de salud y energía para mostrar la regeneración de alimentos que te queda.",
				"config.option.fixcraftingpagerecipesorting_name": "Arreglar la clasificación de recetas por defecto",
				"config.option.fixcraftingpagerecipesorting_description": "Con el nuevo menú de cocina desactivado, las recetas se ordenan primero por vainilla y después por costumbre.\nEsta opción actualiza el método de ordenación para mezclar todas las recetas.\n\nRequiere el menú de cocción por defecto.",
				"config.option.remembersearchfilter_name": "Recordar filtro de búsqueda",
				"config.option.remembersearchfilter_description": "Con el nuevo menú de cocina activado, puedes buscar recetas con filtros.\nEl menú ya guarda el último filtro de búsqueda utilizado,\nPero se reinicia la próxima vez que juegues.\nPuede desactivar esta opción para utilizar siempre el filtro predeterminado.",
				"config.option.defaultsearchfilter_name": "Filtro de búsqueda por defecto",
				"config.option.defaultsearchfilter_description": "Con el nuevo menú de cocina activado, puedes buscar recetas con filtros.\nEl menú ya guarda el último filtro de búsqueda utilizado,\nPero se reinicia la próxima vez que juegues.\nAquí puede establecer un filtro predeterminado para todas las sesiones de juego.",
				"config.option.defaultsearchsorter_name": "Clasificador de búsqueda por defecto",
