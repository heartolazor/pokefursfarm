{
    //Dispositons
    "Name.Cambria": "Cambria",
    "Name.Castle": "Castle",
    "Name.Orchid": "Orchid",
    //Locations
    "Cambria.Location.Home": "Residencia Castlegrove",
    "Cambria.Location.Greenhouse": "Invernadero de Cambria",
    "Cambria.Location.TwilightOcean": "Mar de Gemas al Anochecer",
    //Shop and Items
    "Shop.DoubleFang.Dialogue": "¿En qué puedo ayudarte?",
    "Objects.RoastedCoffeeBeans.Name": "Granos de Café Tostados",
    "Objects.RoastedCoffeeBeans.Description": "Granos de café recién tostados. Coloca tres en un barril para hacer un espresso triple.",
    "Objects.VoidTaintedMead.Name": "Hidromiel Contaminada por lo sombrío",
    "Objects.VoidTaintedMead.Description": "Hay algo extraño en esta hidromiel. ¿Algo acaba de moverse ahí dentro?",
    "Objects.CoffeeInfusedMead.Name": "Hidromiel con Infusión de Café",
    "Objects.CoffeeInfusedMead.Description": "Entre la cafeína y el alcohol, te sientes genial. Seguro que puedes hacer ese truco de tiro.",
    "Objects.BloodStarfruitMead.Name": "Hidromiel de Fruta Estelar Sangrienta",
    "Objects.BloodStarfruitMead.Description": "Una hidromiel suave, tal vez demasiado. Por favor, bebe con responsabilidad.",
    "Objects.ElderTigerLily.Name": "Lirio Tigre Anciano",
    "Objects.ElderTigerLily.Description": "Nunca has visto nada igual. Un regalo de ella, como agradecimiento por tu compañía.",
    "Objects.ElderTigerLily.Denied": "Sus zarcillos bebende lo sombrío. No será feliz aquí.",
    "Objects.ElderLilySeeds.Name": "Semillas de Lirio Anciano",
    "Objects.ElderLilySeeds.Description": "Mantenla caliente, mantenla a salvo. Está vieja y cansada.",
    "Objects.ElderLilyHoney.Name": "Miel de Lirio Anciano",
    "Objects.ElderLilyHoney.Description": "Dulce con un misterioso toque de especias. El color del jarabe cambia constantemente.",
    "Objects.ElderLilyMead.Name": "Hidromiel de Lirio Anciano",
    "Objects.ElderLilyMead.Description": "Beber esto te transporta a una vida que nunca tuviste. Recuerdos de otra persona, de una vida pasada. Una tristeza primigenia.",
    "Objects.ElderLilyDrink.Name": "Bebida de Lirio Anciano",
    "Objects.ElderLilyDrink.Description": "¿Es té? ¿Es café? Quién sabe, pero ahora puedes huir de lo que te persigue.",
    "Objects.DriedElderLilyPetals.Name": "Pétalos Secos de Lirio Anciano",
    "Objects.DriedElderLilyPetals.Description": "Pétalos secos. Huelen como el hogar de una madre amorosa. Nostálgico y cálido.",
    "Objects.ElderLilyLeaves.Name": "Hojas de Lirio Anciano",
    "Objects.ElderLilyLeaves.Description": "Un segundo regalo de ella. ¿En qué se puede convertir?",
    //Special Orders
    "SpecialOrders.Cambria.Name": "Se Necesita Comida sombría",
    "SpecialOrders.Cambria.Text": "Orchid y yo tuvimos una pelea y ahora se niega a producir huevos. Hasta que vuelva a ganarme su favor, ¿alguien podría proporcionarme una docena de huevos sombríos? También necesito reabastecerme de mariscos sombríos.",
    "SpecialOrders.Cambria.Obj1": "Coloca los huevos sombríos en el refrigerador del invernadero de Cambria.",
    "SpecialOrders.Cambria.Obj2": "Coloca un salmón sombrío en el refrigerador del invernadero de Cambria.",
    //Cambria Dialogue
    "Cambria.Dialogue.Introduction": "Oh, eres el nuevo granjero del que escuché hablar. Bienvenido al valle, @.$8^, eres la nueva granjera de la que escuché hablar. Bienvenida al valle, @.$8#$b# Soy Cambria, vivo en la cala junto a East Scarp. Sigue la playa y no podrás perderte.#$b# Avísame si necesitas ayuda con algo. Cuídate, ¿sí?$1",
    "Cambria.Dialogue.spring12.1": "Nunca tuve la oportunidad de unirme a la cacería cuando era niña.$2#$b# No estoy segura de tener la energía ahora.$13",
    "Cambria.Dialogue.spring12.2": "¿Debería llevar huevos rellenos mañana?$10#$b# La última vez la gente pensó que estaban podridos...$5#$b# No es mi culpa que los huevos sombríos huelan así.",
    "Cambria.Dialogue.spring23": "No iré al baile. Está demasiado lejos para estos viejos huesos, y además es muy sofocante.$2#$b# Tráeme algunas sobras si puedes.$1",
    "Cambria.Dialogue.spring28": "El verano llegará pronto. Eso significa dos cosas: insectos y articulaciones doloridas.#$b# También que Júpiter me provoque un golpe de calor cada vez que nos acurrucamos.$5#$b# No hace falta decir que estoy deseando que llegue el otoño.$3",
    "Cambria.Dialogue.summer10": "¿Vas a llevar algo bueno mañana? Yo lo haría, pero Lewis me miró mal cuando llevé hidromiel una vez.#$b# Es eso o mayonesa sombría, así que realmente tiene que elegir sus batallas.$5",
    "Cambria.Dialogue.summer27a": "Las medusas de la luz de la luna son la mejor manera de terminar el verano.$1#$b# Pero hará frío, así que abrígate bien.",
    "Cambria.Dialogue.summer27b": "Júpiter va a extrañar los viajes a la playa ahora que hace más frío.",
    "Cambria.Dialogue.fall15": "Disfruto viendo todas las exhibiciones agrícolas en esta época del año.#$b# Más vale que derrotes a Pierre, @.$1",
    "Cambria.Dialogue.fall26": "¿Debería llevar a Orquídea mañana?#$b# Por supuesto, me disfrazaré, pero Orquídea le dará un buen toque espeluznante.$1",
    "Cambria.Dialogue.SpiritsEveInn.1": "¡Hey, @! Estaba a punto de entrar. ¡Vamos!$8",
    "Cambria.Dialogue.SpiritsEveInn.2": "Prefiero esto en lugar del evento principal en Pelican Town. Después de todo, aquí puedo jugar al billar.$1",
    "Cambria.Dialogue.winter7": "Aunque disfruto pescar, no podré ir.$2#$b# Entre la distancia y el frío, el festival es demasiado para mí. Pero espero que te diviertas.$3",
    "Cambria.Dialogue.winter10": "¿Hm? ¿Qué quiero para mi cumpleaños? ¿Es mañana ya?$10#$b# Mis articulaciones han estado más rígidas últimamente. Pero todo está bien, no necesito nada. ¡Gracias de todos modos!$8",
    "Cambria.Dialogue.winter15": "Por muy frío que esté, nunca me perdería el mercado.$1",
    "Cambria.Dialogue.winter16": "El café gratis es un salvavidas. Ojalá fuera con hielo, eso sí.",
    "Cambria.Dialogue.winter17": "¿Has visto el espectáculo de la sirena? Se siente de otro mundo pero... reconfortante.$3",
    "Cambria.Dialogue.winter24": "El intercambio de regalos secreto es un fastidio, especialmente cuando es en todo el pueblo.$5#$b# ¿Tienes ya un regalo para mañana? Confía en mí, no vale la pena pensarlo demasiado.",
    "Cambria.Dialogue.winter28": "Otro año que se va...$2 Espero que el próximo sea igual de tranquilo que este.$2",
    "Cambria.Dialogue.GreenRain": "¿Cómo lo llevas, @? Este clima tiene a todos alterados.#$b# ¿Hm? Nah, es inofensivo. Ya lo sabrías si no lo fuera.",
    "Cambria.Dialogue.GreenRain.2": "¿Quieres ver quién puede recolectar más musgo? Lo uso para reparar las ruinas de la cala.#$b# El año pasado llené casi un barril.$1",
    "Cambria.Dialogue.GreenRainFinished": "Todo volvió a la normalidad ahora que terminó esa lluvia extraña.#$b#¿Crees que vuelva el próximo año? Ojalá que sí, me vendría bien un poco más de musgo.",
    "Cambria.Dialogue.trash": "¿Encontraste algo bueno? Escuché que puedes conseguir galletas recién horneadas o comidas calientes ahí.$8#$b# Oh-- en fin, de repente tengo que irme a otro lado.$13",
    "Cambria.Dialogue.mine0": "Buena suerte en las minas hoy.",
    "Cambria.Dialogue.mine2": "¡No olvides llevar comida contigo!$1",
    "Cambria.Dialogue.mine4": "Mira por dónde pisas, ¿sí? La semana pasada terminé cubierto de baba.#$b# Finalmente logré quitarla toda.$5",
    "Cambria.Dialogue.mine6": "Hoy no bajaré, pero aprecio el aire fresco.$1",
    "Cambria.Dialogue.mine8": "¿Has visto a los duendecillos de polvo?#$b# Son adorables, pero atacan en grupo.",
    "Cambria.Dialogue.mine10": "Hey, @. Cuídate, ¿de acuerdo?#$b# Es peligroso, así que toma esto. [228]",
    "Cambria.Dialogue.saloon0": "Oh, hey. Vengo aquí para estar solo, así que...$13",
    "Cambria.Dialogue.saloon2": "¿Tomando un descanso? Puedes verme jugar.$1",
    "Cambria.Dialogue.saloon4": "¿Rayas o lisos?$1",
    "Cambria.Dialogue.saloon8": "¡Hey, @! ¿Tienes tiempo para un par de partidas?$1#$b# Prometo ir fácil contigo.$1",
    "Cambria.Dialogue.resort": "Esta isla me resulta familiar, creo. Como recuerdos de hace mucho tiempo.$10#$b# ¿Tal vez estuve aquí de bebé? Hmm...",
    "Cambria.Dialogue.slingshot": "...¿Por qué eres así?$5",
    "Cambria.Dialogue.RejectMovie.Invited": "Lo siento, @, alguien más ya me invitó al cine.#$b# ¿Nos vemos en la próxima?$3",
    "Cambria.Dialogue.RejectMovie.Went": "Pero... ya fuimos al cine esta semana. ¿No es la misma película...?$10",
    "Cambria.Dialogue.divorced1": "Oh no, qué triste noticia, @. Espero que te tomes un tiempo para ti, ¿de acuerdo?$2#$b# Estaré aquí si necesitas algo.$3",
    "Cambria.Dialogue.divorced2": "Hmm, ¿es demasiado pronto para decir que iré a la próxima boda?#$b# Mala suerte, @. Solo recuerda que tres es una tendencia.",
    "Cambria.Dialogue.Pet": "Escuché de Marnie que acogiste a un animal callejero.$8#$b# Eso es muy lindo. No hay nada como las mascotas para hacerte compañía.$1#$b# Asegúrate de darle caricias en la cabeza de mi parte, ¿sí?$1",
    "Cambria.Dialogue.Upgrade1": "Dicen por ahí que mejoraste tu casa. Claro, significa que fue el chisme candente del grupo de mamás del pueblo.#$b# ¡Eso es genial! Seguro es mucho mejor que la pequeña cabaña con la que empezaste.$1",
    "Cambria.Dialogue.Upgrade2": "¿Otra mejora? No preguntes cómo lo sé, en un pueblo pequeño las noticias viajan rápido.$1#$b# ¿Qué harás con tanto espacio? Odiaría tener que decorarlo. O limpiarlo del polvo, para el caso.",

    //Generic Dialogue
    //0-4 Hearts
    //About Cambria
    "Cambria.Dialogue.0-4.1": "%Cambria parece apresurada.#$b# Oh, @. Lo siento, no puedo hablar ahora.$12",
    "Cambria.Dialogue.0-4.2": "El cielo nocturno hace que valga la pena vivir aquí.$1#$b# Nunca verías tantas estrellas en la ciudad.",
    "Cambria.Dialogue.0-4.3": "%Cambria se está frotando el brazo izquierdo.#$b# ¿Oh, esto? No es nada.$3#$b# Solo me esforcé demasiado, eso es todo.",
    "Cambria.Dialogue.0-4.4": "%Cambria pasa cojeando visiblemente. Te ofrece una sonrisa mientras sigue con su recado.",
    "Cambria.Dialogue.0-4.5": "Una de las mejores cosas de vivir aquí en lugar de la ciudad es poder volver a ver el cielo nocturno.$1#$b# No te das cuenta de cuánto está oculto por la contaminación lumínica hasta que desaparece.",
    "Cambria.Dialogue.0-4.6": "¿Alguna vez has jugado billar solo?#$b# Parece solitario, pero es bastante divertido.",
    "Cambria.Dialogue.0-4.7": "%Cambria se estira y se escuchan varios crujidos audibles en su espalda.#$b# Oh, ehh...#$b# Sí, eso pasa.$3",
    "Cambria.Dialogue.0-4.8": "%Cambria pasa apresurada junto a ti. Te echa un vistazo, pero no ofrece más reconocimiento.",
    "Cambria.Dialogue.0-4.9": "No importa dónde haya estado en la vida, siempre he sentido una atracción hacia el mar.#$b# ¿Es místico? Tal vez. Crecí junto al mar, así que se siente raro estar lejos por mucho tiempo.",
    "Cambria.Dialogue.0-4.10": "Hey, @. ¿Has oído cantar al océano alguna vez? A veces lo escucho en noches lluviosas mientras reviso mis trampas para peces.#$b# ¿No? Hmm, entonces debe ser mi imaginación.",
    "Cambria.Dialogue.0-4.11": "¿Alguna vez te dije que hago hidromiel con cafeína?#$b# ¡Sí! Yo también me sorprendí de que funcionara.$1#$b# Me tomó un par de resacas con temblores para calcular el contenido de cafeína.",
    "Cambria.Dialogue.0-4.12": "Me gusta observar las estrellas todo el año, pero diría que disfruto más hacerlo en otoño.#$b# Algunas de mis constelaciones favoritas son más fáciles de ver en esa época del año.$1",
    "Cambria.Dialogue.0-4.13": "¿Cómo va tu día, @?#$b# Recuerda tomarte un tiempo para ti mismo.#$b# Sí, sé que no sigo mi propio consejo.$5",
    "Cambria.Dialogue.0-4.14": "¿Alguna vez te has levantado de la cama y simplemente tus piernas no responden?#$b# Oh, ¿solo yo?",
    "Cambria.Dialogue.0-4.15": "A veces los sueños son tan surrealistas.#$b# Como anoche, soñé que estaba en el fondo del océano rodeada de... ¿eran sirenas o peces globo?$10#$b# De cualquier forma, fue una experiencia muy extraña.",

    //About Family and Pets
    "Cambria.Dialogue.0-4.16": "¿Heredé mi granja también?#$b# Bueno... algo así.$3#$e# ...$2",
    "Cambria.Dialogue.0-4.17": "Orchid a veces canta al amanecer si tiene mucha hambre.#$b# Aunque en realidad no es un canto, sino más bien un grito distorsionado de los condenados.#$b# Algunos días tiene suerte de ser linda.$5",
    "Cambria.Dialogue.0-4.18": "A pesar de lo diferentes que son, Jupiter y Orchid se llevan sorprendentemente bien.#$b# Creo que solo le bastaron uno o dos picotazos para aprender dónde está en la cadena alimenticia.",
    "Cambria.Dialogue.0-4.19": "Es incómodo tener que explicar los gritos que salen de mi granja.#$b# No puedo exactamente entrenarle lo del 'sombrío' a una gallina sombría.$5",
    "Cambria.Dialogue.0-4.20": "Perdí a Jupiter entre mis plantas de café hoy.#$b# ¿Sabes cuán grande es un bernés? No son precisamente fáciles de perder.#$b# Pero lo vi entrar y no salió hasta que le ofrecí premios.$5",
    "Cambria.Dialogue.0-4.21": "Algunos días son más difíciles que otros. Pero llegar a casa y ver a Orchid y Jupiter acurrucados frente al fuego lo hace valer la pena.#$b# Excepto que no encendí el fuego antes de irme...#$b# Estoy segura de que estará bien... ¿verdad?$12",
    "Cambria.Dialogue.0-4.22": "¿La estatua cerca de mi granja? No estoy segura de quién es tampoco, probablemente algún antepasado mío.#$b# Mis abuelos no eran muy dados a la historia familiar.",
    "Cambria.Dialogue.0-4.23": "Mi familia ha vivido en el área de Lore's Cove por generaciones.#$b# Hay un viejo monumento a alguien llamado 'Lore Seeker', así que el nombre tiene sentido, supongo.",
    "Cambria.Dialogue.0-4.24": "¿Conoces a tus padres, @?#$b# Mi abuela siempre decía que mi madre se escapó con un tritón.",
    "Cambria.Dialogue.0-4.25": "Le pedí a Orchid si podíamos pasar un día sin que hiciera algo malo.#$b# La mirada en sus ojos me dijo que ya era demasiado tarde.",
    "Cambria.Dialogue.0-4.26": "Uno de los dichos favoritos de mi abuelo era 'Los sueños se hacen realidad para aquellos que realmente los desean.'#$b# Mi abuela también tenía un dicho favorito, pero creo que era en su mayoría palabrotas.",
    "Cambria.Dialogue.0-4.27": "Pensé que la gente exageraba cuando trataban a su masa madre como un ser vivo.$10#$b# Bueno, estoy bastante segura de que la mía me exigió que la alimentara. Quizás deba dejar el hidromiel...$2#$e# Ni siquiera me llamo Seymour.$5",
    "Cambria.Dialogue.0-4.28": "¿Por qué no tengo un espantapájaros? No estoy segura, pero los cuervos nunca me han molestado por alguna razón.#$b# Orchid probablemente los intimida, ja. A mí también me asustaría si fuera un pájaro.$1",
    "Cambria.Dialogue.0-4.29": "No sé si alguna vez te lo dije, pero soy alérgica a los mangos. Mortalmente, de hecho, tengo que lavarme las manos después de tocarlos.#$b# ¿Por qué te lo digo? Bueno, mejor prevenir que lamentar, ¿no?",
    "Cambria.Dialogue.0-4.30": "¿Qué tan común es tener una familia extendida? Quiero decir, yo solo conocí a mis abuelos.#%b$ Cuando me fui, estuve sola por mucho tiempo, hasta que... ah, olvídalo. Es bastante aburrido.",

    //About Friends and Neighbors
    "Cambria.Dialogue.0-4.31": "¿Alguna vez has despertado y descubierto que uno de tus animales ha aprendido una nueva habilidad?#$b# Encontré a Orchid boca abajo en mis cortinas esta mañana.$5",
    "Cambria.Dialogue.0-4.32": "¿Has estado aceptando peticiones del tablón de anuncios?#$b# Si es así, gracias.$1",
    "Cambria.Dialogue.0-4.33": "Pierre siempre me insiste para que compre semillas cuando visito la tienda.#$b# No tuve el corazón para decirle que mis plantas de café ya son más que suficiente trabajo para mí.",
    "Cambria.Dialogue.0-4.34": "Caroline me compartió un poco de té verde el otro día.#$b# Estaba bastante bueno y me recordó a mi... oh, olvídalo.$2",
    "Cambria.Dialogue.0-4.35": "Sam me pidió un girasol para ponerlo bajo su almohada el otro día.#$b# Tuve que convencerlo de que la terapia de exposición no funciona así.",
    "Cambria.Dialogue.0-4.36": "Emily preguntó si hablaría más con la gente si ella pusiera una petición en el tablón para ello.$5#$b# Si alguna vez la ves, ¿podrías uhh, aceptarla por mí?#$b# Gracias de antemano, @.$3",
    "Cambria.Dialogue.0-4.37": "Juro que las peticiones no eran tan extrañas cuando era más joven.$5#$b# Aunque, claro, Joja tampoco existía en ese entonces... ¿Conspiración?$10",
    "Cambria.Dialogue.0-4.38": "%Cambria está cargando un saco repleto de granos de café.#$b# ¡Oh, hola! Estoy en camino a dejar una entrega en la taberna.$8#$b# Gus siempre hace pedidos grandes, pero tengo algo extra. ¡Nos vemos luego! [(O)433][(O)433][(O)433][(O)433][(O)433]",
    "Cambria.Dialogue.0-4.39": "La gente se queja de que Pierre cierra los miércoles, pero todo el mundo necesita un día libre.#$b# ...¿Por qué me miras así?$10",
    "Cambria.Dialogue.0-4.40": "Sé que Harvey no es dentista, pero me pregunto si tiene alguna recomendación local.$2#$b# ¡Oh, no para mí! Pam pidió un cuarzo para frotarlo en su diente adolorido y no puedo dejar de pensar en ello.$12",
    "Cambria.Dialogue.0-4.41": "Escucha, sé que la cola Joja contiene químicos más allá de la comprensión humana.#$b# Pero siento que el hecho de que Demetrius haya pedido una para diseccionarla es llevarlo demasiado lejos, ¿no crees?",
    "Cambria.Dialogue.0-4.42": "%Cambria no se ve bien.#$b# ¿Oh? Estoy bien, solo un poco indispuesta.$11#$b# Sí, sé que debería descansar, pero Harvey pidió una entrega especial de café.$9#$b# Aunque me hará quedarme en la clínica... Hm...$2",
    "Cambria.Dialogue.0-4.43": "¿La taberna los viernes? Ni de broma.#$b# Voy antes de que se llene, si es que voy. Si no, prefiero ir a la posada si quiero jugar al billar.",
    "Cambria.Dialogue.0-4.44": "Los días que tengo energía, subo a las montañas profundas para pasar el rato con las cabras.#$b# Trato de tener cuidado con ellas, especialmente cuando siento que alguien me está observando.",
    "Cambria.Dialogue.0-4.45": "No te dejes engañar, soy bastante buena con la espada.#$b# Incluso Marlon se sorprende de lo ágil que puedo ser cuando es necesario.$8",

    //Other
    "Cambria.Dialogue.0-4.46": "¿Has estado usando nasas para cangrejos?#$b# Descubrí que da buena suerte usar un número impar y hasta ahora no me ha fallado.$1",
    "Cambria.Dialogue.0-4.47": "Se acerca la luna llena. No soy muy supersticiosa, pero hay cosas que la ciencia conocida no puede explicar fácilmente.#$b# Mantente alerta, @. Podrías despertarte con una sorpresa.",
    "Cambria.Dialogue.0-4.48": "Escuché que te hiciste cargo de la granja de tu familia, @.#$b# Espero que, hasta ahora, los pros superen a los contras para ti.$1",
    "Cambria.Dialogue.0-4.49": "Oye, @. ¿Has comido algo? No tengo mucho conmigo, pero toma esto. [16 20 403]",
    "Cambria.Dialogue.0-4.50": "¿Tienes colmenas? La miel y la cera de abeja son bastante versátiles.#$b# La cera se puede usar en abrillantador de zapatos y para recubrir queso. Personalmente, la usaría para hacer velas si tuviera tiempo.",
    "Cambria.Dialogue.0-4.51": "Oye, @. ¿Has comido algo? No tengo mucho conmigo, pero toma esto. [398 404 396 259 403]",
    "Cambria.Dialogue.0-4.52": "Oye, @. ¿Has comido algo? No tengo mucho conmigo, pero toma esto. [422 281 404 408 406 403]",
    "Cambria.Dialogue.0-4.53": "Oye, @. ¿Has comido algo? No tengo mucho conmigo, pero toma esto. [412 414 416 403]",
    "Cambria.Dialogue.0-4.54": "¡Qué suerte que te encontré, @!$1#$b# Hice un poco de esto de más y quiero que lo tengas. ¡Cuídate!$1 [395 227 228]",
    "Cambria.Dialogue.0-4.55": "Dime, @, ¿alguna vez te tomas un día libre? Juro que cada vez que te veo, estás corriendo de un lado a otro.#$b# Sí, sí, el sartén le dice a la olla... Ja ja.$5",
    "Cambria.Dialogue.0-4.56": "Me sorprende un poco que los cangrejos de roca que invaden la playa de East Scarp no se aventuren más lejos.$12#$b# No es que me queje... ¿Qué? ",
    "Cambria.Dialogue.0-4.57": "Las moscas en los niveles bajos de la mina son lo peor.$5#$b# Voy a tener un zumbido en los oídos por días.",
    "Cambria.Dialogue.0-4.58": "¿Qué tan lejos has llegado en las minas? Escuché que hay una parte completamente oscura, pero nunca la he visto.#$b# Sí, el juego de palabras fue intencional. Y que sepas que una vez llegué hasta el lago de lava.$5",
    "Cambria.Dialogue.0-4.59": "Estuve observando mis abejas melíferas el otro día y nunca me di cuenta de lo torpes que son.#$b# ¡En serio! Un aterrizaje mal calculado y de repente hay un montón de 8 abejas apiladas.#$b# Vaya riesgo de vuelo, ja.$1",
    "Cambria.Dialogue.0-4.60": "Pescando en la mina, atrapé una medusa de cueva la última vez.#$b# Para ser sincera, sabe bastante bien. ¿Eh? ¿Estás bien, @? Te pusiste verde de repente.$10",

    //Seasonal
    "Cambria.Dialogue.0-4.Spring.1": "¿Consejo para la granja? Bueno, te recomendaría cultivar judías verdes esta temporada. No se venden por mucho, pero vuelven a crecer.#$b# Genial para quienes están empezando.$1",
    "Cambria.Dialogue.0-4.Spring.2": "Sebastian me pidió una papa para lanzarla a la montaña otra vez.#$b# ¿Debería hornearla primero? Probablemente sería más satisfactorio de lanzar.#$b# ¿O solo estaría fomentándolo?",
    "Cambria.Dialogue.0-4.Spring.3": "Pam me pidió una papa madura el otro día. Aún intento averiguar si planeaba hacer vodka.#$b# Necesitaría más de una papa para eso.",
    "Cambria.Dialogue.0-4.Spring.4": "%Cambria hace una mueca al dar un paso.#$b# Estaré bien, no te preocupes. A mis músculos simplemente no les gusta el frío de la primavera.$11",
    "Cambria.Dialogue.0-4.Spring.5": "¿El festival del desierto? He oído hablar de él, pero está demasiado lejos para mí.",
    "Cambria.Dialogue.0-4.Spring.6": "Durante la primavera y el otoño no puedo esperar a que llueva.#$b# ¿Por qué? ¡Para pescar anguilas, por supuesto! Son mis favoritas.",
    "Cambria.Dialogue.0-4.Spring.7": "Por extravagantes que sean mis preferencias alimenticias, no hay dinero que me haga comer rábano picante silvestre.",
    "Cambria.Dialogue.0-4.Spring.8": "Es bonito ver las flores florecer otra vez después del frío del invierno.#$b# Aunque las que están junto a mi casa nunca parecen verse afectadas.",
    "Cambria.Dialogue.0-4.Spring.9": "¿Tienes planes para hoy, @? Yo estoy ocupada como siempre. Si tengo un momento libre, iré a la playa.",
    "Cambria.Dialogue.0-4.Spring.10": "¿Junimos? Sí, sé de ellos; mi abuelo me contó todo sobre ellos. ¿Por qué?#$b# ¿Se instalaron en el centro comunitario, eh? Quizás les haga una visita.",
    "Cambria.Dialogue.0-4.Summer.1": "Hay algunos días en verano cuando el mar se vuelve de un verde esmeralda.#$b# Seguro hay una razón científica, pero es hermoso de todas formas.$1",
    "Cambria.Dialogue.0-4.Summer.2": "Las uvas silvestres que crecen por aquí son deliciosas.$1#$b# A Orchid le encantan especialmente.$1",
    "Cambria.Dialogue.0-4.Summer.3": "Si vas a nadar al océano, mantén un ojo en los peces globo.#$b# No estoy segura de si la especie local es tóxica, pero se venden bien.",
    "Cambria.Dialogue.0-4.Summer.4": "El verano siempre trae muchas solicitudes de pepinos de mar.#$b# Tengo preguntas que prefiero no responder.",
    "Cambria.Dialogue.0-4.Summer.5": "%Cambria parece sin aliento.#$b# Oye, @. Lo siento, no soporto bien la humedad aquí.$9#$b# Hablemos en otro momento.$11",
    "Cambria.Dialogue.0-4.Summer.6": "%Cambria no parece notar tu presencia. Mientras camina, la escuchas murmurar sobre super pepinos de mar.",
    "Cambria.Dialogue.0-4.Summer.7": "No puedo esperar a que el mar se vuelva verde otra vez. Suena raro decirlo, pero escúchame.#$b# Cuando el mar es verde, juro que hay más conchas en la playa de lo normal.$1",
    "Cambria.Dialogue.0-4.Summer.8": "Aprovecha la playa mientras puedas. Disfruta el sol, nada en el océano.#$b# ¿Si yo nado? Bueno, solía hacerlo, pero dejé de hacerlo después de...#$b# Oh, no importa, no quiero aburrirte.",
    "Cambria.Dialogue.0-4.Summer.9": "Odio cuando Willy pide peces que solo salen con la lluvia.$5#$b# O sea, una solicitud es una solicitud, pero ¿en verano?#$b# Si no hace un calor insoportable, hay una tormenta eléctrica. No, gracias.",
    "Cambria.Dialogue.0-4.Summer.10": "@, creo que deberíamos revisar a Leah.$2#$b# El otro día me pidió un pulpo para ponerlo debajo de su almohada.$2#$b# ¿Es posible que haya recogido el hongo equivocado?$12",
    "Cambria.Dialogue.0-4.Fall.1": "Mantén los ojos abiertos en busca de hongos en esta época del año, @. No te recomendaría comerlos, pero se venden bien.",
    "Cambria.Dialogue.0-4.Fall.2": "¿Soy solo yo, o últimamente la gente pide cosas cada vez más raras?$10#$b# Lewis me pidió una berenjena para su rodilla adolorida el otro día.",
    "Cambria.Dialogue.0-4.Fall.3": "¡Pescando de noche atrapé una carpa de medianoche!$8#$b# No, eh... no preguntes por qué estaba despierta tan tarde.$3",
    "Cambria.Dialogue.0-4.Fall.4": "Aparte del café, el único cultivo que planto en otoño son berenjenas.#$b# Seguro que hay un chiste en eso en algún lado.$5",
    "Cambria.Dialogue.0-4.Fall.5": "Tuve que sacarle un hongo rojo de la boca a Jupiter el otro día.#$b# Juro que intenta darme un infarto.$5",
    "Cambria.Dialogue.0-4.Fall.6": "Al parecer, la miel hecha con polen de rosa de hada es de las mejores que se pueden producir en la zona.#$b# He considerado diversificarme, pero ya tengo demasiado en mis manos.",
    "Cambria.Dialogue.0-4.Fall.7": "Durante la primavera y el otoño no puedo esperar a que llueva.#$b# ¿Por qué? ¡Para pescar anguilas, por supuesto! Son mis favoritas.",
    "Cambria.Dialogue.0-4.Fall.8": "¿Mis plantas de café? ¿Qué pasa con ellas?#$b# Oh, ¿no deberían crecer en otoño? No sé qué decirte, @.#$b# Algo, algo, regalo de la naturaleza en las hojas.",
    "Cambria.Dialogue.0-4.Fall.9": "¿Tienes planes para hoy, @? Yo estoy ocupada como siempre. Si tengo un momento libre, iré a la playa.",
    "Cambria.Dialogue.0-4.Fall.10": "Nunca me he molestado en tallar calabazas. Se ven bonitas, pero duran demasiado poco.",
    "Cambria.Dialogue.0-4.Winter.1": "%Cambria tiene evidentes ojeras.#$b# Oh, hola, @. Atrapé otra carpa de medianoche.$11",
    "Cambria.Dialogue.0-4.Winter.2": "Orchid y Jupiter odian estar encerrados en este clima frío.$5#$b# Pero sé que si los dejo salir, volverán corriendo a la puerta en un instante.",
    "Cambria.Dialogue.0-4.Winter.3": "Alguien pidió una papa en el tablón de anuncios hoy.#$b# Es invierno. ¿Quién tiene papas de hace tres estaciones?#$b# No respondas eso.$5",
    "Cambria.Dialogue.0-4.Winter.4": "Creo que el mercado nocturno de invierno es nuevo.#$b# No recuerdo que estuviera por aquí en mis tiempos.",
    "Cambria.Dialogue.0-4.Winter.5": "¿Soy solo yo o los inviernos cada vez son más fríos aquí?$10#$b# Creo que el océano tiene algo que ver.",
    "Cambria.Dialogue.0-4.Winter.6": "El invierno significa que las abejas están inactivas y los cultivos no crecen.#$b# Para otras personas, claro. Supongo que mis abejas y mi café son más resistentes de lo normal.",
    "Cambria.Dialogue.0-4.Winter.7": "Espero que te estés manteniendo abrigado esta temporada, @.#$b# También, aquí tienes, ¡usa esto para decorar! [283]$8#$b# Ayuda a alejar los peligros del invierno.$1",
    "Cambria.Dialogue.0-4.Winter.8": "Ojalá hubiera más solicitudes de caza de monstruos en esta época del año.#$b# ¿Por qué no ir de todos modos? No voy a hacer ese viaje tan largo sin una buena razón, @.",
    "Cambria.Dialogue.0-4.Winter.9": "Atención, @. Gus siempre anhela Albacora cerca del final de la temporada.#$b# Justo pesqué una extra, así que puedes tenerla. [705]",
    "Cambria.Dialogue.0-4.Winter.10": "Orchid está dentro y se niega a salir al frío.#$b# Actúa como si el exterior fuera una ofensa.$5",

    //6-10 Hearts
    //About Cambria
    "Cambria.Dialogue.6-10.1": "%Cambria parece aliviada de verte.#$b# Oh bien, eres tú, @.$2#$b# Tuve un sueño rarísimo donde tú eras yo... ¿pero no realmente?$10#$b# Fue espeluznante, para ser honesta.$2",
    "Cambria.Dialogue.6-10.2": "%Cambria parece a punto de desplomarse del cansancio.#$b# Oh, hey, @. Lo siento, estoy agotada ahora mismo.$11#$b# Saqué mi guitarra anoche y me puse a recordar viejos tiempos. A veces extraño presentarme en el escenario.$9",
    "Cambria.Dialogue.6-10.3": "%Cambria levanta la vista de la libreta que lleva en la mano.#$b# Hey, @. ¿Cómo va tu día?#$b# Tengo mucho trabajo que poner al día, así que hablamos luego, ¿sí?#$b# Cuídate.$1",
    "Cambria.Dialogue.6-10.4": "Definitivamente hay cosas que extraño de vivir en la ciudad. Cape Starlet tenía una esencia única que ningún otro lugar puede igualar.$8#$b# Aun así, nada se siente más como hogar que abrir mi puerta y recibir la brisa fresca del mar.#$b# La falta de contaminación lumínica también es una gran ventaja.$1",
    "Cambria.Dialogue.6-10.5": "Ser tatuadora en la ciudad fue una gran experiencia, pero vaya que tengo historias para contar.#$b# Tendré que contarte algunas algún día.",
    "Cambria.Dialogue.6-10.6": "Probablemente no lo sepas, pero Joja nunca logró establecerse en Cape Starlet.#$b# Intentaron abrir una tienda y básicamente todos les dijeron que se largaran.$12",
    "Cambria.Dialogue.6-10.7": "Abigail me preguntó sobre la cicatriz en mi nariz la última vez que fui a la tienda. Parecía decepcionada de que no fuera de una épica batalla contra un monstruo.#$b# La única pelea que tuve fue contra el asfalto... y perdí.",
    "Cambria.Dialogue.6-10.8": "Hey, @. ¿Alguna vez has escuchado cantar al océano? A veces lo oigo en las noches lluviosas mientras reviso mis trampas de pesca.#$b# ¿No? Hmm, entonces debe ser mi imaginación.",
    "Cambria.Dialogue.6-10.9": "Una vez en la ciudad me invitaron a probar la 'Lechuga del Diablo'.#$b# No me hizo gracia descubrir que ni era lechuga ni tenía nada de diabólico.$5",
    "Cambria.Dialogue.6-10.10": "Los sueños son tan surrealistas a veces.#$b# Como anoche, soñé que estaba en el fondo del océano rodeada de... ¿eran sirenas o peces gota?#$b# Sea lo que sea, fue una experiencia muy extraña.",
    "Cambria.Dialogue.6-10.11": "¿Alguna vez te conté que hago hidromiel con cafeína?#$b# ¡Sí! Yo también me sorprendí de que funcionara.#$b# Me tomó un par de resacas nerviosas calcular bien la cantidad de cafeína.",
    "Cambria.Dialogue.6-10.12": "¿Alguna vez te has levantado de la cama y, de repente, tus piernas simplemente no responden?#$b# Oh, ¿solo yo?",
    "Cambria.Dialogue.6-10.13": "%Cambria te sonríe ampliamente. ¿Siempre ha tenido los colmillos así de largos?#$b# ¿Qué tal, @? ¡Espero que tu día vaya bien!$8",
    "Cambria.Dialogue.6-10.14": "%Cuando Cambria te mira, hay un destello en sus ojos que parece casi antinatural.#$b# ¿Cómo te va? ¿Todo bien? ¿Tengo algo en el ojo?",
    "Cambria.Dialogue.6-10.15": "A veces oigo ruidos que vienen del bosque detrás de mi casa.#$b# ¿Investigarlos? ¿Estás bromeando? He leído suficiente terror como para saber cómo termina eso.",

    //About Family and Pets
    "Cambria.Dialogue.6-10.16": "A veces, cuando miro hacia el océano, juro que veo un barco pirata a lo lejos.#$b# No estoy segura de que realmente sea un barco pirata, pero no sé qué más podría ser.$10",
    "Cambria.Dialogue.6-10.17": "¿Has visto a Orchid por ahí?$10#$b# Me despertó con una llamada desde el vacío como siempre, pero ya no estaba cuando me levanté.#$b# Me han dicho que le gusta deambular.",
    "Cambria.Dialogue.6-10.18": "Mi abuela solía contarme historias sobre sus viajes por las distintas islas del Mar de Gemas.#$b# Nunca especificó por qué viajaba tanto, y mi abuelo tampoco dio más detalles.$10",
    "Cambria.Dialogue.6-10.19": "Probablemente ya lo notaste, pero hay una puerta extraña en mi casa, junto a la chimenea.#$b# Tengo la sensación de que la vieja habitación de mis abuelos está al otro lado. No estoy segura de qué pasó con la perilla de la puerta.",
    "Cambria.Dialogue.6-10.20": "Tuve que cepillar a Jupiter el otro día.#$b# Juro que saqué de su pelaje lo suficiente para hacer otro perro.#$b# Se llama Pluto.$1",
    "Cambria.Dialogue.6-10.21": "Jupiter casi me sofoca mientras dormía esta mañana.$5#$b# ¿Por qué los perros grandes creen que caben en cualquier parte?",
    "Cambria.Dialogue.6-10.22": "A veces, Orchid tiene esa mirada de que sabe algo que yo no.$10#$b# Lo cual es raro, porque es solo una gallina... ¿o no?$2",
    "Cambria.Dialogue.6-10.23": "Mi abuelo fue quien me enseñó sobre la apicultura.#$b# Todo lo que sé, lo aprendí viéndolo cuando era niña.",
    "Cambria.Dialogue.6-10.24": "Cuando tengo tiempo y energía, me gusta visitar a Gil en el Gremio de Aventureros.#$b# La abuela Claw solía contarme historias sobre él en su juventud.#$b# Aparentemente, él fue quien admitió a Marlon, lo cual es genial.",
    "Cambria.Dialogue.6-10.25": "¿Por qué cultivo carambola? Es otra cosa que heredé de mis abuelos. Además, la fruta es deliciosa.#$b# Pero entre tú y yo, ojalá pudiera cultivar pitahaya por aquí.",
    "Cambria.Dialogue.6-10.26": "Orchid a veces cacarea al amanecer si tiene mucha hambre.#$b# Excepto que no es un cacareo, sino más bien un grito deformado de los condenados.#$b# Algunos días, tiene suerte de ser linda.$5",
    "Cambria.Dialogue.6-10.27": "Tuve que golpear mi masa madre con una espátula y ¡me siseó!$7#$b# Pensé que la gente exageraba cuando hablaban de alimentarla...$13#$b# Estoy segura de que Orchid está bien.",
    "Cambria.Dialogue.6-10.28": "¿Mis padres? Nunca los conocí. Uno de mis primeros recuerdos es el crujido de las tablas y el sonido de las olas chocando.#$b# Tal vez nací en un barco pirata, eso sería algo interesante.",
    "Cambria.Dialogue.6-10.29": "Ha habido días en los que no encuentro a Orchid por ninguna parte y siento una presencia en las ruinas detrás de mi casa.#$b# Se siente como Orchid, pero... ¿no? Es muy surrealista, pero al final siempre aparece.",
    "Cambria.Dialogue.6-10.30": "Jupiter es mi perro de servicio retirado, ahora que ya no corro riesgo de caerme.#$b# Estoy bastante segura de que sus neuronas se fueron junto con el arnés cuando se lo quité por última vez.",

    //About Friends and Neighbors
    "Cambria.Dialogue.6-10.31": "Aunque extraño vivir con Gabe, vivir sola tiene sus ventajas.#$b# Por ejemplo, cuando compro comida, sigue ahí hasta que la como.#$b# Hubo demasiados días en los que me despertaba y la nevera estaba vacía con él alrededor.$5",
    "Cambria.Dialogue.6-10.32": "A veces me gusta ir a las montañas al norte de East Scarp.#$b# Hay unas cabras sombrías que deambulan por ahí y tienen un aspecto genial.#$b# Me tomó tiempo, pero algunas me dejaron acercarme para acariciarlas. Son cálidas al tacto, como Orchid.$12",
    "Cambria.Dialogue.6-10.33": "Jodi me dio un poco de ginger ale como agradecimiento hoy.#$b# No me gusta mucho la soda, así que puedes quedártela. [903]#$b# Al parecer, a Vincent le encanta.",
    "Cambria.Dialogue.6-10.34": "Sam me invitó a la sesión de improvisación de la banda este sábado.#$b# He estado debatiendo si debería ir o no. Sería genial, pero no estoy segura.#$b# La verdad es que debería salir más. Hmm...$2",
    "Cambria.Dialogue.6-10.35": "¿Fuiste a conciertos cuando vivías en la ciudad, @?#$b# Gabe y yo solíamos tener una banda llamada Double Fang.#$b# Suena un poco intenso, pero nos divertíamos mucho. Creo que ayudó el hecho de que siempre lo vimos como un pasatiempo.",
    "Cambria.Dialogue.6-10.36": "Aideen pidió algas marinas para su próxima fiesta de té. No sé qué pensar.$10#$b# Las algas tostadas son una cosa, y están muy buenas. Pero ¿algas crudas? ¿Para una sofisticada fiesta de té? Mentiría si dijera que no me preocupa.$3",
    "Cambria.Dialogue.6-10.37": "¿Alguna vez has encontrado una fruta estelar, @?#$b# He oído hablar de ellas por Willy, pero nunca he entendido a qué saben.$10#$b# ¿Que sabe a %favorite? Eso... es raro.$2",
    "Cambria.Dialogue.6-10.38": "Gabe hace una sidra de manzana especiada increíble en esta época del año.#$b# Espero poder probarla de nuevo algún día.",
    "Cambria.Dialogue.6-10.39": "Creo que lo de 'Rejuvenecimiento de Rocas' de Emily se fue un poco de las manos.$2#$b# Caroline pidió un diamante para frotarlo en su rodilla adolorida.#$b# ¿Eso siquiera funciona?$10",
    "Cambria.Dialogue.6-10.40": "Sam ha estado pidiéndome consejos para jugar al billar. Se le da bien golpear las bolas, pero podría mejorar su puntería... y su fuerza.#$b# Explicarle a Gus el ladrillo roto de la pared no fue divertido.$5",
    "Cambria.Dialogue.6-10.41": "Emily y yo crecimos juntas. Éramos las únicas de nuestra edad en el pueblo.#$b# Me enseñó varias manualidades. Tal vez debería hacerle algo.",
    "Cambria.Dialogue.6-10.42": "Vivir con Gabe en la ciudad fue definitivamente toda una experiencia.#$b# Es un milagro que no me salieran canas antes de los 30.",
    "Cambria.Dialogue.6-10.43": "Ojalá hubiera más fuentes de madera noble por aquí. Robin me pidió ayuda para reabastecer su almacén, pero el bosque está tan lejos.$2",
    "Cambria.Dialogue.6-10.44": "%Cambria lleva un saco lleno hasta el tope de granos de café.#$b# ¡Oh, hey! Estoy de camino a dejar una entrega en la taberna.$8#$b# Gus siempre hace pedidos en grandes cantidades, pero tengo un poco de sobra. ¡Nos vemos! [433][433][433][433][433]",
    "Cambria.Dialogue.6-10.45": "Jodi y Caroline me invitaron a hornear con ellas como pasatiempo. Es realmente agradable pasar tiempo con otras madres-- eh, quiero decir.#$b# En fin, se pusieron raras con lo que hice, pero estoy segura de que dejó de parpadear. Toma, prueba un poco. [203]",

    //Other
    "Cambria.Dialogue.6-10.46": "De todas las solicitudes de caza de monstruos, estoy bastante segura de que los Niños Calamar son los peores.$5#$b# No solo son difíciles de rastrear, sino que tampoco quiero hacerle daño a la gente de las sombras, ¿sabes?$2",
    "Cambria.Dialogue.6-10.47": "¡Hey, @! ¡Ahí estás!$8#$b# Espero que te guste la comida picante, porque hice demasiado. No fue intencional, lo prometo. [395][215 226 907] #$e# Si no te gusta, no me sentiré mal si la vendes. Que tengas un buen día.$1",
    "Cambria.Dialogue.6-10.48": "%Cambria sonríe cuando te acercas.#$b# @, ¡es genial verte! Espera un momento, tengo algo para ti.$8#$e# ¡Aquí tienes! Llevé extra por si me encontraba contigo. [253][611 651 203]",
    "Cambria.Dialogue.6-10.49": "¿Crees que cuando los tritones tienen hijos, hay una posibilidad de que uno sea completamente pez o completamente humano?$10",
    "Cambria.Dialogue.6-10.50": "Hey, @, ¿quieres probar algo de mariscos? He estado probando nuevos platillos. [253][921 265 733]#$b# No te preocupes, está certificado como libre de vacío. Y, por supuesto, viene con un espresso gratis.$1",
    "Cambria.Dialogue.6-10.51": "Intento no adentrarme demasiado en las minas. Los pisos más bajos son demasiado calurosos, y pelear contra la gente de las sombras nunca me ha parecido correcto.#$b# Después de hacerte amigo de uno, es difícil verlos de la misma manera.$2",
    "Cambria.Dialogue.6-10.52": "¿Apuestas, @? He ido al casino del desierto unas cuantas veces. Dejé de ir cuando el dueño intentó hablar conmigo.#$b# Algo sobre ser una salsa...?$2",
    "Cambria.Dialogue.6-10.53": "Pesqué una medusa de cueva la última vez que bajé a las minas.#$b# Sabe bastante bien, para ser honesto. ¿Eh? ¿Estás bien, @? De repente te pusiste verde.$10",
    "Cambria.Dialogue.6-10.54": "Se acerca la luna llena. No soy muy supersticiosa, pero hay cosas que no pueden explicarse fácilmente con la ciencia conocida.#$b# Mantente alerta, @. Podrías despertarte con una sorpresa.",
    "Cambria.Dialogue.6-10.55": "El otro día estaba observando mis abejas y nunca me di cuenta de lo torpes que son.#$b# ¡En serio! Un aterrizaje en falso y terminan en un montón de 8 abejas.#$b# Hablando de riesgos de vuelo, ja.",
    "Cambria.Dialogue.6-10.56": "¿Te sorprendería si te dijera que puedo ver en la oscuridad?#$b# Yo mismo no lo entiendo, pero nunca tuve problemas para ver, incluso en ciertos niveles de las minas.",
    "Cambria.Dialogue.6-10.57": "Me sorprende un poco que los cangrejos de roca que invaden la playa de East Scarp no viajen más lejos.#$b# No es que me queje de un cangrejo regalado... ¿Qué?",
    "Cambria.Dialogue.6-10.58": "Las moscas en los primeros niveles de la mina son las peores.$5#$b# Voy a tener un zumbido en los oídos durante días.",
    "Cambria.Dialogue.6-10.59": "Juro que las solicitudes no eran tan extrañas cuando era más joven.$5#$b# Aunque, pensándolo bien, Joja tampoco existía en ese entonces... ¿Conspiración?$10",
    "Cambria.Dialogue.6-10.60": "Escucha, sé que la cola de Joja contiene químicos más allá de la comprensión humana.#$b# Pero siento que Demetrius pidiendo una para diseccionarla es llevarlo un poco demasiado lejos, ¿no crees?",

    //Family
    "Cambria.Dialogue.Family.1": "Espero que esa carta mal entregada haya sido un caso aislado.#$b#Digamos que preferiría que no vieras lo que me envía Rin.$5",
    "Cambria.Dialogue.Family.2": "Dolly me envió otro dibujo hoy, ¡mira!$8#$b#%Cambria te muestra un garabato infantil de un ganso.#$b#Lo colgaré en mi pared en cuanto tenga la oportunidad.$1",
    "Cambria.Dialogue.Family.3": "%Cambria está murmurando para sí misma.#$b#Rin me envió una carta hoy. Apenas podía leerla por todas las manchas de lágrimas.$5#$b#¿Qué? Oh, está bien, lo más probable es que se haya hecho llorar solo por el drama. Le enviaré chocolate extra para que no se sienta ignorado.",
    "Cambria.Dialogue.Family.4": "La carta que recibí hoy prácticamente explotaba del sobre. Cuando la abrí, solo contenía una copia del artículo más reciente de Rin.#$b#Leo las noticias de Cape Starlet en línea, pero insiste en enviarme cada artículo que escribe.#$b#Bueno, sí, los guardo todos, ¿por qué?",
    "Cambria.Dialogue.Family.5": "La carta que recibí hoy prácticamente explotaba del sobre. Cuando la abrí, ni siquiera había una carta, solo un montón de dibujos de Dolly.#$b# Uno de ellos era de patos en un estanque. Tal vez debería enviarle algunas fotos de los patos locales.",
    "Cambria.Dialogue.Family.6": "El otro día recibí una carta del hermano de Rin, de todas las personas. Aparentemente, Rin ha estado especialmente melancólico en su diván.#$b#Mejor él que yo, pero le enviaré algunos regalos como disculpa.",
    "Cambria.Dialogue.Family.7": "%Apenas te acercas, Cambria te muestra una foto de una niña vestida de rosa.#$b#¡Mira! ¿No es Dolly adorable? Rin le compró un vestido nuevo hace poco.$8#$b#...Ah, lo siento. Se me nota lo de madre, ¿verdad?$4",
    "Cambria.Dialogue.Family.8": "%Cambria está completamente sonrojada y se niega a mirarte. Sin duda es por su 'chico gótico' especial.",

    //Seasonal
    "Cambria.Dialogue.6-10.Spring.1": "¿Qué tiene Sebastián contra las verduras?$10#$b# El otro día pidió una judía verde para lanzarla a la montaña. La vez anterior fue una patata.$5",
    "Cambria.Dialogue.6-10.Spring.2": "La mayoría de la gente prefiere ir a la playa en verano.#$b# Pero personalmente, me encantan las noches frescas de primavera o de otoño.",
    "Cambria.Dialogue.6-10.Spring.3": "Demetrius pidió un salmón el otro día, pero no le gustó el salmón sombrío que le llevé.#$b# No sé qué esperaba si pidió algo fuera de temporada. En fin, más sashimi para mí.",
    "Cambria.Dialogue.6-10.Spring.4": "Debería intentar hacer pastel de zanahoria algún día. Sin nueces, por supuesto, esas son horribles.",
    "Cambria.Dialogue.6-10.Spring.5": "¿Ya tienes un ahumador de pescado? Quiero probar anguila ahumada. Oooh, o salmón sombrío ahumado.#$b# ¿Por qué esa cara?$10",
    "Cambria.Dialogue.6-10.Summer.1": "Veo a Orchid flotando en el río muchas veces en verano.#$b# Lo curioso es que, si aparto la vista un segundo, desaparece por completo.$10#$b# Seguro que es cosa normal en una gallina sombría o algo así.",
    "Cambria.Dialogue.6-10.Summer.2": "Las temperaturas extremas siempre afectan mis articulaciones, ya sea en verano o en invierno.$9#$b# Pero no te preocupes, buscaré sombra después de hacer mis recados.$11",
    "Cambria.Dialogue.6-10.Summer.3": "Me da pena Jupiter con este calor. No lo demuestra, pero últimamente se queda más tiempo dentro de casa.$2#$b# Quizás un paseo por la playa le haría bien.",
    "Cambria.Dialogue.6-10.Summer.4": "Abigail publicó una solicitud para un pepino superporque está aburrida...$2#$b# ¿Vas a aceptarla tú o lo hago yo?$3",
    "Cambria.Dialogue.6-10.Summer.5": "Los girasoles son de mis flores favoritas. Pero no los del valle.#$b# En Cape Starlet había unos con pétalos de un rojo intenso.",
    "Cambria.Dialogue.6-10.Fall.1": "Creo que el otoño es mi estación favorita para ir a la playa.#$b# En verano siempre está llena de gente, y la brisa marina en esta época es muy agradable.",
    "Cambria.Dialogue.6-10.Fall.2": "La mayoría de la gente prefiere ir a la playa en verano.#$b# Pero personalmente, me encantan las noches frescas de primavera o de otoño.",
    "Cambria.Dialogue.6-10.Fall.3": "Sabes, pensé que la petición de Abigail por un pepino super era rara.#$b# Pero el otro día Alex pidió un pepino de mar para ponerlo en una cadena...$2#$b# Diría que me preocupa, pero a estas alturas ya lo acepté.$3",
    "Cambria.Dialogue.6-10.Fall.4": "A pesar de su edad, a Jupiter le encanta jugar entre las hojas.#$b# Ayer salí de casa justo a tiempo para verlo asustar a Orchid al saltar de un montón de hojas.$8#$b# Espero que sus graznidos no fueran demasiado fuertes.$2",
    "Cambria.Dialogue.6-10.Fall.5": "Me gusta observar las estrellas todo el año, pero diría que en otoño lo disfruto más.#$b# Algunas de mis constelaciones favoritas son más fáciles de ver en esta época.$1",
    "Cambria.Dialogue.6-10.Winter.1": "%Cambria parece caminar más lento de lo habitual.#$b# Definitivamente, el invierno es mi estación menos favorita. La nieve se ve increíble, pero mis cicatrices odian el frío.$9#$b# Debería hibernar o algo así.$9",
    "Cambria.Dialogue.6-10.Winter.2": "Las sirenas en el mercado nocturno siempre me miran como si supieran algo que yo no.#$b# Nunca he tenido la oportunidad de preguntarles qué pasa, pero algo me dice que tampoco me lo dirían.",
    "Cambria.Dialogue.6-10.Winter.3": "¿Te gusta observar las estrellas, @? Creo que el invierno es la época más tranquila para hacerlo.#$b# Sentarte en el muelle con solo el sonido de las olas y el cielo como compañía.$1",
    "Cambria.Dialogue.6-10.Winter.4": "Orchid parece estar de mejor humor en invierno.#$b# Bueno, al menos hace menos bromas, y eso ya es una victoria.",
    "Cambria.Dialogue.6-10.Winter.5": "Me sorprende lo bueno que está el 'powdermelon', para ser honesta. El nombre es un poco engañoso, ¿no?",

    //Tattoo Stories
    "Cambria.Dialogue.Tattoo.Story.1": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Una costurera vino y pidió una línea de dos pulgadas en su dedo. Explicó que así se ahorraría tiempo buscando una cinta de medir. Bastante ingenioso, si me preguntas.",
    "Cambria.Dialogue.Tattoo.Story.2": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Un tipo que trabajaba en un gimnasio cercano vino por su primer tatuaje. Se hacía el fuerte y rudo hasta que saqué la aguja.#$b# Demuestra que todos tienen sus miedos. Y terminó siendo uno de mis mejores clientes.",
    "Cambria.Dialogue.Tattoo.Story.3": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# ¿Alguna vez has visto hermanos hacerse tatuajes a juego? He hecho más de los que puedo contar.#$b# Pero hubo una vez en que ¡un grupo de septillizos vino juntos! Mis respetos para su madre.$7",
    "Cambria.Dialogue.Tattoo.Story.4": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Si no lo has notado, no soy una persona muy social. Las conversaciones largas no son mi fuerte.#$b# La peor clienta que tuve fue la mujer más habladora que he conocido. Creo que me contó toda su vida antes de que terminara de hacer el diseño.$13",
    "Cambria.Dialogue.Tattoo.Story.5": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Una vez tuvimos que rechazar a un chico que intentó entrar con una identificación falsa. Estoy bastante segura de que era de su hermano.#$b# De todos modos, su madre terminó viniendo después para armar un berrinche enorme porque se hizo un tatuaje en otro lugar.$5",
    "Cambria.Dialogue.Tattoo.Story.6": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Los retoques son mucho más comunes que las eliminaciones, al menos en mi caso.#$b# La cantidad de nombres que cubrí con otros nombres era un poco... preocupante.$2#$b# Especialmente cuando empecé a reconocer a ciertas personas como clientes frecuentes.$3",
    "Cambria.Dialogue.Tattoo.Story.7": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Una chica de voz suave vino una vez. La reconocí de la floristería de la calle.#$b# Pensé que era su primer tatuaje, pero apenas encontramos espacio para lo que quería.#$b# Nunca juzgues un libro por su portada, y todo eso.",
    "Cambria.Dialogue.Tattoo.Story.8": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Una pareja vino un día para hacerse piezas de rompecabezas a juego. Se veían realmente felices.$8#$b# Me rompió el corazón ver a uno de ellos regresar solo después para hacerse la otra pieza y una fecha.$13",
    "Cambria.Dialogue.Tattoo.Story.9": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Hay una persona en Cape Starlet conocida por rescatar animales callejeros.$8#$b# Cada vez que uno fallecía, se tatuaba su nombre y su huella en nuestra tienda.#$b# Fue un honor ser parte de eso, de alguna manera.$1",
    "Cambria.Dialogue.Tattoo.Story.10": "¿Una historia de tatuajes? Claro, déjame pensar... ¡Oh!$12#$b# Una vez vino un anciano que solo hablaba con juegos de palabras. Juro que estaba maldito o algo así.$5#$b# Nadie más quería atenderlo, así que pasé varias sesiones con él y sus malos chistes.#$b# A veces todavía lo extraño. Espero que le esté yendo bien.",
    //Mod Related Dialogue
    "Cambria.Dialogue.Nova.1": "Ese tipo Eli me estaba mirando el otro día. Cuando le pregunté qué pasaba, solo entrecerró los ojos y se fue caminando?$10",
    "Cambria.Dialogue.Nova.2": "Ocasionalmente veo a Dylan en el muelle de la cala. Se toma su trabajo muy en serio, es admirable.",
    "Cambria.Dialogue.Nova.3": "Eli me preguntó si sabía sobre los junimos y pareció sorprendido cuando le dije que sí.#$b# Verlos es una cosa, pero la mayoría de la gente al menos ha oído hablar de ellos, ¿verdad?",
    "Cambria.Dialogue.Nova.4": "Dylan estaba en mi sueño anoche. Parecía que nos estábamos mirando en una fosa marina profunda.#$b# Cuando abrió la boca para hablar, me desperté. ¿Debería hablar con él sobre eso?$2",
    "Cambria.Dialogue.Nova.5": "Orchid se niega a acercarse a la casa de Eli y Dylan. Se ve espeluznante, pero ella también.#$b# Aunque a veces escucho ruidos extraños salir de ahí.",
    "Cambria.Dialogue.Nova.6": "Si encuentras a Eli, ¿le puedes dar un golpe por mí?$5#$b# Lo atrapé de nuevo en el techo de mi garaje, ese mocoso. Nada que unos golpes con una escoba no puedan arreglar.$5",
    "Cambria.Dialogue.Nova.7": "Veo a Eli merodeando en el bosque detrás de mi casa de vez en cuando.#$b# ¿Da miedo? Nah, sé que está buscando algún críptido. Orchid, en cambio, se altera bastante.",
    "Cambria.Dialogue.Nova.8": "¿Alguna vez te conté cómo Eli pensó que era ciega la primera vez que nos conocimos?#$b# Supongo que los ojos grises no son tan comunes, aunque prefiero un error social a que piense que soy un críptido.",
    "Cambria.Dialogue.Nova.9": "Soot es una cosita muy linda. No le digas a Dylan, pero la última 'tormenta de polvo' fue mi culpa.$3#$b# ¡En mi defensa, no sabía que los espíritus de polvo podían estornudar!$7",
    "Cambria.Dialogue.Nova.10": "Cada vez que estoy en la casa Moray, tengo que admirar la pecera de Dylan.#$b# ¡Es un pequeño ecosistema justo en su hogar! Si tuviera espacio, consideraría tener una propia.$1",
    "Cambria.Dialogue.Mads.1": "¿Has visto a Sig por ahí? Lo invité a probar un nuevo lote de hidromiel que hice.#$b# Sin cafeína esta vez, para su delicado paladar.$1",
    "Cambria.Dialogue.Mads.2": "Sig y yo no hablamos mucho cuando pasamos el rato juntos. Realmente no hace falta.#$b# Normalmente nos sentamos en el acantilado con una botella de hidromiel y solo miramos las olas.#$b# Es algo relajante después de lo que hemos pasado.",
    "Cambria.Dialogue.Mads.3": "Júpiter ya no sale mucho de la cala ahora que está envejeciendo.#$b# La última vez que tuve que perseguirlo, ¡logró tumbar a Sig de todas las personas!$7#$b# O lo hizo a propósito. Quién sabe.",
    "Cambria.Dialogue.Mads.4": "No es raro que tenga que salir a buscar a Orchid cuando está de humor para hacer bromas.#$b# El otro día la encontré en un concurso de miradas con Sig. Pobre tipo, se le estaban poniendo los ojos rojos.$2",
    "Cambria.Dialogue.Mads.5": "Sig me ayuda en la cala de vez en cuando. Tener una mano extra es genial, ya que mover los barriles por mi cuenta lleva tiempo.#$b# Aunque curiosamente, solo acepta hidromiel como pago.",
    "Cambria.Dialogue.Mads.6": "A este ritmo, creo que Júpiter se está convirtiendo en el perro de apoyo de Sig por asociación.$1#$b# Cuando viene en sus días malos, mi viejo amigo actúa como si hubiera sido entrenado ayer.#$b# Sig no lo admite, pero creo que le ayuda.",
    "Cambria.Dialogue.Mads.7": "%Cambria se ríe para sí misma.#$b# Jaja, oh, hola, @. Perdón, acabo de ganar una apuesta contra Teren y Sig. Dijeron que no podría levantar a ese chico grande. Bueno...#$b# Digamos que las caras que pusieron fueron invaluables.$1",
    "Cambria.Dialogue.Mads.8": "¿Has visto a Sig, @? ¿No? Ah...$2#$b# Estaba más callado de lo habitual y quería ver cómo estaba.",
    "Cambria.Dialogue.Mads.9": "%Cambria murmura para sí misma.#$b# Ese maldito... ¡Oh! @, no te vi. Sig me robó la lista de recados para 'evitar que me lastime'.#$b# Da igual, haré estos quehaceres de todas formas.$5",
    "Cambria.Dialogue.Mads.10": "Sig ha progresado mucho con la apicultura desde que buscó consejos.$1#$b# Está muy dedicado a sus pequeñas amigas, es admirable. Ojalá se diera más crédito.$2#$b# Aunque en eso nos parecemos bastante.",
    "Cambria.Dialogue.Dodo.1": "%Cambria bosteza mientras te acercas a ella.#$b# Oh, hola, perdón. Rodney hizo otra de sus lecturas de poesía nocturnas.$5#$b# Pensarías que no lo escucharía desde la cala, pero su voz resuena más de lo que esperaba.",
    "Cambria.Dialogue.Dodo.2": "Rodney apareció en mi propiedad más temprano diciendo algo sobre ser un 'coach de vida'.$5#$b# No duró mucho antes de que Orchid lo ahuyentara. Hoy le daré chispas de maíz extra.$1",
    "Cambria.Dialogue.Dodo.3": "La última vez que Rodney me ofreció su autógrafo, le dije que lo aceptaría si me ganaba en un pulso.#$b# ¡Es sorprendentemente fuerte! Lástima para él que yo soy más fuerte, incluso después del accidente.$1",
    "Cambria.Dialogue.Dodo.4": "A veces desearía no ver tan bien en la oscuridad.$2#$b# Anoche pasé por la casa de Rodney en el MOMENTO EQUIVOCADO y vi más de lo que quería en la ventana.$2",
    "Cambria.Dialogue.Dodo.5": "Nunca he sido mucho de leer, especialmente ciencia ficción. He oído hablar de los libros de Rodney, pero actuó como si fuera una mocosa solo porque no sabía quién era.#$b# Vaya ego.$5",
    "Cambria.Dialogue.Axell.1": "Los shadowfolk son una de las entidades más complejas de la zona.#$b# Los que están en lo profundo de las minas son violentos... más o menos. Pero luego tienes a Sen y Krobus, lo que hace difícil atacarlos.",
    "Cambria.Dialogue.Axell.2": "¡Sen me tejió una bufanda el otro día!$8#$b# Es cálida y me recuerda a... bueno, olvídalo.$3",
    "Cambria.Dialogue.Axell.3": "Jupiter empezó a ladrarle a Sen anoche cuando lo encontró hurgando en mi basura.#$b# Después de calmar a mi chico, le ofrecí algunas sobras a Sen. Al menos los shadowfolk aprecian mi cocina.",
    "Cambria.Dialogue.Axell.4": "Últimamente evito las partes más profundas de las minas.#$b# A veces pesco en el estanque de lava, pero trato de evitar a la gente de Sen tanto como puedo.",
    "Cambria.Dialogue.Axell.5": "A veces, cuando toco la guitarra por la noche en el cementerio, Sen se acerca y se sienta conmigo.#$b# No hablamos, pero aprecio la compañía en silencio.",
    "Cambria.Dialogue.Desty.1": "Mateo y yo crecimos juntos, más o menos. Nos cruzamos de vez en cuando, pero estaban ocupados en la biblioteca.#$b# Nunca supe qué pasó con ellos después de que me fui.",
    "Cambria.Dialogue.Desty.2": "Mateo se ofreció a acompañarme la última vez que fui a las minas.#$b# Lo consideré, pero mis viajes no suelen ser muy emocionantes.",
    "Cambria.Dialogue.Desty.3": "¿Las noches de juegos? He ido algunas veces.#$b# No muy seguido, ya que suelen durar bastante y me cuesta quedarme quieta tanto tiempo.",
    "Cambria.Dialogue.Desty.4": "A veces veo unos ojos verdes observándome desde el bosque. Al principio pensé que era Orchid, pero sus ojos son... ¿Eh?$10",
    "Cambria.Dialogue.Desty.5": "Duele ver cómo las corporaciones destruyen la naturaleza solo para ahorrar dinero.#$b# Ojalá pudiéramos hacer más como individuos. Cape Starlet tiene el mismo problema.$2",
    "Cambria.Dialogue.Bagi.1": "Atrapé a Orchid molestando a la serpiente rosa de Nora el otro día. Pequeña fastidiosa, pero no hubo daño.$5#$b# No puedo decir lo mismo si Jupiter la hubiera atrapado.$13",
    "Cambria.Dialogue.Bagi.2": "Al principio me sentí mal porque llamaran 'Stupid' a Stupid. Luego miré sus ojos y no vi nada ahí.#$b# Como un juego de ping-pong en cámara lenta, pero aún así seguía fallando la pelota.",
    "Cambria.Dialogue.Bagi.3": "Sabía que Harvey y Gus pedían mucho café, pero luego recibí el primer pedido de Nora.$7#$b# Creo que voy a tener que plantar más arbustos de café solo para seguir el ritmo.",
    "Cambria.Dialogue.Bagi.4": "¡De alguna manera Orchid se las arregló para robar uno de los audífonos de Nora!$7#$b# Me sentí tan mal después de devolverlo que no le he cobrado el café desde entonces.$2",
    "Cambria.Dialogue.Bagi.5": "Jupiter casi derriba a Nora el otro día mientras corría.$2#$b# Llevaba una pila enorme de libros, menos mal que no se cayeron por todas partes.",

    //Gift Taste Reactions
    "gifts.Cambria.love": "¿En serio, @? Esto debió haber sido difícil de conseguir. ¿Estás seguro de que puedo quedármelo?$8^¿En serio, @? Esto debió haber sido difícil de conseguir. ¿Estás segura de que puedo quedármelo?$8#$b# Gracias, esto significa mucho para mí.$1",
    "gifts.Cambria.like": "¡Oh, me gustan estos! Muchas gracias.$1",
    "gifts.Cambria.dislike": "No soy muy fan, pero aprecio el gesto.",
    "gifts.Cambria.hate": "Amigo, si hice algo mal, podrías habérmelo dicho.#$b# ¿Qué se supone que es esto?$5",
    "gifts.Cambria.neutral": "Gracias por pensar en mí.",

    //Winter Star
    "gifts.Cambria.WinterStar.Starfruit": "¡Oh, wow! ¿Guardaste esto desde el verano, @? ¡Muchas gracias!$8",
    "gifts.Cambria.WinterStar.SpicyEel": "Esto va a ser perfecto para combatir el frío. Eres el mejor, @.$1",
    "gifts.Cambria.WinterStar.SquidInkRavioli": "¡Ja! Nada dice 'Estrella Invernal' como una boca manchada de tinta de calamar. ¿Quieres compartir?$1",

    //Birthday
    "gifts.Cambria.GiftReaction.Loved.Birthday": "¡Oh, wow! ¡Y en mi cumpleaños, nada menos! Eres muy astuto, @. ¡Muchas gracias!$8",
    "gifts.Cambria.GiftReaction.Liked.Birthday": "Gracias, aprecio que hayas pensado en mí.$1",
    "gifts.Cambria.GiftReaction.Disliked.Birthday": "Oh... eh, gracias, supongo.$10",
    "gifts.Cambria.GiftReaction.Hated.Birthday": "¿Hablas en serio? ¿Y en mi cumpleaños, además? ¿Qué demonios, @?$5",
    "gifts.Cambria.GiftReaction.Neutral.Birthday": "Ah, gracias. Está bonito.",

    //Loves
    "gifts.Cambria.GiftReaction.TripleEspresso": "¡Oh, sí! ¡Muchas gracias! Ahora podré oler los colores.$8",
    "gifts.Cambria.GiftReaction.Starfruit": "Oooh, se ve casi tan bien como los que tengo en mi invernadero.#$b# Es broma, es broma. Gracias por el regalo.$1",
    "gifts.Cambria.GiftReaction.SpicyEel": "Eres una estrella de rock, @. No puedo esperar para despejar mis senos nasales con esto.$1",
    "gifts.Cambria.GiftReaction.SquidInkRavioli": "No es picante, pero me encanta este ravioli igual. ¿Crees que mi boca se pondrá del color de las plumas de Orchid?",
    "gifts.Cambria.GiftReaction.StarShards": "¿Cómo supiste que me encantan estos? Muchas gracias. ¡Lo agregaré a mi colección!$1",
    "gifts.Cambria.GiftReaction.VoidSalmon": "Dejé de aventurarme al pantano cuando la bruja se mudó allí cuando era niña.#$b# El sashimi va a saber increíble. Puedes tomar un poco si quieres.$1",
    "gifts.Cambria.GiftReaction.DinoMayo": "¡Vaya! ¡No he comido esto en años! Mi abuelo lo ponía en tostadas con huevos de avestruz cuando era niño.$8#$b# Gracias por darme un viaje al pasado.$1",
    "gifts.Cambria.GiftReaction.MysticSyrup": "¿En serio me estás dando esto? ¡Gracias, @!$1#$b# Será perfecto para mis huevos benedictinos de vacío. Oooh, o panqueques de vacío. ¿Hm? ¿Qué es esa cara?$10",
    "gifts.Cambria.GiftReaction.MysticTreeSeed": "¿Te salen de las orejas o qué? No me imagino otra razón para regalar algo tan raro.$10#$b# Muchas gracias, @.$2",
    "gifts.Cambria.GiftReaction.CaveJelly": "Mi reserva justo estaba bajando. Gracias por reponerla, @.$1#$b# Me encanta comer esto con anguila frita y fruta estelar.",
    "gifts.Cambria.GiftReaction.Book_Void": "Puede que no luche contra monstruos seguido, pero me encanta leer sobre ellos. Esto será una gran adición a mi colección, ¡gracias!$1",
    "gifts.Cambria.GiftReaction.EnD.DragonEye": "¡Oh, me encantan estos! Deberías haber visto la cara de Eli cuando me comí cinco seguidos.$8#$b# Tal vez vaya a buscarlo, ¡gracias!$1",
    "gifts.Cambria.GiftReaction.HxW.Whiskey": "Nada como un vaso de whisky con hielo en un día lluvioso. Gracias, @, le daré un buen uso a esta botella.$1",
    "gifts.Cambria.GiftReaction.Cornucopia.Durian": "¿Alguna vez los has probado con café? Te prometo que no es tan raro como suena. Sí, incluso viniendo de mí.#$b# De todos modos, ¡gracias!$1",
    "gifts.Cambria.GiftReaction.RSV.LavaLily": "Son como calentadores de manos naturales. Son geniales para llevar en largas caminatas de recados.#$b# También son muy hermosas, por supuesto. Gracias, @.$1",
    "gifts.Cambria.GiftReaction.RSV.MistbloomSyrup": "Gracias, me estaba quedando sin existencias. Es excelente para las náuseas y hace maravillas con mi fatiga.$1",
    "gifts.Cambria.GiftReaction.SVE.Elixir": "¿Me estás dando esto? ¿Y te costó CUÁNTO?? ¡Por Yoba, @, muchísimas gracias!$8#$b# Definitivamente me ayudará en mis viajes a la mina.$1",
    "gifts.Cambria.GiftReaction.SVE.GreenMushroom": "¿Me estás dando esto?? ¡Por Yoba, @, muchísimas gracias!$8#$b# Son muy difíciles de conseguir, y las Tierras Altas me quedan bastante lejos.$1",
    "gifts.Cambria.GiftReaction.SVE.MonsterFruit.1": "El sabor de estos es interesante. He oído que es lo más cercano que alguien puede estar de probar una fruta estelar.#$b# La última vez que comí uno, sabía a whisky barato. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.SVE.MonsterFruit.2": "El sabor de estos es interesante. He oído que es lo más cercano que alguien puede estar de probar una fruta estelar.#$b# La última vez que comí uno, sabía a espresso tibio. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.SVE.MonsterFruit.3": "El sabor de estos es interesante. He oído que es lo más cercano que alguien puede estar de probar una fruta estelar.#$b# La última vez que comí uno, sabía a fruta estelar sin madurar. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.SVE.MonsterFruit.4": "El sabor de estos es interesante. He oído que es lo más cercano que alguien puede estar de probar una fruta estelar.#$b# La última vez que comí uno, sabía a anguila picante de un día. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.SVE.MonsterFruit.5": "El sabor de estos es interesante. He oído que es lo más cercano que alguien puede estar de probar una fruta estelar.#$b# La última vez que comí uno, sabía a ravioli de tinta de calamar de un día. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.SVE.PoisonMushroom": "Oh, estos saben geniales con bayas venenosas y arroz. Tal vez debería prepararte algo algún día, en agradecimiento.$1",
    "gifts.Cambria.GiftReaction.SVE.VoidDelight": "No solo atrapaste una anguila sombría, sino que además la cocinaste sin lastimarte. Me impresionas, @. Muchas gracias.$1",
    "gifts.Cambria.GiftReaction.SVE.VoidEel": "Estas son más difíciles de atrapar que los salmones sombríos, ¡me impresionas! ¿La bruja no te espantó, verdad?$1#$b# Ya sé qué cenaré, ¡gracias!$1",
    "gifts.Cambria.GiftReaction.SVE.VoidSalmonSushi": "No solo atrapaste un salmón sombrío, sino que además lo preparaste sin lastimarte. Me impresionas, @. Muchas gracias.$1",
    "gifts.Cambria.GiftReaction.Spice": "Justo estaba pensando en pedir más para mi especiero. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.LovedFlowers": "¡Vaya, no sabía que esto podía crecer en el suelo del valle! Tal vez debería intentarlo.#$b# Me encantan, ¡gracias!$8",

    //Likes
    "gifts.Cambria.GiftReaction.StrangeBun": "Estos van genial con mayonesa de vacío. Gracias.$1",
    "gifts.Cambria.GiftReaction.VoidEgg": "Oh, Orchid me da un suministro constante, pero nunca diré que no a más. Gracias.$1",
    "gifts.Cambria.GiftReaction.Coffee": "¿Parezco alguien que no necesita cafeína? La respuesta es sí, siempre. ¡Gracias!$1",
    "gifts.Cambria.GiftReaction.Mead": "A veces es agradable beber algo que otra persona preparó. Lo aprecio, @.$1",
    "gifts.Cambria.GiftReaction.Book_Bombs": "¿Esto es una medida preventiva? Gracias, pero me aseguraré de no ir a la mina contigo. Es broma, es broma.$1",
    "gifts.Cambria.GiftReaction.Book_Marlon": "¿Por qué demonios- @, aprecio el gesto pero realmente no lo necesito.#$b# Pero si insistes, no diré que no. ¡Gracias!$1",
    "gifts.Cambria.GiftReaction.GoldenAnimalCracker": "Gracias. Se los doy a Orchid de vez en cuando, pero nunca parece afectar sus huevos.",
    "gifts.Cambria.GiftReaction.WWWA.GenuineAutograph": "Eh, gracias, creo. Sé que es un autógrafo, pero también es la cara de mi vecino, así que...$10#$b# Tal vez Orchid pueda usarlo en su nido.",
    "gifts.Cambria.GiftReaction.EnD.SanguineHeart": "Metal Y vegano. Esto será un bocadillo hardcore, ¡muchas gracias!$1",
    "gifts.Cambria.GiftReaction.EnD.Bluffshroom": "Oh, mira, soy yo en forma de hongo, ja. Gracias, @.$1",
    "gifts.Cambria.GiftReaction.SVE.RedBaneberry": "Ooh, saben genial con champiñones y arroz. Tal vez debería prepararte algo algún día, en agradecimiento.$1",
    "gifts.Cambria.GiftReaction.SVE.Void": "Gracias, @. No sé por qué, pero a Orchid le gustan estos. Así que realmente lo estoy aceptando en su nombre.$1",
    "gifts.Cambria.GiftReaction.LikedFlowers": "Justo estaba pensando en pedir más para mi especiero. ¡Gracias, @!$1",
    "gifts.Cambria.GiftReaction.Alcohol": "Gracias, @, le daré un buen uso a esta botella.$1",
    //Neutral
    "gifts.Cambria.GiftReaction.WWWA.Autograph": "Eh, gracias, creo. Veo estos flotando en el agua todo el tiempo, así que...#$b# Tal vez Orchid pueda usarlo en su nido.",
    //Dislakes
    "gifts.Cambria.GiftReaction.Rabbit'sFoot": "¿Eso es... uh, eso es un ugh de mi parte, amigo.$5#$b# ¿El conejo está bien? Tal vez Jacob pueda conseguir una prótesis.$2",
    "gifts.Cambria.GiftReaction.Chowder": "Tú... te das cuenta de que esto está hecho con leche, ¿verdad? ¿Nunca te dije que soy alérgico? Mi culpa, pero aún así, no gracias.$2",
    "gifts.Cambria.GiftReaction.LobsterBisque": "Siempre quise probar esto pero... tiene leche, ¿verdad?$2#$b# Lamentablemente, no solo soy intolerante, sino muy alérgico. Lo siento.$13",
    "gifts.Cambria.GiftReaction.ShrimpCocktail": "Blegh, ya puedo olerlo. Lo siento, pero no soy fan.$5",
    "gifts.Cambria.GiftReaction.VoidGhostPendant": "No sé si lo sabes, pero esto es para proponerle matrimonio a los shadowfolk.#$b# Aprecio la oferta, pero ni soy shadowfolk ni estoy interesado en ti de esa manera. Gracias.$2",
    "gifts.Cambria.GiftReaction.MangoStickyRice": "Sí, claro, amigo. Déjame simplemente comer esta comida hecha con algo a lo que soy alérgico.$5",
    "gifts.Cambria.GiftReaction.Eggs": "Ah, gracias, @.#$b# ¿Hm? Oh, no soy muy fan de los huevos normales. Demasiado insípidos para mí.",
    "gifts.Cambria.GiftReaction.Book_Friendship": "Buen chiste, @. Lástima que no me dé risa. Sé que soy antisocial, ¿ok? Echando sal en la herida y todo eso.$5",
    "gifts.Cambria.GiftReaction.StardropTea": "Sabes, siempre escucho cosas increíbles sobre este té. Pero simplemente me sabe artificial.#$b# Tal vez nada supere el sabor de la verdadera comida sombría. De todas formas, aprecio el detalle.$1",
    "gifts.Cambria.GiftReaction.Raisins": "Uhh, creo que tus uvas están viejas, @.$2",
    "gifts.Cambria.GiftReaction.SVE.SportsDrink": "Oh wow, electrolitos, es lo que las plantas necesitan. Yo no, puedes quedártelo.",

    //Hates
    "gifts.Cambria.GiftReaction.Milk": "Lo siento, @. Aprecio el gesto, pero mis intestinos no.$2",
    "gifts.Cambria.GiftReaction.Dairy": "Lo siento, @. Aprecio el gesto, pero mis intestinos no.$2",
    "gifts.Cambria.GiftReaction.Mango": "¡Oh! Por favor, mantén eso lejos de mí. Soy muy alérgico.$7#$b# Ahora necesito ir a lavarme las manos. Gracias por el detalle, de todas formas.$13",
    "gifts.Cambria.GiftReaction.Joja": "Eh. No. No quiero tener nada que ver con ese monopolio corporativo. Gracias.$5",
    "gifts.Cambria.GiftReaction.Medicine": "¿Qué? Uh... ¿por qué me das esto? Por favor, no...$13",
    "gifts.Cambria.GiftReaction.ButterflyPowder": "Hombre, si no te gusta Júpiter, solo dímelo. No es que importe de todas formas.#$b# Piérdete, @. En serio.$5",

    //Orchid Antisocial Dialogue
    "VoidOrchid.Dialogue.Random.1": "Orchid está pensando en nachos.$4",
    "VoidOrchid.Dialogue.Random.2": "Orchid está considerando venderte por un nacho.$5#$b# O está planeando tu desaparición.$6",
    "VoidOrchid.Dialogue.Random.3": "Orchid está cacareando al cielo. Sientes el inconfundible llamado de lo sombrío.$3",
    "VoidOrchid.Dialogue.Random.4": "Orchid te está mirando con ojos grandes.$2#$b# Tan lindo como parece, te preocupa que esté tramando algo.$2",
    "VoidOrchid.Dialogue.Random.5": "Orchid está pavoneándose con una sonrisa.$1#$b# Es inquietantemente ominoso.$1",
    "VoidOrchid.Dialogue.Random.6": "Orchid está actuando como una gallina normal.#$b# Espera hacerte bajar la guardia.",

    //Event Dialogue
    //O Hearts - Introduction
    "MGC.Cambria.Intro.01": "Buenos días, @. Espero que te estés adaptando bien.$1",
    "MGC.Cambria.Intro.02": "Oh, estoy revisando el tablón de peticiones. Pueden llegar a ser bastante extrañas.#$b# Justo el otro día, Clint pidió un rábano silvestre para frotarlo en su codo.$12#$b# Aprendí a dejar de hacer preguntas.$3",
    "MGC.Cambria.Intro.03": "Voy a entregar esta. Nos vemos, @.",
    "MGC.Cambria.Intro.04": "...$9",
    "MGC.Cambria.Intro.05": "No te preocupes... Estoy bien.$11",

    //1/2 Heart - Gifts Item to Player
    "MGC.Cambria.Help.01": "¿Dónde lo puse?$2",
    "MGC.Cambria.Help.02": "¿En serio lo dejé con Ga-$5",
    "MGC.Cambria.Help.03": "¡Oh, @! Es bueno verte.$8#$b# ¿Qué estoy haciendo? Estoy tratando de encontrar algo en una de estas cajas...$2",
    "MGC.Cambria.Help.04": "De hecho, ya que estás aquí, tengo una pregunta para ti.",
    "MGC.Cambria.Help.question": "¿Qué planes tienes para tu terreno?",
    "MGC.Cambria.Help.option1": "Me estoy enfocando primero en recolectar materiales.",
    "MGC.Cambria.Help.option2": "¡Quiero cubrir mi terreno con la mayor cantidad de cultivos posible!",
    "MGC.Cambria.Help.option3": "No lo he pensado mucho. Hay tantas opciones.",
    "MGC.Cambria.Help.answer1": "Eso es comprensible, creo que tengo algunos materiales extra por aquí.#$b# ¡Aquí tienes!$1 [330 382][330 382][330 382]",
    "MGC.Cambria.Help.answer2": "Los cultivos siempre son un buen comienzo, especialmente los que vuelven a crecer.#$b# Aquí, esto te será útil. [599 599 599 599 599 621 621 621 645]",
    "MGC.Cambria.Help.answer3": "Está bien, definitivamente toma tiempo hacer crecer una granja.#$b# Toma esto, debería ayudarte a comenzar.$1 [(O)MysteryBox][(O)MysteryBox][(O)MysteryBox]",
    "MGC.Cambria.Help.05": "No te preocupes, ya no lo necesito. No podría manejar todos estos suministros aunque quisiera.#$b# Si encuentro algo más útil, te lo haré saber.",

    //2 hearts - Camie chases Orchid
    "MGC.Cambria.Orchid.01": "¡Bawk!$2",
    "MGC.Cambria.Orchid.02": "¡Orchid, regresa aquí!$7",
    "MGC.Cambria.Orchid.03": "¡$6",
    "MGC.Cambria.Orchid.04": "Orchid, maldición--$5",
    "MGC.Cambria.Orchid.05": "-jadeo- Ugh...",
    "MGC.Cambria.Orchid.06": "Yo-- *jadeo* Estoy bien. He estado persiguiendo a esa condenada gallina por todas partes.$9#$b# Espero que no te haya causado demasiados problemas.",
    "MGC.Cambria.Orchid.07": "Vamos, peligro andante, llevémoste a casa.$5",
    "MGC.Cambria.Orchid.08": "Coo...",
    "MGC.Cambria.Orchid.09": "¿De dónde sacaste ese cuchillo?",
    "MGC.Cambria.Orchid.10": "@.",
    "MGC.Cambria.Orchid.11": "Sé amable con Cambria, sabré si no lo eres.$7#$b# Rasmodius no es el único con ojos en todo el valle.$5",

    //4 Hearts Part 1 - Evelyn
    "MGC.Cambria.EvelynTalk.01": "Hola, querida.",
    "MGC.Cambria.EvelynTalk.02": "Hola, abuelita. Te traje las hojas de té que pediste.$1",
    "MGC.Cambria.EvelynTalk.03": "Gracias, Camie. Espero que no haya sido mucha molestia.$1",
    "MGC.Cambria.EvelynTalk.04": "No, Caroline estaba--",
    "MGC.Cambria.EvelynTalk.05": "Ahora siéntate, las galletas están casi listas.",
    "MGC.Cambria.EvelynTalk.06": "Necesito ir a dejar una entrega a Marnie, no puedo--$13",
    "MGC.Cambria.EvelynTalk.07": "Vamos, seguro que puedes tomarte unos minutos para un bocadillo.$2",
    "MGC.Cambria.EvelynTalk.08": "Está bien...",
    "MGC.Cambria.EvelynTalk.09": "Gracias, querida. Alex llevó a George a una cita, así que me vendría bien algo de compañía.",
    "MGC.Cambria.EvelynTalk.10": "Me alegra que estés de vuelta en el valle, cariño. No es lo mismo sin un Castlegrove por aquí.$1",
    "MGC.Cambria.EvelynTalk.11": "Si tú lo dices.",
    "MGC.Cambria.EvelynTalk.12": "Tú conociste a mis abuelos, ¿verdad...? ¿Cómo eran?",
    "MGC.Cambria.EvelynTalk.13": "Camie, sabes que ya me lo has preguntado antes. Eran personas maravillosas.$2#$b# Allen y Claudia eran pilares de la comunidad incluso antes de que llegaras de pequeña--",
    "MGC.Cambria.EvelynTalk.14": "Eh...",
    "MGC.Cambria.EvelynTalk.15": "¿Pequeña? Pensé que llegué siendo un recién nacido...$10",
    "MGC.Cambria.EvelynTalk.16": "¡Sí! ¡Eso es! Oh, fue hace tres décadas, querida, seguro que lo recordé mal.$1",
    "MGC.Cambria.EvelynTalk.17": "Pero tú acabas de...",
    "MGC.Cambria.EvelynTalk.18": "Ahora come, cariño, antes de que las galletas se enfríen.#$b# Te daré las que sobren como un regalo, ¿de acuerdo?",

    //4 hearts Part 2 - Grandparents
    "MGC.Cambria.OpenUp.01": "Hey, @. ¿Qué haces por aquí tan lejos?",
    "MGC.Cambria.OpenUp.02": "¿La canción que estaba tocando? Supongo que la música debe haberse escuchado a lo lejos.",
    "MGC.Cambria.OpenUp.03": "Hoy me siento muy... nostálgico. Pensando en el pasado y todo eso.$2",
    "MGC.Cambria.OpenUp.question1": "Dime, ",
    "MGC.Cambria.OpenUp.question2": ", ¿sabes mucho sobre tus abuelos?",
    "MGC.Cambria.OpenUp.option1": "Recuerdo jugar mucho con el abuelo cuando era pequeño.",
    "MGC.Cambria.OpenUp.option2": "No hablaban mucho de sí mismos cuando yo era niño.",
    "MGC.Cambria.OpenUp.option3": "Ambos fallecieron antes de que pudiera conocerlos bien.",
    "MGC.Cambria.OpenUp.answer1": "Eso debió dejarte recuerdos muy bonitos.",
    "MGC.Cambria.OpenUp.answer2": "Me identifico mucho con eso.$2",
    "MGC.Cambria.OpenUp.answer3": "Lamento escuchar eso.$2",
    "MGC.Cambria.OpenUp.05": "A mí me criaron los míos, pero aparte de sus historias fantásticas, no sé casi nada sobre ellos.",
    "MGC.Cambria.OpenUp.06": "Se siente aislante, ¿sabes? Como si todos supieran más sobre mi familia que yo.$2",
    "MGC.Cambria.OpenUp.07": "Por eso, cuando fallecieron, me fui. Me mudé y aproveché la oportunidad de ser mi propia persona.$3",
    "MGC.Cambria.OpenUp.08": "¿Por qué volví? Bueno... Nunca lo planeé. Pero la vida, eh, encuentra la manera.$2",
    "MGC.Cambria.OpenUp.09": "Perdón por abrirme contigo de repente, @.#$b# Pero gracias por venir. Es agradable hablar de esto con alguien.",
    "MGC.Cambria.OpenUp.10": "Ven, déjame tocarte esa canción de antes.$1",

    //6 Hearts Part 1 - Mismailed Letter
    "MGC.Cambria.Letter.01": "@? ¿Por qué tanta prisa?$12",
    "MGC.Cambria.Letter.02": "¿Una carta? ¿Para mí?$10",
    "MGC.Cambria.Letter.03": "Yo... ugh, maldición. Por supuesto que tenía que llegar a esto.$5",
    "MGC.Cambria.Letter.04": "Hey, @. ¿Puedes hacerme compañía en el muelle?$3",
    "MGC.Cambria.Letter.05": "Probablemente te estés preguntando quién es Gabriel.$0",
    "MGC.Cambria.Letter.06": "Supongo que debería empezar desde el principio. Cuando me fui a Cape Starlet.$2",
    "MGC.Cambria.Letter.07": "Cape Starlet es una ciudad portuaria al oeste. De adolescente, llegué a un acuerdo con una tienda de tatuajes allí y me convertí en aprendiz.",
    "MGC.Cambria.Letter.08": "Años después conocí a Gabriel, bueno, Gabe. Nos hicimos compañeros de cuarto y prosperamos en la ciudad.#$b# Fue también cuando conocí a Darien y Dolly... eh, mejor sigo con la historia...$2",
    "MGC.Cambria.Letter.09": "Hubo un accidente.#$b# Iba en mi motocicleta. Honestamente, tuve suerte de sobrevivir.$2",
    "MGC.Cambria.Letter.10": "Perdí mucho aquel día. Desde movilidad hasta confianza en mí mismo.$2#$b# La recuperación fue casi peor que el accidente en sí. Perdí la estabilidad en las manos que necesitaba para ser tatuador.$2#$b# Nunca volveré a ser como antes.$0",
    "MGC.Cambria.Letter.11": "Ahora lo he aceptado, pero en su momento me llevó a una espiral mental. Me volví autodestructivo y me saboteaba a mí mismo.$2#$b# Hubo un punto en el que pensé que recuperarme era inútil porque nunca volvería a ser el mismo.$5",
    "MGC.Cambria.Letter.12": "Pero Gabe estuvo ahí para mí todo el tiempo.#$b# Tanto él como Rin sacrificaron mucho para cuidarme.$2#$b# Por eso nos escribimos constantemente. Seguro que has visto los dibujos infantiles por toda mi casa.$1",
    "MGC.Cambria.Letter.question": "Han querido visitarme desde que volví al valle, pero...",
    "MGC.Cambria.Letter.option1": "Tienes miedo de que te vean así.",
    "MGC.Cambria.Letter.option2": "Abrazar a Cambria",
    "MGC.Cambria.Letter.option3": "Escuchar en silencio",
    "MGC.Cambria.Letter.answer1": "Maldición, ¿soy realmente tan fácil de leer?$3",
    "MGC.Cambria.Letter.answer2": "¡¡¡!!!$7#$b# @... Gracias. Necesitaba eso.$3",
    "MGC.Cambria.Letter.answer3": "Gracias por escucharme, @.",
    "MGC.Cambria.Letter.13": "Para ser sincero, me sorprende que no haya amenazado con venir antes.#$b# Incluso en la ciudad, él y Rin siempre tenían que darme amor duro por mi propio bien.$3",
    "MGC.Cambria.Letter.14": "Voy a responderle al menos. Gracias por tomarte el tiempo de estar conmigo, @.$8#$b# Aprecio mucho nuestra amistad.$1#$b# ¡Oh! Y antes de que lo olvide, 'Castle' es el apodo que me dieron. Si quieres, puedes llamarme así también.$1",

    //10 hearts - Twilight Ocean
    "MGC.Cambria.Twilight.01": "¡Oh, @! No esperaba a nadie a esta hora del día. Estaba cuidando mis plantas de café.$12",
    "MGC.Cambria.Twilight.02": "No me mires así.$5#$b# Aunque probablemente nunca me has visto cuidarlas antes.",
    "MGC.Cambria.Twilight.03": "Si no lo has notado, el tamaño real del campo es mucho más grande por dentro.$1#$b# He perdido a Júpiter ahí un par de veces.$3",
    "MGC.Cambria.Twilight.04": "Ya que estás aquí...",
    "MGC.Cambria.Twilight.05": "¿Te importaría ayudarme a revisar las colmenas? Es más rápido con otra pareja de manos.$1",
    "MGC.Cambria.Twilight.06": "¿Eh? Por supuesto que no hay colmenas extra. No digas tonterías.$10",
    "MGC.Cambria.Twilight.07": "Ahora vamos.",
    "MGC.Cambria.Twilight.08": "El Mar de Gemas es realmente hermoso a esta hora, ¿no crees?$1",
    "MGC.Cambria.Twilight.09": "Cuando regresé, no estaba segura de cómo me adaptaría en comparación con la ciudad.#$b# Viví en Cape Starlet tanto tiempo que casi olvidé cómo era el valle.",
    "MGC.Cambria.Twilight.10": "Al principio fue difícil, por supuesto. Especialmente después de dejar a mi familia atrás en nombre de la recuperación.$13#$b# Para ser honesto, no pasa un día sin que los extrañe.$2",
    "MGC.Cambria.Twilight.11": "Dicho esto...",
    "MGC.Cambria.Twilight.12": "Has sido un gran apoyo en todo esto, @.$1#$b# No sé si lo he dicho lo suficiente, pero gracias por no solo ser mi amigo, sino también por escucharme cuando lo necesitaba.$1^No sé si lo he dicho lo suficiente, pero gracias por no solo ser mi amiga, sino también por escucharme cuando lo necesitaba.$1#$b# Sé que estás ocupado con %farm, así que aprecio que te tomes el tiempo de buscarme.$1",
    "MGC.Cambria.Twilight.13": "Bueno, eso es todo con las colmenas. Vamos a llevar esto a la casa, ¿sí?",
    "MGC.Cambria.Twilight.14": "Gracias de nuevo, @. Por ayudar y por ser un buen amigo.#$b# ¿Qué te parece si te pago con una comida caliente? Te prometo que está libre de vacío.$1",
    "MGC.Cambria.Twilight.15": "Gracias, @. Por ser el amigo que Cambria necesitaba desesperadamente.$1",
    "MGC.Cambria.Twilight.16": "Lleva una vida aislada, tanto de su familia como de su historia.#$b# Si las circunstancias fueran mejores, le explicaría todo. Se lo mostraría todo.",
    "MGC.Cambria.Twilight.17": "Pero me siento cada vez más cansado. Algún día tendré la oportunidad de revelárselo todo.$5",
    "MGC.Cambria.Twilight.18": "Algún día...",
    "MGC.Cambria.Twilight.19": "Castle me mostró sus planos para colmenas durante la cena. ¡Ahora las casas de abejas requieren menos madera y carbón para fabricarse!",

    //Mail
    "Mail.Cambria.Greenhouse.Title": "El Invernadero de Cambria",
    "Mail.Cambria.Greenhouse": "Hey @,^^Sé que lo sigo diciendo, pero gracias de nuevo por escucharme el otro día. No estoy tan cerca de la gente de aquí como solía estarlo, así que tu compañía significó mucho.^Como muestra de mi gratitud, dejaré mi invernadero abierto para ti. No es gran cosa, pero es uno de mis lugares favoritos.^^¡Nos vemos por ahí! (o algo así)^^P.D. Si necesitas suministros extra, hay un catálogo junto a mi molinillo de café. ¡Ayúdate con lo que necesites!",
    "Mail.Cambria.ElderLily.Title": "Regalo de Cambria de parte de Orchid",
    "Mail.Cambria.ElderLily": "Hey @,^^Muchas gracias por ayudarme. Orchid ha vuelto a poner huevos e incluso me dio algunas semillas para demostrar que volvimos a estar en buenos términos.^^No me preguntes de dónde las sacó, pero tendré algunas extra disponibles en mi invernadero.",
    "Mail.Gabriel.Misdelivered.Title": "Carta Mal Entregada de Gabe",
    "Mail.Gabriel.Misdelivered": "Hey Castle,^^Han pasado temporadas, colega. Cada vez que menciono visitarte, dices que no estás listo.^Pues me harté de esperar. En cuanto tenga la tienda en orden, zarpo para allá. Punto final.^Tienes suerte de que tu novio gótico esté en un viaje de negocios, porque si no, lo arrastraría conmigo.^^Nos vemos pronto,^Gabriel Bang",

    //Quests
    "MGC.WrongLetter.Title": "Una Carta Mal Entregada",
    "MGC.WrongLetter.Body": "Una carta destinada a Cambria te fue entregada por error. Será mejor que se la lleves.",
    "MGC.WrongLetter.Hint": "Encuentra a Cambria en East Scarp.",

    //Conversation Topics
    //Cambria
    "Cambria.CT.joja.begin": "Así que al final sucedió, ¿eh? Estoy segura de que fue una decisión difícil para Lewis.$13#$b# Aun así, no puedo creer que lo vayan a convertir en un almacén.$2",
    "Cambria.CT.cc.begin": "Cuando volví a Pueblo Pelícano, me entristeció ver el centro comunitario tan deteriorado.#$b# Me alegra que quieras ayudar a repararlo.$1#$e# Por cierto... ¿viste algo ahí dentro? ¿Solo ratas? Oh, está bien.$10",
    "Cambria.CT.cc.bus": "¡Penny me dijo que el autobús vuelve a estar operativo!$1#$b# Tal vez pueda tomarlo de vuelta a la ciudad...",
    "Cambria.CT.cc.minecart": "No puedo creer que hayas logrado que los carros mineros funcionen.$1#$b# Me ayudarán mucho a desplazarme.#$b# Gracias, @.$1",
    "Cambria.CT.cc.bridge": "¡El acceso a la cantera está abierto de nuevo!#$b# Esto es genial; ahora puedo conseguir minerales sin tener que entrar a la mina.",
    "Cambria.CT.cc.complete": "Tengo muchos recuerdos de infancia en el centro comunitario.#$b# Verlo reconstruido... significa mucho para mí.",
    "Cambria.CT.movietheater": "¿Un cine ahora? Qué genial. Hace siglos que no voy a uno.",
    "Cambria.CT.CamieIntro": "%Cambria parece estar teniendo dificultades, pero se niega a aceptar ayuda.",
    "Cambria.CT.CamieHelps": "@, ¡encontré algo más que podrías usar!#$b# Tú le sacarás más provecho que yo. [621]",
    "Cambria.CT.CamieOrchidKnife": "Espero que Orchid no te haya asustado demasiado.$2#$b# Diría que prometo mantenerla bajo control, pero el hecho de que consiga cuchillos es lo último que me preocupa.$5",
    "Cambria.CT.CamieEvelynTalk": "%Cambria está perdida en sus pensamientos con una expresión de confusión. Será mejor dejarla tranquila.",
    "Cambria.CT.CamieGrandparents": "Gracias por escucharme, @. Pensaré en algo para demostrarte mi gratitud.$8",
    "Cambria.CT.CamieMail": "Además... por favor, no le menciones lo del 'novio gótico' a nadie...$6#$b# Ya tiene el ego lo suficientemente grande.$3",
    "Cambria.CT.CoveAtTwilight": "¿Te sirvieron mis planos? Son un secreto familiar, pero como no tengo familia cerca para que se lo digas, pues, ehh.",

    //Vanilla
    "Cambria.CT.wedding": "La boda fue hermosa, @. Tú y %spouse se veían increíbles.$1",
    "Cambria.CT.luauBest": "Haya sido el mejor o no, Lewis tendría que sobornarme con una estatua de oro propia antes de que siquiera considere comerlo.$5",
    "Cambria.CT.Baby": "¡Oh, Yoba, ¿ya un bebé?! ¿Qué le gusta? ¿Color favorito? ¿Dinosaurio? ¿Comida?$8#$b# !$7#$b# Perdón, me emociono con los niños. Espero que le guste esto.$4 [126 127]",
    "Cambria.CT.jojaMartStruckByLightning": "¿Un rayo golpeó qué??$7#$b# Me alegra que nadie haya salido herido, aunque eso explica la puerta dañada.$8#$b# No voy a mentir, pensé que Sam se coló ahí una noche.",

    //Lucikiel by Arknir
    "Cambria.CT.LucikielArrives": "Hey, @, ¿qué pasa? Escuché un gran alboroto en el pueblo.$12#$b# ¿¿Un demonio?? Bueno, supongo que no es lo más raro que ha pasado aquí.$10#$e# ¿Eh? ¿Por qué no me preocupa? He vivido aquí lo suficiente como para no alterarme por cosas como demonios y monstruos.",
    "Cambria.CT.ReputationIncreased": "¿Me estás diciendo que el demonio que invocaron ahora trabaja con Clint?$12#$b# Bueno, esta zona ha sido de todo menos aburrida desde que volví.#$b# ¿Qué quieres decir con que no te gusta mi definición de 'interesante'?$10",

    //RSV
    "Cambria.CT.KeahiPrank": "¡Hey, @!$8#$b# ¿Qué? ¿Hueles mal? No lo creo. Me recuerda un poco a la comida en mi nevera, para ser honesto.$10#$b# Yo no me preocuparía si fuera tú.",

    //ARV
    "Cambria.CT.SterlingDrugs": "Sterling vino a mi casa el otro día. Me preguntó si tenía contactos en la ciudad.#$b# Le dije que no, pero no quiso explicar por qué preguntaba...$2",
    "Cambria.CT.SterlingRelapse": "Esto era lo que temía...$2#$b# La recuperación siempre es una batalla cuesta arriba. Las recaídas pueden ocurrir incluso si haces todo lo posible por evitarlas.$2#$b# Lamentablemente, lo sé por experiencia.$2",
    "Cambria.CT.SterlingApology": "¡Vi a Sterling de vuelta en la tienda de Pierre por primera vez en mucho tiempo! Me alegra verlo mejor.$1",
    "Cambria.CT.SterlingRiver": "Dejé de ver a Shane y Sterling juntos en la taberna.#$b# Me alegra ver que se está enfocando en la sobriedad total. ¿Sería raro decirle que estoy orgullosa de él?",
    // ELI AND DYLAN
    "Cambria.CT.EliIntro": "¿Conociste a Eli? Sí, es un tipo interesante.#$b# A veces me mira como si supiera algo que yo no.$10#$b# Tal vez lo invite a tomar café algún día.",
    "Cambria.CT.EliSaloon": "Emily me contó sobre su conversación con Eli el otro día. Es bueno que tenga a alguien más con quien hablar sobre gemas.#$b# Me gusta hablar con ella, pero ya me sé de memoria todo lo que me ha contado.",
    "Cambria.CT.EliJunimo1": "Casi me da envidia que un junimo se haya interesado en Eli. Aunque, pensándolo bien, ya tengo suficiente con lo que sea que Orchid esté tramando.$5",
    "Cambria.CT.EliJunimo2": "Uno pensaría que Eli sería mejor guardando secretos sobre cosas sobrenaturales.#$b# No todos pueden ver junimos y eso lleva a situaciones incómodas.#$b# ¿Recuerdas cómo preocupaste a Lewis cuando los viste por primera vez en el centro comunitario?",
    "Cambria.CT.EliWoods": "Ese tonto... Eli puede ser muy imprudente.$5#$b# ¿Y si ese poder suyo tiene efectos secundarios a largo plazo? Sin mencionar que los sustos NO son divertidos cuando estás tan adentro en el bosque.$5",
    "Cambria.CT.EliMushroomCave": "¿Una cueva de hongos, eh? Tal vez debería echar un vistazo.#$b# Me pregunto a qué saben. ¿Crees que le importe?$10",
    "Cambria.CT.EliOldWoods": "Vaya, ¿quién hubiera pensado que un tótem de teletransporte podría fallar?$5#$b# Me alegra que ustedes dos estén bien, pero eso fue bastante arriesgado.",
    "Cambria.CT.JunimoKingIntro": "Orchid ha estado bastante apática últimamente. Tal vez Jacob pueda echarle un vistazo.$13#$b# Ha estado durmiendo más, lo cual ya es decir mucho cuando casi no dormía antes.",
    "Cambria.CT.EliGuild": "Siempre me ha parecido interesante que, siendo criptozoólogo, Eli evita dañar a CUALQUIER monstruo. Incluso a los menos inteligentes.$1#$b# Es admirable, aunque eso sí, le deja más trabajo a los demás para controlar la población.",
    "Cambria.CT.EliGuestRoom": "Cada vez que hay una tormenta eléctrica, no encuentro a Orchid por ningún lado.#$b# Las primeras veces me preocupé muchísimo, pero siempre aparecía a la mañana siguiente.",
    "Cambria.CT.DylanIntro": "Te vi a ti y a Dylan admirando las pozas en la marea baja. Me alegra ver que le agradas.$1#$b# Sí, así es como demuestra que le agrada alguien: hablando sin parar sobre la vida marina.",
    "Cambria.CT.DylanBeach": "El desperdicio irresponsable es un efecto molesto de la sociedad moderna. Siempre habrá gente demasiado perezosa como para cuidar su planeta.$5#$b# Afortunadamente, hay personas como tú y Dylan que se preocupan lo suficiente como para limpiar el desastre. ¡Gracias!$1",
    "Cambria.CT.DylanTown": "¿Cómo está Dylan? Eli me contó que su ansiedad se intensificó la otra noche.#$b# Asegúrate de escucharlo con especial atención, ¿sí?",
    "Cambria.CT.DylanSaloon": "%Cambria está tratando de no reírse.#$b# Casi desearía haber estado ahí para ver el desastre que hizo Dylan en la taberna.$1#$b# Me alegra verlo más sociable, pero tal vez eso fue DEMASIADO social.",
    "Cambria.CT.DylanCCAquarium": "El nuevo acuario en el centro comunitario es impresionante.$1",
    "Cambria.CT.SootIntro": "Soot es una cosita adorable. No se lo digas a Dylan, pero la última 'tormenta de polvo' fue culpa mía.$3#$b# En mi defensa, ¡no sabía que los duendecillos de polvo podían estornudar!$7",
    "Cambria.CT.ThistleIntro": "Thistle intentó comerse mis cultivos unas cuantas veces, pero entre Orchid y Júpiter nunca tuvo oportunidad.#$b# Ahora se limita a mirarme mal desde los árboles... ¿Las urracas pueden mirar mal?",
    //East Scarp
    "Cambria.CT.AideenGarden": "Ese nuevo jardín junto al centro comunitario es hermoso. Aideen realmente se lució.$1",
    //Bearfam
    "Cambria.CT.BearFamFullHouse": "¿Conociste a los Osos que se mudaron? Uhh, yo conocí a Gudrun a la fuerza.$3#$b# Me interrogó sobre la ética de mi apicultura y no se fue hasta que quedó satisfecha con mi respuesta.",
    "Cambria.CT.BearFamTimeForBees": "Las abejas son un animal de apoyo poco convencional, pero he visto el cuidado y la atención que Sig les da a sus colmenas.#$b# Tal vez debería esforzarme más con las mías.",
    "Cambria.CT.SigLowBattery": "¡HEY— oh, ups. Perdón, estaba hablando con Sig.#$b# Si tienes alguna batería de sobra, seguro que le gustaría recibirla como regalo.",
    "Cambria.CT.SondraAgingGracefully": "Veía a Sondra de vez en cuando cuando crecí aquí. Juro que no ha envejecido nada desde la última vez que la vi.",
    "Cambria.CT.GunnarOpenForBusiness": "La cantidad de veces que olvidé provisiones camino a las minas es vergonzosa. Estoy muy agradecida por la pequeña tienda de Gunnar.#$b# El hecho de que la tenga abierta más por pasión que por dinero me recuerda a cierto alguien.",
    //Other NPCs CTs
    "Abigail.CT.CamieIntro": "Cambria intentó ayudarme con 'Journey of the Prairie King' y FRACASÓ por completo en el primer nivel.#$b# Iba a reírme, pero luego la vi iniciar 'Junimo Kart'. Superó mi récord sin problema.#$b# Oh bueno, ¡nuevo objetivo por alcanzar!$1",
    "Alex.CT.CamieEvelynTalk": "La abuela siempre sonríe más después de que Camie la visita. No tenemos mucho en común, pero cualquiera que pase tiempo con ella me cae bien.#$b# ¿Crees que sepa algo sobre gridball?",
    "Caroline.CT.CamieIntro": "Cambria me ayudó a cuidar mis hojas de té el otro día. Es muy delicada con las plantas.#$b# Entre tú y yo, creo que también les hablaba.",
    "Evelyn.CT.CamieEvelynTalk": "Pobrecita. Merece saber la verdad, pero no es mi secreto para contar.$2#$b# Oh, no me hagas caso, cariño. Solo pensaba en voz alta.",
    "Jas.CT.CamieOrchidKnife": "La señorita Camie trae a su gallina a veces y me deja jugar con ella.$1#$b# Es divertido, pero las otras gallinas le tienen miedo.",
    "Lewis.CT.CamieGrandparents": "Claudia y Allen fueron miembros importantes de la comunidad en su tiempo.#$b# Nadie sabe de dónde vinieron, pero tenían la escritura de una tierra y el resto es historia.",
    "Shane.CT.CamieOrchidKnife": "Hay algo raro en esa gallina de Cambria.$2#$b# No, aparte del cuchillo— ¡espera, qué!?$5",

    //Location Strings
    "HomeExterior.String.MGCgarden": "Un jardín bien cuidado y herramientas.",
    "HomeExterior.String.MGCbeehives": "Estas abejas ocupadas zumban alrededor de sus colmenas.",
    "HomeExterior.String.MGCcoffee": "Plantas de café en constante crecimiento. No te pierdas en ellas.",
    "HomeExterior.String.MGColdbike": "Una motocicleta que ha visto días mejores.",
    "HomeExterior.String.OrchidCoop": "No dejes que Orchid te atrape husmeando en su gallinero.",
    "CambriaHouse.String.Stool": "Por su apariencia, Cambria se sienta aquí cuando se pone las botas.",
    "CambriaHouse.String.SeafoodOven": "El olor a mariscos cocidos persiste. Debe haberse horneado algo recientemente.",
    "CambriaHouse.String.BurntHair": "El refrigerador está lleno de mariscos y algunos recipientes extraños. #Algo huele a cabello quemado.",
    "CambriaHouse.String.CoffeePot": "Debajo del fregadero hay un suministro interminable de café molido y filtros. ¿Acaso no tiene fin?",
    "CambriaHouse.String.Trash": "Cambria sabía que no debía tener basura en casa después de ver al granjero local hurgando.^Cambria sabía que no debía tener basura en casa después de ver a la granjera local hurgando.",
    "CambriaHouse.String.Peppers": "Estás bastante seguro de que estos son Mesa Scorpions, los chiles más picantes de Ferngill.",
    "CambriaHouse.String.SmallRadio.1": "'Bitter' de Archers está sonando.",
    "CambriaHouse.String.SmallRadio.2": "'Lighthouse' de Loveless está sonando.",
    "CambriaHouse.String.SmallRadio.3": "'Over It' de Arrows in Action está sonando.",
    "CambriaHouse.String.SmallRadio.4": "'Blanket Fort' de Archers está sonando.",
    "CambriaHouse.String.SmallRadio.5": "'Voodoo Doll' de Loveless está sonando.",
    "CambriaHouse.String.SmallRadio.6": "'Put You Through Me' de Arrows in Action está sonando.",
    "CambriaHouse.String.CamieBed": "La cama de Cambria con un peluche de abeja. ^Parece que la han movido a la sala de estar.",
    "CambriaHouse.String.GardenBooks": "'Botanicum Medicinale', 'El Manual del Recolector', '100 Plantas que Curan', 'El Cazador de Flores'... #Los estantes están llenos de recursos sobre medicina natural.",
    "CambriaHouse.String.LockedDoor": "La puerta no se mueve.",
    "CambriaHouse.String.StrawHat": "Parece haber estado colgado en la pared durante años, pero no tiene ni una mota de polvo.",
    "CambriaHouse.String.WallNotes": "La pared está llena de notas y bocetos. Incluso hay algunos dibujos infantiles en exhibición.",
    "CambriaHouse.String.TableJars": "Hay pequeñas bolas de musgo flotando suavemente en el agua. ^Quieres apretar una.",
    "CambriaHouse.String.FrontWindow": "Desde aquí tienes una gran vista del océano.",
    "CambriaHouse.String.LoneBox.1": "Hay montones de cartas apiladas en la caja. #Debajo de ellas hay un collar. ^Es una estrella de obsidiana envuelta en alambre sobre una banda de cuero. #Sientes una sensación distinta de pérdida al sostenerlo.",
    "CambriaHouse.String.LoneBox.2": "Hay montones de cartas apiladas en la caja. Tomas una para leer... #La carta está manchada con esmalte de cerámica, las palabras son demasiado difíciles de leer.",
    "CambriaHouse.String.LoneBox.3": "Hay montones de cartas apiladas en la caja. Tomas una para leer... #Estás bastante seguro de que esta cantidad de insultos haría ruborizar a un marinero.",
    "CambriaHouse.String.LoneBox.4": "Hay montones de cartas apiladas en la caja. Tomas una para leer... #¿Cuánto tiempo puede hablar una persona sobre el océano?",
    "CambriaHouse.String.LoneBox.5": "Hay montones de cartas apiladas en la caja. Tomas una para leer... #Su caligrafía ilegible se ve empeorada por manchas de lágrimas. ¿Es rímel?",
    "CambriaHouse.String.LoneBox.6": "Hay montones de cartas apiladas en la caja. Tomas una para leer... #La cantidad de anhelo es casi exagerada. Huele a lavanda.",
    "CambriaHouse.String.LoneBox.7": "Una foto de un hombre vestido completamente de negro, sosteniendo a una pequeña princesa rosada. #En la parte trasera dice 'Te extraño, te quiero, Rin + Dolly Storms' con una fecha.",
    "CambriaHouse.String.LoneBox.8": "Hay montones de cartas apiladas en la caja. Tomas una para leer... #La carta es simplemente el dibujo de una niña de ella misma y Camie. #Una flecha señala a la mujer, llamándola mamá.",
    "CambriaHouse.String.Polaroids": "En las fotos se ve a Cambria sonriendo con dos hombres de aproximadamente su edad. #En la parte trasera está escrito 'Cape Starlet' con una fecha.",
    "CambriaHouse.String.DustyGuitar": "Un bajo que ha visto días mejores. Parece haber sido colocado y olvidado.",
    "CambriaHouse.String.BandItems": "Púas de guitarra y carteles con 'Double Fang' impreso en ellos. ^¿La antigua banda de Cambria?",
    "CambriaHouse.String.OldClothes": "Encima hay un chaleco de mezclilla cubierto de pines y parches varios. Debajo, camisetas de bandas dobladas cuidadosamente.",
    "CambriaHouse.String.VariousBooks": "Las cajas contienen libros sobre diversos temas que van desde la infertilidad hasta ejercicios de fisioterapia.",
    "CambriaHouse.String.TrossPlant": "Hay una nota adjunta a la maceta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Tross'.",
    "CambriaHouse.String.RioPlant": "Hay una nota adjunta a la maceta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Rio'.",
    "CambriaHouse.String.InkyPlant": "Hay una nota adjunta a la maceta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Inky'.",
    "CambriaHouse.String.KeelPlant": "Hay una nota adjunta a la maceta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Keel'.",
    "CambriaHouse.String.QuinnPlant": "Hay una nota adjunta a la maceta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Quinn'.",
    "CambriaGH.String.CamieCasks": "Toneles llenos de hidromiel que Cambria está envejeciendo.",
    "CambriaGH.String.GHNote": "Parece que son tiempos de producción y gastos. ^Cambria parece ganarse bien la vida.",
    "CambriaGH.String.CamieGrinder": "Una trituradora de madera que ha sido reacondicionada como molinillo de café.",
    "CambriaGH.String.GHChest": "Está lleno de granos de café enteros y paquetes etiquetados 'Castlegrove Coffee Co.'.",
    "CambriaGH.String.CamieSeedMaker": "Tiene un leve aroma a carambola.",
    "CambriaGH.String.GHLilies": "Estas lilas se parecen mucho a las que están junto a las lápidas cerca de la playa. ^Cambria parece cuidarlas con especial atención.",
    "CambriaGH.String.RaisedBed1": "Un bancal elevado vacío para plantas.",
    "CambriaGH.String.RaisedBed2": "Un bancal elevado vacío para plantas.",
    "CambriaGH.String.RaisedBed3": "Un bancal elevado vacío para plantas.",
    "CambriaGH.String.CamieStarfruit": "¡Estas son carambolas de alta calidad!",
    "CambriaGH.String.GHBeehives": "Una colmena a medio construir y una plataforma de metal.",
    "CambriaGH.String.OberonPlant": "Hay una nota adjunta a la maceta de la planta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Dylan'.",
    "CambriaGH.String.DairePlant": "Hay una nota adjunta a la maceta de la planta. ^Tiene instrucciones meticulosas de cuidado. #El nombre de esta planta es 'Sonder'.",
    "CambriaGH.String.CamieKegs": "Los barriles que Cambria usa para fermentar hidromiel. ^Parece que han sido muy usados.",
    "CambriaHouse.String.FamilyMail.1": "Wolf,^^¿Realmente necesitabas mudarte al medio de la nada para 'aclarar tu mente'? Mira, no te juzgo, pero al mismo tiempo sí te estoy juzgando un poco. ¿Qué se supone que debo usar cuando vaya? ¿Zapatillas deportivas?? Yoba...^^Bueno, espero que te sientas mejor estos días. Sé que sin mi brillante presencia debes estar aburrido, pero si estás lejos de todo el desastre de casa, no te culpo.^Gabe mencionó algo sobre que estás explorando minas, ¿verdad? Por supuesto que lo estás.^^Solo no te rompas un hueso ni intentes curarte con alguna loca 'magia' del bosque.^^Recuerda, ¡los aceites esenciales son una estafa!",
    "CambriaHouse.String.FamilyMail.2": "Wolf,^^Tengo una nueva mascota. Se llama Mortimer. Es un bastardo engreído que se rompió un ala y me mordió cuando lo llevé al veterinario.^¿Quieres saber cómo se ROMPIÓ esa ala? Se estrelló contra el capó de mi coche. ¡Qué idiota!^^Voy a soltarlo en la habitación de mi hermano mientras duerme.",
    "CambriaHouse.String.FamilyMail.3": "Castle,^^Dolly preguntó por ti y le dije que aún estabas enfermo. Por suerte para ambos, todavía es lo suficientemente joven como para creérselo, pero incluso ella empieza a darse cuenta.^^Dijo que te dijera que te extraña y que cada noche le da un beso a Wolfie por ti.^^Algún día, dejará de preguntar.",
    "CambriaHouse.String.FamilyMail.4": "Castle,^^No me hagas suplicar, por favor. ¿No puedes volver a casa pronto? Dolly te extraña, Gabe te extraña, yo te extraño.^^Yo lo--^No puedo seguir hacien--^Esto no es justo--^^(La carta está inconclusa)",

    //Festival Dialogue
    //Cambria
    "Cambria.Dialogue.EggFest.1": "¿Sebastian te habló sobre el 'lanzamiento de huevos podridos' que solían hacer?#$b# Sí... los huevos no estaban podridos. Pasé el día anterior haciendo lotes de huevos sombríos rellenos.$5#$b# Sé que son un gusto adquirido, pero te aseguro que huelen completamente diferente.$2",
    "Cambria.Dialogue.EggFest.2": "No entiendo cómo todos pueden comer tantos huevos.#$b# Los huevos normales son demasiado insípidos para mí. Prefiero el toque eldritch de los sombríos.$1#$b# Sin contar el olor.$3",
    "Cambria.Dialogue.EggFest.3": "Cada año parece que Gus trae nuevos platos con huevos al festival.#$b# Una vez incluso pidió huevos sombríos. La pobre Orchid tuvo que trabajar horas extra por la cantidad que pidió.",
    "Cambria.Dialogue.Luau.1": "Oh, vaya, no pensé que me encontrarías tan lejos.#$b# Gracias por buscarme. Diviértete.$1",
    "Cambria.Dialogue.Luau.2": "La gente considera raro mi gusto por la comida infusionada con el vacío.#$b# Pero se burlan en vano, porque no me pagarían lo suficiente para comer lo que sea que hay en esa olla.$5",
    "Cambria.Dialogue.Luau.3": "Sé que es un pueblo pequeño y todo, pero ¿cómo esperan que la gente coma ese estofado comunitario?#$b# No creo que Marnie haya usado un solo guante, y sé dónde han estado esas manos.",
    "Cambria.Dialogue.Jellies.1": "El resplandor de las medusas lunares ilumina el océano como un cielo estrellado.#$b# Realmente es un espectáculo de otro mundo.$8",
    "Cambria.Dialogue.Jellies.2": "Gracias por acompañarme este año, @.$1#$b# Aprecio la compañía. Especialmente en una noche tan especial como esta.$1#$b# Recuerda tener cuidado en tu camino de regreso a casa.",
    "Cambria.Dialogue.Jellies.3": "¿Crees que haya medusas de aguas profundas?#$b# Sé que hay un paseo en submarino en invierno, pero no me arriesgaría a una muerte por presión solo por curiosidad.",
    "Cambria.Dialogue.SVFair.1": "Aprecio la comida gratis que ofrece Gus.#$b# Pero estoy de acuerdo con Evelyn; debería haber más opciones.",
    "Cambria.Dialogue.SVFair.2": "El tipo del puesto de fuerza se rió de mí cuando me acerqué.$5#$b# Pero la broma fue para él, porque hice sonar la campana tres veces seguidas.$8#$b# ...Voy a lamentarlo por la mañana.$9",
    "Cambria.Dialogue.SVFair.3": "Las ferias pequeñas como esta no son gran cosa en el gran esquema de las cosas.#$b# Pero al final del día, lo que importa es reunir a la gente.#$b# Y superar la puntuación más alta en tiro al blanco.",
    "Cambria.Dialogue.WinterStar.1": "Hey, @. ¿Tuviste un buen año? Creo que el mío fue bastante bien.#$b# Aquí, sé que es un regalo secreto, pero quería compartir algo de lo que hice este año.$1 [(O)Squeaks.MGC.CP_VoidTaintedMead (O)Squeaks.MGC.CP_CoffeeInfusedMead (O)Squeaks.MGC.CP_CoffeeInfusedMead (O)Squeaks.MGC.CP_BloodStarfruitMead (O)Squeaks.MGC.CP_BloodStarfruitMead]",
    "Cambria.Dialogue.WinterStar.2": "Voy a dar mi regalo de inmediato y luego salir corriendo a casa.#$b# Mis articulaciones no soportan temperaturas extremas, pero me alegra haberte encontrado. Quiero que tengas esto.#$b# Brindemos por un nuevo año, ¿sí? Cuídate, @.$1 [(O)Squeaks.MGC.CP_VoidTaintedMead (O)Squeaks.MGC.CP_CoffeeInfusedMead (O)Squeaks.MGC.CP_CoffeeInfusedMead (O)Squeaks.MGC.CP_BloodStarfruitMead (O)Squeaks.MGC.CP_BloodStarfruitMead]",
    "Cambria.Dialogue.WinterStar.3": "¿Recibiste algo bueno este año, @? Siempre es interesante ver qué se les ocurre a los demás. No es que yo sea mejor, siempre regalo hidromiel cada año.#$b# Como esta. Asegúrate de mantenerte abrigado, ¿vale? No te quedes fuera demasiado tiempo.$1 [(O)Squeaks.MGC.CP_VoidTaintedMead (O)Squeaks.MGC.CP_CoffeeInfusedMead (O)Squeaks.MGC.CP_CoffeeInfusedMead (O)Squeaks.MGC.CP_BloodStarfruitMead (O)Squeaks.MGC.CP_BloodStarfruitMead]",
    "Cambria.Dialogue.RSVEmber.1": "%Cambria parece sin aliento.#$e# Estoy bien, esta caminata es solo una vez al año, así que vale la pena el esfuerzo.$9#$b# Ve a socializar y diviértete, recuerda pedir un deseo para el próximo año.$11",
    "Cambria.Dialogue.RSVEmber.2": "Espero que enciendan la fogata pronto, algunos de nosotros tenemos huesos viejos aquí.#$b# Bueno, más que viejos, 'mal curados' para ser honesto. Pero el punto sigue en pie.",
    "Cambria.Dialogue.RSVEmber.3": "Por más especial que sea esta reunión, no me emociona el camino de regreso a casa.#$b# Imagina hacer esto antes de que instalaran el elevador. Yo no lo haría.",
    "Cambria.Dialogue.RSVGathering.1": "Algunos de los artículos en los puestos me preocupan.$12#$b# Jeric intentó venderme un huevo de dinosaurio, de todas las cosas.$10#$b# No te voy a mentir, fue tentador, pero Orchid no estaría feliz.",
    "Cambria.Dialogue.RSVGathering.2": "Lenny se enteró de que era músico antes de regresar al pueblo. Pensé que intentaría chantajearme para que tocara.",
    "Cambria.Dialogue.RSVGathering.3": "La verdad, no estoy aquí por los puestos de venta. Lo que realmente vale la pena es la anguila picante de Pika.#$b# Y el espresso triple, por supuesto.",

    //Movie Tastes
    "Movies.Cambria.BraveLittleSapling.Before": "Las comedias familiares pueden ser un acierto o un fracaso. Hay muchas hechas solo por dinero.",
    "Movies.Cambria.BraveLittleSapling.After": "Equilibraron muy bien la comedia y los momentos conmovedores.#$b# No me importaría verla otra vez.$1",
    "Movies.Cambria.NaturalWonders.Before": "No puedo decirle que no a un buen documental.",
    "Movies.Cambria.NaturalWonders.After": "¿Crees que el narrador acepta peticiones?",
    "Movies.Cambria.PrairieKing.Before": "Mis abuelos siempre contaban historias como si el Rey de la Pradera fuera real.",
    "Movies.Cambria.PrairieKing.After": "Hombre, lo que ha pasado ese tipo... Sería genial escuchar sus historias.$1",
    "Movies.Cambria.Wumbus.Before": "¿Oh, ciencia ficción? Me interesa.$1",
    "Movies.Cambria.Wumbus.After": "Yo... hmm... Tendré que pensarlo un poco.",
    "Movies.Cambria.Mysterium.Before": "El abuelo intentaba asustarme con esta película cuando era niña, pero siempre me pareció más entretenida que otra cosa.$1",
    "Movies.Cambria.Mysterium.After": "De alguna manera, es incluso menos aterradora de lo que recordaba, pero igual la pasé genial.$1",
    "Movies.Cambria.ItHowlsInTheRain.Before": "Oh vaya, travesuras de adolescentes que seguramente acabarán mal. ¿Listo para verla?$1",
    "Movies.Cambria.ItHowlsInTheRain.After": "¿Cuántas películas más necesitamos antes de que la gente aprenda a no seguir cada ruido que escucha?$5",
    "Movies.Cambria.MiracleAtColdstarRanch.Before": "Esta parece una de esas películas navideñas cursis, y no lo digo como un cumplido.",
    "Movies.Cambria.MiracleAtColdstarRanch.After": "Ugh, tenía razón.$5",
    "Movies.Cambria.ZuzuCityExpress.Before": "Esta era la película favorita de mi abuela cuando crecía. Siempre veíamos la original juntos.",
    "Movies.Cambria.ZuzuCityExpress.After": "Hombre, fue tan buena como la recordaba. Gracias por invitarme.$1",
    "Movies.Cambria.Love.During": "Los ojos de Cambria están pegados a la pantalla con asombro y nostalgia.",
    "Movies.Cambria.Like.During": "Cambria está disfrutando la película en silencio.",
    "Movies.Cambria.Dislike.During": "Cambria parece que preferiría estar en cualquier otro lugar."
}