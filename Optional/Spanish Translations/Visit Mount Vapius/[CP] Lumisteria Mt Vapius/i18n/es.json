	//2
    "AloiseDialogueMon2": "HACER",
    "AloiseDialogueTue2": "HACER",
    "AloiseDialogueWed2": "HACER",
    "AloiseDialogueThu2": "HACER",
    "AloiseDialogueFri2": "HACER",
    "AloiseDialogueSat2": "Algunos ingredientes para los dulces se encuentran en la naturaleza. En algunas ocasiones, contrato a Moïra para que me los recoja. Ella sabe mucho sobre búsqueda de comida.",
    "AloiseDialogueSun2": "HACER",
