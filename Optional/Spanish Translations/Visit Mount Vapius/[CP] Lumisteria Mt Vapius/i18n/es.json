	//Charline, CharlineClochertonVMV,
	"CharlineDialogueLumisteria.MtVapius.Arrival": "HACER",
    "CharlineDialogueMon": "HACER",
    "CharlineDialogueTueR01": "Cuando era niño vine una vez con mis padres.#$b#Realmente no sé por qué, pero quedé realmente encantado.#$b#Este es mi destino favorito ahora.",
    "CharlineDialogueTueR02": "Esos lugares pequeños son tan rústicos. Tan auténtico.",
    "CharlineDialogueWedR01": "$query TIME 1500 1800#*pantalón* *pantalón*¡Es bueno correr así de vez en cuando!#Caminaré y luego regresaré a la posada para una agradable cena.|Me gusta correr en la naturaleza. Eso es bastante bueno para mi estado de ánimo.",
    "CharlineDialogueWedR02": "Escuché sobre Pueblo Pelicano. No me gusta mucho la playa.",
    "CharlineDialogueThuR01": "Qué placer no tener que cocinar.#$b#Ésa es la verdadera ruptura. Para el almuerzo, suelo llevar una cesta de picnic y comer cerca del estanque.",
    "CharlineDialogueThuR02": "Ojalá tengamos más variedad de frutas. Un poco de piña o mango estaría genial.",
    "CharlineDialogueFriR01": "¡Es más barato venir a mitad de semana!#$b#Después de todo, necesito hacer que las cosas se ajusten al presupuesto.",
    "CharlineDialogueFriR02": "Mi teléfono no recibe ninguna red. ¿Qué están haciendo las empresas, te pregunto?",
    "CharlineDialogueSat": "HACER",
    "CharlineDialogueSun": "HACER",
    //2
	"CharlineDialogueMon2": "HACER",
    "CharlineDialogueTue2": "HACER",
    "CharlineDialogueWed2": "La cocina del hotel es excelente, ¡pero a veces los platos son bastante picantes!",
