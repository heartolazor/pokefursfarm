    "PriyaDisplayName": "Priya",
    "PriyaNaveenName": "Mamá Naveen, mi tío.",
	
	
    "PriyaDialogueAcceptGift_(O)StardropTea": "¡Sí! Soy una princesa de la luna y bebo un té de estrellas. Ven a jugar a las casitas conmigo, haremos una fiesta de té.",
    
	//Aloïse, AloiseFischerVMV,
	"AloiseDialogueLumisteria.MtVapius.Arrival": "Mi nombre es Aloïse Fischer. Soy pastelero y vendo mis productos en los mercados y en la tienda de mi familia.",
    "AloiseDialogueMon": "Tiene hermanos, @? Mi hermana es más joven que yo.",
    "AloiseDialogueTue": "HACER",
    "AloiseDialogueWed": "HACER",
    "AloiseDialogueThu": "HACER",
    "AloiseDialogueFri": "HACER",
    "AloiseDialogueSat": "HACER",
