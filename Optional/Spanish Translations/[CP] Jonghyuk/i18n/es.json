    //Mobile Phone Responses
    "MP.Greeting.Jonghyuk": "¿Qué tal, cariño?$h",
    "MP.Reminisce.Jonghyuk": "Vaya, eso realmente trae recuerdos...$15",
    "MP.Goodbye.Jonghyuk": "¡Cuídate! Nos vemos luego.",
    "MP.Greeting.Raymond": "¿Necesitas un hacker? ¡Todos los servicios son solo con pago anticipado!$h#$b#Oh--¡Hola, @!",
    "MP.Reminisce.Raymond": "Oh, recuerdo esa vez...",
    "MP.Goodbye.Raymond": "¡Siempre estoy aquí si alguna vez necesitas hablar con alguien!$6",

