    //Other Dialogue
    "Jonghyuk.Dialogue.MovieInvitation": "¿Me estás invitando a una cita? Pues me encantaría ir contigo.$h#$e#Nos vemos en el cine, cariño.$u",
    "Spanner.Dialogue.MovieInvitation": "Me encantaría ir contigo.$h#$e#Nos vemos en el cine",

    //Resort Dialogue

    //Vanilla
    "Jonghyuk.Dialogue.Resort_Entering": "Tengo licencia para ser el salvavidas de turno. Alguien tiene que mantener a la gente a salvo.$h",
    "Jonghyuk.Dialogue.Resort_Leaving": "Escucha el sonido de las olas y relájate. Nadie se lastima bajo mi vigilancia.$u",
    "Jonghyuk.Dialogue.Resort_Shore": "El océano es peligroso. Si alguna vez te arrastra una ola, haré todo lo que pueda para traerte a salvo.$15",
    "Jonghyuk.Dialogue.Resort_Chair": "Estoy tomando un descanso, así que nadie puede entrar al agua. Aprovecharé el poco tiempo que me queda.$24",
    "Jonghyuk.Dialogue.Resort_Bar": "Estoy tomando un descanso, así que nadie puede entrar al agua. Aprovecharé el poco tiempo que me queda.$22",
    "Jonghyuk.Dialogue.Resort": "Debería invitar a Harvey a venir aquí más tarde. Ha estado todo el día atrapado en su departamento.$u#$b#Una vez mencionó que quería ver el atardecer con alguien cercano. Sé el lugar perfecto para disfrutar de la vista juntos.$h",

