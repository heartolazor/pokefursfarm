    //CROPS

    "Core.Items.MandrakeRoot": "Raíz de Mandrágora",
    "Core.Items.MandrakeRoot.Description": "Un vegetal extraño pero delicioso. Te odia por despertarlo.",
    "Core.Items.MandrakeRootSeeds": "Semillas de Raíz de Mandrágora",
    "Core.Items.MandrakeRootSeeds.Description": "Plántalas en otoño. Tarda 12 días en producir una raíz de mandrágora.",
    "Core.Items.SanguineHeart": "Corazón Sanguíneo",
    "Core.Items.SanguineHeart.Description": "Esta jugosa fruta arcana late al ritmo de tu propio corazón. A pesar de su apariencia macabra, ¡es sabrosa y apta para veganos!",
    "Core.Items.SanguineHeartSeeds": "Semillas de Corazón Sanguíneo",
    "Core.Items.SanguineHeartSeeds.Description": "Plántalas en otoño. Tarda 10 días en producir una fruta que es, francamente, perturbadora.",
    "Core.Items.BeholderFruit": "Fruta del Beholder",
    "Core.Items.BeholderFruit.Description": "Esta fruta ocular ha presenciado misterios insondables de más allá del tiempo y el espacio, pero ahora se conforma con observarTE a TI.",
    "Core.Items.BeholderFruitSeeds": "Semillas de Fruta del Beholder",
    "Core.Items.BeholderFruitSeeds.Description": "Plántalas en otoño. Tarda 13 días en madurar y continúa produciendo enormes ojos que te miran después de la primera cosecha.",
    "Core.Items.DragonEye": "Ojo de Dragón",
    "Core.Items.DragonEye.Description": "Aunque estos raros frutos con aspecto de joyas no son ojos de dragón literales, aún así debes tener cuidado: ¡son muy picantes!",
    "Core.Items.DragonEyeSeeds": "Semillas de Ojo de Dragón",
    "Core.Items.DragonEyeSeeds.Description": "Plántalas en verano. Tarda 13 días en madurar y sigue produciendo ojos de dragón después de la primera cosecha.",
    "Core.Items.CrystallineLily": "Lirio Cristalino",
    "Core.Items.CrystallineLily.Description": "Una flor de crecimiento lento y hermosa, formada de alguna manera por cristal vivo. Los delicados pétalos brillan de manera incandescente a la luz.",
    "Core.Items.CrystallineLilySeeds": "Semillas de Lirio Cristalino",
    "Core.Items.CrystallineLilySeeds.Description": "Plántalas en invierno. Tarda 14 días en producir una flor de otro mundo.",
    "Core.Items.PixieBloom": "Flor de Hada",
    "Core.Items.PixieBloom.Description": "Después de madurar, estas flores iridiscentes toman vuelo y pueden confundirse con mariposas. Mantenerlas en un jarrón decorativo es más fácil decirlo que hacerlo.",
    "Core.Items.PixieBloomSeeds": "Semillas de Flor de Hada",
    "Core.Items.PixieBloomSeeds.Description": "Plántalas en primavera y verano. Tarda 14 días en producir flores que revolotean.",
    "Core.Items.Bluffshroom": "Hongo Engañoso",
    "Core.Items.Bluffshroom.Description": "Este hongo realmente quiere que pienses que es mortal, hasta el punto de que evolucionó un pequeño cráneo en su sombrero. En verdad, es completamente seguro de comer.",
    "Core.Items.BluffshroomStarter": "Inicio de Hongo Engañoso",
    "Core.Items.BluffshroomStarter.Description": "Plántalos en primavera y invierno. Tarda 8 días en crecer, pero sigue produciendo después de eso. Crece sobre un tocón de árbol en descomposición.",
    //FISH

    "Core.Items.LambentHyphafin": "Hyphafin Luminiscente",
    "Core.Items.LambentHyphafin.Description": "Un hongo simbiótico dentro de su cuerpo alimenta sus señuelos bioluminiscentes, lo que le permite capturar presas y señalar a otros Hyphafins.",
    "Core.Items.Junimeel": "Junimeel",
    "Core.Items.Junimeel.Description": "Un pez raro y delicado con un sorprendente parecido a los espíritus del bosque en la leyenda. Solo puede prosperar en las aguas más puras.",
    "Core.Items.CombJelly": "Medusa Peine",
    "Core.Items.CombJelly.Description": "Un pariente cercano de la medusa que se impulsa con filas de pequeños peines. Los peines difractan la luz, produciendo un efecto de arco iris brillante.",
    "Core.Items.BloodybellyCombJelly": "Medusa Peine Barriga Sangrienta",
    "Core.Items.BloodybellyCombJelly.Description": "Una medusa peine de aguas profundas. En la oscuridad total de las profundidades en las que vive, su coloración roja la hace casi invisible tanto para los depredadores como para las presas.",

    //FORAGE

    "Core.Items.Marimo": "Marimo",
    "Core.Items.Marimo.Description": "Una variedad acuática de musgo que crece en forma de bola y rueda por el fondo de ríos y lagos. Es popular en acuarios.",
    "Core.Items.FrogspawnCoral": "Coral Pónsalo de Rana",
    "Core.Items.FrogspawnCoral.Description": "Un coral pedregoso con grandes pólipos que se asemejan a los huevos de rana. Pueden extender tentáculos largos y urticantes para atacar a los corales cercanos que crecen demasiado cerca.",
    "Core.Items.TorchCoral": "Coral Antorcha",
    "Core.Items.TorchCoral.Description": "Un coral pedregoso con grandes pólipos que terminan en tentáculos largos y de colores vibrantes. Es agresivo y picará otros corales cercanos.",
    "Core.Items.DuncanCoral": "Coral Duncan",
    "Core.Items.DuncanCoral.Description": "Un coral pedregoso de crecimiento rápido con pólipos de color verde azulado brillante que terminan en tentáculos morados cortos. Tiene un apetito voraz, pero no es agresivo.",
    "Core.Items.Trachyphyllia": "Trachyphyllia",
    "Core.Items.Trachyphyllia.Description": "Conocido como el coral cerebro abierto, es capaz de inflar sus tejidos para moverse lentamente con la ayuda de la corriente de agua.",
    "Core.Items.Scolymia": "Scolymia",
    "Core.Items.Scolymia.Description": "Una hermosa variedad de coral pedregoso que viene en una amplia gama de colores impresionantes. Son muy solicitados por los acuaristas.",
    "Core.Items.AcanCoral": "Coral Acan",
    "Core.Items.AcanCoral.Description": "Un coral pedregoso con una enorme cantidad de variaciones de color. Las colonias forman una forma de cúpula a medida que crecen.",
    "Core.Items.ToadstoolCoral": "Coral Hongo",
    "Core.Items.ToadstoolCoral.Description": "Una especie de coral de cuero. Los cientos de pequeños pólipos que cubren su 'sombrero' le dan una apariencia suave y difusa. ¡Puede alcanzar tamaños impresionantes!",
    "Core.Items.CandyCaneCoral": "Coral Bastón de Caramelo",
    "Core.Items.CandyCaneCoral.Description": "También conocido como el coral trompeta, esta especie pedregosa se puede encontrar en variaciones verdes, moradas y marrones. Las colonias pueden crecer hasta 5 metros de ancho.",
    "Core.Items.AcroporaCoral": "Coral Acropora",
    "Core.Items.AcroporaCoral.Description": "Un coral pedregoso que viene en una amplia variedad de colores y crece en patrones de ramificación distintivos. Es muy sensible a los cambios en la química del agua.",
    "Core.Items.EleganceCoral": "Coral Elegante",
    "Core.Items.EleganceCoral.Description": "Este gran coral pedregoso a veces se confunde con una anémona de mar. Con sus largos tentáculos que se balancean, es tan elegante como su nombre sugiere.",
    "Core.Items.Gorgonian": "Gorgonia",
    "Core.Items.Gorgonian.Description": "Esta delicada fanega marina está compuesta por una colonia de pequeños organismos microscópicos. Muchas especies son filtradoras, pero otras dependen de la fotosíntesis.",


