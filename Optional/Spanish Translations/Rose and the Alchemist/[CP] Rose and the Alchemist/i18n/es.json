  //Festival Dialogue

  //Egg Festival
  "Festivals_EggFest.Rose": "¡No, Wildflour, no te muevas o la gente me verá!$6#$b#Puedo ver perfectamente el Festival del Huevo desde aquí detrás de ti.$1",

  //Flower Dance
  "Festivals_FlowerDance.Rose": "Harumph. No veo ni de cerca suficientes tortas ni scones aquí.$s#$b#Creo que me engañaste, alquimista.$5",
   
  //Luau
  "Festivals_Luau.Rose": "¿Por qué me trajiste a ESTE festival, de entre todos los festivales?$3#$b#¿¡Qué crees que harán cuando vean un ratón cerca de su sopa?!$6",
    
  //Moonlight Jellies
  "Festivals_Jellies.Rose": "Bueno, al menos este festival es bastante oscuro.$1#$b#Dudo que alguien me note aquí, y realmente me gustaría ver esas medusas.",

  //Stardew Fair
  "Festivals_StardewFair.Rose": "¿Podemos votar?#$b#Yo voto por Marnie, porque los huevos de sus gallinas hacen que mis tortas queden deliciosas.",
    
  //Spirit's Eve
  "Festivals_SpiritEve.Rose": "Los fantasmas no existen.$6#$b#Los espectros no existen.$2#$b#Los esqueletos no existen... espera, oh no.$3",
   
  //Ice Festival
  "Festivals_IceFest.Rose": "Me pregunto... si hubiera traído pastel de pescado, tal vez tendría algo de qué hablar con los otros aldeanos...$6",
   
  //WinterStar
  "Festivals_WinterStar.Rose": "¡Un nuevo año, lleno de comienzos nuevos y brillantes!$1#$b#Eso espero.$6",

