  "SASS_SO_1.name": "¡Se Necesitan Ingredientes!",
  "SASS_SO_1.text": "Necesito urgentemente ingredientes mágicos recolectados para mi próximo proyecto alquímico. No me importa si son variados, pero deben estar en buen estado. Por favor, tráelos a mi atelier en el Bosque Sunberry.",
  "SASS_SO_1a.deliver": "Entrega 5 ingredientes mágicos de recolección en la cesta vacía del Atelier de la Alquimista.",

  "SASS_SO_2.name": "¡Se Necesitan Plumas!",
  "SASS_SO_2.text": "Necesito urgentemente plumas para mi próximo proyecto alquímico. No me importa el tipo de pluma, pero deben estar en buen estado. Por favor, tráelas a mi atelier en el Bosque Sunberry.",
  "SASS_SO_2a.deliver": "Entrega 5 plumas en el buzón del Atelier del Alquimista.",

  "SASS_SO_3.name": "¡Se Necesitan Setas!",
  "SASS_SO_3.text": "Necesito urgentemente setas para mi próximo proyecto alquímico. Una variedad servirá, pero nada de esos comunes, morados o rojos. Por favor, tráelos a mi atelier en el Bosque Sunberry.",
  "SASS_SO_3a.deliver": "Entrega 5 setas mágicas en el buzón del Atelier del Alquimista.",

  "SASS_SO_4.name": "¡Se Necesitan Frutas!",
  "SASS_SO_4.text": "Necesito urgentemente frutas para mi próximo proyecto alquímico. ¡Pero no cualquier fruta! Busco frutas fuera de temporada y mágicas. Por favor, tráelas a mi atelier en el Bosque Sunberry.",
  "SASS_SO_4a.deliver": "Entrega 5 frutas mágicas en el buzón del Atelier de la Alquimista.",

  "SASS_SO_5.name": "¡Se Necesitan Flores!",
  "SASS_SO_5.text": "Necesito urgentemente flores para mi próximo proyecto alquímico. ¡Pero no cualquier flor! Busco flores que parezcan inusuales por naturaleza. Por favor, tráelas a mi atelier en el Bosque Sunberry.",
  "SASS_SO_5a.deliver": "Entrega 5 flores mágicas en el buzón del Atelier del Alquimista.",

  "SASS_SO_RoseParty.name": "¡Shh! ¡Es una Fiesta Sorpresa!",
  "SASS_SO_RoseParty.text": "Cori y Wildflour quieren organizar una fiesta sorpresa para Rose, pero necesitan tu ayuda para entregar las invitaciones sin que Rose se dé cuenta.",

  "SASS_SO_RoseParty_Evelyn.deliver": "Entrega una invitación para la fiesta sorpresa directamente a Evelyn.",
  "SASS_SO_RoseParty_Evelyn.accept": "¿Rose? ¿La dulce y tímida ratoncita panadera de la que Miyoung y Jumana me han hablado tanto? Esta fiesta suena como una idea encantadora, ${querido^querida}$. Por supuesto que iremos.$h",

  "SASS_SO_RoseParty_Miyoung.deliver": "Entrega una invitación para la fiesta sorpresa directamente a Miyoung.",
  "SASS_SO_RoseParty_Miyoung.accept": "¿Una fiesta sorpresa para Rose? ¡No puedo imaginar una mejor forma de pasar la tarde!$h",

  "SASS_SO_RoseParty_Jumana.deliver": "Entrega una invitación para la fiesta sorpresa directamente a Jumana.",
  "SASS_SO_RoseParty_Jumana.accept": "¡Qué idea tan maravillosa! Amina ha estado deseando conocer a Rose, pero no quería ir sola, así que la llevaré conmigo.$h",

  "SASS_SO_RoseParty_Linus.deliver": "Entrega una invitación para la fiesta sorpresa directamente a Linus.",
  "SASS_SO_RoseParty_Linus.accept": "Con gusto haré el viaje al Bosque Sunberry por la señorita Ratona. Estaré allí.$h",

  "SASS_SO_RoseParty_Leah.deliver": "Entrega una invitación para la fiesta sorpresa directamente a Leah.",
  "SASS_SO_RoseParty_Leah.accept": "¡Me preguntaba cómo presentarme a esa ratoncita tan dulce que sale a recolectar con Linus! ¡Cuenta conmigo y también llevaré a Elliott!$h",

  "SASS_Party_Invitation.name": "Invitación a la Fiesta",
  "SASS_Party_Invitation.description": "Una invitación ultrasecreta para la fiesta de Rose.",

