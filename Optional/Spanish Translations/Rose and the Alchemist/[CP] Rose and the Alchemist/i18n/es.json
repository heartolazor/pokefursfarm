// Map Strings

  "MapString.atelier.cakes": "Una exhibición de tortass coloridas.",
  "MapString.atelier.packagedtreats": "Una exhibición de postres elegantemente empaquetados.",
  "MapString.atelier.petitfours": "Una exhibición de adorables y diminutos petit fours.",
  "MapString.atelier.cookbooks": "Una estantería llena de libros de cocina.",

  "MapString.atelier.herbalistbooks": "Una estantería repleta de libros sobre alquimia, herbolaria y recolección.",
  "MapString.atelier.bookstack": "Libros que ya no cabían en la estantería.",
  "MapString.atelier.teapotbooks": "Una mesa llena de papeles, una tetera y un libro abierto. El título dice:#'¡Atención! Cómo evitar un retraso en los objetivos'.",
  "MapString.atelier.teapotbooks2": "Otra mesa llena de papeles, libros abiertos y otra tetera.",

  "MapString.atelier.fairydress": "¡Un vestido digno de una princesa hada!",
  "MapString.atelier.cheesebooks": "Una estantería con una mezcla de libros de cocina y novelas de fantasía de Redfloor.",
  "MapString.atelier.mushteapot": "Una tetera con forma de seta.",
  "MapString.atelier.roseplants": "Una vibrante exhibición de plantas de interior, cuidadas con mucho amor.",

  "MapString.atelier.moretea": "¿En serio, cuánto té toman estas dos?",
  "MapString.atelier.opencookbook": "Un conjunto de libros de cocina abiertos. Es una receta para Scones de Fresa Galardonados.",
  "MapString.atelier.lemons": "Un saco de limones pequeños recién cosechados.",

  "MapString.atelier.flowers": "Una exhibición de flores recién recolectadas. Huelen delicioso.",
  "MapString.atelier.yarrow": "Una exhibición de hierbas recién recolectadas como milenrama y lavanda.",
  "MapString.atelier.mushrooms": "Una exhibición de setas recién recolectados. ¡Ñam!",

  "MapString.atelier.cauldron": "Un gran caldero que burbujea con un líquido misterioso.",
  "MapString.atelier.sprouthouse": "¡Es una adorable casita de seta! Es demasiado pequeña para que alguien viva ahí... probablemente.",
  "MapString.atelier.alchemybookcase": "Una estantería llena de libros de alquimia y velas ceremoniales.",

  //Shop Dialogue
  "SASS_AlchemistShop_Dialogue.1": "¡Recolección! ¡Semillas! ¡Setas! ¡Ven por tu comida silvestre aquí!",
  "SASS_AlchemistShop_Dialogue.2": "${Bienvenido^Bienvenida}$, ${bienvenido^bienvenida}$. ¿Qué te interesa en este hermoso día?",
  "SASS_AlchemistShop_Dialogue.3": "¿Qué opinas, te animas a probar estas nuevas bayas que encontré hoy? Probablemente no sean venenosas...",

  "SASS_Alchemist_TwilightShop_Closed": "¡Cerrado hasta que inicie el festival!",
  "SASS_Alchemist_TwilightShop": "¡Bienvenido al Atelier del Crepúsculo!",

  //Interior and Shop Names

  "SASS_FamiliarsShop.Dialogue": "Enciclopedia de los Familiares de la Alquimista",
  "SASS_AtelierInterior": "Atelier del Alquimista",

  ///////////////
 // ALCHEMIST //
  ///////////////

  //Display Names
  "Name.Wildflour": "Wildflour",

  //Generic Gift Taste Dialogue

  //Love
  "Gift_Love.Wildflour": "¿¡PARA MÍ?! ¿EN SERIO?! ¡Oh, @, esto es increíble! ¡Muchísimas gracias!$1",

  //Like
  "Gift_Like.Wildflour": "Por Yoba, qué gesto tan amable. Gracias, @.$h",

  //Dislike
  "Gift_Dislike.Wildflour": "Mmm, sí, esto es... bueno, seguro puedo echarlo al caldero para alguna poción o algo así.$5",

  //Hate
  "Gift_Hate.Wildflour": "Oh. No. No, en serio, esto lo odio.$2",

  //Neutral
  "Gift_Neutral.Wildflour": "Gracias, @.",

  //Birthday
  "Gift_Positive.Alchemist": "EEEEEEEEEEEEEEEEEEE.$1#$b#Ejem, quiero decir, gracias, @, por un regalo de cumpleaños tan lindo.$0",
  "Gift_Negative.Alchemist": "Ah bueno, eh, gracias, @.$2#$b#Me aseguraré de poner esto en algún lugar... especial.$10",

  //Animation Dialogue
  "Animations_AlchemistForaging": "%La alquimista parece completamente absorta en su recolección.",

  //Festival Dialogue

  //Egg Festival
  "Festivals_EggFest.Wildflour": "¿Rose, cómo es posible que puedas ver o disfrutar del festival desde ahí abajo?$s#$b#¡Deja de esconderte y sal a divertirte!$1",

  //Flower Dance
  "Festivals_FlowerDance.Wildflour": "Puede que... le haya dicho a Rose que este era un festival de repostería para que viniera.$10#$b#No está muy contenta conmigo, ¡pero TENÍA que ver los arreglos florales!$12",

  //Luau
  "Festivals_Luau.Wildflour": "Rose, te prometo que no dejaré que nadie te tire a la sopa$1#$b#...ni al muelle$2#$b#...ni a las resacas de marea...$3",

  //Moonlight Jellies
  "Festivals_Jellies.Wildflour": "¡Esa es la actitud, Rose!#$b#Creo.$10#$b#En cualquier caso, me alegra que puedas disfrutar.$h",

  //Stardew Fair
  "Festivals_StardewFair.Wildflour": "Sería un buen cambio de ritmo que todos pudiéramos votar en lugar de que solo Lewis tome la decisión.#$b#No dejes que lo escuche o pensará que queremos destituirlo como alcalde.",

  //Spirit's Eve
  "Festivals_SpiritEve.Wildflour": "No hay necesidad de que Rose sepa cuáles monstruos son reales y cuáles inventados...#$b#Yoba sabe que ya le tiene miedo a suficientes cosas.",

  //Ice Festival
  "Festivals_IceFest.Wildflour": "Hmm, creo que me gustaría más este festival si cocináramos el pescado en lugar de solo... atraparlo muy rápido.$12",

  //WinterStar
  "Festivals_WinterStar.Wildflour": "¡Oh, cómo me encantan los festivales del solsticio!$h#$b#Una tradición encantadora para recibir el nuevo año junto a la comunidad.",

  //TWILIGHT FESTIVAL SBV 
  "Alchemist_Dialogue.TwilightFestival1": "¿Estás ${emocionado^emocionada}$ por las festividades de esta tarde, @?#$b#Yo sin duda lo estoy.$1#$b#No olvides pasar por mi puesto para ver los regalitos EXTRA especiales que tengo a la venta.",
  "Alchemist_Dialogue.TwilightFestival2": "¡Espero que tengas suficientes plumas para todo lo que te llame la atención!$1",

  //Seasonal Events Dialogue

  "Alchemist_Dialogue.Introduction": "Hola, no creo que nos hayamos conocido. Soy Wildflour, una alquimista de Villa Sunberry. @$10#$b#...#$b#¡Ah, debes de ser ${el nuevo granjero^la nueva granjera}$ de Pueblo Pelícano!$h#$b#¡${Bienvenido^Bienvenida}$ al Valle! Si alguna vez necesitas forraje o semillas únicas, no dudes en pasar por el atelier en el Bosque Sunberry.",

  //Spring
  "Alchemist_Dialogue.spring_1": "¡Un nuevo año, una nueva primavera, un nuevo comienzo!#$b#No puedo esperar para comenzar a plantar semillas y recolectarlas, @. ¿Qué es lo que más te emociona?",
  "Alchemist_Dialogue.spring_12": "¿El festival del huevo? ¡No me lo perdería por nada!#$b#Puede que ya no conserve sus raíces paganas, pero sigue siendo una forma encantadora para dar la bienvenida a la primavera con amigos.",
  "Alchemist_Dialogue.spring_23": "¿No sería genial que, un año, la ceremonia fuera realmente flores bailando en lugar de humanos?#$b#¡Ciertamente sería divertido ver las reacciones de los jóvenes ante un montón de margaritas danzantes!",

  //Summer
  "Alchemist_Dialogue.summer_1": "No es que no me guste el verano, es solo que el sol del verano es muy fuerte para mí.#$b#Menos mal que tengo este gran sombrero para evitar quemarme demasiado.",
  "Alchemist_Dialogue.summer_10": "Ni me gusta el calor del verano ni comer sopa caliente de un caldero comunal...#$b#pero estaré allí para ayudar por si... bueno, alguien pone algo dudoso en la olla.",
  "Alchemist_Dialogue.summer_27": "¡El otoño está casi aquí y tengo tanto por hacer!#$b#Claro que haré tiempo para la Danza de las Medusas Lunares.#$b#Puede que el verano no sea mi estación favorita, pero aún así merece nuestro agradecimiento.",

  //Fall
 "Alchemist_Dialogue.fall_1":"Aire fresco, hojas crujientes, el aroma de pastel recién horneado... Vaya, ¿no es el otoño simplemente divino, @?",
  "Alchemist_Dialogue.fall_15": "¿Participarás en la feria este año, @?#$b#Debo admitir que solo voy por la comida gratis que reparte Gus, ¡pero te deseo suerte con tu exhibición!",
  "Alchemist_Dialogue.fall_26": "No tengo tiempo para hablar, @, prometí ayudar con las festividades de mañana, ¡pero olvidé por completo las festividades de HOY!#$b#Ahora, ¿dónde dejé ese libro de cocina...",

 //Winter
  "Alchemist_Dialogue.winter_1": "¡El invierno significa menos agricultura y más recolección!#$b#Estoy en busca de algo nuevo y emocionante, @. ¡Espero encontrarlo!",
  "Alchemist_Dialogue.winter_7": "No puedo decir que pescar en un agujero en el hielo me parezca particularmente... fascinante, pero ¿las esculturas de hielo? ¡ESO sí que lo aprecio!#$b#¿Por qué no puede ser sobre eso el concurso en lugar de pescar?",
  "Alchemist_Dialogue.winter_16": "Siempre espero con ansias el mercado nocturno, @.#$b#Es tan acogedor y festivo.$h",
  "Alchemist_Dialogue.winter_24": "Ah, @. El fin de año se acerca, ¡y casi es hora de celebrar la Fiesta de la Estrella Invernal!#$b#Si necesitas ayuda para encontrar un regalo para alguien especial, avísame. Estoy segura de que tengo algo por aquí...",

  //Green Rain
  "Alchemist_Dialogue.GreenRain":"¿Preocupada?#$b#¿Por qué estaría preocupada?$10#$b#¡Esta tormenta significará setas hasta donde alcanza la vista, @! Estoy prácticamente vibrando de emoción.$1",
  "Alchemist_Dialogue.GreenRainFinished":"¿Lograste recolectar algo bueno, @?#$b#¡Tengo tantos setas que ni siquiera sé qué hacer con todas ellos!$h",
  "Alchemist_Dialogue.GreenRain_2":"¿Quieres competir a ver quién recolecta más tesoros durante la tormenta?#$b#¡Será como el Festival del Huevo pero aún mejor!$h",

  //Base Dialogue

  "Alchemist_Dialogue.Mon": "¿Sabes de dónde viene el nombre de las dedaleras?#$b#Al parecer, las hadas les colocaban las flores en las patas a los zorros traviesos para que pudieran colarse en los corrales y robar gallinas!$1", 
  "Alchemist_Dialogue.Tue": "Nunca podría ser una granjera de flores, @.$s#$b#En lugar de cortar las flores para venderlas, ¡terminaría dejándolas todas en la tierra para mirarlas durante toda la estación!$h",
  "Alchemist_Dialogue.Wed": "¿Qué es un alquimista?#$b#Bueno, es alguien que recolecta materiales encontrados en la naturaleza y los transforma en cosas completamente nuevas para ayudarse a sí mismo y a su comunidad.#$b#Ah, y quizá algo de magia también, pero no se lo digas al mago.$6",
  "Alchemist_Dialogue.Thu": "Nunca salgas sin una cesta de recolección, @. ¿Quién sabe qué podrías encontrar en tu viaje diario al pueblo?#$b#$1# ¡Por ejemplo, encontré estas setas encantadoras justo afuera de la casa de Robin!$1",
  "Alchemist_Dialogue.Fri": "¡El fin de semana se acerca! ¿Debería acurrucarme con un libro de alquimia o salir de excursión?#$b#Hmm, decisiones, decisiones.",
  "Alchemist_Dialogue.Sat": "¿Has echado un vistazo al bosque detrás de la casa del mago?$3#$b#Creo que vi algunos recursos interesantes en esa dirección...",
  "Alchemist_Dialogue.Sun": "¿Has tenido un fin de semana tranquilo, @? ¡No me gustaría escuchar que te estás sobrecargando de trabajo!#$b#Siempre se debe programar tiempo suficiente para un poco de travesuras.$6",

  "Alchemist_Dialogue.Mon2": "¿Interesado en la alquimia? Debo decir que ya tienes talento para ello, @.#$b#¿De qué otra forma logras cocinar comidas tan elaboradas tan rápido?", 
  "Alchemist_Dialogue.Tue2": "¿Has tenido suerte conociendo a Rose, @? ¿Dices que chilla y huye cuando intentas hablarle?#$b#Ah, bueno, sigue intentándolo. Estoy segura de que se abrirá contigo en poco tiempo.",
  "Alchemist_Dialogue.Wed2": "¿Tienes una flor favorita, @?#$b#Si tuviera que elegir, diría que las peonías son mis favoritas. Me parecen tan esponjosas y encantadoras a la vez.",
  "Alchemist_Dialogue.Thu2": "Si estás cortando algunas de tus flores para un arreglo, asegúrate de cortar los tallos en un ángulo adecuado.#$b#¡Eso les permite absorber mejor el agua en el florero y durar más!",
  "Alchemist_Dialogue.Fri2": "A veces mis ojos son más grandes que mi estómago.#$b#Debería compartir algunos de mis setas extra con Linus. Ese hombre sabe hacer un excelente kebab de setas...$1",
  "Alchemist_Dialogue.Sat2": "Creo que hoy me quedaré en casa horneando uno o dos pasteles.#$b#De alguna forma tengo que usar estas bayas recolectadas.",
  "Alchemist_Dialogue.Sun2": "...eh, ¿qué fue eso?#$b#Perdón, estaba pensando en cómo construir una nueva máquina de alquimia.",

  "Alchemist_Dialogue.Mon4": "Brotecito quiere saber si tienes algún dulce para él.#$b#Si no, sugiere que le lleves fresas la próxima vez que lo veas.", 
  "Alchemist_Dialogue.Tue4": "¿El mago? ¿Qué pasa con él?$5#$b#No, no hablamos mucho.$6#$b#Cree que la magia y la alquimia deben mantenerse ocultas para la mayoría de la gente y yo simplemente no lo veo como un problema.#$b#$1¡La gente debería ayudarse entre sí! Ya sea con magia, alquimia o cualquier otra cosa, ¿no crees ${granjero^granjera}$?",
  "Alchemist_Dialogue.Wed4": "Estaba leyendo en uno de mis tomos el otro día sobre un bosque de setas donde crecían árboles de setas gigantes.#$b#¿No sería ese lugar el sueño hecho realidad de cualquier recolector? Me pregunto si la historia está basada en algún lugar real...",
  "Alchemist_Dialogue.Thu4": "¿Qué hago con todas las cosas que recolecto?#$b#${Amigo^Amiga}$, ¿qué NO hago?#$b#Se pueden transformar en tés, popurrí, perfumes, productos horneados...#$b#Prometo que no uso los setas venenosos para esa última cosa.$6",
  "Alchemist_Dialogue.Fri4": "Encontré unas setas raras el otro día y compartí algunos con Maru.#$b#¡Deberías haber visto lo feliz que la hizo! Siempre anda buscando algo nuevo para analizar. Sería una alquimista excelente.$1",
  "Alchemist_Dialogue.Sat4": "Mi maestra de alquimia solía hablar de un sabio de esta zona. Creo que su nombre era... ¿Cannoli?#$b#Él fue quien le habló por primera vez sobre los junimos, ¡así que vine aquí a buscarlos!#$b#Y entonces encontré a Brotecito aquí, ¡así que ahora este lugar es el hogar de ambos!$1",
  "Alchemist_Dialogue.Sun4": "¡Ajá! Finalmente he perfeccionado mi receta de té de manzanilla.#$b#Debo recordar compartirla con Caroline la próxima vez que la vea.",

  "Alchemist_Dialogue.Mon6": "¿Crees que alguien le dio un caramelo de roca a Abigail cuando era niña y simplemente asumió que todas las rocas eran dulces?#$b#No soy quien para juzgar, pero encuentro su apetito fascinante, sin duda.$1",
  "Alchemist_Dialogue.Tue6": "¡Ah, @! ¡Quería mencionártelo la próxima vez que te viera!#$b#Ten cuidado con los lugares donde dejas que tus mascotas entren en la granja. Muchas de las flores que cultivas pueden ser tóxicas para un gato o perro demasiado curioso.$3",
  "Alchemist_Dialogue.Wed6": "Brotecito dice que tu granja está progresando muy bien!#$b#Él y sus amigos disfrutan jugando entre los cultivos por la noche. Prometen que solo se roban unos pocos snacks.",
  "Alchemist_Dialogue.Thu6": "Una cueva llena de cristales suena intrigante, ¿no crees, @?#$b#Ah, es otra referencia que encontré en otro de mis viejos libros. ¡Es tan difícil saber qué es fantasía y qué es una pista para descubrir una nueva ubicación secreta!",
  "Alchemist_Dialogue.Fri6": "¡Ah, hola, @! Otra semana terminada, ¡otro fin de semana para celebrar! ¿Tienes algo emocionante planeado?#$b#Personalmente, creo que probaré nuevas mezclas de té con las flores que recolecté ayer.",
  "Alchemist_Dialogue.Sat6": "Tendré que recordar pasar por el salón y darle a Emily esos cristales que le prometí.#$b#Imbuir energía espiritual en ellos requiere bastante trabajo, pero me alegra ayudar a una compañera amante de las artes místicas y la alquimia.",
  "Alchemist_Dialogue.Sun6": "¡@! Justo la persona que quería ver.$1#$b#Terminé sintetizando demasiados pasteles en mi caldero esta mañana, así que pensé en compartir. [220 221] ",

 "Alchemist_Dialogue.Mon8": "Me pregunto qué tipo de propiedades alquímicas se podrían derivar de la ropa de una persona.#$b#¿Tal vez de un par de calzoncillos morados, por ejemplo?$6",
 "Alchemist_Dialogue.Tue8": "Jas me detuvo el otro día para preguntarme si ella también podía ser alquimista. ¿No es adorable?#$b#Ella también puede ver a Brotecito, así que quizá algún día sea una excelente aprendiz.$1",
  "Alchemist_Dialogue.Wed8": "Brotecito dice que si construyes una cabaña junimo en tu granja, podría ir a quedarse a dormir.#$b#También promete que NO hará una gran fiesta junimo mientras esté allí.$1",
  "Alchemist_Dialogue.Thu8": "¡@! Encontré notas sobre otro lugar mágico para recolectar: parece ser un prado de flores silvestres en la cima de una montaña.#$b#El libro no da detalles específicos, pero al parecer solo podría descubrirlo alguien muy hábil recolectando, a comienzos de la primavera.",
  "Alchemist_Dialogue.Fri8": "Ah, hola, @. Rápido, prueba un bocado y dime qué te parece. [608]#$b#Le agregué un poco de canela silvestre que recolecté. ¡Creo que realza mucho el sabor!",
  "Alchemist_Dialogue.Sat8": "¿Sabes? Si quieres verme hacer algo de alquimia, eres más que ${bienvenido^bienvenida}$.$1#$b#Podríamos intentar crear nuevos sabores de té, ¿o tal vez una poción mágica?",
  "Alchemist_Dialogue.Sun8": "Ah, @. Hoy no tengo muchas ganas de hablar.#$b#No, no es nada grave... solo creo que me excedí ayer pasando tanto tiempo frente al caldero.",

  "Alchemist_Dialogue.Mon10": "¡Escúchame bien! ¿Y si  usara alquimia para crear maquillaje mágico?#$b#¡Piénsalo! En lugar de una crema para desaparecer el acné, ¡podría ser una crema para volverse completamente invisible!",
  "Alchemist_Dialogue.Tue10": "¿Te molesta que Brotecito aún no te hable?#$b#Lamento escuchar eso, @. Brotecito habla TODO el tiempo sobre ti, pero en persona es bastante tímido.",
  "Alchemist_Dialogue.Wed10": "¿Cómo puedo estar recolectando ingredientes y atender la tienda al mismo tiempo?#$b#Muy simple: la persona que ves en la tienda en realidad son tres amiguitos de Brotecito disfrazados mediante una ilusión para parecerse a mí.#$b#Funciona como por arte de magia.$6",
 "Alchemist_Dialogue.Thu10": "Un huerto secreto...#$b#¿Eh? Ah, perdón, @. Estaba pensando en voz alta.#$b#Parece que este valle inspiró muchas leyendas sobre zonas secretas para recolectar, ¡y estoy decidida a encontrarlas todas!",
  "Alchemist_Dialogue.Fri10": "Ahí está mi conejillo de indias favorito... ¡QUISE DECIR, mi catador oficial!$1#$b#Esta vez usé frutas silvestres y un toque de esencia de vainilla. [610]",
  "Alchemist_Dialogue.Sat10": "Leah vino el otro día a preguntarme si podía usar alquimia para crear tintes y pinturas únicas.#$b#Es muy reconfortante que distintas personas del pueblo pasen por el atelier en busca de ayuda o simplemente para charlar.",
  "Alchemist_Dialogue.Sun10": "Creo que pronto visitaré a mi amiga Rose. Vive en el Bosque Sunberry.#$b#¡Un día de estos te la voy a presentar, @!#$b#Estoy segura de que se llevarían muy bien.",

//Conversation Topics

  "Alchemist_Dialogue.cc_Begin": "Creí haberte visto curioseando por el viejo Centro Cívico. ¡Es lindo ver que alguien más aparte de los amigos de Brotecito se interesa por él!",
  "Alchemist_Dialogue.cc_Boulder": "Ahora que la roca ya no está, la tierra alrededor de las minas tendrá acceso a más minerales.#$b#Eso debería enriquecer la tierra y, con suerte, mejorar también lo que se pueda recolectar.",
  "Alchemist_Dialogue.cc_Greenhouse": "Brotecito dice que espera que te guste tu nuevo invernadero; él y sus amigos trabajaron muy duro en eso.",
  "Alchemist_Dialogue.cc_Minecart": "¡Ah, @! ¿Fuiste tú quien logró reparar los carritos mineros? Debo darte las gracias. ¡Hace que recolectar por el valle sea MUCHO más eficiente!",
  "Alchemist_Dialogue.cc_Complete": "¡Brotecito me contó la buena noticia! Deberías sentirte muy orgulloso, @.#$b#¡Le devolviste un pedacito de comunidad a este pueblo, y de más de una manera!",
  "Alchemist_Dialogue.cc_Bridge": "Tener acceso a una cantera es todo un logro, @. Sin duda vas a necesitar bastante mineral y gemas si algún día querés hacer alquimia por tu cuenta.",
  "Alchemist_Dialogue.cc_Bus": "¿Ah, arreglaron el autobús? ¡Qué buena noticia! Yo no lo necesito, ya que tengo otras formas de ir al desierto, pero será genial para que tú puedas visitarlo y para que algunos amigos lejanos se reencuentren.",
  "Alchemist_Dialogue.movieTheater": "¿Un cine? Bueno, sin duda es una mejora respecto a las ruinas de Joja, pero... un invernadero comunitario también habría sido bonito.",
  "Alchemist_Dialogue.willyCrabs": "La verdad, @, me sorprende tu comportamiento. Lo que haga Willy en la privacidad de su casa no es asunto mío.",
  "Alchemist_Dialogue.pamHouseUpgrade": "Es realmente admirable, @. Hiciste muchísimo por Pam con este regalo. Ojalá más personas sigan tu ejemplo.",
  "Alchemist_Dialogue.pamHouseUpgradeAnonymous": "Escuché que alguien simplemente fue y le encargó a Robin que le construyera una casa a Pam. ¡Qué alma tan generosa, y tan humilde también! Mantenerse en el anonimato así...",
	
  "Alchemist_Dialogue.LucikielArrives": "¿Un demonio en Pueblo Pelícano? Bueno, no creo que debamos apresurarnos a juzgar, @.#$b#Sabes, mucha gente todavía piensa que los alquimistas también somos unos herejes.#$b#Mejor esperemos a ver qué pasa.",
  "Alchemist_Dialogue.ReputationIncreased": "¿Ves lo que te decía, @?#$b#Siempre hay que darle una oportunidad a las personas, ¡y ahora Lucikiel ya parece un habitante más de Pueblo Pelícano!",
  "Alchemist_Dialogue.MeetTheCats": "¿Gatos que hablan?#$b#Ay, @... Lo próximo que dirás es que hay un pequeño tipo verde sentado en mi hombro.$u",
  "Alchemist_Dialogue.ButteredJorts": "Tengo que decirlo: Pam tiene buenas intenciones.#$b#Lástima que eso implique tanta manteca.",
  "Alchemist_Dialogue.keahi_prank": "Ay, no... Eh, @, ¿cómo decirlo?#$b#Tal vez un chapuzón en el lago te vendría bien.",

  "Alchemist_Dialogue.ReihanaIntro": "No deberíamos juzgar tan rápido a Reihana ni a Aicha. Ellas no pidieron estar aquí, y de repente sus vidas se vieron sacudidas y traídas a nuestro pequeño pueblo.#2#$b#Creo que al menos podríamos intentar darles una buena bienvenida, ¿no te parece, @?$h",
  "Alchemist_Dialogue.wedding": "¡Ah @, debes volar de alegría! Felicidades, y te deseo lo mejor en esta nueva etapa de tu relación.$h",
  "Alchemist_Dialogue.luauBest": "A veces, @, lanzar varios ingredientes al azar en un caldero —ehh, quiero decir, en una olla de sopa— da resultados sorprendentes.$10",
  "Alchemist_Dialogue.luauShorts": "Pensar que comí una sopa con esencia de... Lewis.$5#$b#Bueno, si me disculpás, voy a casa a comerme varios scones de Rose para sacarme este sabor de la boca.$12",
 "Alchemist_Dialogue.luauPoisoned": "¿QUÉ tenía esa sopa?$2#$b#Tengo que preparar de inmediato un remedio de hierbas antes de que todo el pueblo caiga enfermo.",
  "Alchemist_Dialogue.AriGetsSlimed": "Lo que le pasó a Ari fue absolutamente deplorable.$3#$b#Verdaderamente monstruoso.$2#$b#Nada gracioso.$10#$b#No, ni un poquito.$12",

  "Alchemist_Dialogue.SterlingTrash": "Oh, vamos, @. ¿Te gustaría que yo anduviera riéndome de tus desafortunadas borracheras con los vecinos?$3#$b#Estoy segura de que Sterling ya se siente bastante mal sin que nosotros le echemos más peso encima.$s",
  "Alchemist_Dialogue.SterlingDrugs": "@, debo admitir que estoy un poco preocupada por nuestro amigo Sterling. Está actuando de forma extraña, pero no quiero ser demasiado directa y preguntarle.#2#$b#Tal vez lleve unos scones a casa de Mia, a ver si ella también lo ha notado.",
  "Alchemist_Dialogue.SterlingRelapse": "Parece que ese altercado en lo de Pierre fue peor de lo que imaginaba.$3#$b#Hace siglos que no veo a Sterling.#$b#Donde sea que esté, espero que sepa que aquí en Sunberry hay personas que se preocupan mucho por él.$s",
  "Alchemist_Dialogue.SterlingApology": "Pasé por lo de Pierre y, ¡ni te imaginas! ¡Sterling estaba ahí!$9#$b#De vuelta al trabajo con esa sonrisa encantadora. Qué alivio… Espero que eso signifique que ya se siente mejor.$1",


////////////////////////////
//ALCHEMIST EVENT DIALOGUE//
////////////////////////////

//2 Heart - Mysterious Forage

  "SASS_MysteriousForage.01": "¡Ah, @!#$b#Perfecto, justo la persona que necesitaba.#$b#¿Podrías venir a echarle un vistazo a esto?",
  "SASS_MysteriousForage.02": "¿Pero qué demonios es eso?",
  "SASS_MysteriousForage.03": "Esperaba que pudieras ayudarme a descubrirlo.$10#$b#Recolecto por esta zona al sur del Camino Sunberry bastante seguido, pero es la primera vez que me topo con esta flor.",
  "SASS_MysteriousForage.04": "¿Tal vez sea solo una maleza?",
  "SASS_MysteriousForage.05": "Bueno, una rosa es una maleza en un campo de trigo, mi ${buen granjero^buena granjera}$.$1#$b#Tú más que nadie sabes que 'maleza' es solo el nombre que le damos a las plantas que no queremos. Todo depende del punto de vista.$7",
  "SASS_MysteriousForage.06": "Voy a llevarla a la florería de Jumana a ver si se le ocurre algo.#$b#Por cierto, mantén los ojos abiertos por si ves otras cosas raras creciendo por ahí, ¿sí?$0#$b#Tengo la sensación de que esto no va a ser algo aislado.",
  "SASS_MysteriousForage.07": "Mira, si al final no es nada especial, te invito uno de los scones de Rose, ¿trato hecho?$9#$b#Y si encuentras algo interesante, ¿podrías traerlo al atelier para que lo examine?$0",
  "SASS_MysteriousForage.08": "¡Genial! Entonces espero verte pronto.$1#$b#¡Hasta luego, @!",

//4 Heart - Sprouts MoonDrops

  "SASS_SproutMoonDrops.01":"¡Hola, @!#$b#Qué bueno verte por este rincón del bosque también.",
  "SASS_SproutMoonDrops.02":"¿No es una maravilla? Brotecito la llama Lágrima Lunar.$h#$b#Dice que solo aparecen después de la lluvia o la nieve, y que la mayoría de los humanos ni siquiera pueden verlas.",
  "SASS_SproutMoonDrops.03":"Brotecito. El junimo.",
  "SASS_SproutMoonDrops.04":"El junimo.$0#$b#En mi hombro.$7#$b#Habla sin parar.$s#$b#Imita mis estados emocionales por amor o por burla, no estoy muy segura, para ser honesta.",
  "SASS_SproutMoonDrops.05":"¿Estás ${seguro^segura}$ de que te sientes bien?",
  "SASS_SproutMoonDrops.06":"¿No lo ves?$3#$b#Brotecito, sal ahora mismo.$5",
  "SASS_SproutMoonDrops.07":"¿Cómo que estuviste escondiéndote ${del granjero^de la granjera}$?$11#$b#¡ESPERA!",
  "SASS_SproutMoonDrops.08":"Entonces eso significa...$12#$b#¿¡Pensaste que estuve hablando sola todo este tiempo!?",
  "SASS_SproutMoonDrops.09":"Bueno, ahora que ESO está aclarado...$13#$b#Como decía, Brotecito dice que estas son Gotas Lunares, ¡y poder verlas y cosecharlas es una habilidad rara en humanos! El hecho de que puedas verlas es una excelente noticia.#$b#Pienso intentar cultivarlas, pero quizás tú también puedas hacerlo.#$b#¡Quien logre que crezcan primero, tiene que compartirle semillas al otro!",
  "SASS_SproutMoonDrops.10":"¡Brotecito!$13#$b#¡Necesitaba eso para extraer semillas!#$b#¿No podías esperar a tu snack hasta que llegáramos a casa?",

//6 Heart - Magic Mushrooms

  "SASS_MagicMushrooms.01":"¡Rose, VAMOS!#$b#Mira, no hay babas, ni humanos, solo un montón de setas hermosas.$1#$b#Voy a recogerlas todas, jejeje.",
  "SASS_MagicMushrooms.02":"¡Pero podrían ser venenosas!$2#$b#No tienes idea si son seguras para comer y ya hablamos de esto: no puedes andar por ahí metiéndote setas al azar en la boca. ¡Eso no es una buena práctica de recolección!$6",
  "SASS_MagicMushrooms.03":"¿Cómo que qué quiero decir?$6#$b#Soy Wildflour, la poderosa alquimista.$0#$b#Sé cuáles setas son comestibles y cuáles no, y estoy bastante segura de que esta es una...$10#$b#seta definitivamente comestible cuyo nombre se me ha escapado por el momento.#$b#Mira, te lo mostraré-$1",
  "SASS_MagicMushrooms.04":"¡No, ESPERA!$3",
  "SASS_MagicMushrooms.05":"¿Ves?$12#$b#Totalmente bien.",
  "SASS_MagicMushrooms.06":"Eso es todo, Señorita Sabelotodo Alquimista.$5#$b#Me vuelvo al atelier ¿y sabes qué?:",
  "SASS_MagicMushrooms.07":"Ya que parece que tienes mucho para comer con todas estas seta, supongo que ya no necesitas más de mis scones.$1",
  "SASS_MagicMushrooms.08":"Estás bromeando.$3#$b#Rose, lo siento, solo era una pequeña broma.$2",
  "SASS_MagicMushrooms.09":"¡Rose, espera, no! Lo siento, no lo volveré a hacer, lo prometo.$3",
  "SASS_MagicMushrooms.10":"Creo que simplemente quitaré los scones del menú. Seguramente los scones son comida inferior para una alquimista tan poderosa.$7",
  "SASS_MagicMushrooms.11":"¡Rose, POR FAVOR! Sabes que me pongo de mal humor sin mi scone matutino.$2",
  "SASS_MagicMushrooms.12":"Entonces quizás haz un scone con esas seta.",
  "SASS_MagicMushrooms.13":"Está bien, está bien. Limpiaré TODO el atelier, ¿te parece bien?",
  "SASS_MagicMushrooms.14":"Hmm... eso ya suena mejor.",

//8 Heart - Strange Fruit

  "SASS_StrangeFruit.01":"¡Esa es MI manzana!$5#$b#Dámela, pequeño gremlin de la basura.$12",
  "SASS_StrangeFruit.02":"El mapache gruñe y se lleva la manzana triunfalmente, alejándose de Aicha.",
  "SASS_StrangeFruit.03":"Dá.$12#$b#ME.$12#$b#LA.$12",
  "SASS_StrangeFruit.04":"Te quedaste con la última, esta es MÍA.$5",
  "SASS_StrangeFruit.05":"Woah, woah, woah, ¿qué está pasando aquí?$3",
  "SASS_StrangeFruit.06":"El mapache sisea.",
  "SASS_StrangeFruit.07":"Aicha le responde con otro siseo.",
  "SASS_StrangeFruit.08":"YA BASTA de tanto sisear, gracias.$5#$b#Este pequeño huerto solo funciona como un huerto libre si todos comparten.#$b#Aicha, ¿por qué no puedes simplemente tomar otra fruta en lugar de esta?$7",
  "SASS_StrangeFruit.09":"¡PORQUEEEE, esta manzana es especial, OBVIAMENTE. ¿No lo ves?$6",
  "SASS_StrangeFruit.10":"¿Qué quieres decir con especial?$3#$b#Ah, ahora que lo mencionas, sí, tiene un color raro comparado con las otras que crecen en este árbol.$10",
  "SASS_StrangeFruit.11":"El mapache observa hambriento mientras la alquimista examina la manzana.",
  "SASS_StrangeFruit.12":"Tienes toda la razón, Aicha.$0#$b#Hay ALGO extraño en esta manzana.#$b#Tendré que estudiarla en mi atelier para averiguar qué pasó con el cultivar.",
  "SASS_StrangeFruit.13":"PERO- PERO-$14",
  "SASS_StrangeFruit.14":"Peeero, casualmente tengo algunas galletas recién horneadas de Rose aquí si ustedes dos se comportan.$1",
  "SASS_StrangeFruit.15":"El mapache entrecierra los ojos hacia Aicha y luego asiente solemnemente a la alquimista.",
  "SASS_StrangeFruit.16":"...Está bien.$8#$b#Pero ahora somos vecinas, bruja-",
  "SASS_StrangeFruit.17":"ALQUIMISTA.$8#$b#¿Aicha, cuántas veces tengo que-",
  "SASS_StrangeFruit.18":"Bruja.$7#$b#Alquimista.$0#$b#Es lo mismo.$3#$b#Mi punto es, los vecinos mágicos deben apoyarse. Si descubres cómo hacer que crezcan más de esas manzanas, será mejor que compartas conmigo y con el gremlin de la basura antes que con los humanos.$5",
  "SASS_StrangeFruit.19":"El mapache se acerca a Aicha y asiente con entusiasmo hacia la alquimista.",
  "SASS_StrangeFruit.20":"La alquimista pone los ojos en blanco y suspira.",
  "SASS_StrangeFruit.21":"Por supuesto.#$b#Ahora, si me disculpan, tengo una manzana que investigar.$9",

//10 Heart - Fae Flowers

  "SASS_FaeFlowers.01":"Un poco de esto, una pizca de aquello.#$b#¿Ahora, dónde dejé mi frasco de telarañas...?$10",
  "SASS_FaeFlowers.02":"¡Señorita Alquimista! ¡Señorita Alquimista!",
  "SASS_FaeFlowers.03":"Hola, chicas.$0#$b#¿Todo está bien?$3",
  "SASS_FaeFlowers.04":"¿Si te contamos algo, nos creerías?$3",
  "SASS_FaeFlowers.05":"¿Aunque suene inventado?$3",
  "SASS_FaeFlowers.06":"Por supuesto.$7#$b#Ustedes dos no son de contar mentiras.#$b#¿Qué pasa, ocurrió algo?$2",
  "SASS_FaeFlowers.07":"Bueno, Jas y yo estábamos jugando en el bosque-$0",
 "SASS_FaeFlowers.08":"¡...y entonces escuchamos a alguien riéndose!$0",
  "SASS_FaeFlowers.09":"¿Vieron a alguien?$3",
 "SASS_FaeFlowers.10":"No, fuimos a ver quién era, porque pensamos que tal vez era Vincent haciéndonos una broma-$4",
 "SASS_FaeFlowers.11":"...y entonces terminamos en una parte del bosque que no conocíamos.$2#$b#Teníamos miedo. No sabíamos cómo regresar, pero entonces- ",
 "SASS_FaeFlowers.12":"¡UN CAMINO DE FLORES NOS MOSTRÓ LA SALIDA!$3",
 "SASS_FaeFlowers.13":"¿Siguieron flores que reconocieron para encontrar el camino de regreso?#$b#Jas, eso no suena muy-",
  "SASS_FaeFlowers.14":"NO.$5#$b#Cuando dice que las flores nos 'mostraron', ¡quiere decir que APARECIERON como por arte de magia!$3#$b#No estaban allí antes, pero de repente, ¡PUF! Ahí estaban.$1",
  "SASS_FaeFlowers.15":"Tratamos de contarle a la tía Marnie, pero desaparecieron cuando tratamos de mostrárselas, así que dijo que seguramente lo imaginamos.$2#$b#¡Pero jugamos en el bosque TODO el tiempo, y nunca hemos visto esas flores antes, mucho menos un camino entero hecho de ellas!$1",
  "SASS_FaeFlowers.16":"Fascinante.$11#$b#Chicas, les voy a contar un pequeño secreto.$12#$b#Creo que... una pequeña hada les estaba haciendo una broma.$13",
  "SASS_FaeFlowers.17":"Y, al ver que se asustaron, creó ese camino para ayudarlas a regresar a casa.$1#$b#Los seres feéricos no son inherentemente malos ni malvados, solo traviesos.$0",
  "SASS_FaeFlowers.18":"Pero, por si acaso, si vuelven a escuchar esa risa, no se acerquen.$2#$b#Prométanme que vendrán a buscarme, ¿sí?#$b#No queremos que ninguna de ustedes entre en un círculo de hadas y desaparezcan, ¿verdad?$11",
  "SASS_FaeFlowers.19":"¡Lo prometemos!",
  "SASS_FaeFlowers.20":"Ahora, ¿qué tal una buena taza de cacao para cada una y me cuentan el resto de su aventura?$1",
  "SASS_FaeFlowers.21":"¡Yay!",
  "SASS_FaeFlowers.22":"¡Eso suena genial!",

