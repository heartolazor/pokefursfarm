"Isla.GiftTaste.Love": "¡Esto es maravilloso! Muchas gracias, amable @.$8",
"Isla.GiftTaste.Like": "Gracias @, ¡es muy considerado de tu parte!$1",
"Isla.GiftTaste.Dislike": "Oh @, aprecio el gesto.",
"Isla.GiftTaste.Hate": "Oh querido @, esto realmente no me gusta para nada.$2",
